      "text": "E aí, vamos ficar por aqui mesmo?"
    },
    {
      "start": 433.88,
      "end": 435.52,
      "text": "Vamos jogar mais um lance aqui"
    },
    {
      "start": 435.52,
      "end": 436.34,
      "text": "E depois nós vamos"
    },
    {
      "start": 436.34,
      "end": 437.14,
      "text": "Depois eu vou"
    },
    {
      "start": 437.14,
      "end": 442.0,
      "text": "Pessoal, não sei se dá pra vocês escutar aí"
    },
    {
      "start": 442.0,
      "end": 443.48,
      "text": "Ó, o barulho aí, ó"
    },
    {
      "start": 443.48,
      "end": 448.91,
      "text": "As correntes passando nessas fiações aqui"
    },
    {
      "start": 448.91,
      "end": 452.62,
      "text": "É muita tensão, viu?"
    },
    {
      "start": 456.97,
      "end": 457.45,
      "text": "Ó, pô"
    },
    {
      "start": 457.45,
      "end": 460.1,
      "text": "Tá um medo da porra de ficar aqui embaixo"
    },
    {
      "start": 460.1,
      "end": 464.02,
      "text": "Que energia demais"
    },
    {
      "start": 464.02,
      "end": 466.44,
      "text": "Mas é isso aí"
    },
    {
      "start": 466.44,
      "end": 470.98,
      "text": "E aí, galera"
    },
    {
      "start": 470.98,
      "end": 471.98,
      "text": "Não deu certo lá"
    },
    {
      "start": 471.98,
      "end": 474.27,
      "text": "Tava puxando muito pouco"
    },
    {
      "start": 474.27,
      "end": 476.39,
      "text": "Agora nós temos esse desafio aqui"
    },
    {
      "start": 476.39,
      "end": 476.83,
      "text": "Pra subir"
    },
    {
      "start": 476.83,
      "end": 477.67,
      "text": "Olha o tanto de escada"
    },
    {
      "start": 477.67,
      "end": 479.75,
      "text": "Olha o tanto que eu já subi"
    },
    {
      "start": 479.75,
      "end": 484.42,
      "text": "Que é cansativo demais"
    },
    {
      "start": 484.42,
      "end": 486.64,
      "text": "É bom pra escar"
    },
    {
      "start": 486.64,
      "end": 488.26,
      "text": "Mas nessa escada aqui acaba"
    },
    {
      "start": 488.26,
      "end": 492.68,
      "text": "Eita, vista linda, velho"
    },
    {
      "start": 492.68,
      "end": 497.54,
      "text": "Ó, beleza?"
    },
    {
      "start": 500.42,
      "end": 501.58,
      "text": "É só pra quem gosta, viu?"
    },
    {
      "start": 503.32,
      "end": 503.98,
      "text": "Quem não gosta"
    },
    {
      "start": 503.98,
      "end": 505.34,
      "text": "Não tem essa disposição, não"
    },
    {
      "start": 505.34,
      "end": 511.88,
      "text": "A subida é grande, mas"
    },
    {
      "start": 511.88,
      "end": 514.12,
      "text": "A chegada é bonita"
    },
    {
      "start": 514.12,
      "end": 520.26,
      "text": "Chegando, galera"
    },
    {
      "start": 520.26,
      "end": 531.57,
      "text": "Ó, beleza?"
    },
    {
      "start": 531.57,
      "end": 548.58,
      "text": "Tenório deixou em fira aqui"
    },
    {
      "start": 548.58,
      "end": 549.08,
      "text": "Vocês viram?"
    },
    {
      "start": 550.71,
      "end": 551.51,
      "text": "Ó, deixou aqui"
    },
    {
      "start": 551.51,
      "end": 555.51,
      "text": "Essa minha"
    },
    {
      "start": 555.51,
      "end": 567.43,
      "text": "É isso aí, galera"
    },
    {
      "start": 567.43,
      "end": 570.37,
      "text": "Vou pegar minhas coisas"
    },
    {
      "start": 570.37,
      "end": 571.51,
      "text": "E levar logo esse fira aqui"
    },
    {
      "start": 571.51,
      "end": 572.03,
      "text": "Tenório"
    },
    {
      "start": 572.03,
      "end": 574.51,
      "text": "Tá escalar nos piaus"
    },
    {
      "start": 574.51,
      "end": 576.37,
      "text": "Beleza?"
    },
    {
      "start": 580.1,
      "end": 580.6,
      "text": "Ó, beleza?"
    },
    {
      "start": 590.81,
      "end": 592.17,
      "text": "Tá em obra aí a barragem"
    },
    {
      "start": 592.17,
      "end": 593.55,
      "text": "Não sei o que é que tão fazendo, mas"
    },
    {
      "start": 593.55,
      "end": 595.54,
      "text": "Tô fazendo uma obra"
    },
    {
      "start": 595.54,
      "end": 603.05,
      "text": "Essa chuva tá forte aqui, ó"
    },
    {
      "start": 603.05,
      "end": 603.89,
      "text": "Não bateu nada"
    },
    {
      "start": 603.89,
      "end": 605.29,
      "text": "Ainda peguei um piauzinho pequeno"
    },
    {
      "start": 605.29,
      "end": 606.6,
      "text": "Tá aqui"
    },
    {
      "start": 606.6,
      "end": 608.56,
      "text": "Mas o negócio tá fraco"
    },
    {
      "start": 608.56,
      "end": 609.94,
      "text": "Chuvendo, não bate nada, não"
    },
    {
      "start": 609.94,
      "end": 612.46,
      "text": "A gente pensou que ia sair um sol"
    },
    {
      "start": 612.46,
      "end": 613.08,
      "text": "Aí, mas"
    },
    {
      "start": 613.08,
      "end": 615.06,
      "text": "Tá meio difícil"
    },
    {
      "start": 615.06,
      "end": 616.52,
      "text": "Ó, como tá aí"
    },
    {
      "start": 616.52,
      "end": 619.2,
      "text": "O clima de chuva"
    },
    {
      "start": 619.2,
      "end": 621.65,
      "text": "Vamos embora pra petróleo"
    },
    {
      "start": 621.65,
      "end": 623.25,
      "text": "Não é só com espinha"
    },
    {
      "start": 623.25,
      "end": 625.53,
      "text": "Vamos levar o piauzinho"
    },
    {
      "start": 625.53,
      "end": 626.07,
      "text": "Passa na"
    },
    {
      "start": 626.07,
      "end": 627.13,
      "text": "Vamos levar"
    },
    {
      "start": 627.13,
      "end": 630.89,
      "text": "Tá pro soia"
    },
    {
      "start": 630.89,
      "end": 633.3,
      "text": "Aqui com o limãozinho, hein, meu amigo"
    },
    {
      "start": 633.3,
      "end": 634.4,
      "text": "Tá bom demais"
    },
    {
      "start": 634.4,
      "end": 636.79,
      "text": "Ele já morreu"
    },
    {
      "start": 636.79,
      "end": 638.84,
      "text": "Viu, não, pô"
    },
    {
      "start": 638.84,
      "end": 642.73,
      "text": "Mas ele vai"
    },
    {
      "start": 642.73,
      "end": 644.13,
      "text": "Chuvendo tá forte agora"
    },
    {
      "start": 644.13,
      "end": 644.85,
      "text": "Agora vejo os carros"
    },
    {
      "start": 644.85,
      "end": 645.71,
      "text": "Pescar direto"
    },
    {
      "start": 645.71,
      "end": 646.63,
      "text": "Que bate chuva, né"
    },
    {
      "start": 646.63,
      "end": 647.35,
      "text": "E pegar peixe"
    },
    {
      "start": 647.35,
      "end": 648.21,
      "text": "E a gente não consegue"
    },
    {
      "start": 648.21,
      "end": 648.61,
      "text": "Por quê?"
    },
    {
      "start": 649.79,
      "end": 650.83,
      "text": "Rapaz, é meio difícil"
    },
    {
      "start": 650.83,
      "end": 652.67,
      "text": "Pra pegar os peixes na chuva dessa"
    },
    {
      "start": 652.67,
      "end": 663.74,
      "text": "Hoje tu é doido"
    },
    {
      "start": 663.74,
      "end": 664.5,
      "text": "Pô, tá forte"
    },
    {
      "start": 664.5,
      "end": 665.62,
      "text": "O cabalho já foi embora"
    },
    {
      "start": 665.62,
      "end": 674.46,
      "text": "Eram pisar, pô"
    },
    {
      "start": 674.46,
      "end": 678.56,
      "text": "Mas nós estando lá pro lado de lá"
    },
    {
      "start": 678.56,
      "end": 679.68,
      "text": "Tá mais fácil pra noite"
    },
    {
      "start": 679.68,
      "end": 681.64,
      "text": "Tá perto de casa"
    },
    {
      "start": 681.64,
      "end": 686.2,
      "text": "Próxima vez nós vem aí"
    },
    {
      "start": 686.2,
      "end": 687.0,
      "text": "Um dia melhor"
    },
    {
      "start": 687.0,
      "end": 688.42,
      "text": "Dia de solzão"
    },
    {
      "start": 688.42,
      "end": 690.38,
      "text": "O problema é esse"
    },
    {
      "start": 690.38,
      "end": 693.78,
      "text": "A gente não consegue programar"
    },
    {
      "start": 693.78,
      "end": 695.49,
      "text": "Isso aí, galera"
    },
    {
      "start": 695.49,
      "end": 696.83,
      "text": "Hoje pela primeira"
    },
    {
      "start": 696.83,
      "end": 697.33,
      "text": "A minha sol"
    },
    {
      "start": 697.33,
      "end": 698.09,
      "text": "Pegada"
    },
    {
      "start": 698.09,
      "end": 700.05,
      "text": "Era pra ser sol de manhã"
    },
    {
      "start": 700.05,
      "end": 700.81,
      "text": "E chuva de tarde"
    },
    {
      "start": 700.81,
      "end": 704.92,
      "text": "Não era certo"
    },
    {
      "start": 704.92,
      "end": 708.07,
      "text": "Vamos ver se foi"
    },
    {
      "start": 708.07,
      "end": 710.57,
      "text": "Acho que pra lá não tá chovendo, não"
    },
    {
      "start": 710.57,
      "end": 711.37,
      "text": "Olha como tá claro"
    },
    {
      "start": 711.37,
      "end": 711.79,
      "text": "Pra ler"
    },
    {
      "start": 711.79,
      "end": 717.02,
      "text": "Ainda vamos subir essa paredinha"
    },
    {
      "start": 717.02,
      "end": 719.18,
      "text": "A petrola não fica nem aqui"
