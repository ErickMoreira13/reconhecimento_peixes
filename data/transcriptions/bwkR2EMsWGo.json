      "start": 555.46,
      "end": 556.2,
      "text": "Olha."
    },
    {
      "start": 560.29,
      "end": 561.47,
      "text": "Que ira."
    },
    {
      "start": 564.29,
      "end": 565.05,
      "text": "Capalmitão."
    },
    {
      "start": 565.27,
      "end": 566.41,
      "text": "Vem cá que eu vou te pegar."
    },
    {
      "start": 582.84,
      "end": 584.1,
      "text": "Nossa, gente."
    },
    {
      "start": 590.57,
      "end": 591.43,
      "text": "Que beleza."
    },
    {
      "start": 594.84,
      "end": 595.62,
      "text": "Olha que beleza."
    },
    {
      "start": 597.1,
      "end": 603.39,
      "text": "Olha lá."
    },
    {
      "start": 610.64,
      "end": 611.62,
      "text": "Vai embora, peixe?"
    },
    {
      "start": 624.0,
      "end": 624.68,
      "text": "Ó, pessoal."
    },
    {
      "start": 626.94,
      "end": 628.62,
      "text": "Pescaria agora é de rodada."
    },
    {
      "start": 629.84,
      "end": 632.8,
      "text": "Nosso guia Jefferson vem, posiciona, desliga."
    },
    {
      "start": 634.51,
      "end": 635.09,
      "text": "E aqui, ó."
    },
    {
      "start": 635.55,
      "end": 636.84,
      "text": "Uma tuveirinha."
    },
    {
      "start": 636.84,
      "end": 640.26,
      "text": "E a gente usa um chumbinho bem pequenininho."
    },
    {
      "start": 641.26,
      "end": 644.21,
      "text": "Vai afundando bem devagar."
    },
    {
      "start": 657.21,
      "end": 657.69,
      "text": "Arremessa."
    },
    {
      "start": 657.83,
      "end": 658.87,
      "text": "Vocês devem ter visto aí."
    },
    {
      "start": 658.93,
      "end": 660.97,
      "text": "A Márcio já arremessou o equipamento dela."
    },
    {
      "start": 663.87,
      "end": 668.03,
      "text": "E essa pescaria de rodada eu gosto de pescar com a isca bem longe."
    },
    {
      "start": 668.19,
      "end": 669.55,
      "text": "Bem longe da canoa."
    },
    {
      "start": 671.76,
      "end": 673.68,
      "text": "Então, arremesso mais longe que der."
    },
    {
      "start": 673.68,
      "end": 678.23,
      "text": "E a medida que o barco vai descendo, eu vou soltando linha."
    },
    {
      "start": 679.28,
      "end": 680.76,
      "text": "Deixo bem longe, realmente."
    },
    {
      "start": 683.38,
      "end": 684.62,
      "text": "Agora é só paciência."
    },
    {
      "start": 684.72,
      "end": 686.1,
      "text": "Vamos ver o que a gente acha aqui."
    },
    {
      "start": 686.48,
      "end": 711.48,
      "text": "O que é barbado?"
    },
    {
      "start": 712.58,
      "end": 713.16,
      "text": "Sei não."
    },
    {
      "start": 715.78,
      "end": 716.98,
      "text": "Tá vindo muito fácil."
    },
    {
      "start": 724.4,
      "end": 725.38,
      "text": "Tem briga."
    },
    {
      "start": 727.53,
      "end": 728.09,
      "text": "Calminho."
    },
    {
      "start": 734.1,
      "end": 734.76,
      "text": "Olha só carinho."
    },
    {
      "start": 734.76,
      "end": 749.62,
      "text": "Olha o tamanzinho do Jaú."
    },
    {
      "start": 751.52,
      "end": 752.44,
      "text": "Pega o Jaú."
    },
    {
      "start": 755.38,
      "end": 757.0,
      "text": "Vou tirar essa vara daqui."
    },
    {
      "start": 757.5,
      "end": 759.21,
      "text": "Pega o Jaú, né?"
    },
    {
      "start": 759.63,
      "end": 770.1,
      "text": "Quer que eu pego?"
    },
    {
      "start": 770.82,
      "end": 771.64,
      "text": "Traz ele aqui."
    },
    {
      "start": 775.91,
      "end": 777.49,
      "text": "Não, não, não, não, não."
    },
    {
      "start": 777.99,
      "end": 779.51,
      "text": "Não vou te pegar no alicate."
    },
    {
      "start": 781.25,
      "end": 787.75,
      "text": "Ó, bem fisgadinho."
    },
    {
      "start": 789.07,
      "end": 799.46,
      "text": "Sem o alicate não vai sair."
    },
    {
      "start": 800.38,
      "end": 811.94,
      "text": "Gente, quando pega aqui no cantinho da boca."
    },
    {
      "start": 811.94,
      "end": 816.82,
      "text": "Aí, aí, aí."
    },
    {
      "start": 816.96,
      "end": 817.92,
      "text": "Saiu facinho."
    },
    {
      "start": 818.74,
      "end": 818.96,
      "text": "Ó."
    },
    {
      "start": 820.14,
      "end": 821.58,
      "text": "Toma, esse que o peixe é seu."
    },
    {
      "start": 823.8,
      "end": 825.14,
      "text": "Olha que belezinha."
    },
    {
      "start": 826.01,
      "end": 828.49,
      "text": "Se você tem um aquário de mais de 100 litros,"
    },
    {
      "start": 829.64,
      "end": 831.12,
      "text": "dá pra pôr tranquilo."
    },
    {
      "start": 831.38,
      "end": 831.6,
      "text": "Ó."
    },
    {
      "start": 832.54,
      "end": 833.94,
      "text": "Vou soltar esse aqui."
    },
    {
      "start": 863.48,
      "end": 863.92,
      "text": "Xê."
    },
    {
      "start": 869.54,
      "end": 871.48,
      "text": "Bateu com força esse."
    },
    {
      "start": 890.88,
      "end": 892.54,
      "text": "Pegou no corpo do peixe."
    },
    {
      "start": 892.54,
      "end": 893.8,
      "text": "Por isso que ele tá bravo."
    },
    {
      "start": 895.35,
      "end": 895.81,
      "text": "Olha lá."
    },
    {
      "start": 897.06,
      "end": 898.42,
      "text": "Ei, barbadinho."
    },
    {
      "start": 898.42,
      "end": 902.08,
      "text": "Achei que tinha pego um peixe grande."
    },
    {
      "start": 902.18,
      "end": 903.92,
      "text": "Olha, fisgou pela barriga."
    },
    {
      "start": 920.04,
      "end": 920.58,
      "text": "Olha aí."
    },
    {
      "start": 921.41,
      "end": 921.95,
      "text": "Olha aí."
    },
    {
      "start": 922.35,
      "end": 929.28,
      "text": "O peixinho bravo, gente."
    },
    {
      "start": 936.29,
      "end": 936.65,
      "text": "Calma."
    },
    {
      "start": 938.36,
      "end": 938.8,
      "text": "Calma."
    },
    {
      "start": 946.77,
      "end": 947.21,
      "text": "Gente."
    },
    {
      "start": 958.05,
      "end": 958.37,
      "text": "Pronto."
    },
    {
      "start": 961.68,
      "end": 962.9,
      "text": "Se embora da minha linha."
    },
    {
      "start": 973.08,
      "end": 973.6,
      "text": "Olha aí."
    },
    {
      "start": 980.53,
      "end": 981.01,
      "text": "Vai embora."
    },
    {
      "start": 981.47,
      "end": 991.73,
      "text": "Tá com o peixe."
    },
    {
      "start": 991.73,
      "end": 992.35,
      "text": "Fisga, fisga."
    },
    {
      "start": 992.45,
      "end": 992.77,
      "text": "Vai, vai."
    },
    {
      "start": 992.85,
      "end": 994.15,
      "text": "Recorda que ele tá debaixo da canoa."
    },
    {
      "start": 998.27,
      "end": 998.53,
      "text": "Ó."
    },
    {
      "start": 998.61,
      "end": 999.09,
      "text": "Daqui, daqui."
    },
    {
      "start": 999.19,
      "end": 1001.03,
      "text": "Deixa eu passar a linha pra lá e te dou do outro lado."
    },
    {
      "start": 1001.03,
      "end": 1002.49,
      "text": "Senão vai estourar a linha na canoa."
    },
    {
      "start": 1002.49,
      "end": 1018.75,
      "text": "Já boiou ali."
    },
    {
      "start": 1018.89,
      "end": 1019.75,
      "text": "Parece barbado."
    },
    {
      "start": 1027.03,
      "end": 1027.47,
      "text": "Vixi."
    },
    {
      "start": 1032.7,
      "end": 1034.5,
      "text": "Olha o tamanho do barbado."
    },
    {
      "start": 1035.58,
      "end": 1037.57,
      "text": "Bonito, hein?"
    },
    {
      "start": 1038.33,
      "end": 1038.89,
      "text": "Nossa."
    },
    {
      "start": 1039.47,
      "end": 1041.13,
      "text": "Vamos fazer pertinho aqui."
    },
    {
      "start": 1041.23,
      "end": 1041.61,
      "text": "Vamos ver."
    },
    {
      "start": 1042.25,
      "end": 1043.11,
      "text": "Tá bravo."
    },
    {
      "start": 1046.22,
      "end": 1046.42,
      "text": "Vem."
    },
    {
      "start": 1046.7,
      "end": 1047.06,
      "text": "Opa."
    },
    {
      "start": 1050.3,
      "end": 1051.32,
      "text": "Joga água, joga."
    },
    {
      "start": 1054.17,
      "end": 1055.59,
      "text": "Nossa, peixe."
    },
    {
      "start": 1056.93,
      "end": 1057.87,
      "text": "Joga água."
    },
    {
      "start": 1059.43,
      "end": 1060.35,
      "text": "Olha que tamanho."
    },
    {
      "start": 1060.35,
      "end": 1064.88,
      "text": "Olha o barbadão."
    },
    {
      "start": 1065.2,
      "end": 1069.64,
      "text": "Não gosto de pegar no alicate."
    },
    {
      "start": 1069.9,
      "end": 1070.98,
      "text": "Deixa eu pegar com a mão."
    },
    {
      "start": 1071.34,
      "end": 1078.34,
      "text": "Tá muito louco."
    },
    {
      "start": 1079.08,
      "end": 1083.5,
      "text": "Calma, peixe."
    },
    {
      "start": 1083.72,
      "end": 1087.32,
      "text": "Nossa."
    },
    {
      "start": 1088.89,
      "end": 1089.39,
      "text": "Olha aí."
    },
    {
      "start": 1089.43,
      "end": 1090.39,
      "text": "Olha que bonito."
    },
    {
      "start": 1092.8,
      "end": 1094.52,
      "text": "Que beleza, gente."
    },
    {
      "start": 1095.83,
      "end": 1096.53,
      "text": "Olha aí, ó."
    },
    {
      "start": 1096.71,
      "end": 1099.13,
      "text": "Anzol encastuado, rancho do pescador."
    },
    {
      "start": 1100.64,
      "end": 1102.92,
      "text": "E esse não escapa mesmo."
    },
    {
      "start": 1103.2,
      "end": 1104.78,
      "text": "E ó, perfeitinho ainda."
    },
    {
      "start": 1106.48,
      "end": 1107.12,
      "text": "Que beleza."
    },
    {
      "start": 1107.4,
      "end": 1108.08,
      "text": "Que beleza."
    },
    {
      "start": 1109.64,
      "end": 1110.62,
      "text": "Vambora, peixinho."
    },
    {
      "start": 1111.16,
      "end": 1112.1,
      "text": "Bora pra sua casa."
    },
    {
      "start": 1116.12,
      "end": 1116.56,
      "text": "Calma."
    },
    {
      "start": 1117.1,
      "end": 1118.93,
      "text": "Faz pertinho aqui."
    },
    {
      "start": 1119.49,
      "end": 1120.19,
      "text": "Dá um close aqui."
    },
    {
      "start": 1120.19,
      "end": 1151.43,
      "text": "Nada que você quiser."
    },
    {
      "start": 1151.59,
      "end": 1152.31,
      "text": "Pode soltar."
    },
    {
      "start": 1153.24,
      "end": 1157.2,
      "text": "Quer falar de falar um close aqui nele."
    },
    {
      "start": 1157.64,
      "end": 1159.83,
      "text": "Olha que beleza."
    },
    {
      "start": 1160.35,
      "end": 1161.33,
      "text": "Bora pra sua casa?"
    },
    {
      "start": 1161.65,
      "end": 1162.41,
      "text": "Então vai, filho."
    },
    {
      "start": 1162.55,
      "end": 1162.81,
      "text": "Tchau."
    },
    {
      "start": 1168.12,
      "end": 1168.56,
      "text": "E aí?"
    },
    {
      "start": 1170.66,
      "end": 1171.88,
      "text": "Esse é o Pantanal."
    },
    {
      "start": 1173.12,
      "end": 1177.4,
      "text": "Acho que deu pra pegar um peixe de quase todos que tem aqui."
    },
    {
      "start": 1177.4,
      "end": 1184.78,
      "text": "Pegamos tucunaré, pegamos dourado, barbado, pacu, jaú."
    },
    {
      "start": 1185.76,
      "end": 1188.5,
      "text": "Faltou um apalmito, pegamos também."
    },
    {
      "start": 1189.66,
      "end": 1192.88,
      "text": "Faltou o pintadinho e faltou o piaussu."
    },
    {
      "start": 1192.88,
      "end": 1195.47,
      "text": "Essa é a diversidade."
    },
    {
      "start": 1195.53,
      "end": 1198.63,
      "text": "É isso que você encontra quando você vier pescar."
    },
    {
      "start": 1199.82,
      "end": 1204.94,
      "text": "E a gente não podia deixar de agradecer a Joyce ou a Demilson por ter convidado a gente."
    },
    {
      "start": 1205.52,
      "end": 1210.34,
      "text": "Essa semana a gente tá viajando no barco Cayamã 5 estrelas."
    },
    {
      "start": 1211.56,
      "end": 1214.94,
      "text": "E eu não posso deixar de agradecer."
    },
    {
      "start": 1215.04,
      "end": 1216.58,
      "text": "Eu vou até virar a câmera aqui."
    },
    {
      "start": 1216.58,
      "end": 1219.04,
      "text": "E esse cara aqui, ó."
    },
    {
      "start": 1219.34,
      "end": 1220.19,
      "text": "Muito obrigado."
    },
    {
      "start": 1220.31,
      "end": 1223.9,
      "text": "Esse é o Jefferson."
    },
    {
      "start": 1225.64,
      "end": 1230.04,
      "text": "O Jefferson é um dos guias do Cayamã 5 estrelas."
    },
    {
      "start": 1230.3,
      "end": 1233.38,
      "text": "E é o chefe de todos os guias."
    },
    {
      "start": 1233.5,
      "end": 1239.34,
      "text": "É ele que comanda todo esse time que, diga-se de passagem, é excepcional."
    },
    {
      "start": 1240.45,
      "end": 1243.85,
      "text": "Ó, minha parceirona aqui que pegou todos os peixes nessa viagem."
    },
    {
      "start": 1247.03,
      "end": 1248.57,
      "text": "Vem conhecer o Pantanal."
    },
    {
      "start": 1248.57,
      "end": 1249.97,
      "text": "Vem na Joyce Tour."
    },
    {
      "start": 1250.78,
      "end": 1252.48,
      "text": "Vem com a sua família."
    },
    {
      "start": 1252.66,
      "end": 1258.3,
      "text": "Eu posso te garantir que o peixe numa viagem dessa, ele fica assim, quinto plano."
    },
    {
      "start": 1258.94,
      "end": 1266.06,
      "text": "Viajar com a família, tá num lugar desse com a sua mulher, com seus filhos, é realmente uma coisa excepcional."
    },
    {
      "start": 1267.32,
      "end": 1269.38,
      "text": "Infelizmente, hoje a gente não tem mais tempo."
    },
    {
      "start": 1269.94,
      "end": 1275.12,
      "text": "Se você gostou, curte, comenta, compartilha, se inscreva no nosso canal."
    },
    {
      "start": 1275.12,
      "end": 1281.84,
      "text": "Semana que vem eu tô de volta com muito mais novidade e com muito mais pescaria pra vocês."
    },
    {
      "start": 1282.64,
      "end": 1287.03,
      "text": "Muito obrigado pelo carinho da audiência e até o nosso próximo encontro."
    },
    {
      "start": 1287.03,
      "end": 1288.82,
      "text": "Tchau."
    }
  ],
