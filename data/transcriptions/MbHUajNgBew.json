    },
    {
      "start": 276.46,
      "end": 277.46,
      "text": "Recuerden,"
    },
    {
      "start": 277.46,
      "end": 278.46,
      "text": "arrancan con esto apretado,"
    },
    {
      "start": 278.46,
      "end": 279.46,
      "text": "y este apretado."
