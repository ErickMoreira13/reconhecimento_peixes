    {
      "start": 279.46,
      "end": 280.46,
      "text": "Si?"
    },
    {
      "start": 280.46,
      "end": 281.46,
      "text": "Empiezan a tirar,"
    },
    {
      "start": 281.46,
      "end": 282.46,
      "text": "a tirar,"
