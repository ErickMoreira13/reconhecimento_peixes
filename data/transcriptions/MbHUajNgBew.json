    {
      "start": 282.46,
      "end": 283.46,
      "text": "a tirar,"
    },
    {
      "start": 283.46,
      "end": 284.46,
      "text": "a tirar."
    },
    {
      "start": 284.46,
      "end": 285.46,
      "text": "Este apenitas."
    },
    {
      "start": 285.46,
      "end": 286.46,
      "text": "A tirar,"
    },
    {
      "start": 286.46,
      "end": 287.46,
