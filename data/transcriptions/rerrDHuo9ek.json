      "text": "Que eu já temia que pudesse acontecer"
    },
    {
      "start": 946.71,
      "end": 947.73,
      "text": "Se não cuidasse"
    },
    {
      "start": 947.73,
      "end": 949.26,
      "text": "Nós colocamos"
    },
    {
      "start": 949.26,
      "end": 950.34,
      "text": "Esses refis"
    },
    {
      "start": 950.34,
      "end": 951.32,
      "text": "Aqui, ó"
    },
    {
      "start": 951.32,
      "end": 952.66,
      "text": "Esses aqui já estão"
    },
    {
      "start": 952.66,
      "end": 954.08,
      "text": "Já resfriaram"
    },
    {
      "start": 954.08,
      "end": 955.16,
      "text": "Estão guardados ali"
    },
    {
      "start": 955.16,
      "end": 957.82,
      "text": "Aqui dentro desse compartimento"
    },
    {
      "start": 957.82,
      "end": 959.06,
      "text": "Compartimento da canoa"
    },
    {
      "start": 959.06,
      "end": 961.12,
      "text": "E tava muito quente"
    },
    {
      "start": 961.12,
      "end": 962.0,
      "text": "Muito quente"
    },
    {
      "start": 962.0,
      "end": 962.88,
      "text": "E eu esqueci"
    },
    {
      "start": 962.88,
      "end": 965.32,
      "text": "Nós estávamos ali na beirada do rio"
    },
    {
      "start": 965.32,
      "end": 966.56,
      "text": "Isso aqui explodiu"
    },
    {
      "start": 966.56,
      "end": 967.66,
      "text": "A tampa voou"
    },
    {
      "start": 967.66,
      "end": 971.01,
      "text": "Olha a pancada que deu na tampa"
    },
    {
      "start": 971.01,
      "end": 971.77,
      "text": "Onde ele tava"
    },
    {
      "start": 971.77,
      "end": 973.09,
      "text": "Como uma bomba"
    },
    {
      "start": 973.65,
      "end": 974.64,
      "text": "Tá vendo?"
    },
    {
      "start": 975.3,
      "end": 976.34,
      "text": "O refil que fez"
    },
    {
      "start": 976.34,
      "end": 977.44,
      "text": "De gás"
    },
    {
      "start": 977.44,
      "end": 979.16,
      "text": "O refil"
    },
    {
      "start": 979.16,
      "end": 980.59,
      "text": "Explodiu"
    },
    {
      "start": 980.59,
      "end": 981.49,
      "text": "Mas não"
    },
    {
      "start": 981.49,
      "end": 981.87,
      "text": "Olha aí"
    },
    {
      "start": 981.87,
      "end": 982.89,
      "text": "Chegou a dobrar"
    },
    {
      "start": 982.89,
      "end": 984.31,
      "text": "Explodiu"
    },
    {
      "start": 984.31,
      "end": 984.95,
      "text": "Mas não"
    },
    {
      "start": 984.95,
      "end": 986.95,
      "text": "Não com fogo"
    },
    {
      "start": 986.95,
      "end": 988.81,
      "text": "Explodiu por causa da pressão"
    },
    {
      "start": 988.81,
      "end": 990.94,
      "text": "Aqueceu demais"
    },
    {
      "start": 990.94,
      "end": 991.7,
      "text": "Ele aquece"
    },
    {
      "start": 991.7,
      "end": 993.26,
      "text": "O ar expande"
    },
    {
      "start": 993.26,
      "end": 994.76,
      "text": "Explodiu o refil do gás"
    },
    {
      "start": 994.76,
      "end": 996.79,
      "text": "Causando um efeito"
    },
    {
      "start": 996.79,
      "end": 997.23,
      "text": "Ó"
    },
    {
      "start": 997.23,
      "end": 998.11,
      "text": "Chegou a afundar aqui"
    },
    {
      "start": 998.11,
      "end": 999.31,
      "text": "Essa parte da canoa"
    },
    {
      "start": 999.31,
      "end": 1001.83,
      "text": "Um efeito nos outros, ó"
    },
    {
      "start": 1001.83,
      "end": 1003.49,
      "text": "Esse aqui também chegou a vazar, ó"
    },
    {
      "start": 1003.49,
      "end": 1004.67,
      "text": "Aqueceu muito"
    },
    {
      "start": 1004.67,
      "end": 1007.4,
      "text": "E foi um susto"
    },
    {
      "start": 1007.4,
      "end": 1008.46,
      "text": "Porque foi um som alto"
    },
    {
      "start": 1008.46,
      "end": 1009.66,
      "text": "E a tampa saiu voando"
    },
    {
      "start": 1009.66,
      "end": 1010.38,
      "text": "A gente"
    },
    {
      "start": 1010.38,
      "end": 1011.64,
      "text": "Nós estávamos ali"
    },
    {
      "start": 1011.64,
      "end": 1014.62,
      "text": "Que sirva aí de"
    },
    {
      "start": 1014.62,
      "end": 1016.21,
      "text": "De alerta"
    },
    {
      "start": 1016.21,
      "end": 1017.53,
      "text": "Nunca deixe um refil desse aí"
    },
    {
      "start": 1017.53,
      "end": 1018.45,
      "text": "Dentro do carro"
    },
    {
      "start": 1018.45,
      "end": 1019.86,
      "text": "Dentro"
    },
    {
      "start": 1019.86,
      "end": 1020.92,
      "text": "Ou no sol quente"
    },
    {
      "start": 1020.92,
      "end": 1022.02,
      "text": "Porque ele explode"
    },
    {
      "start": 1022.02,
      "end": 1023.08,
      "text": "Ainda bem que não estamos"
    },
    {
      "start": 1023.08,
      "end": 1024.24,
      "text": "Em cima da canoa, né"
    },
    {
      "start": 1024.24,
      "end": 1025.62,
      "text": "Não estamos fora"
    },
    {
      "start": 1025.62,
      "end": 1026.88,
      "text": "Mas é um alerta"
    },
    {
      "start": 1026.88,
      "end": 1027.6,
      "text": "Agora a gente vai começar"
    },
    {
      "start": 1027.6,
      "end": 1028.2,
      "text": "A guardar"
    },
    {
      "start": 1028.2,
      "end": 1029.48,
      "text": "Melhor"
    },
    {
      "start": 1029.48,
      "end": 1030.84,
      "text": "Envolvido em um pano"
    },
    {
      "start": 1030.84,
      "end": 1031.9,
      "text": "Para não aquecer tanto"
    },
    {
      "start": 1031.9,
      "end": 1033.98,
      "text": "Deixa eu mostrar"
    },
    {
      "start": 1033.98,
      "end": 1034.94,
      "text": "O acampamento aqui"
    },
    {
      "start": 1034.94,
      "end": 1036.16,
      "text": "Olha aí"
    },
    {
      "start": 1036.16,
      "end": 1037.08,
      "text": "Tá uma baguncinha ali"
    },
    {
      "start": 1037.08,
      "end": 1038.02,
      "text": "Mas vamos organizar"
    },
    {
      "start": 1038.02,
      "end": 1039.39,
      "text": "Olha aí"
    },
    {
      "start": 1039.39,
      "end": 1040.61,
      "text": "Onde estamos acampados"
    },
    {
      "start": 1040.61,
      "end": 1042.53,
      "text": "Minha barraca ali em cima"
    },
    {
      "start": 1042.53,
      "end": 1043.93,
      "text": "Local bom"
    },
    {
      "start": 1043.93,
      "end": 1044.59,
      "text": "Sombra"
    },
    {
      "start": 1044.59,
      "end": 1046.17,
      "text": "As redes aqui"
    },
    {
      "start": 1046.17,
      "end": 1046.73,
      "text": "E aí, Raul"
    },
    {
      "start": 1046.73,
      "end": 1047.91,
      "text": "Essa é a rede"
    },
    {
      "start": 1047.91,
      "end": 1048.75,
      "text": "Que a gente improvisou"
    },
    {
      "start": 1048.75,
      "end": 1049.19,
      "text": "Com o Raul"
    },
    {
      "start": 1049.19,
      "end": 1050.25,
      "text": "Com a capa"
    },
    {
      "start": 1050.25,
      "end": 1051.28,
      "text": "E lá"
    },
    {
      "start": 1051.28,
      "end": 1052.58,
      "text": "Tá a barraca do Raul"
    },
    {
      "start": 1052.58,
      "end": 1053.82,
      "text": "Que lugar bom, hein"
    },
    {
      "start": 1053.82,
      "end": 1053.98,
      "text": "Cara"
    },
    {
      "start": 1053.98,
      "end": 1055.5,
      "text": "Você mostrou o acidente"
    },
    {
      "start": 1055.5,
      "end": 1057.16,
      "text": "É, eu mostrei o quase acidente"
    },
    {
      "start": 1057.16,
      "end": 1058.42,
      "text": "É, um alerta"
    },
    {
      "start": 1058.42,
      "end": 1058.92,
      "text": "Para quem"
    },
    {
      "start": 1058.92,
      "end": 1060.52,
      "text": "Carrega esses refis aí"
    },
    {
      "start": 1060.52,
      "end": 1061.68,
      "text": "Nunca deixar dentro do carro"
    },
    {
      "start": 1061.68,
      "end": 1063.04,
      "text": "Porque se ele aquece"
    },
    {
      "start": 1063.04,
      "end": 1063.4,
      "text": "Dentro do carro"
    },
    {
      "start": 1063.4,
      "end": 1064.34,
      "text": "Ele vai explodir também"
    },
    {
      "start": 1064.34,
      "end": 1064.88,
      "text": "Olha"
    },
    {
      "start": 1064.88,
      "end": 1068.26,
      "text": "Um sustaço"
    },
    {
      "start": 1068.26,
      "end": 1070.62,
      "text": "Um sustaço"
    },
    {
      "start": 1070.62,
      "end": 1071.82,
      "text": "É"
    },
    {
      "start": 1071.82,
      "end": 1073.73,
      "text": "É isso"
    },
    {
      "start": 1073.73,
      "end": 1075.45,
      "text": "Que local incrível"
    },
    {
      "start": 1075.45,
      "end": 1076.25,
      "text": "Foi um dia bom"
    },
    {
      "start": 1076.25,
      "end": 1077.77,
      "text": "Bati mais iscas ali"
    },
    {
      "start": 1077.77,
      "end": 1079.45,
      "text": "Dos dois, três lados aqui"
    },
    {
      "start": 1079.45,
      "end": 1081.13,
      "text": "Mas não rolou nada"
    },
    {
      "start": 1081.13,
      "end": 1083.03,
      "text": "Rolou esse dourado aí"
    },
    {
      "start": 1083.03,
      "end": 1083.79,
      "text": "Que foi muito legal"
    },
    {
      "start": 1083.79,
      "end": 1085.71,
      "text": "Teve ação de dourado"
    },
    {
      "start": 1085.71,
      "end": 1086.87,
      "text": "Então amanhã eu vou acordar cedo"
    },
    {
      "start": 1086.87,
      "end": 1087.67,
      "text": "E bater isca aqui"
    },
    {
      "start": 1087.67,
      "end": 1088.25,
      "text": "E ver o que dá"
    },
    {
      "start": 1088.25,
      "end": 1089.36,
      "text": "É"
    },
    {
      "start": 1089.36,
      "end": 1090.6,
      "text": "Até amanhã"
    },
    {
      "start": 1090.6,
      "end": 1091.66,
      "text": "E aí"
    },
    {
      "start": 1091.66,
      "end": 1093.66,
      "text": "E aí"
    }
  ],
