    {
      "start": 1500.69,
      "end": 1529.5,
      "text": "Piauzinho no molho"
    },
    {
      "start": 1529.5,
      "end": 1537.43,
      "text": "Juntou bonito ali, ó"
    },
    {
      "start": 1537.43,
      "end": 1556.29,
      "text": "Aqui é bom que quase não tem lenha, né"
    },
    {
