      "end": 1298.43,
      "text": "Já já nós estamos chegando lá"
    },
    {
      "start": 1298.43,
      "end": 1299.11,
      "text": "Vamos lá"
    },
    {
      "start": 1299.11,
      "end": 1301.09,
      "text": "Ligar o motor e partir pra casa"
    },
    {
      "start": 1301.09,
      "end": 1308.95,
      "text": "Acabei de chegar agora gente ó"
    },
    {
      "start": 1308.95,
      "end": 1312.46,
      "text": "Mostrar aqui a produção de hoje"
    },
    {
      "start": 1312.46,
      "end": 1321.44,
      "text": "A manzaria a colgande aí ó"
    },
    {
      "start": 1321.44,
      "end": 1327.27,
      "text": "A manzaria boa gente"
    },
    {
      "start": 1327.27,
      "end": 1328.07,
