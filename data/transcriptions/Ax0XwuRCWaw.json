    },
    {
      "start": 1368.74,
      "end": 1370.82,
      "text": "Graças a Deus"
    },
    {
      "start": 1370.82,
      "end": 1373.32,
      "text": "Cheguei em casa aqui com segurança no porto"
    },
    {
      "start": 1373.32,
      "end": 1374.94,
      "text": "Agora é só chegar em casa"
    },
    {
      "start": 1374.94,
