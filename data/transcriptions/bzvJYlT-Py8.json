    },
    {
      "start": 1482.25,
      "end": 1484.28,
      "text": "No meio dos tucunarés."
    },
    {
      "start": 1485.28,
      "end": 1486.28,
      "text": "Bora fazer a soltura dele."
    },
    {
      "start": 1497.42,
      "end": 1498.42,
      "text": "Vai com estilo."
    },
    {
      "start": 1498.42,
      "end": 1499.42,
      "text": "Esse foi educado, hein?"
    },
    {
      "start": 1499.42,
      "end": 1500.42,
      "text": "Esse foi educado."
    },
    {
      "start": 1503.38,
      "end": 1504.38,
      "text": "Agora eu vou pegar o caiaque."
    },
    {
      "start": 1505.86,
      "end": 1506.86,
      "text": "Vou seguir aqui rumo."
    },
    {
      "start": 1507.86,
      "end": 1508.86,
      "text": "Aí pra dentro desse garapé."
    },
    {
      "start": 1509.86,
      "end": 1512.86,
      "text": "E bora ver se te encontre o recorde dos recordes intergalácticos."
    },
    {
      "start": 1513.86,
      "end": 1514.86,
      "text": "Ou de trairomas do tucunaré."
    },
    {
      "start": 1515.86,
      "end": 1516.86,
      "text": "Bora lá."
    },
    {
      "start": 1516.86,
