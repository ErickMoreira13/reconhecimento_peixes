      "text": "No fundo."
    },
    {
      "start": 1412.29,
      "end": 1413.74,
      "text": "No fundo."
    },
    {
      "start": 1413.74,
      "end": 1414.74,
      "text": "No fundo."
    },
    {
      "start": 1414.74,
      "end": 1415.74,
      "text": "No fundo."
    },
    {
      "start": 1415.74,
      "end": 1416.74,
      "text": "Trairão."
    },
    {
      "start": 1416.74,
      "end": 1418.34,
      "text": "Já boiou meu Shed ali."
    },
    {
      "start": 1418.34,
      "end": 1419.34,
      "text": "Tá só no offset."
    },
    {
      "start": 1419.34,
      "end": 1420.5,
      "text": "Bruto, bruto, bruto."
    },
    {
      "start": 1420.5,
      "end": 1423.27,
      "text": "Eita que a gente fez um..."
    },
    {
      "start": 1423.27,
      "end": 1426.27,
      "text": "Um casal de tucunaré e um casal de trairão, né?"
    },
    {
      "start": 1426.27,
      "end": 1428.27,
      "text": "Só não vou falar que é um casal porque eu acho que eram duas fêmeas ali."
    },
    {
      "start": 1428.27,
      "end": 1433.05,
      "text": "No fundo."
    },
    {
      "start": 1433.05,
      "end": 1435.18,
      "text": "Tá no meio dos tucunaré, né?"
    },
    {
      "start": 1435.18,
      "end": 1443.29,
      "text": "No meio dos tucunaré, né?"
    },
    {
      "start": 1443.29,
      "end": 1446.29,
      "text": "Vou pegar só por roupé, como não pode pegar pela guerra."
    },
    {
      "start": 1446.29,
      "end": 1447.29,
      "text": "Que machuca."
    },
    {
      "start": 1448.29,
      "end": 1449.93,
      "text": "Ó."
    },
    {
      "start": 1449.93,
      "end": 1450.93,
      "text": "Tirar aqui, ó."
    },
    {
      "start": 1450.93,
      "end": 1451.93,
      "text": "Meu Shed tá ali."
    },
    {
      "start": 1451.93,
      "end": 1453.93,
      "text": "Aquele branco ali se flutuando."
    },
    {
      "start": 1454.96,
      "end": 1457.54,
      "text": "Na hora que bateu, saiu."
    },
    {
      "start": 1458.54,
      "end": 1462.38,
      "text": "Tá bocão."
    },
    {
      "start": 1462.38,
      "end": 1465.62,
      "text": "Sai, Shed."
    },
    {
      "start": 1466.62,
      "end": 1467.62,
      "text": "Mas, ó."
    },
    {
      "start": 1467.62,
      "end": 1468.62,
      "text": "Já tá solto."
    },
    {
      "start": 1468.62,
      "end": 1469.62,
      "text": "Ó."
    },
    {
      "start": 1469.62,
      "end": 1472.14,
      "text": "Bande integrado aí do Big Onish."
    },
    {
      "start": 1474.06,
      "end": 1475.06,
      "text": "Olha aí."
    },
    {
      "start": 1475.06,
      "end": 1480.1,
      "text": "Show de bola, né?"
    },
    {
      "start": 1480.1,
      "end": 1482.25,
