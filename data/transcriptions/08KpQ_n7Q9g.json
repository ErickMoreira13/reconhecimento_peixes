      "text": "Uh, coisa linda!"
    },
    {
      "start": 301.92,
      "end": 307.42,
      "text": "Eu entrei nesse jogo também com isca fresquinha e me enrosquei com mais um dos grandes."
    },
    {
      "start": 308.3,
      "end": 308.82,
      "text": "Obrigado!"
    },
    {
      "start": 308.9,
      "end": 309.34,
      "text": "Vamos lá!"
    },
    {
      "start": 310.1,
      "end": 311.04,
      "text": "Não vai pra louca não."
    },
    {
      "start": 311.18,
      "end": 311.5,
      "text": "Exato."
    },
    {
      "start": 311.78,
      "end": 312.26,
      "text": "Exato."
    },
    {
      "start": 312.76,
      "end": 315.06,
      "text": "O que será que enroscou aí comigo?"
    },
    {
      "start": 315.06,
      "end": 317.05,
      "text": "Vamos ver já."
    },
    {
      "start": 318.9,
      "end": 319.82,
      "text": "Oh, oh, oh!"
    },
    {
      "start": 319.96,
      "end": 320.96,
      "text": "Agora quer fazer força?"
    },
    {
      "start": 321.08,
      "end": 321.84,
      "text": "Oh, um jauzinho."
    },
    {
      "start": 321.84,
      "end": 322.38,
      "text": "Oh, um jauzinho."
    },
    {
      "start": 328.34,
      "end": 328.74,
      "text": "Aê!"
    },
    {
      "start": 330.08,
      "end": 334.38,
      "text": "Só pra gente ter uma noção mais ou menos, Marcão, um peixe de 15 quilos."
    },
    {
      "start": 334.52,
      "end": 335.08,
      "text": "15 quilos."
    },
    {
      "start": 335.3,
      "end": 335.74,
      "text": "Show de bola."
    },
    {
      "start": 335.74,
      "end": 336.48,
      "text": "Um fiotão, né?"
    },
    {
      "start": 336.48,
      "end": 336.54,
      "text": "Um fiotão, né?"
    },
    {
      "start": 336.74,
      "end": 337.18,
      "text": "Fiotão."
    },
    {
      "start": 337.32,
      "end": 337.9,
      "text": "Me ajuda aí."
    },
    {
      "start": 337.94,
      "end": 339.68,
      "text": "Segura ele pra eu poder pegar direitinho."
    },
    {
      "start": 340.36,
      "end": 343.9,
      "text": "Já deu uma cancena no pescador já."
    },
    {
      "start": 344.4,
      "end": 345.95,
      "text": "Foi embora."
    },
    {
      "start": 350.6,
      "end": 353.22,
      "text": "Rapaz, o peixe tá querendo sair meio ignorante."
    },
    {
      "start": 353.34,
      "end": 354.96,
      "text": "Você fez um detalhe pelo menos?"
    },
    {
      "start": 354.96,
      "end": 359.38,
      "text": "Fim do dia chegando e já tava bom, né?"
    },
    {
      "start": 359.74,
      "end": 362.3,
      "text": "Mas pra gente ainda faltava um troféu."
    },
    {
      "start": 362.68,
      "end": 365.94,
      "text": "Um dos peixes mais admirados e difíceis de se encontrar."
    },
    {
      "start": 366.58,
      "end": 370.34,
      "text": "A pergunta é, será que ainda dava tempo antes do sol ir embora?"
    },
    {
      "start": 370.34,
      "end": 374.08,
      "text": "Vamos ver, o que que é?"
