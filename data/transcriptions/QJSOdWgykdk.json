      "end": 1670.15,
      "text": "Olha que peixão gigante."
    },
    {
      "start": 1670.15,
      "end": 1672.13,
      "text": "Olha isso que aí."
    },
    {
      "start": 1672.87,
      "end": 1673.93,
      "text": "Lendária 90."
    },
    {
      "start": 1675.26,
      "end": 1677.08,
      "text": "Olha o tamanho."
    },
    {
      "start": 1677.88,
      "end": 1679.14,
      "text": "E o tanto que esse peixe tá gordo."
    },
    {
      "start": 1682.15,
      "end": 1683.21,
      "text": "Obrigado, meu Deus."
    },
    {
      "start": 1683.87,
      "end": 1684.13,
      "text": "Uh."
    },
    {
      "start": 1684.59,
      "end": 1687.0,
      "text": "Olha aí."
    },
    {
      "start": 1688.04,
      "end": 1688.72,
      "text": "Fazendo edição."
    },
    {
      "start": 1689.22,
      "end": 1692.36,
      "text": "Fechada."
    },
    {
      "start": 1692.62,
      "end": 1693.8,
      "text": "Olha a largura desse peixe."
    },
    {
      "start": 1695.79,
      "end": 1696.73,
      "text": "Arradinho ali."
    },
    {
      "start": 1697.75,
      "end": 1699.27,
      "text": "84 centímetros, hein."
    },
    {
      "start": 1700.01,
      "end": 1701.75,
      "text": "Olha a largura desse peixe, meus amigos."
    },
    {
      "start": 1703.84,
      "end": 1704.82,
      "text": "É gigantesco."
    },
    {
      "start": 1704.82,
      "end": 1711.49,
      "text": "Vou soltar ele."
    },
    {
      "start": 1712.38,
      "end": 1712.72,
      "text": "Chique."
    },
    {
      "start": 1715.24,
      "end": 1716.24,
      "text": "Fazer a soltura."
    },
    {
      "start": 1716.88,
      "end": 1717.88,
      "text": "Muito obrigado, viu."
    },
    {
      "start": 1717.88,
      "end": 1721.22,
      "text": "Muito obrigado."
    },
    {
      "start": 1721.46,
      "end": 1722.1,
      "text": "Vai com Deus."
    },
    {
      "start": 1723.17,
      "end": 1723.49,
      "text": "Uh."
    },
    {
      "start": 1764.6,
      "end": 1764.9,
      "text": "Ó."
    },
    {
      "start": 1765.2,
      "end": 1766.2,
      "text": "Nossa, que douradão."
    },
    {
      "start": 1766.72,
      "end": 1767.26,
      "text": "Escapou."
    },
    {
      "start": 1767.52,
      "end": 1768.04,
      "text": "Não, tá aqui."
    },
    {
      "start": 1769.01,
      "end": 1769.89,
      "text": "Ó, agora escapou."
    },
    {
      "start": 1771.77,
      "end": 1772.73,
      "text": "Meu Deus."
    },
    {
      "start": 1773.76,
      "end": 1774.4,
      "text": "Era bitelo."
    },
    {
      "start": 1823.54,
      "end": 1823.88,
      "text": "Pegou."
    },
    {
      "start": 1825.46,
      "end": 1825.78,
      "text": "Pegou."
    },
    {
      "start": 1828.71,
      "end": 1830.51,
      "text": "Nossa senhora, meu Deus."
    },
    {
      "start": 1831.07,
      "end": 1836.26,
      "text": "Nossa."
    },
    {
      "start": 1841.55,
      "end": 1842.43,
      "text": "Meu Deus do céu."
    },
    {
      "start": 1844.5,
      "end": 1846.0,
      "text": "Ele tá batendo embaixo do caiaque."
    },
    {
      "start": 1852.8,
      "end": 1853.88,
      "text": "Nossa senhora."
    },
    {
      "start": 1854.38,
      "end": 1855.29,
      "text": "Que loucura."
    },
    {
      "start": 1889.29,
      "end": 1890.59,
      "text": "Fazendo a gente passear, ó."
    },
    {
      "start": 1891.11,
      "end": 1893.05,
      "text": "Aqui o dourado faz o peão passear de caiaque."
    },
    {
      "start": 1895.28,
      "end": 1895.8,
      "text": "Olha isso."
    },
    {
      "start": 1897.67,
      "end": 1899.11,
      "text": "E ele quer brigar embaixo do caiaque."
    },
    {
      "start": 1903.37,
      "end": 1903.83,
      "text": "Meu Deus."
    },
    {
      "start": 1906.91,
      "end": 1907.99,
      "text": "Nossa senhora."
    },
    {
      "start": 1908.79,
      "end": 1909.45,
      "text": "Olha o tamanho."
    },
    {
      "start": 1910.45,
      "end": 1911.05,
      "text": "Olha isso."
    },
    {
      "start": 1912.13,
      "end": 1912.65,
      "text": "Que peixão."
    },
    {
      "start": 1913.43,
      "end": 1914.15,
      "text": "Olha a lunática aí."
    },
    {
      "start": 1916.73,
      "end": 1918.17,
      "text": "Olha só que coisa linda."
    },
    {
      "start": 1919.46,
      "end": 1920.1,
      "text": "Douradaço."
    },
    {
      "start": 1922.48,
      "end": 1923.34,
      "text": "Muito bonito, hein."
    },
    {
      "start": 1924.27,
      "end": 1924.63,
      "text": "Chique."
    },
    {
      "start": 1924.63,
      "end": 1924.79,
      "text": "Olha."
    },
    {
      "start": 1926.34,
      "end": 1928.62,
      "text": "Mediu o garotão."
    },
    {
      "start": 1928.62,
      "end": 1933.52,
      "text": "70 centímetros."
    },
    {
      "start": 1935.5,
      "end": 1936.16,
      "text": "Olha só."
    },
    {
      "start": 1942.26,
      "end": 1943.08,
      "text": "É bonito, hein."
    },
    {
      "start": 1944.31,
      "end": 1945.31,
      "text": "Que peixão."
    },
    {
      "start": 1945.73,
      "end": 1946.35,
      "text": "Peixe grande."
    },
    {
      "start": 1946.43,
      "end": 1947.03,
      "text": "Peixe gordo."
    },
    {
      "start": 1947.93,
      "end": 1948.89,
      "text": "Olha como tá saudável."
    },
    {
      "start": 1949.15,
      "end": 1949.79,
      "text": "Bem amarelo."
    },
    {
      "start": 1952.52,
      "end": 1953.22,
      "text": "Bora, meu amigão."
    },
    {
      "start": 1955.31,
      "end": 1956.13,
      "text": "Muito obrigado."
    },
    {
      "start": 1958.94,
      "end": 1959.88,
      "text": "Aproveitar, meus amigos."
    },
    {
      "start": 1959.96,
      "end": 1961.0,
      "text": "E encerrar a pescaria."
    },
    {
      "start": 1961.46,
      "end": 1962.86,
      "text": "Que pescaria produtiva, hein."
    },
    {
      "start": 1963.36,
      "end": 1967.86,
      "text": "Vou falar um pouquinho pra vocês sobre o comportamento reprodutivo do dourado, né."
    },
    {
      "start": 1968.3,
      "end": 1971.46,
      "text": "Entender o comportamento da espécie que você tá pescando é muito importante."
    },
    {
      "start": 1971.46,
      "end": 1973.8,
      "text": "Pra que você possa fazer boas pescarias."
    },
    {
      "start": 1974.1,
      "end": 1976.6,
      "text": "O dourado é um peixe de piracema."
    },
    {
      "start": 1976.96,
      "end": 1977.46,
      "text": "O que isso significa?"
    },
    {
      "start": 1978.38,
      "end": 1984.14,
      "text": "É um peixe que, quando está se aproximando do período reprodutivo, ele tende a migrar"
    },
    {
      "start": 1984.14,
      "end": 1985.24,
      "text": "pra outras regiões."
    },
    {
      "start": 1985.82,
      "end": 1989.58,
      "text": "Ele sai de um determinado local e migra pra outro."
    },
    {
      "start": 1989.98,
      "end": 1993.46,
      "text": "É nessa migração que o dourado desenvolve o hormônio reprodutivo."
    },
    {
      "start": 1994.58,
      "end": 1997.9,
      "text": "E como que funciona a reprodução em si, né."
    },
    {
      "start": 1997.9,
      "end": 2001.24,
      "text": "As fêmeas sobem até as cabeceiras dos rios."
    },
    {
      "start": 2001.68,
      "end": 2002.7,
      "text": "Os machos também."
    },
    {
      "start": 2003.22,
      "end": 2005.14,
      "text": "A fêmea deposita os ovos."
    },
    {
      "start": 2005.76,
      "end": 2007.22,
      "text": "E o macho fecunda."
    },
    {
      "start": 2007.38,
      "end": 2009.1,
      "text": "Então a fecundação é externa."
    },
    {
      "start": 2009.28,
      "end": 2010.74,
      "text": "A fêmea deposita na água."
    },
    {
      "start": 2011.02,
      "end": 2013.12,
      "text": "E o macho deposita o esperma na água."
    },
    {
      "start": 2013.84,
      "end": 2019.14,
      "text": "Após os ovos serem fecundados, eles vão aderir a alguma estrutura, né."
    },
    {
      "start": 2019.36,
      "end": 2021.2,
      "text": "Os ovos são extremamente aderentes."
    },
    {
      "start": 2021.52,
      "end": 2024.06,
      "text": "Então eles vão aderir em pedras, em galhos."
    },
    {
      "start": 2024.26,
      "end": 2027.88,
      "text": "Enfim, qualquer substrato que permita que eles se fixem ali."
    },
    {
      "start": 2028.56,
      "end": 2031.88,
      "text": "Após a fixação, vai ter o período de incubação."
    },
    {
      "start": 2031.98,
      "end": 2033.46,
      "text": "E depois os ovos vão eclodir."
    },
    {
      "start": 2033.66,
      "end": 2035.4,
      "text": "E nascem as larvas, né."
    },
    {
      "start": 2035.78,
      "end": 2042.92,
      "text": "E essas larvas, elas, a partir do momento que o ovo eclode, né."
    },
    {
      "start": 2043.22,
      "end": 2044.24,
      "text": "Elas ganham autonomia."
    },
    {
      "start": 2044.94,
      "end": 2045.8,
      "text": "O que isso quer dizer?"
    },
    {
      "start": 2046.38,
      "end": 2050.02,
      "text": "Que o macho e a fêmea não cuidam dos filhotes."
    },
    {
      "start": 2050.18,
      "end": 2051.12,
      "text": "No caso do dourado."
    },
    {
      "start": 2051.52,
      "end": 2053.18,
      "text": "Ao contrário dos ciclídeos, né."
    },
    {
      "start": 2053.18,
      "end": 2054.28,
      "text": "Exemplo, o tucunaré."
    },
    {
      "start": 2054.66,
      "end": 2056.42,
      "text": "O tucunaré cuida dos filhotes."
    },
    {
      "start": 2056.42,
      "end": 2059.74,
      "text": "Por isso que a taxa de sobrevivência do tucunaré é muito grande."
    },
    {
      "start": 2060.16,
      "end": 2060.88,
      "text": "O dourado não."
    },
    {
      "start": 2061.24,
      "end": 2064.54,
      "text": "Os alevinos, eles têm um alto cuidado, né."
    },
    {
      "start": 2065.06,
      "end": 2066.42,
      "text": "E qual que é a importância disso?"
    },
    {
      "start": 2066.88,
      "end": 2068.28,
      "text": "É conservação, né."
    },
    {
      "start": 2068.66,
      "end": 2073.08,
      "text": "O dourado, ele deposita uma quantidade muito grande de ovos."
    },
    {
      "start": 2073.08,
      "end": 2077.22,
      "text": "Porém, boa parte dos ovos fecundados, né."
    },
    {
      "start": 2077.62,
      "end": 2078.82,
      "text": "Não vão prosperar."
    },
    {
      "start": 2079.14,
      "end": 2083.5,
      "text": "Ou aqueles que prosperam, os alevinos estão sujeitos à predação, né."
    },
    {
      "start": 2083.6,
      "end": 2087.6,
      "text": "Predação por lambari, predação por piapara, predação por traíra."
    },
    {
      "start": 2087.7,
      "end": 2092.44,
      "text": "Enfim, todos os outros peixes predadores predam os alevinos do dourado."
    },
    {
      "start": 2092.54,
      "end": 2096.84,
      "text": "Porque a fêmea e o macho da espécie não cuidam dos filhotes."
    },
    {
      "start": 2097.14,
      "end": 2097.44,
      "text": "Tá bom?"
    },
    {
      "start": 2097.44,
      "end": 2101.16,
      "text": "Então nós precisamos ter muito cuidado, né, com o manuseio do dourado."
    },
    {
      "start": 2101.26,
      "end": 2102.46,
      "text": "Fazer o manuseio responsável."
    },
    {
      "start": 2102.88,
      "end": 2105.16,
      "text": "E também praticar a soltura da espécie."
    },
    {
      "start": 2105.46,
      "end": 2106.74,
      "text": "Porque vai ter demais, hein."
    },
    {
      "start": 2107.26,
      "end": 2109.86,
      "text": "É, com certeza, a minha pescaria preferida, né."
    },
    {
      "start": 2110.53,
      "end": 2112.19,
      "text": "Então, vamos encerrar assim."
    },
    {
      "start": 2112.61,
      "end": 2115.05,
      "text": "E aproveite, se inscreva no nosso canal no YouTube, tá."
    },
    {
      "start": 2115.43,
      "end": 2116.41,
      "text": "Compartilhe com os amigos."
    },
    {
      "start": 2116.73,
      "end": 2118.91,
      "text": "Você vai estar ajudando muito no crescimento do nosso trabalho."
    },
    {
      "start": 2119.65,
      "end": 2119.97,
      "text": "Fui!"
    },
    {
      "start": 2119.97,
      "end": 2120.07,
      "text": "Fui!"
    }
