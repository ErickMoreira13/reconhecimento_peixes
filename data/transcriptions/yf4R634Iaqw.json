      "text": "Ó"
    },
    {
      "start": 1118.23,
      "end": 1124.96,
      "text": "Esse é uma bêstia, meu amigo"
    },
    {
      "start": 1124.96,
      "end": 1128.27,
      "text": "Ah, que rir"
    },
    {
      "start": 1128.27,
      "end": 1129.15,
      "text": "Vamos ver o tamanho"
    },
    {
      "start": 1129.15,
      "end": 1130.03,
      "text": "Que rir"
    },
    {
      "start": 1130.03,
      "end": 1131.98,
      "text": "Vamos ver o tamanho dele"
    },
    {
      "start": 1131.98,
      "end": 1135.33,
      "text": "Todavia não o pode ver"
    },
    {
      "start": 1135.33,
      "end": 1135.79,
      "text": "Fíjate"
    },
    {
      "start": 1135.79,
      "end": 1137.45,
      "text": "Olha ele, olha ele aí"
    },
    {
      "start": 1137.45,
      "end": 1138.05,
      "text": "Ó"
    },
    {
      "start": 1138.05,
      "end": 1139.31,
      "text": "Olha ele aí em cima aí, ó"
    },
    {
      "start": 1139.31,
      "end": 1140.05,
      "text": "Já vi já"
    },
    {
      "start": 1140.05,
      "end": 1143.28,
