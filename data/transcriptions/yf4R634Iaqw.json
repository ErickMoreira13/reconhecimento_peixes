    {
      "start": 1323.95,
      "end": 1327.17,
      "text": "Agora eu vou acabar de limpar esses peixes"
    },
    {
      "start": 1327.17,
      "end": 1329.93,
      "text": "Nós vamos levar lá pra lanchonete do meu irmão"
    },
    {
      "start": 1329.93,
