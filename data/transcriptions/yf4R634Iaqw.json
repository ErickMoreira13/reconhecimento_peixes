    },
    {
      "start": 1104.18,
      "end": 1106.01,
      "text": "Deixa pra ir que foi"
    },
    {
      "start": 1106.01,
      "end": 1107.43,
      "text": "Cuidado, cuidado"
    },
    {
      "start": 1107.43,
      "end": 1108.29,
      "text": "Que ele tá travando aqui"
