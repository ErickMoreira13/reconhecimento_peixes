    {
      "start": 346.23,
      "end": 347.23,
      "text": "Não foi tucuna"
    },
    {
      "start": 347.23,
      "end": 349.23,
      "text": "Melhor ainda, cara"
    },
    {
      "start": 349.23,
      "end": 350.23,
      "text": "Aquele lugar ali"
    },
    {
      "start": 350.23,
      "end": 351.23,
      "text": "Melhor ainda"
    },
    {
      "start": 351.23,
      "end": 352.23,
      "text": "Vamos voltar lá?"
    },
    {
      "start": 352.23,
      "end": 353.23,
      "text": "Quer fazer mais um, ó?"
    },
    {
      "start": 353.23,
      "end": 355.35,
      "text": "Um hambúrguer"
    },
    {
      "start": 355.35,
      "end": 356.35,
      "text": "Vamos"
    },
    {
      "start": 356.35,
      "end": 357.35,
      "text": "Pegou"
    },
    {
      "start": 357.35,
      "end": 361.62,
      "text": "Pegou?"
    },
    {
      "start": 361.62,
      "end": 362.71,
      "text": "Pegou?"
    },
    {
      "start": 362.71,
      "end": 364.32,
      "text": "Pegou"
    },
    {
      "start": 364.32,
      "end": 365.32,
      "text": "Um, ó, azulão"
    },
    {
      "start": 365.32,
      "end": 368.02,
      "text": "Eita, peixe bom"
    },
    {
      "start": 368.02,
      "end": 370.69,
      "text": "Ah, coisa linda"
    },
    {
      "start": 370.69,
      "end": 373.49,
      "text": "Vai lá, bichinho"
    },
    {
      "start": 373.49,
      "end": 375.49,
      "text": "A gente viu o rebojo dele lá"
    },
    {
      "start": 375.49,
      "end": 378.06,
      "text": "Bateu alguma piaba"
    },
    {
      "start": 378.06,
      "end": 379.06,
      "text": "Ei, rapaz"
    },
    {
      "start": 379.06,
      "end": 381.06,
      "text": "Oia, charutou a zig-zarrinha"
    },
    {
      "start": 381.06,
      "end": 387.79,
      "text": "Garotinho"
    },
    {
      "start": 387.79,
      "end": 391.04,
      "text": "Ô, menino bruto"
    },
    {
      "start": 391.04,
      "end": 392.04,
      "text": "Aqui, ó"
    },
    {
      "start": 392.04,
      "end": 399.02,
      "text": "Olha aí, ó"
    },
    {
      "start": 399.02,
      "end": 401.02,
      "text": "Você viu que é a observação, né?"
    },
    {
      "start": 401.02,
      "end": 403.31,
      "text": "Bicho, tava lá mesmo"
    },
    {
      "start": 403.31,
      "end": 405.72,
      "text": "Tá aqui"
    },
    {
      "start": 405.72,
      "end": 409.13,
      "text": "Mas foi só jogar isso aqui em cima"
    },
    {
      "start": 409.13,
      "end": 410.13,
      "text": "Não precisou dar dúvida"
    },
    {
      "start": 410.13,
      "end": 411.13,
      "text": "Valeu"
    },
    {
      "start": 411.13,
      "end": 416.77,
      "text": "Valeu"
    },
    {
      "start": 416.77,
      "end": 422.28,
      "text": "Mesmo do tamanho do outro, né?"
    },
    {
      "start": 422.28,
      "end": 423.34,
      "text": "É"
    },
    {
      "start": 423.34,
      "end": 424.34,
      "text": "Padrão bom"
    },
    {
      "start": 424.34,
      "end": 425.34,
      "text": "Parecia um pouco maior"
    },
    {
      "start": 425.34,
      "end": 427.08,
      "text": "Que bateu"
    },
    {
      "start": 427.08,
      "end": 432.18,
      "text": "E esses são os azulzinhos"
    },
    {
      "start": 432.18,
      "end": 433.18,
      "text": "Do rio Tucantins"
    },
    {
      "start": 433.18,
      "end": 434.18,
      "text": "Que ficam bem maior"
    },
    {
      "start": 434.18,
      "end": 435.18,
      "text": "Do que esse, na verdade"
    },
    {
      "start": 435.18,
      "end": 436.95,
      "text": "Vamos soltar ele aqui, ó"
    },
    {
      "start": 436.95,
      "end": 444.14,
      "text": "Mais uma vez aqui"
    },
    {
      "start": 444.14,
      "end": 454.71,
      "text": "Esse é o peixinho do rio Tucantins, galera"
    },
    {
      "start": 454.71,
      "end": 461.54,
      "text": "Tá bem louco"
    },
    {
      "start": 461.54,
      "end": 462.82,
      "text": "Vai, garoto"
    },
    {
      "start": 462.82,
      "end": 463.82,
      "text": "Bora"
    },
    {
      "start": 463.82,
      "end": 464.82,
      "text": "Bora"
    }
  ],
