    {
      "start": 379.24,
      "end": 389.96,
      "text": "Nem uma academia"
    },
    {
      "start": 389.96,
      "end": 391.22,
      "text": "Meu Deus do céu"
    },
    {
      "start": 391.22,
      "end": 393.34,
      "text": "Olha, gente, ó"
    },
    {
      "start": 393.34,
      "end": 394.92,
      "text": "Tá agitadinha a cachara"
    },
    {
      "start": 394.92,
      "end": 395.74,
      "text": "Mas olha isso aqui, ó"
    },
    {
      "start": 395.74,
      "end": 396.98,
      "text": "Quando ela chegou"
    },
    {
      "start": 396.98,
      "end": 398.18,
      "text": "Acho que o Dorado"
    },
    {
      "start": 398.18,
      "end": 399.28,
      "text": "Comeu o rabo dela ali"
    },
    {
      "start": 399.28,
      "end": 399.58,
      "text": "Isso"
    },
    {
      "start": 399.58,
      "end": 401.54,
      "text": "Não tem um rabo pra nadar"
    },
    {
      "start": 401.54,
      "end": 402.06,
      "text": "Tadinha, ó"
    },
    {
      "start": 402.06,
      "end": 403.36,
      "text": "Toda agitada"
    },
    {
      "start": 403.36,
      "end": 405.16,
      "text": "Gente, olha"
    },
    {
      "start": 405.16,
      "end": 407.08,
      "text": "O Carlinho chegou na hora certa"
    },
    {
      "start": 407.08,
      "end": 410.08,
      "text": "De tirar um anzol"
    },
    {
      "start": 410.08,
      "end": 411.46,
      "text": "Num lugar que tá difícil ali"
    },
    {
      "start": 411.46,
      "end": 411.86,
      "text": "Sabe"
    },
    {
      "start": 411.86,
      "end": 414.65,
      "text": "Quando você não sabe"
    },
    {
      "start": 414.65,
      "end": 415.39,
      "text": "Tirar a manzol"
    },
    {
      "start": 415.39,
      "end": 416.85,
      "text": "Gente, o negócio é isso"
    },
    {
      "start": 416.85,
      "end": 417.69,
      "text": "Deixar uma pessoa"
    },
    {
      "start": 417.69,
      "end": 419.45,
      "text": "Que tem experiência"
    },
    {
      "start": 419.45,
      "end": 420.53,
      "text": "O Carlinhos"
    },
    {
      "start": 420.53,
      "end": 422.49,
      "text": "É o professor do canal"
    },
    {
      "start": 422.49,
      "end": 423.23,
      "text": "Do Yu de Pesca"
    },
    {
      "start": 423.23,
      "end": 424.11,
      "text": "Professor Carlinhos"
    },
    {
      "start": 424.11,
      "end": 424.97,
      "text": "Novamente aqui"
    },
    {
      "start": 424.97,
      "end": 426.13,
      "text": "É isso"
    },
    {
      "start": 426.13,
      "end": 427.65,
      "text": "Vai pra vida, menina"
    },
    {
      "start": 427.65,
      "end": 430.1,
      "text": "Vai pra vida, menininha"
    },
    {
      "start": 430.1,
      "end": 431.4,
      "text": "E o Yu de Tamuido"
    },
    {
      "start": 431.4,
      "end": 433.06,
      "text": "Com esse molinete"
    },
    {
      "start": 433.06,
      "end": 434.76,
      "text": "Com essa salsicha"
    },
    {
      "start": 434.76,
