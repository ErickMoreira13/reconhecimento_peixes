    {
      "start": 498.37,
      "end": 499.11,
      "text": "Sai do Puxa."
    },
    {
      "start": 499.89,
      "end": 501.63,
      "text": "Olha o tanto de bichinha já que a gente pegou aqui."
    },
    {
      "start": 503.53,
      "end": 505.01,
      "text": "Só joga e puxa."
    },
    {
      "start": 505.01,
      "end": 506.07,
      "text": "Só joga e puxa."
    },
    {
      "start": 506.13,
      "end": 506.85,
      "text": "Lá vem mais uma."
    },
    {
      "start": 508.52,
      "end": 509.28,
      "text": "Né, Idris?"
    },
    {
      "start": 509.28,
      "end": 511.63,
      "text": "Tuca já pegou um bocado ali."
    },
    {
      "start": 511.71,
      "end": 512.17,
      "text": "Vai, José."
    },
    {
      "start": 514.0,
      "end": 517.36,
      "text": "Tá correndo uma lambarizinha frita, a gente já comeu um monte de piadinha."
    },
    {
      "start": 517.44,
      "end": 518.28,
      "text": "Cadê a tua, Tuca?"
    },
    {
      "start": 519.91,
      "end": 521.37,
      "text": "Tá cheia ali já na caixa."
    },
    {
      "start": 523.86,
      "end": 525.96,
      "text": "Na palma, os bichinhos fritinhos aí, vai ficar bom, ó."
    },
    {
      "start": 526.58,
      "end": 527.58,
      "text": "Ah, foi mais um ali."
    },
    {
      "start": 530.82,
      "end": 532.0,
      "text": "Agora vem mais um."
    },
    {
      "start": 532.24,
      "end": 532.52,
      "text": "Cuidado."
    },
    {
      "start": 533.46,
      "end": 534.86,
      "text": "Meu Deus do céu."
    },
    {
      "start": 535.54,
      "end": 536.88,
      "text": "Não acredito não, ó."
    },
    {
      "start": 538.82,
