    {
      "start": 561.5,
      "end": 562.42,
      "text": "Eu entrei também."
    },
    {
      "start": 562.78,
      "end": 563.96,
      "text": "Cadê, José e o Rango?"
    },
    {
      "start": 564.02,
      "end": 564.52,
      "text": "Vamos comer."
    },
    {
      "start": 564.6,
      "end": 566.26,
      "text": "Vamos ver se eu pegasse vocês de volta."
    },
    {
      "start": 566.38,
      "end": 567.76,
      "text": "Trouxe lá os marmitas ali."
    },
    {
      "start": 567.76,
      "end": 568.38,
      "text": "Bem, Idris, ó."
    },
    {
      "start": 570.74,
      "end": 572.1,
      "text": "No meio do nada."
    },
    {
      "start": 572.2,
      "end": 573.38,
      "text": "No meio do lago, olha aí, ó."
    },
    {
      "start": 573.96,
      "end": 574.88,
      "text": "No meio do lago."
    },
    {
      "start": 574.88,
      "end": 580.94,
      "text": "E assim termina mais uma pescaria."
    },
    {
      "start": 581.74,
