    {
      "start": 556.42,
      "end": 557.42,
      "text": "Começou a chover."
    },
    {
      "start": 557.66,
      "end": 558.92,
      "text": "Como é que ele tá, né, na canoa?"
    },
    {
      "start": 559.4,
      "end": 560.4,
      "text": "Vocês sumiram?"
