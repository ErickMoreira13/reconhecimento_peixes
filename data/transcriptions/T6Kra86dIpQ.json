      "end": 481.55,
      "text": "Piranha."
    },
    {
      "start": 482.13,
      "end": 484.09,
      "text": "Uma piranha na pra conta."
    },
    {
      "start": 486.43,
      "end": 487.49,
      "text": "É surubim, hein?"
    },
    {
      "start": 490.53,
      "end": 492.09,
      "text": "Surubim aqui tá bonito, né?"
    },
    {
      "start": 492.63,
      "end": 493.99,
      "text": "Quero ver se capaz desse jeito."
    },
    {
      "start": 494.63,
      "end": 495.55,
      "text": "Pode parar a gravação."
    },
    {
      "start": 496.27,
      "end": 497.95,
      "text": "E esse lugar aqui, José, é bom?"
