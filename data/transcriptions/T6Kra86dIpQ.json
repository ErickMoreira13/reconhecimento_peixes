      "start": 425.46,
      "end": 426.52,
      "text": "Era limpada."
    },
    {
      "start": 428.26,
      "end": 429.56,
      "text": "E aqui é onde a gente dormiu."
    },
    {
      "start": 430.0,
      "end": 430.78,
      "text": "Passamos a noite."
    },
    {
      "start": 433.21,
