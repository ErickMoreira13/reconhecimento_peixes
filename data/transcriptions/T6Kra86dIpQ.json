      "text": "Bagunceida da janta."
    },
    {
      "start": 435.81,
      "end": 436.83,
      "text": "É a Bel."
    },
    {
      "start": 438.02,
      "end": 439.32,
      "text": "Pegamos nem um peixe à noite."
    },
    {
      "start": 440.83,
      "end": 441.29,
      "text": "E é isso aí."
    },
    {
      "start": 441.29,
      "end": 447.2,
      "text": "Filma a mulher."
    },
    {
      "start": 447.9,
      "end": 449.28,
      "text": "Tá indo no meio dos galhos aqui."
    },
    {
      "start": 449.3,
      "end": 449.78,
      "text": "Uma cobra."
    },
    {
      "start": 450.98,
      "end": 451.6,
      "text": "É um jacaré."
    },
    {
      "start": 451.94,
      "end": 453.36,
      "text": "Não acredito que..."
    },
    {
      "start": 453.36,
      "end": 453.94,
      "text": "É um jacaré."
    },
    {
      "start": 454.5,
      "end": 456.46,
      "text": "Entrou embaixo de um pau."
    },
    {
      "start": 456.52,
      "end": 456.76,
      "text": "É."
    },
    {
      "start": 457.04,
      "end": 458.22,
      "text": "Ah, saiu já ele."
    },
    {
      "start": 458.26,
      "end": 459.24,
      "text": "Tá embaixo da galha aqui."
    },
    {
      "start": 459.34,
      "end": 459.7,
      "text": "Saiu."
    },
    {
      "start": 460.2,
      "end": 461.0,
      "text": "Puta que pariu."
    },
    {
      "start": 461.34,
      "end": 461.72,
      "text": "Falei."
    },
    {
      "start": 462.2,
      "end": 463.54,
      "text": "Esperou fazer filmar aí?"
    },
    {
      "start": 463.96,
      "end": 466.57,
      "text": "Ah, mas é..."
    },
    {
      "start": 466.57,
      "end": 467.11,
      "text": "Resposta."
    },
    {
      "start": 468.76,
      "end": 470.04,
      "text": "Olha, ela ainda tá aí não."
    },
    {
      "start": 470.3,
      "end": 470.58,
      "text": "Olha, ó."
    },
    {
      "start": 470.58,
      "end": 470.84,
      "text": "Oi?"
    },
    {
      "start": 471.1,
      "end": 471.54,
