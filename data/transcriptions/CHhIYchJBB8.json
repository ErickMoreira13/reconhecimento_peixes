      "start": 422.05,
      "end": 423.05,
      "text": "Foi bonito."
    },
    {
      "start": 423.05,
      "end": 425.53,
      "text": "Isso aí, Zé."
    },
    {
      "start": 425.53,
      "end": 426.53,
      "text": "Parabéns, Romulo."
    },
    {
      "start": 426.53,
      "end": 427.53,
      "text": "Valeu."
    },
    {
      "start": 427.53,
      "end": 430.65,
      "text": "Já tava careco aqui."
    },
    {
      "start": 430.65,
      "end": 443.54,
      "text": "Olha só aquele..."
    },
    {
      "start": 443.54,
      "end": 446.14,
      "text": "É, já tá vendo cedo demais."
    },
    {
      "start": 446.14,
      "end": 462.74,
      "text": "O peixe tá tudo dormindo aí."
    },
    {
      "start": 462.74,
      "end": 467.23,
      "text": "Cara, que porrada, hein, Romulo?"
    },
    {
      "start": 467.23,
      "end": 468.23,
      "text": "Que porrada, hein?"
    },
    {
      "start": 468.23,
      "end": 478.99,
      "text": "Ó, gostei, hein?"
    },
    {
      "start": 478.99,
      "end": 480.99,
      "text": "Pô, isso aqui é bom, cara."
    },
    {
      "start": 480.99,
      "end": 481.99,
      "text": "O coração dá uma disparada."
    },
    {
      "start": 481.99,
      "end": 483.99,
      "text": "Nem foi na minha esse que bateu."
    },
    {
      "start": 483.99,
      "end": 484.99,
      "text": "Foi na sua."
    },
    {
      "start": 484.99,
      "end": 485.99,
      "text": "Vai dar um..."
    },
    {
      "start": 485.99,
      "end": 487.99,
      "text": "A adrenalina é que a gente precisa, cara."
    },
    {
      "start": 487.99,
      "end": 492.82,
      "text": "É a adrenalina que a gente precisa, cara."
    },
    {
      "start": 492.82,
      "end": 514.78,
      "text": "Agora tá bom."
    },
    {
      "start": 514.78,
      "end": 519.91,
      "text": "Olha como que adianta a vida, velho."
    },
    {
      "start": 519.91,
      "end": 532.35,
      "text": "Tem um alicate desse de poda no barco."
    },
    {
      "start": 532.35,
      "end": 536.46,
      "text": "Adianta muito a vida."
    },
    {
      "start": 536.46,
      "end": 539.46,
      "text": "Corta o galho e tira a isca aqui dentro do barco com segurança."
    },
    {
      "start": 539.46,
      "end": 540.46,
      "text": "Tranquilo."
    },
    {
      "start": 540.46,
      "end": 567.58,
      "text": "Vou começar a gravar."
    },
    {
      "start": 567.58,
      "end": 571.14,
      "text": "Nossa."
    },
    {
      "start": 571.14,
      "end": 574.49,
      "text": "Caraca, o peixe era muito grande, velho."
    },
    {
      "start": 574.49,
      "end": 578.66,
      "text": "Esse peixe era muito grande."
    },
    {
      "start": 578.66,
      "end": 582.7,
      "text": "Caraca, velho."
    },
    {
      "start": 582.7,
      "end": 584.44,
      "text": "Pegou?"
    },
    {
      "start": 584.44,
      "end": 590.62,
      "text": "Pegou?"
    },
    {
      "start": 590.62,
      "end": 591.62,
      "text": "Ih, maravilha."
    },
    {
      "start": 591.62,
      "end": 593.62,
      "text": "Trabalha o peixe."
    },
    {
      "start": 593.62,
      "end": 598.25,
      "text": "Ah, mas..."
    },
    {
      "start": 598.25,
      "end": 601.5,
      "text": "Eu vou continuar arremessando lá, porque o que bateu era maior."
    },
    {
      "start": 601.5,
      "end": 602.5,
      "text": "Era maior."
    },
    {
      "start": 602.5,
      "end": 607.16,
      "text": "Já deixo puçar no esquema aí, ó."
    },
    {
      "start": 607.16,
      "end": 608.16,
      "text": "O que deu pra puçar?"
    },
    {
      "start": 608.16,
      "end": 618.76,
      "text": "Vamos marcar esse peixe."
    },
    {
      "start": 618.76,
      "end": 619.76,
      "text": "Que maravilha."
    },
    {
      "start": 619.76,
      "end": 626.18,
      "text": "Mas o que bateu na mesa era maior, não era, Roma?"
    },
    {
      "start": 626.18,
      "end": 628.56,
      "text": "Era outro peixe, hein?"
    },
    {
      "start": 628.56,
      "end": 636.06,
      "text": "Que bonita."
    },
    {
