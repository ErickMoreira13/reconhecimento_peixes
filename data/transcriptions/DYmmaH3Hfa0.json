    {
      "start": 958.87,
      "end": 959.65,
      "text": "Eu já vi ali criando os dois."
    },
    {
      "start": 959.71,
      "end": 960.15,
      "text": "Vai vir tudo."
    },
    {
      "start": 962.46,
      "end": 963.32,
      "text": "A lá de baixo, de baixo."
    },
    {
      "start": 964.0,
      "end": 965.1,
      "text": "Nossa, eu peguei e foi de dois."
    },
    {
      "start": 965.74,
      "end": 966.16,
      "text": "Dois?"
    },
    {
      "start": 966.74,
      "end": 967.56,
      "text": "Olha lá, foi um só."
    },
    {
      "start": 969.24,
      "end": 970.16,
      "text": "Nossa, que amarelão."
    },
    {
      "start": 971.84,
      "end": 972.24,
      "text": "Rapaz."
    },
    {
      "start": 972.8,
      "end": 973.16,
      "text": "É, né?"
    },
    {
      "start": 973.28,
      "end": 975.82,
      "text": "Não é o amarelão, mas, rapaz, quem sabe, hein?"
    },
    {
      "start": 976.53,
      "end": 977.55,
      "text": "Quem sabe dá um azar."
    },
    {
      "start": 977.79,
      "end": 978.15,
      "text": "Parabéns."
    },
    {
      "start": 979.17,
      "end": 979.95,
      "text": "Aqui, olha aí, rapaz."
    },
    {
      "start": 979.95,
      "end": 980.99,
      "text": "Que amarelinho lindo."
    },
    {
      "start": 981.55,
      "end": 981.99,
      "text": "Top."
    },
    {
      "start": 981.99,
      "end": 983.27,
      "text": "Eu falei que eu ia enchar ele com tudo, hein?"
    },
    {
      "start": 984.06,
      "end": 984.46,
      "text": "Top."
    },
    {
      "start": 984.46,
      "end": 985.14,
      "text": "Aqui uns 38."
    },
    {
      "start": 986.24,
      "end": 986.92,
      "text": "Mais ou menos."
    },
    {
      "start": 986.98,
      "end": 987.32,
      "text": "É isso."
    },
    {
      "start": 989.43,
      "end": 990.89,
      "text": "Olha, que amarelinho top."
    },
    {
      "start": 1007.03,
      "end": 1007.61,
      "text": "Vai para a vida."
    },
    {
      "start": 1010.87,
      "end": 1011.89,
      "text": "Aêê, parabéns."
    },
    {
      "start": 1011.89,
      "end": 1014.25,
      "text": "final de tarde."
    },
    {
      "start": 1016.04,
      "end": 1016.86,
      "text": "Glória a Deus."
    },
    {
      "start": 1017.6,
      "end": 1018.82,
      "text": "Glória a Deus por mais um dia."
    },
    {
      "start": 1021.66,
      "end": 1023.72,
      "text": "Meus amigos, final de tarde."
    },
    {
      "start": 1024.98,
      "end": 1026.16,
      "text": "Rio Grande, Mira Estrela."
    },
    {
      "start": 1027.36,
      "end": 1028.28,
      "text": "Final de torneio."
    },
    {
      "start": 1029.69,
      "end": 1031.41,
      "text": "A gente está quase encerrando aqui."
    },
    {
      "start": 1032.09,
      "end": 1033.51,
      "text": "Foi um dia top, graças a Deus."
    },
    {
      "start": 1034.39,
      "end": 1036.89,
      "text": "Bastante peixe, mas ficamos com uma média muito baixa."
    },
    {
      "start": 1037.96,
      "end": 1038.48,
      "text": "Mas esteve bom."
    },
