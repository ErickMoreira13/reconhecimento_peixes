    {
      "start": 615.1,
      "end": 616.62,
      "text": "Ele perdeu a poãs"
    },
    {
      "start": 616.62,
      "end": 616.92,
      "text": "Olha lá"
    },
    {
      "start": 616.92,
      "end": 618.18,
      "text": "As duas poãs"
    },
    {
      "start": 618.18,
      "end": 618.56,
      "text": "Briga"
    },
    {
      "start": 618.56,
      "end": 621.88,
      "text": "Bota aí, homem"
    },
    {
      "start": 621.88,
      "end": 624.24,
      "text": "Eita, putelo"
    },
    {
      "start": 624.24,
      "end": 625.87,
      "text": "Rapaz"
    },
    {
      "start": 625.87,
      "end": 626.85,
      "text": "Bota conferir"
    },
    {
      "start": 626.85,
      "end": 627.33,
      "text": "Eu tenho poãs, não"
    },
    {
      "start": 627.33,
      "end": 629.14,
      "text": "Olha, perdeu"
    },
    {
      "start": 629.14,
      "end": 630.8,
      "text": "Caraca, véi"
    },
    {
      "start": 630.8,
      "end": 632.08,
      "text": "É bonito demais, gente"
    },
    {
      "start": 632.08,
      "end": 633.95,
      "text": "Olha só"
    },
    {
      "start": 633.95,
      "end": 637.49,
      "text": "Dá uns 300 gramas aqui"
    },
    {
      "start": 637.49,
      "end": 637.95,
      "text": "Mais, não dá?"
    },
    {
      "start": 638.89,
      "end": 639.67,
      "text": "É grande, Núcio"
    },
    {
      "start": 639.67,
      "end": 640.93,
      "text": "Hum"
    },
    {
      "start": 640.93,
      "end": 642.27,
      "text": "Um palmo"
    },
    {
      "start": 642.27,
      "end": 645.25,
      "text": "Rapaz, escolhe o som disso aqui, cara"
    },
    {
      "start": 645.25,
      "end": 647.24,
      "text": "Você consegue limpar"
    },
    {
      "start": 647.24,
      "end": 648.86,
      "text": "Outro camarão"
    },
    {
      "start": 648.86,
      "end": 649.52,
      "text": "Só com ele"
    },
    {
      "start": 649.52,
      "end": 656.28,
      "text": "O que será que ele pega aqui"
    },
    {
      "start": 656.28,
      "end": 656.54,
      "text": "Pra poder"
    },
    {
      "start": 656.54,
      "end": 657.78,
      "text": "Ah, aqui, ó"
    },
    {
      "start": 657.78,
      "end": 658.82,
      "text": "Tem um dente"
    },
    {
      "start": 658.82,
      "end": 665.8,
      "text": "Entra pra aí"
    },
    {
      "start": 665.8,
      "end": 667.36,
      "text": "Rapaz, sete camarão"
    },
    {
      "start": 667.36,
      "end": 675.05,
      "text": "Bora ajeitar"
    },
    {
      "start": 675.05,
      "end": 683.16,
      "text": "Acho que você não precisa recolher, não"
    },
    {
      "start": 683.16,
      "end": 685.65,
      "text": "Só vou tirar ali"
    },
    {
      "start": 685.65,
      "end": 687.53,
      "text": "Tem que recolher"
    },
    {
      "start": 687.53,
      "end": 689.98,
      "text": "Não vai embolar, não vai puxar"
    },
    {
      "start": 689.98,
      "end": 690.56,
      "text": "É"
    },
    {
      "start": 690.56,
      "end": 691.52,
      "text": "Só espera um pouquinho"
    },
    {
      "start": 691.52,
      "end": 695.4,
      "text": "Ó"
    },
    {
      "start": 695.4,
      "end": 696.4,
      "text": "Não é não"
    },
    {
      "start": 696.4,
      "end": 707.16,
      "text": "Já tirei"
    },
    {
      "start": 707.16,
      "end": 712.25,
      "text": "Bora"
    },
    {
      "start": 712.25,
      "end": 713.47,
      "text": "Vou puxar, hein"
    },
    {
      "start": 713.47,
      "end": 738.12,
      "text": "Que comer"
    },
    {
      "start": 738.12,
      "end": 738.72,
      "text": "Ok"
    },
    {
      "start": 738.72,
      "end": 739.72,
      "text": "Obrigado."
    }
  ],
