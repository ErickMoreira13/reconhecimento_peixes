      "end": 444.5,
      "text": "Vou jogar no restaurante"
    },
    {
      "start": 444.5,
      "end": 450.86,
      "text": "Peguei lá na frente"
    },
    {
      "start": 450.86,
      "end": 465.89,
      "text": "Peguei lá do pé do pilar"
    },
    {
      "start": 465.89,
      "end": 676.72,
      "text": "Me arregaçou no pilar"
    },
    {
      "start": 676.72,
      "end": 682.12,
      "text": "Nossa, essa foi bonita, hein, galera"
    },
    {
      "start": 682.12,
      "end": 686.85,
      "text": "Cara, que curva, né"
    },
    {
      "start": 686.85,
      "end": 699.83,
      "text": "Galerinha do canal aqui"
    },
    {
      "start": 699.83,
      "end": 704.78,
      "text": "Que nem o licate"
    },
    {
      "start": 704.78,
      "end": 722.02,
      "text": "Curva, não sei"
    },
    {
      "start": 722.02,
      "end": 766.91,
      "text": "Deixa lá"
    },
    {
      "start": 766.91,
      "end": 768.58,
      "text": "Ela baixa lá"
    },
    {
      "start": 768.58,
      "end": 769.9,
      "text": "Ela vem rascando no pilar"
    },
    {
      "start": 769.9,
      "end": 772.36,
      "text": "Tomar cuidado pra não jogar muito perto"
    },
    {
      "start": 772.36,
      "end": 774.98,
      "text": "Ela não..."
    },
    {
      "start": 774.98,
      "end": 776.54,
      "text": "Essa aqui já vai raspar, já"
    },
    {
      "start": 776.54,
      "end": 781.17,
      "text": "O multifilamento não aguenta ficar raspando"
    },
    {
      "start": 781.17,
      "end": 834.36,
      "text": "Fica massa, galera"
    },
    {
      "start": 834.36,
      "end": 835.58,
      "text": "Aí, a gosto"
    },
    {
      "start": 835.58,
      "end": 862.44,
      "text": "Ela não pegou"
    },
    {
      "start": 862.44,
      "end": 865.36,
      "text": "Ela tava enroscada"
    },
    {
      "start": 865.36,
      "end": 1013.38,
      "text": "Vai no celular, mano"
    },
    {
      "start": 1013.38,
      "end": 1019.51,
      "text": "Bruta"
    },
    {
      "start": 1019.51,
      "end": 1022.96,
      "text": "Fica mais um pouco aqui, galera"
    },
    {
      "start": 1022.96,
      "end": 1024.34,
      "text": "Daqui a pouco já tem que ir também"
    },
    {
      "start": 1024.34,
      "end": 1028.75,
      "text": "Vamos ver se pega mais alguma, hein"
    },
    {
      "start": 1028.75,
      "end": 1031.22,
      "text": "Aquelas duas ali já valeu, hein"
    },
    {
      "start": 1031.22,
      "end": 1036.4,
      "text": "Nossa, eu ia pegar desse tamanho aqui, não"
    },
    {
      "start": 1036.4,
      "end": 1061.55,
      "text": "Top"
    },
    {
      "start": 1061.55,
      "end": 1071.36,
      "text": "Bairro desse jeito mesmo, ali"
    },
    {
      "start": 1071.36,
      "end": 1075.01,
      "text": "Aí, galera"
    },
    {
      "start": 1075.01,
      "end": 1076.67,
      "text": "Aí, pegou"
    },
    {
      "start": 1076.67,
      "end": 1077.29,
      "text": "Pegou outra"
    },
    {
      "start": 1077.29,
      "end": 1077.89,
      "text": "Pegou outra"
    },
    {
      "start": 1077.89,
      "end": 1078.69,
      "text": "Pegou outra"
    },
    {
      "start": 1078.69,
      "end": 1080.07,
      "text": "Olha lá na frente"
    },
    {
      "start": 1080.07,
      "end": 1082.92,
      "text": "Que beleza"
    },
    {
      "start": 1082.92,
      "end": 1084.85,
      "text": "Tá vindo"
    },
    {
      "start": 1084.85,
      "end": 1086.69,
      "text": "Não é tão grande igual a outra, não"
    },
    {
      "start": 1086.69,
      "end": 1090.94,
      "text": "Que pulo de dokunaré que deu atrás de mim aqui"
    },
    {
      "start": 1090.94,
      "end": 1093.8,
      "text": "Ah, né"
    },
    {
      "start": 1093.8,
      "end": 1094.2,
      "text": "Bonito"
    },
    {
      "start": 1094.2,
      "end": 1095.54,
      "text": "Ô, louco, é grande, cara"
    },
    {
      "start": 1095.54,
      "end": 1096.32,
      "text": "O tamanho da outra"
    },
    {
      "start": 1096.32,
      "end": 1099.46,
      "text": "Top, top, top"
    },
    {
      "start": 1099.46,
      "end": 1100.28,
      "text": "Mais uma"
    },
    {
      "start": 1100.28,
      "end": 1102.92,
      "text": "Só falta mais uma agora, galera"
    },
    {
      "start": 1102.92,
      "end": 1105.84,
      "text": "Aí, mordendo"
    },
    {
      "start": 1105.84,
      "end": 1107.36,
      "text": "Ah, filha da mãe"
    },
    {
      "start": 1107.36,
      "end": 1110.54,
      "text": "Sozinha"
    },
    {
      "start": 1110.54,
      "end": 1112.25,
      "text": "Ó, que nave"
    },
    {
      "start": 1112.25,
      "end": 1115.62,
      "text": "Sem alicate, cara"
    },
    {
      "start": 1115.62,
      "end": 1117.06,
      "text": "Ela acaba nos dedos da gente"
    },
    {
      "start": 1117.06,
      "end": 1119.12,
      "text": "Puxou uma ali na outra"
    },
    {
      "start": 1119.12,
      "end": 1119.68,
      "text": "Eu perdi"
    },
    {
      "start": 1119.68,
      "end": 1120.18,
      "text": "Aí"
    },
    {
      "start": 1120.18,
      "end": 1121.78,
      "text": "Aí, essa aqui pegou sozinha"
    },
    {
      "start": 1121.78,
      "end": 1124.08,
      "text": "Dentinho enfiado"
    },
    {
      "start": 1124.08,
      "end": 1127.11,
      "text": "Vou levar quatro"
    },
    {
      "start": 1127.11,
      "end": 1129.53,
      "text": "Legal"
    },
    {
      "start": 1129.53,
      "end": 1131.93,
      "text": "Tirar só o filete"
    },
    {
      "start": 1131.93,
      "end": 1133.81,
      "text": "Tá massa aqui, galera"
    },
    {
      "start": 1133.81,
      "end": 1135.57,
      "text": "Chique, chique noite"
    },
    {
      "start": 1135.57,
      "end": 1137.25,
      "text": "Olha aí pra trás, ó"
    },
    {
      "start": 1137.25,
      "end": 1138.63,
      "text": "Ali já é o barranco, ó"
    },
    {
      "start": 1138.63,
      "end": 1140.56,
      "text": "Na primeira pilar"
    },
    {
      "start": 1140.56,
      "end": 1143.57,
      "text": "Não estou com nada nervoso ali naquele pilar"
    },
    {
      "start": 1143.57,
      "end": 1145.42,
      "text": "Aí, vou ficar aqui agora"
    },
    {
      "start": 1145.42,
      "end": 1147.99,
      "text": "Lá na frente"
    },
    {
      "start": 1147.99,
      "end": 1152.88,
      "text": "No chão e deixando lá"
    },
    {
      "start": 1152.88,
      "end": 1153.74,
      "text": "Não estou nem puxando"
    },
    {
      "start": 1153.74,
      "end": 1155.47,
      "text": "Demorou um pouquinho"
    },
    {
      "start": 1155.47,
      "end": 1156.47,
      "text": "Mas pegou uma bitela"
    },
    {
      "start": 1156.47,
      "end": 1157.09,
      "text": "Você viu, né"
    },
    {
      "start": 1157.09,
      "end": 1159.73,
      "text": "Deixa eu chegar no chão"
    },
    {
      "start": 1159.73,
      "end": 1161.05,
      "text": "Chegou"
    },
    {
      "start": 1161.05,
      "end": 1164.6,
      "text": "Só dou uma esticadinha na linha"
    },
    {
      "start": 1164.6,
      "end": 1174.92,
      "text": "Às vezes, a hora que você joga"
    },
    {
      "start": 1174.92,
      "end": 1175.72,
      "text": "Ela já pega"
    },
    {
      "start": 1175.72,
      "end": 1181.92,
      "text": "Galera, essa é uma boa aqui agora"
    },
    {
      "start": 1181.92,
      "end": 1183.86,
      "text": "Tá até difícil tirar"
    },
    {
      "start": 1183.86,
      "end": 1186.35,
      "text": "Não deu pra gravar a puxada"
    },
    {
      "start": 1186.35,
      "end": 1187.67,
      "text": "Tava com o telefone na mão"
    },
    {
      "start": 1187.67,
      "end": 1189.65,
      "text": "Pra ela não enroscar"
    },
    {
      "start": 1189.65,
      "end": 1190.65,
      "text": "Essa é boa"
    },
    {
      "start": 1190.65,
      "end": 1194.41,
      "text": "Olha, ele tá enroscando em tudo aí embaixo"
    },
    {
      "start": 1194.41,
      "end": 1195.96,
      "text": "Vamos ver"
    },
    {
      "start": 1195.96,
      "end": 1196.9,
      "text": "Acho que vai sair"
    },
    {
      "start": 1196.9,
      "end": 1199.54,
      "text": "Aí, coisa boa, hein"
    },
    {
      "start": 1199.54,
      "end": 1199.76,
      "text": "Ó"
    },
    {
      "start": 1199.76,
      "end": 1206.93,
      "text": "Olha, tá saindo só cavalo aqui, cara"
    },
    {
      "start": 1206.93,
      "end": 1211.43,
      "text": "Nossa, vai aqui"
    },
    {
      "start": 1211.43,
      "end": 1213.47,
      "text": "Olha o barbado"
    },
    {
      "start": 1213.47,
      "end": 1217.37,
      "text": "Nossa, os barbados não largam daí"
    },
    {
      "start": 1217.37,
      "end": 1220.26,
      "text": "Ó"
    },
    {
      "start": 1220.26,
      "end": 1223.05,
      "text": "Mais um, hein"
    },
    {
      "start": 1223.05,
      "end": 1224.25,
      "text": "Pra finalizar o dia"
    },
    {
      "start": 1224.25,
      "end": 1227.0,
      "text": "Chegaram a curvinha"
    },
    {
      "start": 1227.0,
      "end": 1233.8,
      "text": "Agora"
    },
    {
      "start": 1233.8,
      "end": 1251.5,
      "text": "Saindo fora da pilar"
    },
    {
      "start": 1251.5,
      "end": 1253.96,
      "text": "Ó, pegou a outra varinha"
    },
    {
      "start": 1253.96,
      "end": 1254.72,
      "text": "Olha a outra varinha"
    },
    {
      "start": 1254.72,
      "end": 1255.2,
      "text": "Ó"
    },
    {
      "start": 1255.2,
      "end": 1257.26,
      "text": "Pegou"
    },
    {
      "start": 1257.26,
      "end": 1260.72,
      "text": "Agora vamos ver"
    },
    {
      "start": 1260.72,
      "end": 1262.66,
      "text": "Se é curvinha"
    },
    {
      "start": 1262.66,
      "end": 1267.7,
      "text": "Você viu o caiaque saiu de lado"
    },
    {
      "start": 1267.7,
      "end": 1268.1,
      "text": "Olha lá"
    },
    {
      "start": 1268.1,
      "end": 1269.16,
      "text": "Pulou lá na frente"
    },
    {
      "start": 1269.16,
      "end": 1270.89,
      "text": "Curvinha"
    },
    {
      "start": 1270.89,
      "end": 1279.72,
      "text": "Não é tão grande"
    },
    {
      "start": 1279.72,
      "end": 1280.56,
      "text": "Mas ela é bonita"
    },
    {
      "start": 1280.56,
      "end": 1282.3,
      "text": "Passou pro outro lado"
    },
    {
      "start": 1282.3,
      "end": 1284.82,
      "text": "Ó, bonita"
    },
    {
      "start": 1284.82,
      "end": 1285.68,
      "text": "Que grande"
    },
    {
      "start": 1285.68,
      "end": 1294.21,
      "text": "Só tá saindo curvinha boa"
    },
    {
      "start": 1294.21,
      "end": 1297.8,
      "text": "As quatro que eu falei que eu queria"
    },
    {
      "start": 1297.8,
      "end": 1298.54,
      "text": "Já tá na mão"
    },
    {
      "start": 1298.54,
      "end": 1302.33,
      "text": "Eu coloquei em enquete outro dia lá, né"
    },
    {
      "start": 1302.33,
      "end": 1303.57,
      "text": "Que que a galera queria que eu"
    },
    {
      "start": 1303.57,
      "end": 1308.62,
      "text": "Qual tipo de pescaria que a galera queria que eu fizesse"
    },
    {
      "start": 1308.62,
      "end": 1310.14,
      "text": "Ganhou lá a pescaria de curvinha"
    },
    {
      "start": 1310.14,
      "end": 1310.42,
      "text": "Falei"
    },
    {
      "start": 1310.42,
      "end": 1311.24,
      "text": "Ai, ai, ai"
    },
    {
      "start": 1311.24,
      "end": 1312.02,
      "text": "E agora?"
    },
    {
      "start": 1316.54,
      "end": 1318.96,
      "text": "Parar debaixo de uma ponte daquela"
    },
    {
      "start": 1318.96,
      "end": 1319.94,
      "text": "E ver o que que dá, né"
    },
    {
      "start": 1319.94,
      "end": 1321.1,
      "text": "Até que deu bom"
    },
    {
      "start": 1321.1,
      "end": 1323.43,
      "text": "Pronto, galera"
    },
    {
      "start": 1323.43,
      "end": 1325.67,
      "text": "Comprometido"
    },
    {
      "start": 1325.67,
      "end": 1327.29,
      "text": "Fiz a pescaria de curvinha"
    },
    {
      "start": 1327.29,
      "end": 1328.49,
      "text": "Tava legal"
    },
    {
      "start": 1328.49,
      "end": 1330.63,
      "text": "Saímos curvininha boa"
    },
    {
      "start": 1330.63,
      "end": 1332.86,
      "text": "Mas já deu horário"
    },
    {
      "start": 1332.86,
      "end": 1333.86,
      "text": "Preciso ir"
    },
    {
      "start": 1333.86,
      "end": 1337.46,
      "text": "Quem sabe outro dia eu volto e tento mais alguma coisa aqui"
    },
    {
      "start": 1337.46,
      "end": 1338.46,
      "text": "Tava bem bacana"
    },
    {
      "start": 1338.46,
      "end": 1340.64,
      "text": "Bem na ponte aqui, ó"
    },
    {
      "start": 1340.64,
      "end": 1342.85,
      "text": "Sombra tá batendo aqui"
    },
    {
      "start": 1342.85,
      "end": 1343.49,
      "text": "Tá bem legal"
    },
    {
      "start": 1343.49,
      "end": 1344.47,
      "text": "Um vento gostoso"
    },
    {
      "start": 1344.47,
      "end": 1345.87,
      "text": "Vento bem fraquinho"
    },
    {
      "start": 1345.87,
      "end": 1347.09,
      "text": "E é isso"
    },
    {
      "start": 1347.09,
      "end": 1348.39,
      "text": "Comprometido"
    },
    {
      "start": 1348.39,
      "end": 1350.76,
      "text": "Pescaria de curvinha"
    },
    {
      "start": 1350.76,
      "end": 1353.54,
      "text": "É, tá alcançada"
    },
    {
      "start": 1353.54,
      "end": 1355.84,
      "text": "Obrigado, viu, galera"
    },
    {
      "start": 1355.84,
      "end": 1356.88,
      "text": "Por acompanhar aí"
    },
    {
      "start": 1356.88,
      "end": 1360.01,
      "text": "Até logo, logo"
    },
    {
      "start": 1360.01,
      "end": 1361.19,
      "text": "Que no dia eu tô de volta"
    },
    {
      "start": 1361.19,
      "end": 1362.43,
      "text": "Um abraço"
    },
    {
      "start": 1362.43,
      "end": 1363.11,
      "text": "Tudo de bom"
    }
  ],
