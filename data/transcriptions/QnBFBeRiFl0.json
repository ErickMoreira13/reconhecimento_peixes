    {
      "start": 669.77,
      "end": 670.01,
      "text": "Vai."
    },
    {
      "start": 671.55,
      "end": 672.23,
      "text": "Um pouquinho mais."
    },
    {
      "start": 673.25,
      "end": 673.99,
      "text": "Deixa que respire."
    },
    {
      "start": 676.94,
      "end": 677.16,
      "text": "Uh!"
    },
    {
      "start": 678.72,
      "end": 681.42,
      "text": "Dá mais trabalho segurar ela fora d'água do que brigar com ela, alemão."
    },
    {
      "start": 682.5,
      "end": 682.94,
      "text": "Hã?"
    },
    {
      "start": 687.05,
      "end": 687.91,
      "text": "Que coisa, né?"
    },
    {
      "start": 693.48,
      "end": 694.18,
      "text": "O que achou, alemão?"
    },
    {
      "start": 695.57,
      "end": 696.55,
      "text": "De noite, hein?"
    },
    {
      "start": 697.78,
      "end": 698.46,
      "text": "Que monça."
    },
    {
      "start": 699.54,
      "end": 700.9,
      "text": "Peixe de mais de 15 quilos fácil."
    },
    {
      "start": 701.98,
      "end": 702.16,
      "text": "Hã?"
    },
    {
      "start": 703.64,
      "end": 704.0,
      "text": "Cabeçuda."
    },
    {
      "start": 707.23,
      "end": 707.39,
      "text": "Hã?"
    },
    {
      "start": 709.32,
      "end": 709.82,
      "text": "Olha lá, ó."
    },
    {
      "start": 709.82,
      "end": 713.78,
      "text": "Deixa aqui, sem pressa."
    },
    {
      "start": 714.83,
      "end": 715.03,
      "text": "Aí."
    },
    {
      "start": 716.63,
      "end": 717.13,
      "text": "Olha lá, ó."
    },
    {
      "start": 717.92,
      "end": 718.94,
      "text": "Pra vocês verem aqui, tá?"
    },
    {
      "start": 720.16,
      "end": 720.7,
      "text": "Acompanha aí."
    },
    {
      "start": 722.88,
      "end": 723.08,
      "text": "Vai."
    },
    {
      "start": 725.9,
      "end": 726.56,
      "text": "Bate o rabo."
    },
    {
      "start": 727.24,
      "end": 728.84,
      "text": "Já bateu três vezes, mas não deixei ela aí, não."
    },
    {
      "start": 728.88,
      "end": 730.02,
      "text": "Quero segurar mais um pouquinho ainda."
    },
    {
      "start": 740.03,
      "end": 740.71,
      "text": "Agora vai, ó."
    },
    {
      "start": 745.29,
      "end": 746.65,
      "text": "De noite, meus amigos."
    },
    {
      "start": 747.89,
      "end": 750.09,
      "text": "Eu arranquei couro do meu pé aqui, Willi."
    },
    {
      "start": 750.61,
      "end": 752.15,
      "text": "Tem couro do meu pé."
    },
    {
      "start": 754.01,
      "end": 754.21,
      "text": "Ah!"
    },
    {
      "start": 754.35,
      "end": 755.55,
      "text": "É uma lenda esse homem."
    },
    {
      "start": 755.79,
      "end": 757.97,
      "text": "Pega na natural, pega no picho, pegão."
    },
    {
      "start": 759.46,
      "end": 760.5,
      "text": "Ô, alemão, incrível, ó."
    },
    {
      "start": 760.6,
      "end": 761.56,
      "text": "Dá uma olhada na lua aí."
    },
    {
      "start": 763.34,
      "end": 764.14,
      "text": "Olha que espetáculo."
    },
    {
      "start": 764.92,
      "end": 766.64,
      "text": "A gente consegue ver um pouquinho da cidade lá no fundo?"
    },
    {
      "start": 767.5,
      "end": 768.04,
      "text": "Consegue, né?"
    },
    {
      "start": 768.2,
      "end": 769.16,
      "text": "Aquele clarão lá, ó."
    },
    {
      "start": 769.2,
      "end": 771.24,
      "text": "Lá, lá é a cidade."
    },
    {
      "start": 772.59,
      "end": 773.81,
      "text": "Que espetáculo, Willi."
    },
    {
      "start": 774.47,
      "end": 775.79,
      "text": "Vamos comer agora e descansar, né?"
    },
    {
      "start": 776.03,
      "end": 777.42,
      "text": "Não precisa mais do que isso."
    },
    {
      "start": 777.56,
      "end": 778.52,
      "text": "E poder pegar mais, hein?"
    },
    {
      "start": 779.26,
      "end": 779.88,
      "text": "Muita graça."
    },
    {
      "start": 780.99,
      "end": 782.67,
      "text": "Amigos, comenta aí se vocês acham"
    },
    {
      "start": 782.67,
      "end": 785.74,
      "text": "que o alemão tem..."
    },
    {
      "start": 785.74,
      "end": 786.6,
      "text": "Se ele tem..."
    },
    {
      "start": 786.6,
      "end": 787.76,
      "text": "Não é para que não tira ele pegar um dourado."
    },
    {
      "start": 787.76,
      "end": 788.76,
      "text": "Por favor!"
    },
    {
      "start": 789.26,
      "end": 790.7,
      "text": "Faz tempo que eu não pego um douradão, hein?"
    },
    {
      "start": 791.1,
      "end": 791.38,
      "text": "Ah!"
    },
    {
      "start": 792.34,
      "end": 793.22,
      "text": "Vocês já tinham visto isso?"
    },
    {
      "start": 793.34,
      "end": 795.12,
      "text": "Dourado monstro de noite, no currículo."
    },
    {
      "start": 796.12,
      "end": 798.22,
      "text": "Mostramos para vocês aí a experiência do Willi."
    },
    {
      "start": 798.3,
      "end": 798.86,
      "text": "É fantástico."
    },
    {
      "start": 799.82,
      "end": 800.56,
      "text": "Mais uma experiência nova."
    },
    {
      "start": 800.6,
      "end": 801.38,
      "text": "Eu já tinha pescado a noite,"
    },
    {
      "start": 801.44,
      "end": 802.92,
      "text": "mas não tinha pegado um monstro desse, não, tá?"
    },
    {
      "start": 803.62,
      "end": 804.6,
      "text": "Então, agora nós vamos voltar,"
    },
    {
      "start": 804.7,
      "end": 805.38,
      "text": "porque tem que ir de boa."
    },
    {
      "start": 805.46,
      "end": 806.04,
      "text": "A cidade está lá."
    },
    {
      "start": 806.16,
      "end": 807.08,
      "text": "O que nós estamos de distância?"
    },
    {
      "start": 807.28,
      "end": 808.3,
      "text": "Uns 20 minutos, Willi?"
    },
    {
      "start": 808.44,
      "end": 809.2,
      "text": "20 minutos, né?"
    },
    {
      "start": 809.86,
      "end": 811.06,
      "text": "Então, agora já é..."
    },
    {
      "start": 811.06,
      "end": 811.62,
      "text": "Vamos ver aqui."
    },
    {
      "start": 813.03,
      "end": 814.63,
      "text": "Lembra o horário que eu mostrei para vocês antes, alemão?"
    },
    {
      "start": 814.63,
      "end": 817.53,
      "text": "Era 10 para as 9, eu falei antes, né?"
    },
    {
      "start": 818.17,
      "end": 818.65,
      "text": "Tá aí, ó."
    },
    {
      "start": 819.77,
      "end": 821.53,
      "text": "Saiu o primeiro, saiu o segundo rapidinho."
    },
    {
      "start": 822.03,
      "end": 823.45,
      "text": "Mas já está tarde, vamos descansar,"
    },
    {
      "start": 823.51,
      "end": 824.23,
      "text": "porque amanhã tem mais peixe."
    },
    {
      "start": 824.73,
      "end": 826.73,
      "text": "Pedrinho, pesca, pássaro da pátria, pesca noturna."
    },
    {
      "start": 826.85,
      "end": 827.43,
      "text": "Obrigado, Willi."
    },
    {
      "start": 827.77,
      "end": 829.33,
      "text": "Para vocês ficarem aprendendo aí, tá?"
    },
    {
      "start": 829.47,
      "end": 830.11,
      "text": "É a noite também."
    },
    {
      "start": 830.33,
      "end": 831.63,
      "text": "E música natural pegaria também?"
    },
    {
      "start": 832.33,
      "end": 833.13,
      "text": "Pegaria também, né?"
    },
    {
      "start": 833.17,
      "end": 833.63,
      "text": "Não é só artificial."
    },
    {
      "start": 834.66,
      "end": 836.04,
      "text": "Não se esqueça de compartilhar, comentar,"
    },
    {
      "start": 836.1,
      "end": 837.74,
      "text": "toda a regração do canal vai ao Hospital do Câncer,"
    },
    {
      "start": 837.8,
      "end": 839.5,
      "text": "de Porto Velho, Rondônia."
    },
    {
      "start": 839.9,
      "end": 840.68,
      "text": "Hospital do Amor, lá."
    },
    {
      "start": 840.68,
      "end": 842.5,
      "text": "Você pode salvar uma vida só de assistir nossos vídeos."
    },
    {
      "start": 842.84,
      "end": 844.08,
      "text": "Vamos para casa."
    },
    {
      "start": 844.18,
      "end": 845.46,
      "text": "Vamos tomar um tererê agora,"
    },
    {
      "start": 845.46,
      "end": 846.94,
      "text": "que está quente ainda e vamos para casa."
    },
    {
      "start": 847.92,
      "end": 849.24,
      "text": "Graças, fica com a lua aí, amigos."
    }
  ],
