      "end": 711.18,
      "text": "Aqui também está menor."
    },
    {
      "start": 711.4,
      "end": 711.9,
      "text": "Olha aí, ó."
    },
    {
      "start": 715.03,
      "end": 715.63,
      "text": "Parabéns, aí."
    },
    {
      "start": 715.63,
      "end": 722.01,
      "text": "O João pegou mais um, hein, João?"
    },
    {
      "start": 722.25,
      "end": 722.95,
      "text": "Mais um."
    },
    {
      "start": 724.95,
      "end": 725.35,
      "text": "Vindo."
    },
    {
      "start": 725.83,
      "end": 726.67,
      "text": "Que desagaro."
    },
    {
      "start": 730.12,
      "end": 732.1,
      "text": "Ah, se não pegar com material novo, né?"
    },
    {
      "start": 737.1,
      "end": 738.98,
      "text": "Também, se não pegar com material novo, né?"
    },
    {
      "start": 739.34,
      "end": 741.33,
      "text": "Aí pode abandonar, né, Tio?"
    },
    {
      "start": 741.59,
      "end": 742.21,
      "text": "Tá, louco."
    },
    {
      "start": 744.1,
      "end": 745.78,
      "text": "Tá verde ainda a vara dele."
    },
    {
      "start": 745.78,
