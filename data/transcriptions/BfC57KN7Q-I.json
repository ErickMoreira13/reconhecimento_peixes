    {
      "start": 753.76,
      "end": 754.28,
      "text": "Pintado."
    },
    {
      "start": 754.78,
      "end": 757.59,
      "text": "Mais um pintado."
    },
    {
      "start": 757.67,
      "end": 759.19,
      "text": "Mais um pra conta aí, vô."
    },
    {
      "start": 759.79,
      "end": 760.73,
      "text": "Mais um pra conta."
    },
    {
      "start": 761.07,
      "end": 761.79,
      "text": "Tá certo."
    },
    {
      "start": 762.01,
      "end": 762.39,
      "text": "Vamos lá."
    },
    {
      "start": 762.39,
      "end": 817.37,
      "text": "E aí, pessoal, final de pescaria."
    },
    {
      "start": 817.49,
      "end": 818.69,
      "text": "Estamos voltando pra casa."
    },
    {
      "start": 819.73,
      "end": 821.21,
      "text": "E aí, como é que foi, João?"
    },
    {
      "start": 821.83,
      "end": 822.89,
      "text": "Foi boa, foi boa."
    },
    {
      "start": 822.89,
      "end": 825.77,
      "text": "Contratempo ou outro, mas foi boa a pescaria."
    },
    {
      "start": 826.11,
      "end": 826.49,
      "text": "Isso aí."
    },
    {
      "start": 826.99,
      "end": 828.03,
      "text": "E aí, Edson, como é que foi?"
    },
    {
      "start": 828.67,
      "end": 829.55,
      "text": "Bastante ação."
    },
    {
      "start": 829.89,
      "end": 830.65,
      "text": "Feito bom."
    },
    {
      "start": 831.68,
      "end": 833.34,
      "text": "Mas a água estava bastante suja."
    },
    {
      "start": 833.6,
      "end": 834.94,
      "text": "Mas deu pra se divertir."
    },
    {
      "start": 835.02,
      "end": 836.72,
      "text": "Deu pra passar o dia tranquilo."
    },
    {
      "start": 837.98,
      "end": 838.48,
      "text": "É isso aí."
    },
    {
      "start": 838.48,
      "end": 840.46,
      "text": "Pra casa, vou colocar a família agora."
    },
    {
      "start": 840.72,
      "end": 842.32,
      "text": "E só pela próxima."
    },
    {
      "start": 842.78,
      "end": 844.08,
      "text": "É isso aí, então, pessoal."
    },
    {
      "start": 844.86,
      "end": 845.68,
      "text": "Fiquem com Deus."
    },
    {
      "start": 845.94,
      "end": 848.36,
      "text": "E segue lá no YouTube."
    },
    {
      "start": 848.36,
