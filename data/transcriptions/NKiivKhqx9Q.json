      "end": 1106.42,
      "text": "Eu, Davi Lambari, na luta"
    },
    {
      "start": 1106.42,
      "end": 1108.62,
      "text": "Atrás dos peixes, olha aí"
    },
    {
      "start": 1108.62,
      "end": 1110.62,
      "text": "Olha só que bitelos, Gurizada"
    },
    {
      "start": 1110.62,
      "end": 1112.74,
      "text": "Agora vamos tirar umas fotos com ele"
    },
    {
      "start": 1112.74,
      "end": 1114.74,
      "text": "Fazer a soltura aí, beleza?"
    },
    {
      "start": 1114.74,
      "end": 1116.81,
      "text": "Pintadinho do Rio Miranda"
    },
    {
      "start": 1116.81,
      "end": 1119.94,
      "text": "Falei pra vocês que eu tava pra jogo hoje, hein?"
    },
    {
      "start": 1119.94,
      "end": 1121.19,
      "text": "Isso aqui vai pra vida"
    },
    {
      "start": 1121.19,
      "end": 1124.85,
      "text": "Valeu da visão"
    },
    {
      "start": 1124.85,
      "end": 1125.85,
      "text": "Meu guia"
    },
    {
      "start": 1125.85,
      "end": 1126.85,
      "text": "Tiramos fotos"
    },
    {
      "start": 1126.85,
      "end": 1127.85,
      "text": "E o peixe tá na vida"
    },
    {
      "start": 1127.85,
      "end": 1128.85,
      "text": "Tamo junto"
    }
