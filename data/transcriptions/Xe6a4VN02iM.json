      "start": 977.14,
      "end": 979.39,
      "text": "Três já eu perdi."
    },
    {
      "start": 979.39,
      "end": 982.86,
      "text": "É pra acabar, cara."
    },
    {
      "start": 982.86,
      "end": 983.86,
      "text": "Ah, é brincadeira."
    },
    {
      "start": 983.86,
      "end": 985.82,
      "text": "É, meu."
    },
    {
      "start": 985.82,
      "end": 987.82,
      "text": "Outra pegada aqui violenta."
    },
    {
      "start": 987.82,
      "end": 1001.21,
      "text": "Aí o mais um."
    },
    {
      "start": 1001.21,
      "end": 1005.06,
      "text": "Tudo pra baixo da pedra."
    },
    {
      "start": 1005.06,
      "end": 1020.02,
      "text": "É..."
    },
    {
      "start": 1020.02,
      "end": 1024.34,
      "text": "Teria dado bom se eu tivesse pegado aquele grande lá."
    },
    {
      "start": 1024.34,
      "end": 1026.26,
      "text": "Mas aí são..."
    },
    {
      "start": 1026.26,
      "end": 1027.26,
      "text": "Só uns pequenos, hein."
    },
    {
      "start": 1027.26,
      "end": 1030.0,
      "text": "Acho que vai dar pra fritar amanhã."
    },
    {
      "start": 1030.0,
      "end": 1033.0,
      "text": "Vamos ver se o tempo vai deixar nós pescar hoje de noite."
    },
    {
      "start": 1033.0,
      "end": 1034.13,
      "text": "Tá se armando aí."
    },
    {
      "start": 1034.13,
      "end": 1036.13,
      "text": "Tão se armando um tempo feio aí, cara."
    },
    {
      "start": 1036.13,
      "end": 1038.86,
      "text": "Vamos ver o que que vai dar."
    },
    {
      "start": 1038.86,
      "end": 1040.86,
      "text": "Se não, vamos ficar no acampamento aí."
    },
    {
      "start": 1040.86,
      "end": 1042.89,
      "text": "Tomando um café."
    },
    {
      "start": 1042.89,
      "end": 1044.89,
      "text": "Dando umas risadas, hein."
    },
    {
      "start": 1044.89,
      "end": 1052.58,
      "text": "Vamos pro lado da boia."
    },
    {
      "start": 1052.58,
      "end": 1053.58,
      "text": "Ah, apagou o fogo."
    },
    {
      "start": 1053.58,
      "end": 1054.58,
      "text": "Aí, ó."
    },
    {
      "start": 1054.58,
      "end": 1055.58,
      "text": "Apagou o fogo, ó."
    },
    {
      "start": 1055.58,
      "end": 1056.58,
      "text": "Aqui, ó."
    },
    {
      "start": 1056.58,
      "end": 1057.58,
      "text": "Põe junto."
    },
    {
      "start": 1057.58,
      "end": 1058.58,
      "text": "Põe junto ali, ó."
    },
    {
      "start": 1058.58,
      "end": 1059.58,
      "text": "De manhã ali, ó."
    },
    {
      "start": 1059.58,
      "end": 1061.71,
      "text": "De manhã já nós..."
    },
    {
      "start": 1061.71,
      "end": 1063.71,
      "text": "Aí, os bicharinhos bonitos, hein."
    },
    {
      "start": 1063.71,
      "end": 1065.71,
      "text": "Mas tem que gostar de pimenta."
    },
    {
      "start": 1067.66,
      "end": 1069.66,
      "text": "Será que vai ficar bom?"
    },
    {
      "start": 1069.66,
      "end": 1070.66,
      "text": "Meu pai."
    },
    {
      "start": 1070.66,
      "end": 1073.56,
      "text": "Tem bastante pimenta?"
    },
    {
      "start": 1073.56,
      "end": 1074.56,
      "text": "Tem."
    },
    {
      "start": 1074.56,
      "end": 1075.56,
      "text": "Então é com nós."
    },
    {
      "start": 1075.56,
      "end": 1076.56,
      "text": "Pimenta é com nós."
    },
    {
      "start": 1076.56,
      "end": 1085.54,
      "text": "Que boia de capricho."
    },
    {
      "start": 1085.54,
      "end": 1089.78,
      "text": "Tem que me passar essa receita aqui."
    },
    {
      "start": 1089.78,
      "end": 1092.13,
      "text": "Muito fácil de fazer."
    },
    {
      "start": 1092.13,
      "end": 1093.13,
      "text": "Muito fácil de fazer."
    },
    {
      "start": 1093.13,
      "end": 1102.91,
      "text": "Aqui tem tomate, pimentão, arroz."
    },
    {
      "start": 1102.91,
      "end": 1108.03,
      "text": "Tem que pegar, primeiro, linguiça toscana."
    },
    {
      "start": 1108.03,
      "end": 1109.06,
      "text": "Linguiça."
    },
    {
      "start": 1109.06,
      "end": 1111.06,
      "text": "Linguiça toscana."
    },
    {
      "start": 1111.06,
      "end": 1114.22,
      "text": "Daí frita ela."
    },
    {
      "start": 1114.22,
      "end": 1115.22,
      "text": "Tira da pele, né."
    },
    {
      "start": 1115.22,
      "end": 1116.22,
      "text": "Frita ela aí."
    },
    {
      "start": 1116.22,
      "end": 1117.22,
      "text": "Aham."
    },
    {
      "start": 1117.22,
      "end": 1120.23,
      "text": "O arroz."
    },
    {
      "start": 1120.23,
      "end": 1124.23,
      "text": "Daí tem o pimentão, cebola e tomate e cheiro verde."
    },
    {
      "start": 1124.23,
      "end": 1125.23,
      "text": "Isso aí é a gosto."
    },
    {
      "start": 1125.23,
      "end": 1129.66,
      "text": "Tá bom?"
    },
    {
      "start": 1129.66,
      "end": 1133.76,
      "text": "Tá chorinho."
    },
    {
      "start": 1133.76,
      "end": 1136.27,
      "text": "Não vai sobrar."
    },
    {
      "start": 1136.27,
      "end": 1139.1,
      "text": "Botei um pão ainda ali, ó."
    },
    {
      "start": 1139.1,
      "end": 1140.1,
      "text": "O experimento fica mesmo."
    },
    {
      "start": 1140.1,
      "end": 1147.01,
      "text": "Ah, o pão feito em casa é outro pão."
    },
    {
      "start": 1147.01,
      "end": 1169.43,
      "text": "Pessoal, já se recolheu pro berço."
    },
    {
      "start": 1169.43,
      "end": 1170.43,
      "text": "Vamos dormir."
    },
    {
      "start": 1170.43,
      "end": 1172.43,
      "text": "Amanhã levantar, fazer um cafezão."
    },
    {
      "start": 1172.43,
      "end": 1175.43,
      "text": "E ver se pegamos mais uns peixes pra..."
    },
    {
      "start": 1175.43,
      "end": 1177.88,
      "text": "Pra completar a fritada."
    },
    {
      "start": 1177.88,
      "end": 1188.7,
      "text": "E acordamos desse jeito, gurizada."
    },
    {
      "start": 1188.7,
      "end": 1198.06,
      "text": "Barulhinho de chuva aí na lona, ó."
    },
    {
      "start": 1198.06,
      "end": 1200.83,
      "text": "Oh, que coisa boa."
    },
    {
      "start": 1200.83,
      "end": 1219.92,
      "text": "Bom dia!"
    },
    {
      "start": 1219.92,
      "end": 1223.49,
      "text": "Yeah!"
    },
    {
      "start": 1223.49,
      "end": 1231.11,
      "text": "Vamos fazer aquele cafezinho e depois vamos pescar."
    },
    {
      "start": 1231.11,
      "end": 1352.82,
      "text": "Tá pronta a boia."
    },
    {
      "start": 1352.82,
      "end": 1355.87,
      "text": "Ainda não."
    },
    {
      "start": 1355.87,
      "end": 1356.87,
      "text": "Tá quase."
    },
    {
      "start": 1356.87,
      "end": 1361.33,
      "text": "Vamos atacar."
    },
    {
      "start": 1361.33,
      "end": 1367.59,
      "text": "Vamos atacar e depois vamos se atracar embaixo da chuva."
    },
    {
      "start": 1367.59,
      "end": 1373.58,
      "text": "É uma chuva aí."
    },
    {
      "start": 1373.58,
      "end": 1380.31,
      "text": "É uma chuva hoje."
    },
    {
      "start": 1380.31,
      "end": 1389.22,
      "text": "É uma catarina."
    },
    {
      "start": 1389.22,
      "end": 1408.66,
      "text": "Só tem café pra todo mundo, né?"
    },
    {
      "start": 1408.66,
      "end": 1409.66,
      "text": "Amassar."
    },
    {
      "start": 1409.66,
      "end": 1410.66,
      "text": "Ah, esse tio!"
    },
    {
      "start": 1410.66,
      "end": 1412.66,
      "text": "Esse que você trouxe."
    },
    {
      "start": 1412.66,
      "end": 1413.69,
      "text": "Ei, o pai, Cisão."
    },
    {
      "start": 1413.69,
      "end": 1414.69,
      "text": "O pai, Cisão."
    },
    {
      "start": 1414.69,
      "end": 1415.69,
      "text": "O pai, Cisão?"
    },
    {
      "start": 1415.69,
      "end": 1417.69,
      "text": "Mas faz um pouco a ver esse tio."
    },
    {
      "start": 1417.69,
      "end": 1419.75,
      "text": "Só que ele ficou um pouco passado demais, hein."
    },
    {
      "start": 1419.75,
      "end": 1420.75,
      "text": "Foi muito seco."
    },
    {
      "start": 1420.75,
      "end": 1422.75,
      "text": "Começa com uma garapa."
    },
    {
      "start": 1422.75,
      "end": 1423.75,
      "text": "Noia a cana."
    },
    {
      "start": 1423.75,
      "end": 1424.75,
      "text": "Começa com a garapa."
    },
    {
      "start": 1424.75,
      "end": 1427.75,
      "text": "Fervendo, fervendo, fervendo até que ele vem no ponto."
    },
    {
      "start": 1427.75,
      "end": 1429.75,
      "text": "Quando ele vier no ponto, aí."
    },
    {
      "start": 1429.75,
      "end": 1432.75,
      "text": "Tu vê que vai sair um acílio, tu tira ele fora."
    },
    {
      "start": 1432.75,
      "end": 1433.75,
      "text": "Tu tira ele fora."
    },
    {
      "start": 1433.75,
      "end": 1434.75,
      "text": "Tu tira ele fora."
    },
    {
      "start": 1434.75,
      "end": 1435.75,
      "text": "Tu tira e mexe no macaco."
    },
    {
      "start": 1435.75,
      "end": 1436.75,
      "text": "Ele mexe no macaco."
    },
    {
      "start": 1436.75,
      "end": 1437.98,
      "text": "O pai, Cisão."
    },
    {
      "start": 1437.98,
      "end": 1438.98,
      "text": "Sim."
    },
    {
      "start": 1438.98,
      "end": 1440.14,
      "text": "Não é interessante?"
    },
    {
      "start": 1440.14,
      "end": 1441.14,
      "text": "Saber."
    },
    {
      "start": 1441.14,
      "end": 1443.14,
      "text": "Beber com a louca."
    },
    {
      "start": 1443.14,
      "end": 1447.02,
      "text": "Chegou e já sabe fazer também."
    },
    {
      "start": 1447.02,
      "end": 1448.02,
      "text": "Já."
    },
    {
      "start": 1448.02,
      "end": 1450.02,
      "text": "Só beber o cara aprende no primeiro."
    },
    {
      "start": 1450.02,
      "end": 1451.22,
      "text": "Sim."
    },
    {
      "start": 1451.22,
      "end": 1453.22,
      "text": "O segredo é o ponto."
    },
    {
      "start": 1453.22,
      "end": 1455.22,
      "text": "Deixar ele naquele ponto, né?"
    },
    {
      "start": 1455.22,
      "end": 1456.22,
      "text": "Por isso ele passou um pouquinho."
    },
    {
      "start": 1456.22,
      "end": 1458.22,
      "text": "E aí, o melado no pau, assim, não enfia nada."
    },
    {
      "start": 1458.22,
      "end": 1461.57,
      "text": "Cadê quando tu bota na água?"
    },
    {
      "start": 1461.57,
      "end": 1463.57,
      "text": "Fria, daí puxa assim, fica duro assim."
    },
    {
      "start": 1463.57,
      "end": 1464.57,
      "text": "Uhum."
    },
    {
      "start": 1464.57,
      "end": 1466.59,
      "text": "Depois tá boa."
    },
    {
      "start": 1466.59,
      "end": 1470.59,
      "text": "Enfia o pau no melado e depois na água."
    },
    {
      "start": 1470.59,
      "end": 1472.59,
      "text": "E aí, gente, foi isso."
    },
    {
      "start": 1472.59,
      "end": 1473.59,
      "text": "Vou ter que fazer."
    },
    {
      "start": 1473.59,
      "end": 1478.74,
      "text": "Mas tem o melado quente, né?"
    },
    {
      "start": 1478.74,
      "end": 1479.74,
      "text": "Ah, não."
    },
    {
      "start": 1479.74,
      "end": 1480.74,
      "text": "Daí, não."
    },
    {
      "start": 1480.74,
      "end": 1481.74,
      "text": "Daí."
    },
    {
      "start": 1481.74,
      "end": 1482.74,
      "text": "Não, não."
    },
    {
      "start": 1482.74,
      "end": 1483.74,
      "text": "Não, não."
    },
    {
      "start": 1483.74,
      "end": 1486.28,
      "text": "Ele já pegava e pegava."
    },
    {
      "start": 1486.28,
      "end": 1496.77,
      "text": "Pode ficar com esse garfo daí."
    },
    {
      "start": 1496.77,
      "end": 1498.99,
      "text": "Olha essa preta, né?"
    },
    {
      "start": 1498.99,
      "end": 1503.58,
      "text": "Ah, é interessante, né?"
    },
    {
      "start": 1503.58,
      "end": 1504.58,
      "text": "Uhum."
    },
    {
      "start": 1504.58,
      "end": 1507.67,
      "text": "É que hoje faz eu não seguir essas coisas."
    },
    {
      "start": 1507.67,
      "end": 1509.67,
      "text": "É difícil, velho?"
    },
    {
      "start": 1509.67,
      "end": 1512.37,
      "text": "É."
    },
    {
      "start": 1512.37,
      "end": 1514.37,
      "text": "É mais fácil ir lá no mercado e pegar ele pra sacar."
    },
    {
      "start": 1514.37,
      "end": 1515.37,
      "text": "Uhum."
    },
    {
      "start": 1515.37,
      "end": 1519.87,
      "text": "Eu só compro no mercado e ser mascado aí."
    },
    {
      "start": 1519.87,
      "end": 1521.87,
      "text": "Isso é o melhor."
    },
    {
      "start": 1521.87,
      "end": 1525.89,
      "text": "Um café da manhã desse e vamos pra pesca."
    },
    {
      "start": 1525.89,
      "end": 1527.89,
      "text": "Tá parando a chuva."
    },
    {
      "start": 1527.89,
      "end": 1529.89,
      "text": "Vou completar o agosto."
    },
    {
      "start": 1529.89,
      "end": 1530.89,
      "text": "Até daqui a pouco."
    },
    {
      "start": 1530.89,
      "end": 1532.89,
      "text": "Aí, pelas dez, nós voltemos."
    },
    {
      "start": 1532.89,
      "end": 1535.17,
      "text": "Aí, ó."
    },
    {
      "start": 1535.17,
      "end": 1537.17,
      "text": "Compartimentozinho do mato."
    },
    {
      "start": 1537.17,
      "end": 1539.48,
      "text": "Que show, cara."
    },
    {
      "start": 1539.48,
      "end": 1541.48,
      "text": "É minhoca que queremos entrar nele."
    },
    {
      "start": 1541.48,
      "end": 1545.63,
      "text": "Guardo minhas capas de chuva, corda."
    },
    {
      "start": 1545.63,
      "end": 1547.63,
      "text": "Um monte de coisa aqui mesmo."
    },
    {
      "start": 1547.63,
      "end": 1650.65,
      "text": "Viu na medida?"
    },
    {
      "start": 1650.65,
      "end": 1717.6,
      "text": "Não vamos comer assim."
    },
    {
      "start": 1717.6,
      "end": 1723.15,
      "text": "Pra começar, nem tem cachorro aí, né?"
    },
    {
      "start": 1723.15,
      "end": 1724.15,
      "text": "Não tem nem cachorro."
    },
    {
      "start": 1724.15,
      "end": 1733.12,
      "text": "Caloria."
    },
    {
      "start": 1734.63,
      "end": 1738.74,
      "text": "Show de bola, então."
    },
    {
      "start": 1738.74,
      "end": 1741.74,
      "text": "Com essas fritadas aí, nós encerramos a pescada."
    },
    {
      "start": 1741.74,
      "end": 1746.35,
      "text": "Muito obrigado aí pela parceria aí."
    },
    {
      "start": 1746.35,
      "end": 1749.06,
      "text": "E daqui uns dias, nós terminamos de novo."
    },
    {
      "start": 1749.06,
      "end": 1750.22,
      "text": "É."
    },
    {
      "start": 1750.22,
      "end": 1752.22,
      "text": "Daqui uns dias, eu e o pai vamos pra lá."
    },
    {
      "start": 1752.22,
      "end": 1755.11,
      "text": "Lá pra Santa Catarina."
    },
    {
      "start": 1755.11,
      "end": 1758.37,
      "text": "Mas aparece."
    },
    {
      "start": 1758.37,
      "end": 1761.49,
      "text": "Show de bola."
    },
    {
      "start": 1761.49,
      "end": 1763.49,
      "text": "Se inscreve no canal e deixa um like aí."
    },
    {
      "start": 1763.49,
      "end": 1765.62,
      "text": "Até a próxima pescaria."
    }
  ],
