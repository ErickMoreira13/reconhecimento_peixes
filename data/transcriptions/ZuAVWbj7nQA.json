      "text": "Olha lá, rapaziada, ó"
    },
    {
      "start": 616.3,
      "end": 617.68,
      "text": "Esse jundiá que tem umas"
    },
    {
      "start": 617.68,
      "end": 619.95,
      "text": "Tipo umas pipoquinha, ó"
    },
    {
      "start": 619.95,
      "end": 622.19,
      "text": "Vou furar aqui pra nós ver o que tem dentro"
    },
    {
      "start": 622.19,
      "end": 625.45,
      "text": "Diz aí se"
    },
    {
      "start": 625.45,
      "end": 627.02,
      "text": "Se é algum"
    },
    {
      "start": 627.02,
      "end": 628.86,
      "text": "Berminha, alguma coisa"
    },
    {
      "start": 628.86,
      "end": 629.38,
      "text": "Não sei, né?"
    },
    {
      "start": 630.08,
      "end": 630.96,
      "text": "Tá vendo aqui, ó"
    },
    {
      "start": 630.96,
      "end": 631.86,
      "text": "Ó, cheio de bolinha"
    },
    {
      "start": 631.86,
      "end": 635.76,
      "text": "Dá aqui só pra nós ver o que é"
    },
    {
      "start": 635.76,
      "end": 638.92,
      "text": "Ah, olha aí, ó"
    },
    {
      "start": 638.92,
      "end": 643.44,
      "text": "Tipo uns verminho"
    },
    {
      "start": 643.44,
      "end": 643.92,
      "text": "Tá vendo, ó"
    },
    {
      "start": 643.92,
      "end": 646.84,
      "text": "Comenta aí se é verme"
    },
    {
      "start": 646.84,
      "end": 647.46,
      "text": "O que é isso aí"
    },
    {
      "start": 647.46,
      "end": 648.74,
      "text": "Se dá pra comer o peixe"
    },
    {
      "start": 648.74,
      "end": 649.34,
      "text": "Ele tem isso aqui"
    },
    {
      "start": 649.34,
      "end": 650.94,
      "text": "Ó, tipo umas bolinhas"
    },
    {
      "start": 650.94,
      "end": 651.56,
      "text": "Tá vendo, ó"
    },
    {
      "start": 651.56,
      "end": 655.9,
      "text": "Ó"
    },
    {
      "start": 655.9,
      "end": 659.14,
      "text": "Aqui, ó"
    },
    {
      "start": 659.14,
      "end": 659.78,
      "text": "Olha aqui, rapaziada"
    },
    {
      "start": 659.78,
      "end": 663.62,
      "text": "Ó, tem três"
    },
    {
      "start": 663.62,
      "end": 672.8,
      "text": "Tem mais um aqui, ó"
    },
    {
      "start": 672.8,
      "end": 673.72,
      "text": "Olha o tanto, ó"
    },
    {
      "start": 673.72,
      "end": 677.1,
      "text": "Será que presta pra comer, rapaz?"
    },
    {
      "start": 677.1,
      "end": 677.52,
      "text": "Mesmo assim"
    },
    {
      "start": 677.52,
      "end": 679.45,
      "text": "O que que causa isso aqui?"
    },
    {
      "start": 679.51,
      "end": 679.93,
      "text": "Será, né?"
    },
    {
      "start": 680.13,
      "end": 680.31,
      "text": "Olha"
    },
    {
      "start": 680.31,
      "end": 682.46,
      "text": "Tipo uns verminho, ó"
    },
    {
      "start": 682.46,
      "end": 684.33,
      "text": "Beleza, rapaziada"
    },
    {
      "start": 684.33,
      "end": 685.45,
      "text": "Então, tá aí, ó"
    },
    {
      "start": 685.45,
      "end": 688.08,
      "text": "Olha, tá se mexendo"
    },
    {
      "start": 688.08,
      "end": 688.48,
      "text": "Tá vendo, ó"
    },
    {
      "start": 688.48,
      "end": 690.99,
      "text": "Olha aí"
    },
    {
      "start": 690.99,
      "end": 694.16,
      "text": "Que doideira, né, rapaziada?"
    },
    {
      "start": 694.16,
      "end": 697.5,
      "text": "Tem mais um, ó"
    },
    {
      "start": 697.5,
      "end": 708.83,
      "text": "Mais um aqui, ó"
    },
    {
      "start": 708.83,
      "end": 712.03,
      "text": "Então, é isso aí"
    },
    {
      "start": 712.03,
      "end": 713.69,
      "text": "Não tem nada aí"
    },
    {
      "start": 713.69,
      "end": 714.91,
      "text": "Mas só um que tá assim, ó"
    },
    {
      "start": 714.91,
      "end": 718.51,
      "text": "Só vamos encerrando mais uma pescaria"
    },
    {
      "start": 718.51,
      "end": 719.99,
      "text": "Pescaria deu boa demais"
    },
    {
      "start": 719.99,
      "end": 721.37,
      "text": "Só na varinha carpita"
    },
    {
      "start": 721.37,
      "end": 723.31,
      "text": "E a fieirão na bruta, hein"
    },
    {
      "start": 723.31,
      "end": 724.47,
      "text": "Vamos levar lá pro rapaz"
    },
    {
      "start": 724.47,
      "end": 725.21,
      "text": "Que ele vai levar embora"
    },
    {
      "start": 725.21,
      "end": 726.15,
      "text": "Beleza?"
    },
    {
      "start": 726.49,
      "end": 727.19,
      "text": "Show de bola, hein?"
    },
    {
      "start": 727.35,
      "end": 728.19,
      "text": "Baita pescaria"
    },
    {
      "start": 728.19,
      "end": 730.23,
      "text": "Já vale seu like, hein?"
    },
    {
      "start": 730.67,
      "end": 732.05,
      "text": "E se inscreve no nosso canal"
    },
    {
      "start": 732.05,
      "end": 732.75,
      "text": "Pra dar uma força pra nós"
    },
    {
      "start": 732.75,
      "end": 734.75,
      "text": "Temos rumo aos 50 mil seguidores, rapaziada"
    },
    {
      "start": 734.75,
      "end": 735.93,
      "text": "Top demais, né?"
    },
    {
      "start": 736.23,
      "end": 736.73,
      "text": "Show de bola"
    },
    {
      "start": 736.73,
      "end": 737.11,
      "text": "Acompanha"
    },
    {
      "start": 737.11,
      "end": 742.0,
      "text": "Fechou, rapaziada"
    },
    {
      "start": 742.0,
      "end": 742.66,
      "text": "Valeu, Fernando"
    },
    {
      "start": 742.66,
      "end": 744.09,
      "text": "Tudo de bom, hein?"
    },
    {
      "start": 744.17,
      "end": 744.55,
      "text": "Fechou"
    },
    {
      "start": 744.55,
      "end": 746.42,
      "text": "Valeu a pescaria"
    },
    {
      "start": 746.42,
      "end": 746.9,
      "text": "Deu boa, né?"
    },
    {
      "start": 746.94,
      "end": 747.78,
      "text": "Deu sorte pra nós hoje, né?"
    },
    {
      "start": 747.78,
      "end": 748.36,
      "text": "É, deu sorte"
    },
    {
      "start": 748.36,
      "end": 749.04,
      "text": "Aprendeu, hein?"
    },
    {
      "start": 749.3,
      "end": 750.5,
      "text": "Aí, ó, a fieirão na bruta aí"
    },
    {
      "start": 750.5,
      "end": 750.82,
      "text": "Que ele vai levar"
    },
    {
      "start": 750.82,
      "end": 752.4,
      "text": "O Rafa já pegou uns peixes também"
    },
    {
      "start": 752.4,
      "end": 766.12,
      "text": "Pega a fieira primeiro, Rafa"
    },
    {
      "start": 766.12,
      "end": 770.41,
      "text": "Caraca, isso aí, rapaz"
    },
    {
      "start": 770.41,
      "end": 770.69,
      "text": "Vambora"
    }
  ],
