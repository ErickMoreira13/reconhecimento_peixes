      "start": 653.36,
      "end": 654.78,
      "text": "Isso aqui vai dar o frito."
    },
    {
      "start": 656.82,
      "end": 657.66,
      "text": "Ó a boia lá, afundou."
    },
    {
      "start": 659.1,
      "end": 659.28,
      "text": "Ó."
    },
    {
      "start": 659.72,
      "end": 659.84,
      "text": "Ó."
    },
    {
      "start": 661.05,
      "end": 661.45,
      "text": "Vai trairinha."
    },
    {
      "start": 661.77,
      "end": 663.77,
      "text": "Nossa, é uma bitela na traíra, bicho."
    },
    {
      "start": 665.46,
      "end": 667.5,
      "text": "Nossa senhora, era uma cepa na traíra."
    },
    {
      "start": 668.82,
      "end": 669.22,
      "text": "Soltou."
    },
    {
      "start": 669.22,
      "end": 672.28,
      "text": "Tava tirando a carazinha aqui, bicho."
    },
    {
      "start": 673.85,
      "end": 675.45,
      "text": "Tava tirando a caradonzola aqui."
    },
    {
      "start": 675.85,
      "end": 677.72,
      "text": "Ó a boia, ó."
    },
    {
      "start": 680.74,
      "end": 681.26,
      "text": "Passeando."
    },
    {
      "start": 685.34,
      "end": 686.44,
      "text": "Ah, trairinha pequena."
    },
    {
      "start": 686.56,
      "end": 687.96,
      "text": "Tô vendo aqui ela puxando lá, ó."
    },
    {
      "start": 690.14,
      "end": 690.6,
      "text": "Ó lá, ó."
    },
    {
      "start": 690.94,
      "end": 696.87,
      "text": "Ela vai esticar ali e não vai engolir."
    },
    {
      "start": 697.33,
      "end": 705.6,
      "text": "Tô na flor da água lá, ó."
    },
    {
      "start": 706.74,
      "end": 707.26,
      "text": "Comendo."
    },
    {
      "start": 707.68,
      "end": 730.01,
      "text": "Fica mais isso que ela puxar aqui armada."
    },
    {
      "start": 738.49,
      "end": 738.89,
      "text": "Aí, ó."
    },
    {
      "start": 740.38,
      "end": 741.36,
      "text": "Só caracinha aqui."
    },
    {
      "start": 782.92,
      "end": 783.54,
      "text": "Aí, ó."
    },
    {
      "start": 783.94,
      "end": 784.16,
      "text": "Ó."
    },
    {
      "start": 784.16,
      "end": 784.18,
      "text": "Ó."
    },
    {
      "start": 784.68,
      "end": 785.44,
      "text": "Ó."
    },
    {
      "start": 785.44,
      "end": 791.8,
      "text": "Tô falando que aqui só dá caralho bonito."
    },
    {
      "start": 792.36,
      "end": 793.3,
      "text": "Nesse pocinho aqui."
    },
    {
      "start": 794.14,
      "end": 794.36,
      "text": "Aí."
    },
    {
      "start": 796.23,
      "end": 796.85,
      "text": "Nem tirei."
    },
    {
      "start": 808.62,
      "end": 809.0,
      "text": "De onde?"
    },
    {
      "start": 810.28,
      "end": 811.4,
      "text": "Ó a traíra lá, ó."
    },
    {
      "start": 811.4,
      "end": 811.76,
      "text": "Comendo."
    },
    {
      "start": 811.94,
      "end": 812.72,
      "text": "Traíra pequena."
    },
    {
      "start": 812.96,
      "end": 813.34,
      "text": "É fundo."
    },
    {
      "start": 814.31,
      "end": 815.57,
      "text": "Não, é menos que lá."
    },
    {
      "start": 816.29,
      "end": 817.25,
      "text": "Ó, ó, ó."
    },
    {
      "start": 817.69,
      "end": 818.85,
      "text": "Só carazona, Gil."
    },
    {
      "start": 818.91,
      "end": 819.01,
      "text": "Ó."
    },
    {
      "start": 819.39,
      "end": 819.67,
      "text": "Aqui."
    },
    {
      "start": 822.63,
      "end": 823.45,
      "text": "Ó lá, lá, lá."
    },
    {
      "start": 823.45,
      "end": 824.07,
      "text": "A traíra, ó."
    },
    {
      "start": 824.49,
      "end": 825.19,
      "text": "Vai afundar, ó."
    },
    {
      "start": 826.7,
      "end": 827.52,
      "text": "Trairinha, quer ver?"
    },
    {
      "start": 829.77,
      "end": 832.07,
      "text": "É uma castrairinha pequena que pega e fica passeando."
    },
    {
      "start": 832.17,
      "end": 832.31,
      "text": "Não tem?"
    },
    {
      "start": 832.73,
      "end": 834.05,
      "text": "Viu um peixe ali na boia."
    },
    {
      "start": 834.05,
      "end": 834.79,
      "text": "Acho que é uma trairinha."
    },
    {
      "start": 835.29,
      "end": 845.08,
      "text": "Ó lá, a traíra pegou."
    },
    {
      "start": 845.2,
      "end": 846.12,
      "text": "Ela vem na boia."
    },
    {
      "start": 846.5,
      "end": 847.24,
      "text": "Eu joguei a..."
    },
    {
      "start": 847.24,
      "end": 848.4,
      "text": "Eu joguei a..."
    },
    {
      "start": 848.4,
      "end": 850.16,
      "text": "A isca, ela vem."
    },
    {
      "start": 855.02,
      "end": 855.66,
      "text": "Soltou, rapaz."
    },
    {
      "start": 855.74,
      "end": 856.96,
      "text": "O chão vem no meu nariz."
    },
    {
      "start": 859.34,
      "end": 859.98,
      "text": "Aquela aqui."
    },
    {
      "start": 866.62,
      "end": 868.84,
      "text": "Ela ficou rodinhando a boia, rodinhando a boia."
    },
    {
      "start": 872.8,
      "end": 873.56,
      "text": "Vai pra lá também."
    },
    {
      "start": 873.66,
      "end": 874.5,
      "text": "Encheu o meu saco, não."
    },
    {
      "start": 910.16,
      "end": 910.42,
      "text": "Ó."
    },
    {
      "start": 911.59,
      "end": 911.89,
      "text": "Ó."
    },
    {
      "start": 911.89,
      "end": 913.19,
      "text": "Outra carazona, quer ver?"
    },
    {
      "start": 913.69,
      "end": 915.13,
      "text": "A gente tá brigando, hein?"
    },
    {
      "start": 916.26,
      "end": 916.74,
      "text": "Aí, ó."
    },
    {
      "start": 918.17,
      "end": 918.73,
      "text": "Molecona."
    },
    {
      "start": 920.05,
      "end": 922.48,
      "text": "É."
    },
    {
      "start": 926.04,
      "end": 926.98,
      "text": "Aí, galera, ó."
    },
    {
      "start": 927.38,
      "end": 928.34,
      "text": "Prato de cara, ó."
    },
    {
      "start": 929.08,
      "end": 930.48,
      "text": "Temperar só no sal e no limão."
    },
    {
      "start": 930.7,
      "end": 932.0,
      "text": "Já tem um suquinho aqui, ó."
    },
    {
      "start": 932.58,
      "end": 933.28,
      "text": "Suco natural."
    },
    {
      "start": 934.58,
      "end": 935.52,
      "text": "Só chamar."
    },
    {
      "start": 941.66,
      "end": 943.16,
      "text": "Tô passando a farinha de rosca, ó."
    },
    {
      "start": 944.24,
      "end": 945.82,
      "text": "Passei na farinha de rosca, ó."
    },
    {
      "start": 947.37,
      "end": 947.79,
      "text": "Aí, ó."
    },
    {
      "start": 947.93,
      "end": 948.95,
      "text": "Os pés de cana, hein?"
    },
    {
      "start": 949.03,
      "end": 950.27,
      "text": "Só aguardando."
    },
    {
      "start": 950.41,
      "end": 951.93,
      "text": "É, cara."
    },
    {
      "start": 952.65,
      "end": 954.71,
      "text": "Joga aqui, Júlio, no óleo pra mim, que eu só tô com a mão."
    },
    {
      "start": 955.13,
      "end": 961.34,
      "text": "Vou pegar pra não se queimar."
    },
    {
      "start": 961.88,
      "end": 962.46,
      "text": "Aí, ó."
    },
    {
      "start": 962.54,
      "end": 963.38,
      "text": "Já tá quente, hein?"
    },
    {
      "start": 963.38,
      "end": 966.11,
      "text": "Ô, rapaz."
    },
    {
      "start": 966.21,
      "end": 966.65,
      "text": "Pesca aí."
    },
    {
      "start": 966.73,
      "end": 967.49,
      "text": "É bom por causa disso."
    },
    {
      "start": 967.55,
      "end": 970.53,
      "text": "Não enche muito, não, porque joga mais um ali, ó."
    },
    {
      "start": 970.73,
      "end": 971.23,
      "text": "No cana."
    },
    {
      "start": 971.89,
      "end": 972.37,
      "text": "Mais um."
    },
    {
      "start": 973.03,
      "end": 973.93,
      "text": "Aí, tá bom."
    },
    {
      "start": 974.03,
      "end": 974.43,
      "text": "Aí, ó."
    },
    {
      "start": 976.11,
      "end": 976.47,
      "text": "Rapaz."
    },
    {
      "start": 977.09,
      "end": 977.59,
      "text": "Tá bonito."
    },
    {
      "start": 978.13,
      "end": 979.37,
      "text": "O bicho tá pegando, hein?"
    },
    {
      "start": 979.63,
      "end": 982.5,
      "text": "Então, mas tem um martelo."
    },
    {
      "start": 982.66,
      "end": 982.94,
      "text": "Será?"
    },
    {
      "start": 985.18,
      "end": 985.78,
      "text": "Aí, ó."
    },
    {
      "start": 985.78,
      "end": 988.42,
      "text": "Quando eles falam que vão tomar um martelo, isso aqui, ó."
    },
    {
      "start": 988.78,
      "end": 989.88,
      "text": "Um martelo aqui, ó."
    },
    {
      "start": 990.38,
      "end": 991.74,
      "text": "Ó o martelo que eles vão tomar."
    },
    {
      "start": 991.74,
      "end": 994.02,
      "text": "Aqui é caldo de cana, tá?"
    },
    {
      "start": 994.44,
      "end": 994.8,
      "text": "Fortificante."
    },
    {
      "start": 994.88,
      "end": 996.76,
      "text": "Não tem nada alcoólico aqui, não."
    },
    {
      "start": 998.14,
      "end": 999.26,
      "text": "Aqui já tá bom, né, tio?"
    },
    {
      "start": 999.42,
      "end": 999.58,
      "text": "Ó."
    },
    {
      "start": 1002.98,
      "end": 1003.38,
      "text": "Douradinho."
    },
    {
      "start": 1006.24,
      "end": 1007.12,
      "text": "Será que prestou, hein?"
    },
    {
      "start": 1007.26,
      "end": 1010.52,
      "text": "Deixa eu abrir uma vitamina aqui, ó."
    },
    {
      "start": 1010.68,
      "end": 1011.08,
      "text": "Opa."
    },
    {
      "start": 1013.13,
      "end": 1013.77,
      "text": "Vê aí, tio."
    },
    {
      "start": 1013.83,
      "end": 1014.61,
      "text": "Faz o teste aí."
    },
    {
      "start": 1015.81,
      "end": 1017.49,
      "text": "Eu pego lá da água doce."
    },
    {
      "start": 1018.29,
      "end": 1018.99,
      "text": "Fica demais."
    },
    {
      "start": 1019.09,
      "end": 1019.97,
      "text": "Ó os pés de cana."
    },
    {
      "start": 1020.19,
      "end": 1020.55,
      "text": "Top."
    },
    {
      "start": 1020.77,
      "end": 1021.91,
      "text": "Dá pra tomar um martelo, Júlio?"
    },
    {
      "start": 1022.09,
      "end": 1022.23,
      "text": "Hã?"
    },
    {
      "start": 1027.38,
      "end": 1027.82,
      "text": "Ó."
    },
    {
      "start": 1028.54,
      "end": 1028.74,
      "text": "Não."
    },
    {
      "start": 1032.57,
      "end": 1033.45,
      "text": "Tem que comer um espinho."
    },
    {
      "start": 1039.18,
      "end": 1039.4,
      "text": "Ó."
    },
    {
      "start": 1039.4,
      "end": 1044.16,
      "text": "Essa pescaria aqui, valeu a pena, hein?"
    },
    {
      "start": 1045.09,
      "end": 1046.23,
      "text": "Nós vamos ficando por aqui."
    },
    {
      "start": 1046.71,
      "end": 1049.49,
      "text": "Deixa o like aí que os martelos vão rolar solto aqui, ó."
    },
    {
      "start": 1049.69,
      "end": 1050.75,
      "text": "Vamos lá sair de cana aí, ó."
    },
    {
      "start": 1050.79,
      "end": 1051.29,
      "text": "Com certeza."
    },
    {
      "start": 1052.01,
      "end": 1052.21,
      "text": "Ó."
    },
    {
      "start": 1052.39,
      "end": 1053.65,
      "text": "Pegamos três quilos."
    },
    {
      "start": 1053.75,
      "end": 1054.65,
      "text": "Só o três quilinho."
    },
    {
      "start": 1054.81,
      "end": 1055.25,
      "text": "Vamos lá."
    },
    {
      "start": 1055.35,
      "end": 1057.29,
      "text": "Não mais porque é deixar pra amanhã."
    },
    {
      "start": 1057.29,
      "end": 1057.69,
      "text": "É."
    }
  ],
