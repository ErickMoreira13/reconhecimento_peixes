      "start": 324.42,
      "end": 324.72,
      "text": "Piau."
    },
    {
      "start": 325.38,
      "end": 325.68,
      "text": "Piau?"
    },
    {
      "start": 326.02,
      "end": 327.1,
      "text": "Piau, rapaz."
    },
    {
      "start": 327.12,
      "end": 327.34,
      "text": "Ih, ó."
    },
    {
      "start": 327.82,
      "end": 328.12,
      "text": "Três."
    },
    {
      "start": 328.24,
      "end": 328.74,
      "text": "Seis pinta."
    },
    {
      "start": 329.34,
      "end": 330.28,
      "text": "Olha, levanta ele aí."
    },
    {
      "start": 330.46,
      "end": 331.62,
      "text": "Pega mais perto da linha."
    },
    {
      "start": 332.1,
      "end": 334.77,
      "text": "Não, tá de feroz hoje, hein."
    },
    {
      "start": 334.77,
      "end": 336.27,
      "text": "Hoje, menino, esse menino tá demais."
    },
    {
      "start": 337.48,
      "end": 338.34,
      "text": "O menino tá feroz."
    },
    {
      "start": 338.42,
      "end": 339.88,
      "text": "Pegou o lobó, pegou o piau, o lambari."
    },
    {
      "start": 341.55,
      "end": 343.61,
      "text": "Por enquanto, agora, não peguei pisciroca nenhuma."
    },
    {
      "start": 343.81,
      "end": 344.95,
      "text": "O Gilmar ainda pegou o piau, né, Gilmar?"
    },
    {
      "start": 345.21,
      "end": 345.99,
      "text": "Peguei o piau aí, cara."
    },
    {
      "start": 345.99,
      "end": 346.97,
      "text": "Você pegou, sim."
    },
    {
      "start": 347.75,
      "end": 348.51,
      "text": "Salva a pátria."
    },
    {
      "start": 348.67,
      "end": 349.53,
      "text": "Fecha a boca, rapaz."
    },
    {
      "start": 350.27,
      "end": 351.13,
      "text": "Deixa nós conversar."
    },
    {
      "start": 353.84,
      "end": 354.92,
      "text": "Pega mais, então, né, Daniel?"
    },
    {
      "start": 355.12,
      "end": 355.58,
      "text": "Pega mais."
    },
    {
      "start": 355.72,
      "end": 356.44,
      "text": "O que é que tá acontecendo, Daniel?"
    },
    {
      "start": 356.46,
      "end": 356.96,
      "text": "Tem que ter curso?"
    },
    {
      "start": 357.58,
      "end": 357.9,
      "text": "Não."
    },
    {
      "start": 358.68,
      "end": 359.38,
      "text": "Tem que ter sorte, né?"
    },
    {
      "start": 361.42,
      "end": 361.76,
      "text": "Isso aí."
    },
    {
      "start": 363.62,
      "end": 364.38,
      "text": "Olha, pessoal, ó."
    },
    {
      "start": 364.5,
      "end": 365.64,
      "text": "Esse menino pegou o talobó."
    },
    {
      "start": 366.52,
      "end": 367.78,
      "text": "Esse menino hoje tá pegador."
    },
    {
      "start": 368.86,
      "end": 370.46,
      "text": "Só coloquei e já puxou."
    },
    {
      "start": 371.46,
      "end": 373.14,
      "text": "Ele só colocou aqui, foi rápido."
    },
    {
      "start": 373.26,
      "end": 374.38,
      "text": "Não deu tempo nem de filmar."
    },
    {
      "start": 375.38,
      "end": 377.02,
      "text": "E o meu não peguei pisciroca nenhuma."
    },
    {
      "start": 377.14,
      "end": 379.08,
      "text": "O Gilmar também não pegou pisciroca nenhuma."
    },
    {
      "start": 379.08,
      "end": 381.92,
      "text": "Só esse menino já pegou duas lobó, lambari."
    },
    {
      "start": 383.57,
      "end": 384.23,
      "text": "Tem que ter curso?"
    },
    {
      "start": 385.49,
      "end": 388.09,
      "text": "Hoje é o dia do pescador."
    },
    {
      "start": 426.39,
      "end": 426.59,
      "text": "Escapou."
    },
    {
      "start": 431.25,
      "end": 431.85,
      "text": "Ui, rapaz."
    },
    {
      "start": 434.24,
      "end": 434.86,
      "text": "Segura aí, Daniel."
    },
    {
      "start": 436.88,
      "end": 437.24,
      "text": "Tira a mão."
    },
    {
      "start": 438.47,
      "end": 438.91,
      "text": "Pega na linha."
    },
    {
      "start": 439.17,
      "end": 439.77,
      "text": "Tem que pegar na linha."
    },
    {
      "start": 440.67,
      "end": 441.15,
      "text": "Aí, pessoal."
    },
    {
      "start": 441.31,
      "end": 441.89,
      "text": "Vai lá, lá."
    },
    {
      "start": 441.89,
      "end": 442.99,
      "text": "Vai piau aí, ó."
    },
    {
      "start": 444.11,
      "end": 446.41,
      "text": "Piau três pinta aqui na calabresinha."
    },
    {
      "start": 446.41,
      "end": 447.85,
      "text": "Show."
    },
    {
      "start": 449.1,
      "end": 449.42,
      "text": "Calabresa."
    },
    {
      "start": 450.18,
      "end": 451.24,
      "text": "É a isca de hoje, né, galera?"
    },
    {
      "start": 451.28,
      "end": 451.4,
      "text": "Tira."
    },
    {
      "start": 452.18,
      "end": 452.54,
      "text": "Tira."
    },
    {
      "start": 453.28,
      "end": 461.37,
      "text": "Puxa isso daí, Daniel."
    },
    {
      "start": 461.49,
      "end": 461.87,
      "text": "Puxa isso daí."
    },
    {
      "start": 461.95,
      "end": 462.27,
      "text": "Tira isso daí."
    },
    {
      "start": 466.35,
      "end": 466.87,
      "text": "Deixa aí agora."
    },
    {
      "start": 466.95,
      "end": 467.29,
      "text": "Deixa aí."
    },
    {
      "start": 468.77,
      "end": 469.29,
      "text": "Ah, não."
    },
    {
      "start": 469.39,
      "end": 470.51,
      "text": "Tava segurado na chuva."
    },
    {
      "start": 473.95,
      "end": 474.31,
      "text": "Segura."
    },
    {
      "start": 477.45,
      "end": 478.51,
      "text": "Eita, é monstro."
    },
    {
      "start": 482.84,
      "end": 483.54,
      "text": "É, aquele mesmo."
    },
    {
      "start": 484.82,
      "end": 485.54,
      "text": "Calabro."
    },
    {
      "start": 486.4,
      "end": 486.52,
      "text": "Ó."
    },
    {
      "start": 489.11,
      "end": 489.45,
      "text": "Aí, Daniel."
    },
    {
      "start": 489.53,
      "end": 490.15,
      "text": "Quem pega, Daniel?"
    },
    {
      "start": 490.19,
      "end": 491.35,
      "text": "Se for assim, ele não pega nada."
    },
    {
      "start": 492.77,
      "end": 493.63,
      "text": "Quem pega nada?"
    },
    {
      "start": 499.32,
      "end": 499.64,
      "text": "Olha aí."
    },
    {
      "start": 501.25,
      "end": 502.39,
      "text": "Não é só o Daniel que pega, não."
    },
    {
      "start": 502.39,
      "end": 506.49,
      "text": "Mas ele está pegando mais que a nós hoje."
    },
    {
      "start": 507.3,
      "end": 510.34,
      "text": "O menino está virado para a lua."
    },
    {
      "start": 512.24,
      "end": 512.5,
      "text": "Olha aí."
    },
    {
      "start": 512.5,
      "end": 513.28,
      "text": "Esse é grande."
    },
    {
      "start": 514.54,
      "end": 515.12,
      "text": "Vou pegar mais."
    },
    {
      "start": 516.93,
      "end": 519.41,
      "text": "O Danielzinho vai soltar aqui os lobó, tá?"
    },
    {
      "start": 520.24,
      "end": 521.52,
      "text": "A gente vai soltar os lobó."
    },
    {
      "start": 522.99,
      "end": 525.01,
      "text": "E um, dois piais pequenos."
    },
    {
      "start": 525.13,
      "end": 526.29,
      "text": "E o restante a gente vai estar levando."
    },
    {
      "start": 526.85,
      "end": 527.33,
      "text": "Vai, Daniel."
    },
    {
      "start": 527.69,
      "end": 528.13,
      "text": "Manda para o..."
    },
    {
      "start": 528.13,
      "end": 528.33,
      "text": "Olha aí."
    },
    {
      "start": 528.41,
      "end": 528.75,
      "text": "Vamos embora."
    },
    {
      "start": 529.78,
      "end": 530.24,
      "text": "Ó, Gilmar."
    },
    {
      "start": 531.21,
      "end": 532.41,
      "text": "Cadê aquela outra lobó, Gilmar?"
    },
    {
      "start": 533.48,
      "end": 534.36,
      "text": "Olha a lobózinha."
    },
    {
      "start": 534.5,
      "end": 534.72,
      "text": "Olha lá."
    },
    {
      "start": 535.62,
      "end": 536.36,
      "text": "Olha a outra pequenininha."
    },
    {
      "start": 536.56,
      "end": 536.82,
      "text": "Cuidado."
    },
    {
      "start": 537.97,
      "end": 539.97,
      "text": "Olha o Danielzinho vai soltar a outra aquela lobó que ele pegou."
    },
    {
      "start": 539.99,
      "end": 540.75,
      "text": "Ele pegou duas lobó."
    },
    {
      "start": 541.67,
      "end": 542.71,
      "text": "E ele vai estar soltando aí."
    },
    {
      "start": 542.81,
      "end": 543.11,
      "text": "Solta."
    },
    {
      "start": 543.98,
      "end": 544.3,
      "text": "Ixi."
    },
    {
      "start": 546.56,
      "end": 546.92,
      "text": "Segura."
    },
    {
      "start": 549.25,
      "end": 552.49,
      "text": "E os dois piauzinhos pequenos e aqueles outros piais maiores."
    },
    {
      "start": 552.95,
      "end": 553.99,
      "text": "A gente vai levar, ó."
    },
    {
      "start": 554.19,
      "end": 554.99,
      "text": "Para fazer um frito."
    },
    {
      "start": 555.07,
      "end": 555.39,
      "text": "Beleza?"
    },
    {
      "start": 556.26,
      "end": 556.58,
      "text": "Olha aí."
    },
    {
      "start": 558.12,
      "end": 558.78,
      "text": "Vai com Deus."
    },
    {
      "start": 559.06,
      "end": 559.36,
      "text": "Outro."
    },
    {
      "start": 560.7,
      "end": 561.16,
      "text": "E pronto."
    },
    {
      "start": 562.96,
      "end": 563.2,
      "text": "Aí."
    },
    {
      "start": 566.17,
      "end": 567.59,
      "text": "Tem mais piais pequenos aí, Gilmar?"
    },
    {
      "start": 569.26,
      "end": 570.62,
      "text": "Gilmar, vai soltar um pequeno aí."
    },
    {
      "start": 570.62,
      "end": 571.64,
      "text": "E os grandes vão estar levando."
    },
    {
      "start": 572.08,
      "end": 572.86,
      "text": "E os lambari também."
    },
    {
      "start": 572.86,
      "end": 574.38,
      "text": "Vai estar levando para fazer um frito."
    },
    {
      "start": 576.04,
      "end": 576.34,
      "text": "Olha aí."
    },
    {
      "start": 577.18,
      "end": 577.58,
      "text": "Show."
    },
    {
      "start": 579.26,
      "end": 579.9,
      "text": "Solta Daniel."
    },
    {
      "start": 581.91,
      "end": 582.39,
      "text": "Foi embora."
    },
    {
      "start": 583.78,
      "end": 584.5,
      "text": "Então tá, pessoal."
    },
    {
      "start": 586.12,
      "end": 588.42,
      "text": "Pescaria hoje aqui no Corre Carumbezinho."
    },
    {
      "start": 589.77,
      "end": 590.91,
      "text": "Gilmar esteve com aí conosco."
    },
    {
      "start": 591.31,
      "end": 591.63,
      "text": "É, Gilmar?"
    },
    {
      "start": 591.97,
      "end": 592.25,
      "text": "Isso aí."
    },
    {
      "start": 592.35,
      "end": 593.93,
      "text": "Hoje não foi muito bom de piau, não."
    },
    {
      "start": 594.15,
      "end": 596.49,
      "text": "Não entrou corimba, mas entrou aí uns lambari."
    },
    {
      "start": 596.69,
      "end": 596.83,
      "text": "É."
    },
    {
      "start": 597.11,
      "end": 597.87,
      "text": "E uns piau aí."
    },
    {
      "start": 598.05,
      "end": 599.05,
      "text": "É, lobó."
    },
    {
      "start": 599.79,
      "end": 600.83,
      "text": "Pescaria assim mesmo, né?"
    },
    {
      "start": 601.35,
      "end": 602.33,
      "text": "Tamo junto, pessoal."
    },
    {
      "start": 603.15,
      "end": 605.35,
      "text": "Muito obrigado por acompanhar o canal Simples Pescadores."
    },
    {
      "start": 605.35,
      "end": 607.15,
      "text": "Fiquem todos com Deus."
    },
    {
      "start": 607.67,
      "end": 608.69,
      "text": "E até o próximo vídeo."
    },
    {
      "start": 608.77,
      "end": 608.85,
      "text": "Até."
    },
    {
      "start": 608.91,
      "end": 609.19,
      "text": "Obrigado."
    }
  ],
