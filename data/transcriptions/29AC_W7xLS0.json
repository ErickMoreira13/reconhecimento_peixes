      "start": 292.51,
      "end": 300.8,
      "text": "Sentado no outro"
    },
    {
      "start": 300.8,
      "end": 301.76,
      "text": "Vai que ela me puxa"
    },
    {
      "start": 301.76,
      "end": 302.76,
      "text": "É, vai que ela..."
    },
    {
      "start": 302.76,
      "end": 308.14,
      "text": "Rapazinho, o maújo tá sereno, viu, galera?"
    },
    {
      "start": 308.22,
      "end": 309.06,
      "text": "Olha que coisa linda"
    },
    {
      "start": 309.06,
      "end": 313.31,
      "text": "Sereno, sereno"
    },
    {
      "start": 313.31,
      "end": 314.87,
      "text": "Batingou, daí, ó"
    },
    {
      "start": 314.87,
      "end": 317.45,
      "text": "O peixe, eu falei pra eles"
    },
    {
      "start": 317.45,
      "end": 319.05,
      "text": "Aqui gosta de bater umas arraias"
    },
    {
      "start": 319.05,
      "end": 321.37,
      "text": "Por causa do engodo"
    },
    {
      "start": 321.37,
      "end": 325.7,
      "text": "Que a gente bate aqui pro peixe"
    },
    {
      "start": 325.7,
      "end": 328.54,
      "text": "Aí encosta umas arraias aí, ó"
    },
    {
      "start": 328.54,
      "end": 334.23,
      "text": "Meu amigo tá aí"
    },
    {
      "start": 334.23,
      "end": 335.69,
      "text": "Esperando o peixe cansar"
    },
    {
      "start": 335.69,
      "end": 337.81,
      "text": "Eu cansei primeiro, viu?"
    },
    {
      "start": 338.81,
      "end": 340.59,
      "text": "Eu não vou desistir, não"
    },
    {
      "start": 340.59,
      "end": 343.25,
      "text": "Mas vamos ver ela"
    },
    {
      "start": 343.25,
      "end": 344.41,
      "text": "Ó"
    },
    {
      "start": 344.41,
      "end": 348.56,
      "text": "Tá ajustando ali o drag, ali"
    },
    {
      "start": 348.56,
      "end": 350.56,
      "text": "Pra embarcar já, já o peixe"
    },
    {
      "start": 350.56,
      "end": 371.92,
      "text": "É porque ela é viva, não"
    },
    {
      "start": 371.92,
      "end": 372.58,
      "text": "Tá correndo"
    },
    {
      "start": 372.58,
      "end": 379.58,
      "text": "Nossa migalã engatada aí, hein"
    },
    {
      "start": 379.58,
      "end": 383.5,
      "text": "7 horas e 25 da manhã"
    },
    {
      "start": 383.5,
      "end": 388.7,
      "text": "Hoje nós viemos fazer a pescaria das bicudinhas, né, galera?"
    },
    {
      "start": 390.98,
      "end": 391.72,
      "text": "Arraia"
    },
    {
      "start": 391.72,
      "end": 393.02,
      "text": "Tá aí, arraia"
    },
    {
      "start": 393.02,
      "end": 394.32,
      "text": "Arraia"
    },
    {
      "start": 394.32,
      "end": 395.84,
      "text": "Arraia lá aí, galera"
    },
    {
      "start": 395.84,
      "end": 398.02,
      "text": "Deixa eu pegar no chicote aqui"
    },
    {
      "start": 398.02,
      "end": 398.28,
      "text": "Isso"
    },
    {
      "start": 398.28,
      "end": 403.88,
      "text": "Cláudia arraia na..."
    },
    {
      "start": 403.88,
      "end": 405.44,
      "text": "Libera aí a flexão aí"
    },
    {
      "start": 405.44,
      "end": 409.22,
      "text": "Lá pra lá, mais um pouquinho que eu vou liberar"
    },
    {
      "start": 409.22,
      "end": 413.13,
      "text": "Tá aí, galera"
    },
    {
      "start": 413.13,
      "end": 414.31,
      "text": "Arraia aí"
    },
    {
      "start": 414.31,
      "end": 415.03,
      "text": "Arraia aí"
    },
    {
      "start": 415.03,
      "end": 418.44,
      "text": "Vamos liberar"
    },
    {
      "start": 418.44,
      "end": 419.5,
      "text": "Pequenininha ainda"
    },
    {
      "start": 419.5,
      "end": 421.24,
      "text": "E aí, Alain?"
    },
    {
      "start": 421.28,
      "end": 422.2,
      "text": "Deu pra suar, não foi?"
    },
    {
      "start": 422.38,
      "end": 423.2,
      "text": "Logo cedo"
    },
    {
      "start": 423.2,
      "end": 424.86,
      "text": "Graças a Deus"
    },
    {
      "start": 424.86,
      "end": 425.42,
      "text": "Aí, galera"
    },
    {
      "start": 425.42,
      "end": 426.44,
      "text": "Arraia aqui, ó"
    },
    {
      "start": 426.44,
      "end": 427.92,
      "text": "Coisa linda"
    },
    {
      "start": 427.92,
      "end": 429.24,
      "text": "Vamos liberar ela aí"
    },
    {
      "start": 429.24,
      "end": 430.14,
      "text": "Tá pequena ainda"
    },
    {
      "start": 430.14,
      "end": 431.78,
      "text": "Vai crescer muito"
    },
    {
      "start": 431.78,
      "end": 434.1,
      "text": "Pra vida aí"
    },
    {
      "start": 434.1,
      "end": 435.98,
      "text": "Nós estamos aqui no aguardo um peixinho aí"
    },
    {
      "start": 435.98,
      "end": 436.8,
      "text": "Qualquer momento"
    },
    {
      "start": 436.8,
      "end": 439.02,
      "text": "Pode ter um peixinho pra nós aí"
    },
    {
      "start": 439.02,
      "end": 444.52,
      "text": "Lá vem o homem de novo, gente"
    },
    {
      "start": 444.52,
      "end": 448.07,
      "text": "Olha aí quem chegou, ó"
    },
    {
      "start": 448.07,
      "end": 449.29,
      "text": "Escorózinho branco"
    },
    {
      "start": 449.29,
      "end": 452.57,
      "text": "Chegaram aí, ó"
    },
    {
      "start": 452.57,
      "end": 456.82,
      "text": "Deixa o tamanzinho é bom"
    },
    {
      "start": 456.82,
      "end": 457.86,
      "text": "Fritinho"
    },
    {
      "start": 457.86,
      "end": 462.78,
      "text": "Se tiver dando muito dele"
    },
    {
      "start": 462.78,
      "end": 464.44,
      "text": "A gente diminui mais o anzol"
    },
    {
      "start": 464.44,
      "end": 466.42,
      "text": "Que eles são ladrão de isca"
    },
    {
      "start": 466.42,
      "end": 472.15,
      "text": "Agora tá descendo uma garoazinha aí"
    },
    {
      "start": 472.15,
      "end": 473.37,
      "text": "De chuva, minha gente"
    },
    {
      "start": 473.37,
      "end": 473.63,
      "text": "Ó"
    },
    {
      "start": 473.63,
      "end": 475.11,
      "text": "Como tá o tempo hoje, ó"
    },
    {
      "start": 475.11,
      "end": 477.08,
      "text": "Mas, ó"
    },
    {
      "start": 477.08,
      "end": 479.32,
      "text": "Tá uma lagoa"
    },
    {
      "start": 479.32,
      "end": 483.81,
      "text": "Sardinha tá aí, rapaziada"
    },
    {
      "start": 483.81,
      "end": 486.03,
      "text": "Mas a bicudinha ainda não encostou, não"
    },
    {
      "start": 486.03,
      "end": 489.97,
      "text": "Ó, gente"
    },
    {
      "start": 489.97,
      "end": 490.41,
      "text": "Eu quero"
    },
    {
      "start": 490.41,
      "end": 492.19,
      "text": "Nesse momento aqui"
    },
    {
      "start": 492.19,
      "end": 493.77,
      "text": "Agradecer os amigos aí"
    },
    {
      "start": 493.77,
      "end": 495.83,
      "text": "Ó os presentes que a gente recebeu deles aí"
    },
    {
      "start": 495.83,
      "end": 497.87,
      "text": "Pra fazer questão de mostrar"
    },
    {
      "start": 497.87,
      "end": 500.21,
      "text": "Coisa linda, rapaziada"
    },
    {
      "start": 500.21,
      "end": 504.55,
      "text": "Ó"
    },
    {
      "start": 504.55,
      "end": 510.75,
      "text": "Aí, rapaziada"
    },
    {
      "start": 510.75,
      "end": 511.47,
      "text": "Aí, rapala"
    },
    {
      "start": 511.47,
      "end": 512.29,
      "text": "A zona aí, ó"
    },
    {
      "start": 512.29,
      "end": 513.37,
      "text": "Presente pra mim"
    },
    {
      "start": 513.37,
      "end": 514.95,
      "text": "E o mano da Alã"
    },
    {
      "start": 514.95,
      "end": 518.03,
      "text": "Que pesca mais meu pai, né"
    },
    {
      "start": 518.03,
      "end": 519.29,
      "text": "Coisa linda"
    },
    {
      "start": 519.29,
      "end": 519.91,
      "text": "Ó"
    },
    {
      "start": 519.91,
      "end": 521.55,
      "text": "Presente aí da Fabiana"
    },
    {
      "start": 521.55,
      "end": 522.49,
      "text": "Do Alã"
    },
    {
      "start": 522.49,
      "end": 525.04,
      "text": "Obrigado, meus amigos"
    },
    {
      "start": 525.04,
      "end": 526.62,
      "text": "Vai nos servir muito, ó"
    },
    {
      "start": 526.62,
      "end": 529.28,
      "text": "Vamos pegar bastante peixe aí"
    },
    {
      "start": 529.28,
      "end": 529.9,
      "text": "Se Deus quiser"
    },
    {
      "start": 529.9,
      "end": 531.24,
      "text": "Com essas esconas aí, ó"
    },
    {
      "start": 531.24,
      "end": 531.88,
      "text": "Aí, rapala"
    },
    {
      "start": 531.88,
      "end": 533.5,
      "text": "Coisa linda"
    },
    {
      "start": 533.5,
      "end": 534.22,
      "text": "Ó"
    },
    {
      "start": 534.22,
      "end": 535.08,
      "text": "E o homem aí"
    },
    {
      "start": 535.08,
      "end": 536.66,
      "text": "Tá na ação aí, ó"
    },
    {
      "start": 536.66,
      "end": 538.29,
      "text": "Só vejo"
    },
    {
      "start": 538.29,
      "end": 540.12,
      "text": "Carritilha aí"
    },
    {
      "start": 540.12,
      "end": 540.78,
      "text": "Cantar"
    },
    {
      "start": 540.78,
      "end": 541.78,
      "text": "Ó"
    },
    {
      "start": 541.78,
      "end": 542.94,
      "text": "Fiz gol"
    },
    {
      "start": 542.94,
      "end": 552.24,
      "text": "Vamos já fazer um sistemazinho aí"
    },
    {
      "start": 552.24,
      "end": 554.04,
      "text": "Pra pescar esses peixinhos também, né"
    },
    {
      "start": 554.04,
      "end": 554.46,
      "text": "Fabiane"
    },
    {
      "start": 554.46,
      "end": 554.98,
      "text": "É"
    },
    {
      "start": 554.98,
      "end": 557.7,
      "text": "Tá tudo que é tempo aqui"
    },
    {
      "start": 557.7,
      "end": 559.18,
      "text": "Mas aqui também devagar aí"
    },
    {
      "start": 559.18,
      "end": 559.68,
      "text": "Nesse sardinha"
    },
    {
      "start": 559.68,
      "end": 561.52,
      "text": "Deixa aí as linhas armadas aí"
    },
    {
      "start": 561.52,
      "end": 563.06,
      "text": "Qualquer momento aí"
    },
    {
      "start": 563.06,
      "end": 564.02,
      "text": "Se bater um peixinho"
    },
    {
      "start": 564.02,
      "end": 566.2,
      "text": "Vai ser bom demais"
    },
    {
      "start": 566.2,
      "end": 582.96,
      "text": "Tome chuva"
    },
    {
      "start": 582.96,
      "end": 585.68,
      "text": "Chuvinha boa"
    },
    {
      "start": 585.68,
      "end": 588.26,
      "text": "Chega o mar"
    },
    {
      "start": 588.26,
      "end": 589.38,
      "text": "Tá sereno"
    },
    {
      "start": 589.38,
      "end": 604.29,
      "text": "Tá beliscando"
    },
    {
      "start": 604.29,
      "end": 607.98,
      "text": "Parece que vem umas quatro"
    },
    {
      "start": 607.98,
      "end": 608.54,
      "text": "Agora"
    },
    {
      "start": 608.54,
      "end": 634.66,
      "text": "Olha"
    },
    {
      "start": 634.66,
      "end": 636.98,
      "text": "Soltou"
    },
    {
      "start": 636.98,
      "end": 647.99,
      "text": "Quer experimentar botar isca de sardinha"
    },
    {
      "start": 647.99,
      "end": 650.66,
      "text": "Nos filé dela"
    },
    {
      "start": 650.66,
      "end": 683.5,
      "text": "Deixar bem franco aqui agora pra isso"
    },
    {
      "start": 683.5,
      "end": 709.09,
      "text": "Tardinhona aí, ó"
    },
    {
      "start": 709.09,
      "end": 710.41,
      "text": "Vivinha, vivinha, galera"
    },
    {
      "start": 710.41,
      "end": 710.59,
      "text": "Ó"
    },
    {
      "start": 710.59,
      "end": 711.27,
      "text": "Coisa linda"
    },
    {
      "start": 711.27,
      "end": 714.37,
      "text": "Vai lá trabalhar"
    },
    {
      "start": 714.37,
      "end": 717.08,
      "text": "Caçar o peixe"
    },
    {
      "start": 717.08,
      "end": 718.38,
      "text": "Uhul"
    },
    {
      "start": 718.38,
      "end": 720.58,
      "text": "Caiu na boca da carro"
    },
    {
      "start": 720.58,
      "end": 721.84,
      "text": "Olha lá, meu Deus"
    },
    {
      "start": 721.84,
      "end": 727.51,
      "text": "Tem carreta aí"
    },
    {
      "start": 727.51,
      "end": 729.37,
      "text": "Pra ela correr pra fora"
    },
    {
      "start": 729.37,
      "end": 730.15,
      "text": "Vai lá"
    },
    {
      "start": 730.15,
      "end": 733.29,
      "text": "Já já tem peixe na linha"
    },
    {
      "start": 733.29,
      "end": 737.7,
      "text": "O cabra tá gastando a sorte dele todinha hoje"
    },
    {
      "start": 737.7,
      "end": 738.94,
      "text": "Não acredito não"
    },
    {
      "start": 738.94,
      "end": 741.61,
      "text": "É outra, Cláudia"
    },
    {
      "start": 741.61,
      "end": 744.55,
      "text": "É, Cláudia"
    },
    {
      "start": 744.55,
      "end": 746.55,
      "text": "É, Cláudia"
    },
    {
      "start": 746.55,
      "end": 747.47,
      "text": "É aí, gente"
    },
    {
      "start": 747.47,
      "end": 751.22,
      "text": "Nossa amiga Alain bateu mais um peixinho aí"
    },
    {
      "start": 751.22,
      "end": 758.32,
      "text": "Tá engatada na areia ela, talvez, né"
    },
    {
      "start": 758.32,
      "end": 770.22,
      "text": "O Zação tá devagar hoje"
    },
    {
      "start": 770.22,
      "end": 772.49,
      "text": "Só o Alain aí"
    },
    {
      "start": 772.49,
      "end": 775.49,
      "text": "Que tá matando peixe aí por nós e por ele"
    },
    {
      "start": 775.49,
      "end": 776.41,
      "text": "Graças a Deus"
    },
    {
      "start": 776.41,
      "end": 779.31,
      "text": "Aí, ó"
    },
    {
      "start": 779.31,
      "end": 821.18,
      "text": "Espera aí"
    },
    {
      "start": 821.18,
      "end": 822.8,
      "text": "Não é"
    },
    {
      "start": 822.8,
      "end": 823.96,
      "text": "Que Diego disse que não tem"
    },
    {
      "start": 823.96,
      "end": 824.64,
      "text": "Não, né"
    },
    {
      "start": 824.64,
      "end": 825.98,
      "text": "É uma Cláudia aqui"
    },
    {
      "start": 825.98,
      "end": 826.8,
      "text": "Uma Cláudia"
    },
    {
      "start": 826.8,
      "end": 829.0,
      "text": "Explica pra gente aí"
    },
    {
      "start": 829.0,
      "end": 830.42,
      "text": "É uma Cláudia raia"
    },
    {
      "start": 830.42,
      "end": 831.58,
      "text": "Cláudia raia"
    },
    {
      "start": 831.58,
      "end": 834.26,
      "text": "É uma rainha, né, Diego"
    },
    {
      "start": 834.26,
      "end": 835.26,
      "text": "É"
    },
    {
      "start": 835.26,
      "end": 840.15,
      "text": "Apelidou carinhosamente"
    },
    {
      "start": 840.15,
      "end": 841.35,
      "text": "Cláudia raia"
    },
    {
      "start": 841.35,
      "end": 847.36,
      "text": "Isso é pra despertar"
    },
    {
      "start": 847.36,
      "end": 848.06,
      "text": "Que eu tava meio"
    },
    {
      "start": 848.06,
      "end": 854.06,
      "text": "Gente, agora são oito horas e cinquenta e quatro"
    },
    {
      "start": 854.06,
      "end": 856.02,
      "text": "A gente tá aqui desde aí seis e meia"
    },
    {
      "start": 856.02,
      "end": 858.95,
      "text": "Movimento devagar do peixe"
    },
    {
      "start": 858.95,
      "end": 859.91,
      "text": "Olha aí, ó"
    },
    {
      "start": 859.91,
      "end": 860.65,
      "text": "A Cláudia aí, ó"
    },
    {
      "start": 860.65,
      "end": 861.21,
      "text": "Olha aí, ó"
    },
    {
      "start": 861.21,
      "end": 862.91,
      "text": "Chegou mais uma Cláudiazinha"
    },
    {
      "start": 862.91,
      "end": 866.97,
      "text": "Vamos liberar essa também, galera"
    },
    {
      "start": 866.97,
      "end": 871.03,
      "text": "Mais uma rainha"
    },
    {
      "start": 871.03,
      "end": 871.93,
      "text": "Cheio de bola"
    },
    {
      "start": 871.93,
      "end": 873.49,
      "text": "E o dia hoje tá assim"
    },
    {
      "start": 873.49,
      "end": 875.99,
      "text": "Mas é um sereno, sereno, sereno"
    },
    {
      "start": 875.99,
      "end": 891.38,
      "text": "É não, essa é menor um pouco"
    },
    {
      "start": 891.38,
      "end": 894.51,
      "text": "Vai lá pra vida"
    },
    {
      "start": 894.51,
      "end": 897.26,
      "text": "Oxe"
    },
    {
      "start": 897.26,
      "end": 899.34,
      "text": "Foi que foi ligeira"
    },
    {
      "start": 899.34,
      "end": 907.17,
      "text": "Olha, tem uma sardinha aqui"
    },
    {
      "start": 907.17,
      "end": 908.07,
      "text": "A velha lá da errou"
    },
    {
      "start": 908.07,
      "end": 909.77,
      "text": "Já pegou ela na tarrafa"
    },
    {
      "start": 909.77,
      "end": 926.77,
      "text": "Para a mangoda aqui, ó"
    },
    {
      "start": 926.77,
      "end": 947.43,
      "text": "Sardinha lá, galera"
    },
    {
      "start": 947.43,
      "end": 953.16,
      "text": "Água tá tão clara hoje, gente"
    },
    {
      "start": 953.16,
      "end": 954.16,
      "text": "Que dá pra ver o"
    },
    {
      "start": 954.16,
      "end": 957.35,
      "text": "A areia lá, o chão"
    },
    {
      "start": 957.35,
      "end": 962.22,
      "text": "Ali, ó"
    },
    {
      "start": 962.22,
      "end": 965.32,
      "text": "Sardinha carregando a tarrafa"
    },
    {
      "start": 965.32,
      "end": 983.63,
      "text": "Não sei se eu peguei a grandona não, mas"
    },
    {
      "start": 983.63,
      "end": 986.32,
      "text": "Tem uma que é graúda"
    },
    {
      "start": 986.32,
      "end": 1003.56,
      "text": "Sardinha"
    },
    {
      "start": 1003.56,
      "end": 1008.85,
      "text": "Tinha uma, tem uma que tá maior que essa daí"
    },
    {
      "start": 1008.85,
      "end": 1011.16,
      "text": "Dessa aqui"
    },
    {
      "start": 1011.16,
      "end": 1018.42,
      "text": "Passou mal também"
    },
    {
      "start": 1018.42,
      "end": 1028.33,
      "text": "Não vai dar bastante"
    },
    {
      "start": 1028.33,
      "end": 1030.77,
      "text": "Se você foi o que pegou mais"
    },
    {
      "start": 1030.77,
      "end": 1031.71,
      "text": "É"
    },
    {
      "start": 1031.71,
      "end": 1033.65,
      "text": "Tá compensando"
    },
    {
      "start": 1033.65,
      "end": 1034.71,
      "text": "É, o funcionário"
    },
    {
      "start": 1034.71,
      "end": 1036.61,
      "text": "A gente tem mais uma chance"
    },
    {
      "start": 1036.61,
      "end": 1039.21,
      "text": "É, o funcionário aí trabalha, né"
    },
    {
      "start": 1039.21,
      "end": 1041.83,
      "text": "O funcionário que trabalha"
    },
    {
      "start": 1041.83,
      "end": 1043.55,
      "text": "A gente tem que zelar por ele, né"
    },
    {
      "start": 1043.55,
      "end": 1050.95,
      "text": "Você vê, aqui tá balançando mais do que ali"
    },
    {
      "start": 1050.95,
      "end": 1052.65,
      "text": "E aqui agora eu tô sossegado"
    },
    {
      "start": 1052.65,
      "end": 1055.15,
      "text": "Olha que mazão lindo, minha gente"
    },
    {
      "start": 1055.15,
      "end": 1057.68,
      "text": "Finalizar o vídeo"
    },
    {
      "start": 1057.68,
      "end": 1059.9,
      "text": "Aí com nossos amigos aqui"
    },
    {
      "start": 1059.9,
      "end": 1061.76,
      "text": "De Natal"
    },
    {
      "start": 1061.76,
      "end": 1062.94,
      "text": "Nossa amiga Alain aí"
    },
    {
      "start": 1062.94,
      "end": 1065.3,
      "text": "Que gastou a sorte dele toda ontem e hoje"
    },
    {
      "start": 1065.3,
      "end": 1067.66,
      "text": "E sua esposa Fabiane aí"
    },
    {
      "start": 1067.66,
      "end": 1071.34,
      "text": "Desde já eu quero agradecer pelo ótimo presente"
    },
    {
      "start": 1071.34,
      "end": 1073.22,
      "text": "Vai nos servir bastante aqui"
    },
    {
      "start": 1073.22,
      "end": 1074.74,
      "text": "Na nossa pescaria"
    },
    {
      "start": 1074.74,
      "end": 1076.7,
      "text": "Tanto pra mim quanto a do meu pai também"
    },
    {
      "start": 1076.7,
      "end": 1077.44,
      "text": "Mas o Darlan"
    },
    {
      "start": 1077.44,
      "end": 1080.21,
      "text": "Foi um prazer enorme, né"
    },
    {
      "start": 1080.21,
      "end": 1082.71,
      "text": "Segunda vez que eles vêm aqui pra nossa região"
    },
    {
      "start": 1082.71,
      "end": 1084.17,
      "text": "Pra de Redonda"
    },
    {
      "start": 1084.17,
      "end": 1086.45,
      "text": "E eles dizem que vão já pescar"
    },
    {
      "start": 1086.45,
      "end": 1088.63,
      "text": "Pescou pela manhã com a gente"
    },
    {
      "start": 1088.63,
      "end": 1089.79,
      "text": "São nove e meia ainda"
    },
    {
      "start": 1089.79,
      "end": 1091.01,
      "text": "O peixe foi devagar hoje"
    },
    {
      "start": 1091.01,
      "end": 1092.37,
      "text": "Mas deu pra gente"
    },
    {
      "start": 1092.37,
      "end": 1093.83,
      "text": "Se divertir"
    },
    {
      "start": 1093.83,
      "end": 1094.73,
      "text": "Dar um passeio"
    },
    {
      "start": 1094.73,
      "end": 1095.71,
      "text": "Foi bom demais"
    },
    {
      "start": 1095.71,
      "end": 1096.63,
      "text": "Bom demais"
    },
    {
      "start": 1096.63,
      "end": 1097.69,
      "text": "E aí meus amigos"
    },
    {
      "start": 1097.69,
      "end": 1099.87,
      "text": "Foi um prazer de conhecer você"
    },
    {
      "start": 1099.87,
      "end": 1101.01,
      "text": "Olha pessoal"
    },
    {
      "start": 1101.01,
      "end": 1102.49,
      "text": "Do jeito que ele é no vídeo"
    },
    {
      "start": 1102.49,
      "end": 1103.33,
      "text": "Ele é pessoalmente"
    },
    {
      "start": 1103.33,
      "end": 1104.65,
      "text": "Gente fina demais"
    },
    {
      "start": 1104.65,
      "end": 1106.17,
      "text": "Venham conhecê-lo aqui"
    },
    {
      "start": 1106.17,
      "end": 1107.87,
      "text": "Prestigiar aqui o trabalho dele"
    },
    {
      "start": 1107.87,
      "end": 1109.13,
      "text": "Dá o like aí"
    },
    {
      "start": 1109.13,
      "end": 1110.01,
      "text": "Dá a curtida"
    },
    {
      "start": 1110.01,
      "end": 1110.47,
      "text": "Ajuda nós"
    },
    {
      "start": 1110.47,
      "end": 1112.19,
      "text": "Que o rapaz merece muito, viu"
    },
    {
      "start": 1112.19,
      "end": 1114.43,
      "text": "Espero que vocês tenham curtido"
    },
    {
      "start": 1114.43,
      "end": 1115.33,
      "text": "Deixa o like"
    },
    {
      "start": 1115.33,
      "end": 1116.31,
      "text": "Se inscreva no canal"
    },
    {
      "start": 1116.31,
      "end": 1118.23,
      "text": "E até o próximo episódio"
    },
    {
      "start": 1118.23,
      "end": 1119.43,
      "text": "Tchau, tchau"
    },
    {
      "start": 1119.43,
      "end": 1121.43,
      "text": "Tchau, tchau"
    },
    {
      "start": 1121.43,
      "end": 1121.67,
      "text": "Tchau, tchau"
    }
