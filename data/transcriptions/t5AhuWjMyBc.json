    {
      "start": 212.22,
      "end": 214.85,
      "text": "Já não tem mais espinho"
    },
    {
      "start": 214.85,
      "end": 217.51,
      "text": "Aí só os brotinhos novos"
    },
    {
      "start": 217.51,
      "end": 218.67,
      "text": "Que saem que tem espinho"
