    {
      "start": 128.93,
      "end": 131.6,
      "text": "Eu plantei"
    },
    {
      "start": 131.6,
      "end": 134.62,
      "text": "Murchou não, já tá enramando já"
    },
    {
      "start": 134.62,
      "end": 137.32,
      "text": "Já tem batatinha aqui brotando"
    },
    {
      "start": 137.32,
      "end": 138.72,
      "text": "Vou mostrar aqui a vocês, ó"
    },
    {
      "start": 138.72,
      "end": 141.64,
      "text": "As folhas de batata aqui, ó"
    },
    {
      "start": 141.64,
      "end": 142.76,
      "text": "Velha"
    },
    {
      "start": 142.76,
      "end": 146.43,
      "text": "E olha aqui já os brotinhos já"
    },
    {
      "start": 146.43,
      "end": 148.72,
      "text": "Da batateira brotando"
    },
    {
      "start": 148.72,
      "end": 150.06,
      "text": "Significa que ela não morreu"
    },
    {
      "start": 150.06,
      "end": 154.13,
      "text": "Aqui outro sinal que ela não morreu, ó"
    },
    {
      "start": 154.13,
      "end": 154.55,
      "text": "Quer ver?"
    },
    {
      "start": 154.97,
      "end": 155.53,
