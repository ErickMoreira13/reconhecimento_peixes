    {
      "start": 225.79,
      "end": 226.27,
      "text": "Pra subir"
    },
    {
      "start": 226.27,
      "end": 228.7,
      "text": "Eu pastorava aqui, ó"
    },
    {
      "start": 228.7,
      "end": 231.18,
      "text": "Nesse embuzeiro aqui, ó"
    },
    {
      "start": 231.18,
      "end": 232.91,
      "text": "Eles vinha comer aqui"
