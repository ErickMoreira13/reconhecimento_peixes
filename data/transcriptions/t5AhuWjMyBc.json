    {
      "start": 367.51,
      "end": 368.89,
      "text": "Eu paro de molhar"
    },
    {
      "start": 368.89,
      "end": 370.29,
      "text": "Com os baldes"
    },
    {
      "start": 370.29,
      "end": 371.15,
      "text": "Que eu deixo dois baldes"
    },
    {
      "start": 371.15,
      "end": 371.95,
