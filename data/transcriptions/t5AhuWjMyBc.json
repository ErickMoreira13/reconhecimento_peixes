      "start": 173.63,
      "end": 174.55,
      "text": "Pra mostrar a vocês"
    },
    {
      "start": 174.55,
      "end": 176.65,
      "text": "Esse ano só vou fazer filmagem deles aqui"
    },
    {
      "start": 176.65,
      "end": 179.91,
      "text": "Não vou abater nenhum não aqui"
