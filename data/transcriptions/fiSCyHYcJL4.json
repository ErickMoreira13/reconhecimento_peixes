      "start": 510.24,
      "end": 512.6,
      "text": "Olha o tamanho da bica curvina."
    },
    {
      "start": 513.24,
      "end": 513.56,
      "text": "Hã?"
    },
    {
      "start": 513.76,
      "end": 513.82,
      "text": "Tá."
    },
    {
      "start": 514.95,
      "end": 515.41,
      "text": "E aí?"
    },
    {
      "start": 515.95,
      "end": 520.19,
      "text": "Ô, bichona bruta."
    },
    {
      "start": 520.27,
      "end": 522.07,
      "text": "Aí, ó."
    },
    {
      "start": 523.91,
      "end": 525.13,
      "text": "Corvina linda."
    },
    {
      "start": 526.47,
      "end": 527.11,
      "text": "Carma, filha."
    },
    {
      "start": 527.23,
      "end": 527.67,
      "text": "Carma."
    },
    {
      "start": 528.21,
      "end": 534.98,
      "text": "É brabo, hein?"
    },
    {
      "start": 535.42,
      "end": 536.22,
      "text": "Não brigou."
    },
    {
      "start": 537.56,
      "end": 538.88,
      "text": "Não brigou lá, mãe."
    },
    {
      "start": 542.28,
      "end": 542.92,
      "text": "Carma."
    },
    {
      "start": 542.92,
      "end": 555.54,
      "text": "Carma, bichona."
    },
    {
      "start": 556.47,
      "end": 558.81,
      "text": "Ô, bichona bruta, rapaz."
    },
    {
      "start": 561.03,
      "end": 562.85,
      "text": "Olha o tamanho dessa corvina, rapaz."
    },
    {
      "start": 564.02,
      "end": 564.72,
      "text": "Grande, hein?"
    },
    {
      "start": 568.92,
      "end": 569.44,
      "text": "Rapaz."
    },
    {
      "start": 572.86,
      "end": 574.34,
      "text": "Vou deixar pro profissional."
    },
    {
      "start": 580.92,
      "end": 582.1,
      "text": "Aí, seus montos."
    },
    {
      "start": 582.14,
      "end": 583.14,
      "text": "Olha o tamanho da bruta."
    },
    {
      "start": 584.1,
      "end": 585.08,
      "text": "O alicatinho tá aqui, ó."
    },
    {
      "start": 586.61,
      "end": 587.63,
      "text": "Deixa eu pegar ele pra você aqui."
    },
    {
      "start": 590.1,
      "end": 590.26,
      "text": "Aí."
    },
    {
      "start": 591.46,
      "end": 593.42,
      "text": "Olha lá na guelda."
    },
    {
      "start": 598.78,
      "end": 599.58,
      "text": "O pegador."
    },
    {
      "start": 602.0,
      "end": 603.1,
      "text": "Aí, galera, ó."
    },
    {
      "start": 604.27,
      "end": 605.27,
      "text": "Corvinona aí, ó."
    },
    {
      "start": 605.27,
      "end": 606.61,
      "text": "Do boné virado, hein?"
    },
    {
      "start": 607.68,
      "end": 608.44,
      "text": "Grande, hein?"
    },
    {
      "start": 611.86,
      "end": 612.32,
      "text": "Aí, ó."
    },
    {
      "start": 613.52,
      "end": 617.26,
      "text": "Isso aqui ali vai fazer um frito dela."
    },
    {
      "start": 618.46,
      "end": 619.38,
      "text": "Ela engoliu um anzol."
    },
    {
      "start": 619.5,
      "end": 621.78,
      "text": "Se nem soltar, não vai sobreviver mesmo."
    },
    {
      "start": 622.64,
      "end": 623.62,
      "text": "Vamos levar ela, ó."
    },
    {
      "start": 624.5,
      "end": 626.54,
      "text": "Na tela do pescador, ó."
    },
    {
      "start": 626.66,
      "end": 627.26,
      "text": "A bruta."
    },
    {
      "start": 629.28,
      "end": 630.94,
      "text": "É isso aí, seus montos."
    },
    {
      "start": 631.34,
      "end": 632.42,
      "text": "Apoitemos agora aqui."
    },
    {
      "start": 632.7,
      "end": 633.64,
      "text": "Num poção aqui."
    },
    {
      "start": 633.64,
      "end": 636.46,
      "text": "E vamos atrás dos peixes brutos agora."
    },
    {
      "start": 636.98,
      "end": 638.02,
      "text": "A tardezinha já."
    },
    {
      "start": 639.78,
      "end": 641.28,
      "text": "O molinê tá querendo envergar."
    },
    {
      "start": 641.28,
      "end": 642.38,
      "text": "Aí, pra vocês verem, galera."
    },
    {
      "start": 642.48,
      "end": 643.28,
      "text": "Olha o poço aí, ó."
    },
    {
      "start": 644.27,
      "end": 644.93,
      "text": "Olha o catitu."
    },
    {
      "start": 645.81,
      "end": 649.15,
      "text": "Guia de pesca aqui do rio Guaporé."
    },
    {
      "start": 650.81,
      "end": 651.55,
      "text": "Aí, galera, ó."
    },
    {
      "start": 654.03,
      "end": 655.11,
      "text": "Dá um zóio aí, ó."
    },
    {
      "start": 655.59,
      "end": 657.95,
      "text": "Eu tô vendo a encrenca que nem vai arrumar com esse molinê."
    },
    {
      "start": 657.95,
      "end": 660.92,
      "text": "Agora esse aqui é bruto."
    },
    {
      "start": 663.11,
      "end": 664.93,
      "text": "E é isso aí, seus montos."
    },
    {
      "start": 665.92,
      "end": 667.52,
      "text": "Rebentou umas paredes e veio a linha."
    },
    {
      "start": 668.1,
      "end": 669.4,
      "text": "Eu vou falar a verdade de você, hein?"
    },
    {
      "start": 669.82,
      "end": 671.02,
      "text": "Passei uma apurada, hein?"
    },
    {
      "start": 671.85,
      "end": 673.05,
      "text": "Mas peguemos os peixinhos aí."
    },
    {
      "start": 673.11,
      "end": 676.01,
      "text": "Agora de noite vem os brutos."
    },
    {
      "start": 676.81,
      "end": 677.85,
      "text": "Começando a escurecer."
    },
    {
      "start": 678.88,
      "end": 682.67,
      "text": "Ficar de tardezinha e começam a sair os peixes brutos."
    },
    {
      "start": 682.67,
      "end": 686.0,
      "text": "Ó, piranha, né?"
    },
    {
      "start": 689.23,
      "end": 689.97,
      "text": "Aí, galera, ó."
    },
    {
      "start": 690.39,
      "end": 691.25,
      "text": "Nós mexidinho."
    },
    {
      "start": 691.55,
      "end": 692.05,
      "text": "Eita!"
    },
    {
      "start": 693.28,
      "end": 693.96,
      "text": "Pirarucu."
    },
    {
      "start": 694.4,
      "end": 696.0,
      "text": "Que bruto, hein?"
    },
    {
      "start": 696.9,
      "end": 697.72,
      "text": "Rezinho, galera?"
    },
    {
      "start": 697.8,
      "end": 699.04,
      "text": "O tamanho do pirarucu."
    },
    {
      "start": 699.6,
      "end": 700.62,
      "text": "Tem demais, viu?"
    },
    {
      "start": 702.48,
      "end": 704.12,
      "text": "Rapaz, pulou bonito, hein?"
    },
    {
      "start": 704.98,
      "end": 706.16,
      "text": "E é isso aí, galera."
    },
    {
      "start": 706.76,
      "end": 707.94,
      "text": "Só esperar agora."
    },
    {
      "start": 708.38,
      "end": 753.08,
      "text": "Ó o tamanho do mandubé."
    },
    {
      "start": 756.86,
      "end": 757.38,
      "text": "Barbadinho."
    },
    {
      "start": 757.38,
      "end": 761.51,
      "text": "Fiz a linda, hein, Cati?"
    },
    {
      "start": 766.03,
      "end": 766.65,
      "text": "Bonito, né?"
    },
    {
      "start": 770.54,
      "end": 774.46,
      "text": "Galera, essa aqui tomou linha, mas..."
    },
    {
      "start": 774.46,
      "end": 774.94,
      "text": "Soltar."
    },
    {
      "start": 775.5,
      "end": 776.56,
      "text": "Aí, galera, vai pra vida."
    },
    {
      "start": 780.71,
      "end": 783.87,
      "text": "Rapaz, essa daqui agora tomou linha bonita, hein?"
    },
    {
      "start": 785.74,
      "end": 786.08,
      "text": "Boa?"
    },
    {
      "start": 786.46,
      "end": 793.63,
      "text": "É, vou pegar ela aqui."
    },
    {
      "start": 801.49,
      "end": 802.11,
      "text": "Cati, tô."
    },
    {
      "start": 802.57,
      "end": 806.15,
      "text": "Ih, ó."
    },
    {
      "start": 806.15,
      "end": 807.65,
      "text": "Aí, ó, o barba chata."
    },
    {
      "start": 809.24,
      "end": 810.54,
      "text": "Ele que tá bliscando aqui."
    },
    {
      "start": 817.15,
      "end": 817.71,
      "text": "E, ó, né?"
    },
    {
      "start": 817.71,
      "end": 830.96,
      "text": "Aí, galera, olha o tamanho do bico bruto."
    },
    {
      "start": 834.92,
      "end": 836.88,
      "text": "Pra vida, você vai levar?"
    },
    {
      "start": 837.36,
      "end": 838.18,
      "text": "Vou botar."
    },
    {
      "start": 839.27,
      "end": 840.57,
      "text": "Aí, galera, vai pra vida."
    },
    {
      "start": 843.14,
      "end": 843.94,
      "text": "Tá, obrigado."
    },
    {
      "start": 846.98,
      "end": 847.46,
      "text": "Chama."
    },
    {
      "start": 878.02,
      "end": 878.22,
      "text": "Tá."
    },
    {
      "start": 901.78,
      "end": 902.86,
      "text": "Esse é bruto."
    },
    {
      "start": 908.31,
      "end": 909.21,
      "text": "Essa é ela, viu?"
    },
    {
      "start": 928.66,
      "end": 929.02,
      "text": "Tá."
    },
    {
      "start": 930.29,
      "end": 931.23,
      "text": "Não, tô soltando."
    },
    {
      "start": 936.08,
      "end": 936.52,
      "text": "Deixa lá."
    },
    {
      "start": 937.1,
      "end": 937.7,
      "text": "Linha tem."
    },
    {
      "start": 940.55,
      "end": 942.75,
      "text": "Eu tô controlando a frição aqui pra não..."
    },
    {
      "start": 942.75,
      "end": 963.6,
      "text": "Agora tá vindo."
    },
    {
      "start": 970.27,
      "end": 971.13,
      "text": "Vou apontar."
    },
    {
      "start": 971.13,
      "end": 972.81,
      "text": "A pirarara aí."
    },
    {
      "start": 973.59,
      "end": 975.01,
      "text": "Eita, lasca."
    },
    {
      "start": 975.09,
      "end": 975.79,
      "text": "Olha o tamanho."
    },
    {
      "start": 977.13,
      "end": 978.85,
      "text": "Ah, velho."
    },
    {
      "start": 979.73,
      "end": 982.29,
      "text": "Olha o tamanho da bruta aí, galera."
    },
    {
      "start": 987.14,
      "end": 989.68,
      "text": "Toma linha, bruta."
    },
    {
      "start": 992.3,
      "end": 992.52,
      "text": "Tá."
    },
    {
      "start": 994.08,
      "end": 995.2,
      "text": "Ei, rapaz."
    },
    {
      "start": 995.26,
      "end": 996.14,
      "text": "Essa é bonita, hein?"
    },
    {
      "start": 1007.0,
      "end": 1007.72,
      "text": "É, rapaz."
    },
    {
      "start": 1007.78,
      "end": 1009.36,
      "text": "Você parou no lugar certo, hein, Catu."
    },
    {
      "start": 1015.86,
      "end": 1016.24,
      "text": "Ó."
    },
    {
      "start": 1017.27,
      "end": 1028.2,
      "text": "A bruta."
    },
    {
      "start": 1036.14,
      "end": 1037.42,
      "text": "Eita, lasca."
    },
    {
      "start": 1037.42,
      "end": 1039.04,
      "text": "Não quer se render, não, hein, Catu."
    },
    {
      "start": 1040.18,
      "end": 1041.56,
      "text": "Aí, agora se rendeu, hein."
    },
    {
      "start": 1050.68,
      "end": 1051.64,
      "text": "Meu pegador."
    },
    {
      "start": 1068.94,
      "end": 1070.54,
      "text": "Isso daqui tá ferrado, hein."
    },
    {
      "start": 1070.98,
      "end": 1076.42,
      "text": "Ah, bichinha."
    },
    {
      "start": 1076.52,
      "end": 1077.1,
      "text": "Você não es..."
    },
    {
      "start": 1077.1,
      "end": 1077.68,
      "text": "Ô, bê."
    },
    {
      "start": 1078.84,
      "end": 1081.38,
      "text": "Você não escapa mais não, neném."
    },
    {
      "start": 1081.38,
      "end": 1087.87,
      "text": "Ai, rodou tudo aqui."
    },
    {
      "start": 1088.45,
      "end": 1094.68,
      "text": "Ah, bicha bruta."
    },
    {
      "start": 1095.32,
      "end": 1108.08,
      "text": "Aqui não, neném."
    },
    {
      "start": 1108.54,
      "end": 1111.54,
      "text": "Tá lá."
    },
    {
      "start": 1111.78,
      "end": 1112.04,
      "text": "Ui."
    },
    {
      "start": 1120.98,
      "end": 1121.98,
      "text": "Aí, galera."
    },
    {
      "start": 1122.24,
      "end": 1123.98,
      "text": "Olha o tamanho da bruta aí, ó."
    },
    {
      "start": 1126.71,
      "end": 1129.41,
      "text": "Ai, Catu, velho de guerra."
    },
    {
      "start": 1133.59,
      "end": 1135.31,
      "text": "Ajeitar a bruta aqui, rapaz."
    },
    {
      "start": 1135.35,
      "end": 1136.01,
      "text": "Aí, galera."
    },
    {
      "start": 1136.15,
      "end": 1136.27,
      "text": "Ó."
    },
    {
      "start": 1139.41,
      "end": 1140.33,
      "text": "Coisa linda, hein."
    },
    {
      "start": 1140.95,
      "end": 1141.17,
      "text": "Ui."
    },
    {
      "start": 1141.17,
      "end": 1143.23,
      "text": "Peixe bonito, né, rapaz."
    },
    {
      "start": 1146.91,
      "end": 1147.11,
      "text": "Aí."
    },
    {
      "start": 1155.77,
      "end": 1156.33,
      "text": "Briguinho."
    },
    {
      "start": 1162.73,
      "end": 1163.29,
      "text": "Pirarara."
    },
    {
      "start": 1167.91,
      "end": 1169.17,
      "text": "Aí, seus montos."
    },
    {
      "start": 1169.21,
      "end": 1170.89,
      "text": "Olha o tamanho da bruta aqui, ó."
    },
    {
      "start": 1171.47,
      "end": 1173.03,
      "text": "Ô, rapaz."
    },
    {
      "start": 1173.8,
      "end": 1174.96,
      "text": "Coisa linda, hein."
    },
    {
      "start": 1177.11,
      "end": 1179.05,
      "text": "Coisa linda de uma pirarara, hein."
    },
    {
      "start": 1180.7,
      "end": 1181.16,
      "text": "Aí, ó."
    },
    {
      "start": 1183.06,
      "end": 1185.04,
      "text": "Bater uma foto aqui e soltar a bichinha."
    },
    {
      "start": 1186.7,
      "end": 1187.32,
      "text": "Aí, galera."
    },
    {
      "start": 1187.46,
      "end": 1187.58,
      "text": "Ó."
    },
    {
      "start": 1189.02,
      "end": 1190.08,
      "text": "Coisa bruta."
    },
    {
      "start": 1192.01,
      "end": 1193.61,
      "text": "É isso aí, seus montos."
    },
    {
      "start": 1193.61,
      "end": 1196.35,
      "text": "Finalizando mais uma pescaria aqui, viu."
    },
    {
      "start": 1196.99,
      "end": 1197.81,
      "text": "Já é tarde."
    },
    {
      "start": 1197.97,
      "end": 1199.97,
      "text": "Chegamos quase duas horas da manhã aqui."
    },
    {
      "start": 1200.19,
      "end": 1201.09,
      "text": "Já tô no hotel."
    },
    {
      "start": 1202.3,
      "end": 1203.74,
      "text": "E é isso aí, seus montos."
    },
    {
      "start": 1204.64,
      "end": 1205.16,
      "text": "É..."
    },
    {
      "start": 1205.16,
      "end": 1207.72,
      "text": "Não deu pra filmar a soltura dele aí, do peixe."
    },
    {
      "start": 1207.82,
      "end": 1209.08,
      "text": "Porque..."
    },
    {
      "start": 1209.08,
      "end": 1211.06,
      "text": "Eu falei pro Catitu que tava gravando."
    },
    {
      "start": 1211.18,
      "end": 1214.12,
      "text": "Que a câmera que eu tava usando, ela não tem..."
    },
    {
      "start": 1214.12,
      "end": 1215.32,
      "text": "É..."
    },
    {
      "start": 1215.32,
      "end": 1216.68,
      "text": "Não tem luz, né."
    },
    {
      "start": 1217.26,
      "end": 1218.52,
      "text": "Aí, o meu celular tem."
    },
    {
      "start": 1219.3,
      "end": 1221.76,
      "text": "Aí, eu, de na mão dele, falei que tava gravando."
    },
    {
      "start": 1223.27,
      "end": 1224.55,
      "text": "Aí, o que que aconteceu?"
    },
    {
      "start": 1225.57,
      "end": 1226.64,
      "text": "É..."
    },
    {
      "start": 1226.64,
      "end": 1228.76,
      "text": "Não gravou a soltura do peixe."
    },
    {
      "start": 1229.73,
      "end": 1231.35,
      "text": "Mas nem soltamos o peixe, viu, galera."
    },
    {
      "start": 1232.03,
      "end": 1232.59,
      "text": "É..."
    },
    {
      "start": 1232.59,
      "end": 1233.65,
      "text": "Peixe muito bonito."
    },
    {
      "start": 1233.81,
      "end": 1234.83,
      "text": "Muito..."
    },
    {
      "start": 1234.83,
      "end": 1235.73,
      "text": "Lindo demais."
    },
    {
      "start": 1235.87,
      "end": 1237.83,
      "text": "Não dá coragem de matar um peixe desse, né."
    },
    {
      "start": 1238.47,
      "end": 1239.35,
      "text": "Mas é isso aí."
    },
    {
      "start": 1239.43,
      "end": 1240.71,
      "text": "Não deu pra gravar a soltura."
    },
    {
      "start": 1240.83,
      "end": 1241.87,
      "text": "Mas nós soltamos, viu."
    },
    {
      "start": 1242.73,
      "end": 1245.23,
      "text": "Mandar um forte abraço aí pro meu amigo alemão."
    },
    {
      "start": 1246.8,
      "end": 1248.44,
      "text": "Alemão Tour aqui de..."
    },
    {
      "start": 1248.44,
      "end": 1249.38,
      "text": "Do Rio Guaporé."
