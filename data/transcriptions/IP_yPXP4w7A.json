    {
      "start": 1036.53,
      "end": 1039.01,
      "text": "Ai que dia"
    },
    {
      "start": 1039.01,
      "end": 1039.85,
      "text": "Que dia"
    },
    {
      "start": 1039.85,
      "end": 1040.55,
      "text": "Meus amigos"
    },
    {
      "start": 1040.55,
      "end": 1041.91,
      "text": "Que dia"
