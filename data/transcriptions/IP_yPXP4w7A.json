    },
    {
      "start": 879.54,
      "end": 880.72,
      "text": "Com o lambari dela"
    },
    {
      "start": 880.72,
      "end": 881.26,
      "text": "Olha lá"
    },
    {
      "start": 881.26,
      "end": 882.12,
      "text": "Sem cabeça"
