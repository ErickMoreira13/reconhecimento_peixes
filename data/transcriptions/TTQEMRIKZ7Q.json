      "text": "Eu já aproveito pra fazer aquele mergulho"
    },
    {
      "start": 548.33,
      "end": 549.13,
      "text": "Subir aquático"
    },
    {
      "start": 549.13,
      "end": 552.01,
      "text": "Desci aqui nesse ponto, são alguns pedregulhos"
