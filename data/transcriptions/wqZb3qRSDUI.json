      "text": "Vamos subir."
    },
    {
      "start": 456.4,
      "end": 456.8,
      "text": "Vamos embora."
    },
    {
      "start": 456.8,
      "end": 462.87,
      "text": "Paramos aqui nessa prainha pra fazer aquele churrasco tradicional que vocês gostam de"
    },
    {
      "start": 462.87,
      "end": 464.05,
      "text": "ver no canal, que eu sei."
    },
    {
      "start": 465.07,
      "end": 467.99,
      "text": "Varinha que tá com a tuvira da Natália, eu armei aqui."
    },
    {
      "start": 468.77,
      "end": 473.05,
      "text": "A da mãe eu joguei aqui pertinho, porque tá com o líder muito comprido, não dá pra"
    },
    {
      "start": 473.05,
      "end": 473.61,
      "text": "arremessar."
    },
    {
      "start": 474.54,
      "end": 475.72,
      "text": "E vamos fazer aquele churrasco."
    },
    {
      "start": 475.78,
      "end": 477.06,
      "text": "Agora é desembarcar as coisas."
    },
    {
      "start": 478.08,
      "end": 478.9,
      "text": "Opa, mas é."
    },
    {
      "start": 479.0,
      "end": 479.9,
      "text": "Segura no freio."
    },
    {
      "start": 481.1,
      "end": 483.3,
      "text": "Desce e sobe engrenado, senão afoga."
    },
    {
      "start": 483.3,
      "end": 486.39,
      "text": "E vamos fazer aquele churrasco."
    },
    {
      "start": 487.06,
      "end": 487.52,
      "text": "Bora, bora."
    },
    {
      "start": 511.5,
      "end": 512.32,
      "text": "Aí, moçada."
    },
    {
      "start": 512.9,
      "end": 514.03,
      "text": "O carro tá lá."
    },
    {
      "start": 515.67,
      "end": 516.43,
      "text": "E nós tá aqui."
