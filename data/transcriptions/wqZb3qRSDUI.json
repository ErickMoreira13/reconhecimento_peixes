    {
      "start": 518.29,
      "end": 518.81,
      "text": "Barcão."
    },
    {
      "start": 521.32,
      "end": 522.86,
      "text": "E eu já fiz a minha parte, né?"
    },
    {
      "start": 523.98,
      "end": 525.18,
      "text": "O peixe eu já peguei."
    },
    {
      "start": 526.44,
      "end": 529.7,
      "text": "Então, quem tá zerado aí, o pessoal que corra atrás, né?"
