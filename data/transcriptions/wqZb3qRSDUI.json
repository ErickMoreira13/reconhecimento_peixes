    },
    {
      "start": 430.45,
      "end": 432.19,
      "text": "E daqui pra baixo ninguém mais entra."
    },
    {
      "start": 432.31,
      "end": 433.31,
      "text": "Nem pra passear."
    },
    {
      "start": 434.34,
      "end": 435.06,
      "text": "Você não pode entrar."
    },
    {
      "start": 437.06,
      "end": 437.72,
      "text": "É show, hein."
    },
    {
      "start": 438.06,
      "end": 439.84,
      "text": "O lugar aqui é bem preservado."
    },
    {
      "start": 441.37,
      "end": 442.43,
      "text": "Vamos subir."
    },
    {
      "start": 443.56,
      "end": 444.36,
      "text": "Ó o Guiraizão, ó."
    },
    {
      "start": 445.27,
