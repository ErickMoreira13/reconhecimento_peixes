      "text": "O Guiraí."
    },
    {
      "start": 450.71,
      "end": 452.83,
      "text": "A Ussorana aqui faz a festa."
    },
    {
      "start": 453.07,
      "end": 453.87,
      "text": "É o rei do Guiraí."
    },
    {
      "start": 454.84,
