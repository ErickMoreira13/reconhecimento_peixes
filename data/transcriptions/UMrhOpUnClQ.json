      "end": 724.2,
      "text": "Vinte não"
    },
    {
      "start": 724.2,
      "end": 725.2,
      "text": "Foi só oito"
    },
    {
      "start": 725.2,
      "end": 733.37,
      "text": "Não deixa a linha pegar aí na beira"
    },
    {
      "start": 733.37,
      "end": 734.37,
      "text": "Tá bom"
    },
    {
      "start": 734.37,
      "end": 735.37,
      "text": "Diversão"
    },
    {
      "start": 735.37,
      "end": 740.37,
      "text": "Os caras falando até de parar de fumar aí com uma cachorrinha"
    },
    {
      "start": 740.37,
      "end": 743.06,
      "text": "Olha lá"
    },
    {
      "start": 743.06,
      "end": 744.06,
      "text": "Agora"
    },
    {
      "start": 744.06,
      "end": 746.06,
      "text": "Agora ele perdeu o respeito"
    },
    {
      "start": 746.06,
      "end": 747.06,
      "text": "Ha ha ha ha"
    },
    {
      "start": 747.06,
      "end": 770.14,
      "text": "Pegou do lado"
    },
    {
      "start": 770.14,
      "end": 773.42,
      "text": "Traz ela aqui para mim qualquer coisa ou da pôr"
    },
    {
      "start": 773.42,
      "end": 774.42,
      "text": "Aí ó Josué pega"
    },
    {
      "start": 774.42,
      "end": 776.61,
      "text": "Josué pega ela aí"
    },
    {
      "start": 776.61,
      "end": 782.52,
      "text": "Qualquer coisa Josué pega pelo rabo"
    },
    {
      "start": 782.52,
      "end": 787.38,
      "text": "Se te der muito trabalho para pôr na boca você pega ela pelo rabo"
    },
    {
      "start": 787.38,
      "end": 789.38,
      "text": "Você acertou a poeta e ela pôs na poeta de novo"
    },
    {
      "start": 789.38,
      "end": 795.06,
      "text": "Ué mas você pôs a poeta dentro da água de novo?"
    },
    {
      "start": 795.06,
      "end": 797.11,
      "text": "Água só dispara"
    },
    {
      "start": 797.11,
      "end": 806.0,
      "text": "Os caras descobrem que é uma cachorra perde até o respeito"
    },
    {
      "start": 806.0,
      "end": 810.59,
      "text": "Vou falar para você hein"
    },
    {
      "start": 810.59,
      "end": 851.53,
      "text": "Pega pelo rabo"
    },
    {
      "start": 851.53,
      "end": 852.53,
      "text": "Pega pelo rabo"
    },
    {
      "start": 852.53,
      "end": 854.94,
      "text": "Aí"
    },
    {
      "start": 854.94,
      "end": 859.92,
      "text": "Ah mas pegou do lado mas é bonita"
    },
    {
      "start": 859.92,
      "end": 875.58,
      "text": "Mais para trás"
    },
    {
      "start": 875.58,
      "end": 900.04,
      "text": "Cadê?"
    },
    {
      "start": 900.04,
      "end": 902.04,
      "text": "Dá ela para o dono da obra aí"
    },
    {
      "start": 902.04,
      "end": 905.17,
      "text": "Não dá para o dono da obra soltar"
    },
    {
      "start": 905.17,
      "end": 909.27,
      "text": "Vamos ver a marca agora"
    },
    {
      "start": 909.27,
      "end": 910.27,
      "text": "Como que vai ser"
    },
    {
      "start": 910.27,
      "end": 912.27,
      "text": "Se vai ser carinhoso igual aquele dia"
    },
    {
      "start": 912.27,
      "end": 913.27,
      "text": "Aquilo mano"
    },
    {
      "start": 913.27,
      "end": 915.71,
      "text": "Pega aí"
    },
    {
      "start": 915.71,
      "end": 917.86,
      "text": "Ah é bonita"
    },
    {
      "start": 917.86,
      "end": 926.49,
      "text": "Mostra ela aí para nós"
    },
    {
      "start": 926.49,
      "end": 928.49,
      "text": "Vira ela de lado aí"
    },
    {
      "start": 928.49,
      "end": 931.09,
      "text": "Aê Josué"
    },
    {
      "start": 931.09,
      "end": 932.09,
      "text": "Bonita em"
    },
    {
      "start": 932.09,
      "end": 933.09,
      "text": "Você quer levar Josué?"
    },
    {
      "start": 933.09,
      "end": 934.09,
      "text": "Não"
    },
    {
      "start": 934.09,
      "end": 935.09,
      "text": "Solta esse bicho na água"
    },
    {
      "start": 935.09,
      "end": 946.04,
      "text": "Rapaz"
    },
    {
      "start": 946.04,
      "end": 947.04,
      "text": "Eu sou foda Nogueira"
    },
    {
      "start": 947.04,
      "end": 948.04,
      "text": "Você pegou pelo nariz"
    },
    {
      "start": 948.04,
      "end": 949.04,
      "text": "Eu peguei e foi de lado"
    },
    {
      "start": 949.04,
      "end": 953.04,
      "text": "Você pega esse cara aí pelo rabo e ela não vem"
    },
    {
      "start": 953.04,
      "end": 955.64,
      "text": "Pode soltar?"
    },
    {
      "start": 955.64,
      "end": 956.64,
      "text": "Pode soltar"
    },
    {
      "start": 956.64,
      "end": 961.19,
      "text": "Não levei?"
    },
    {
      "start": 961.19,
      "end": 962.19,
      "text": "Não"
    },
    {
      "start": 962.19,
      "end": 963.19,
      "text": "Ha ha ha ha"
    },
    {
      "start": 963.19,
      "end": 966.4,
      "text": "A duble"
    },
    {
      "start": 966.4,
      "end": 981.35,
      "text": "Agora não"
    },
    {
      "start": 981.35,
      "end": 982.35,
      "text": "Só pela culpa"
    },
    {
      "start": 982.35,
      "end": 983.35,
      "text": "Se ela der uma chacoalhada aqui ela vai embora"
    },
    {
      "start": 983.35,
      "end": 1017.14,
      "text": "Só se calma que ela está quase cansada"
    },
    {
      "start": 1017.14,
      "end": 1018.14,
      "text": "Vai"
    },
    {
      "start": 1018.14,
      "end": 1029.93,
      "text": "Deu o banho"
    },
    {
      "start": 1029.93,
      "end": 1035.22,
      "text": "Cai de novo"
    },
    {
      "start": 1035.22,
      "end": 1037.38,
      "text": "Agora ela der uma cansada melhor"
    },
    {
      "start": 1037.38,
      "end": 1039.08,
      "text": "Vai cansada"
    },
    {
      "start": 1039.08,
      "end": 1046.35,
      "text": "Não é não"
    },
    {
      "start": 1046.35,
      "end": 1047.35,
      "text": "É o cara tudo aí"
    },
    {
      "start": 1047.35,
      "end": 1048.35,
      "text": "Caralho"
    },
    {
      "start": 1048.35,
      "end": 1057.26,
      "text": "Acabou"
    },
    {
      "start": 1057.26,
      "end": 1058.26,
      "text": "Foi embora"
    },
    {
      "start": 1058.26,
      "end": 1060.12,
      "text": "Então"
    },
    {
      "start": 1060.12,
      "end": 1062.12,
      "text": "Agora vou soltar a minha também"
    },
    {
      "start": 1062.12,
      "end": 1063.54,
      "text": "Não é Marco?"
    },
    {
      "start": 1063.54,
      "end": 1064.7,
      "text": "Pegou?"
    },
    {
      "start": 1064.7,
      "end": 1072.24,
      "text": "Então vamos passar o tour, vamos embora!"
    }
