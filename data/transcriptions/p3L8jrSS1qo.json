      "start": 416.71,
      "end": 416.93,
      "text": "Ó."
    },
    {
      "start": 426.2,
      "end": 427.22,
      "text": "Será que tem alguma coisa aí?"
    },
    {
      "start": 431.96,
      "end": 432.22,
      "text": "Ó."
    },
    {
      "start": 440.08,
      "end": 440.54,
      "text": "Deixa eu ver."
    },
    {
      "start": 441.06,
      "end": 443.59,
      "text": "Ah, não parece pesada não."
    },
    {
      "start": 444.17,
      "end": 448.84,
      "text": "Mas alguma coisa bateu firme nela aí."
    },
    {
      "start": 458.36,
      "end": 458.66,
      "text": "Ah, não."
    },
    {
      "start": 458.7,
      "end": 459.28,
      "text": "Agora pesou."
    },
    {
      "start": 459.38,
      "end": 460.06,
      "text": "Pesou um pouco."
    },
    {
      "start": 463.92,
      "end": 464.74,
      "text": "Pesou um pouco, galera."
    },
    {
      "start": 468.04,
      "end": 469.52,
      "text": "Não parece ser peixe grande não."
    },
    {
      "start": 473.26,
      "end": 473.86,
      "text": "Vamos ver."
    },
    {
      "start": 477.06,
      "end": 477.54,
      "text": "Aí, ó."
    },
    {
      "start": 479.3,
      "end": 480.16,
      "text": "Cocoroca na área."
    },
    {
      "start": 481.1,
      "end": 482.98,
      "text": "Poxa, eu tô dando só esse tipo de peixe hoje."
    },
    {
      "start": 483.06,
      "end": 483.88,
      "text": "Eu tô dando Michole."
    },
    {
      "start": 483.88,
      "end": 486.15,
      "text": "Cocoroca."
    },
    {
      "start": 492.42,
      "end": 492.84,
      "text": "Pode ver."
    },
    {
      "start": 493.06,
      "end": 493.5,
      "text": "Isso aí."
    },
    {
      "start": 495.52,
      "end": 496.62,
      "text": "A caixa que eu ia pegar, galera."
    },
    {
      "start": 496.7,
      "end": 497.46,
      "text": "Tá indo pra lá, lá."
    },
    {
      "start": 499.0,
      "end": 500.04,
      "text": "Não vai dar pra pegar mais não."
    },
    {
      "start": 511.08,
      "end": 512.72,
      "text": "Deu uma batida ali bonita, pessoal."
    },
    {
      "start": 526.36,
      "end": 527.28,
      "text": "Vou jogar isso aqui pra ver."
    },
    {
      "start": 529.28,
      "end": 530.32,
      "text": "Ó, tem um peixe ali, ó."
    },
    {
      "start": 530.66,
      "end": 548.96,
      "text": "Tem um peixe ali, galera."
    },
    {
      "start": 549.56,
      "end": 551.8,
      "text": "Ó, ó, ó."
    },
    {
      "start": 552.26,
      "end": 552.84,
      "text": "Viu aí, pessoal?"
    },
    {
      "start": 554.17,
      "end": 555.07,
      "text": "Ah, tem um peixe ali."
    },
    {
      "start": 562.79,
      "end": 563.17,
      "text": "Ó, galera."
    },
    {
      "start": 572.96,
      "end": 574.02,
      "text": "Tá puxando ali toda hora."
    },
    {
      "start": 574.08,
      "end": 574.44,
      "text": "Vamos ver."
    },
    {
      "start": 574.44,
      "end": 577.96,
      "text": "Olha o peixinho."
    },
    {
      "start": 578.34,
      "end": 584.53,
      "text": "Como vem?"
    },
    {
      "start": 585.03,
      "end": 587.63,
      "text": "Tá dando uma espancada bonita."
    },
    {
      "start": 587.87,
      "end": 588.67,
      "text": "Ó, fechou mesmo."
    },
    {
      "start": 589.05,
      "end": 597.53,
      "text": "Ó, ela batendo ali também."
    },
    {
      "start": 599.99,
      "end": 600.63,
      "text": "Ó, lá, ó."
    },
    {
      "start": 602.11,
      "end": 602.71,
      "text": "Olha, ó."
    },
    {
      "start": 604.21,
      "end": 604.91,
      "text": "Da outra vara."
    },
    {
      "start": 606.12,
      "end": 606.3,
      "text": "Ó."
    },
    {
      "start": 608.4,
      "end": 609.16,
      "text": "Eita, ó."
    },
    {
      "start": 612.69,
      "end": 613.09,
      "text": "Vamos ver."
    },
    {
      "start": 613.51,
      "end": 621.05,
      "text": "Vamos ver o peixe dessa aqui."
    },
    {
      "start": 628.7,
      "end": 629.82,
      "text": "Deixa eu pesar agora, hein, galera."
    },
    {
      "start": 631.56,
      "end": 632.5,
      "text": "É pesadinho, hein."
    },
    {
      "start": 637.9,
      "end": 638.18,
      "text": "Viu?"
    },
    {
      "start": 640.14,
      "end": 641.78,
      "text": "Rapaz, eu usei o dia do Michole, hein, galera."
    },
    {
      "start": 643.07,
      "end": 644.17,
      "text": "Tu tá doido, hein?"
    },
    {
      "start": 644.17,
      "end": 644.37,
      "text": "Aí."
    },
    {
      "start": 645.94,
      "end": 647.26,
      "text": "Olha o tamanho desse daí, galera."
    },
    {
      "start": 649.48,
      "end": 655.03,
      "text": "Rapaz, é pequeno demais, hein."
    },
    {
      "start": 656.76,
      "end": 657.26,
      "text": "Olha aí, ó."
    },
    {
      "start": 669.91,
      "end": 670.29,
      "text": "Isso aí."
    },
    {
      "start": 670.29,
      "end": 672.46,
      "text": "Rapaz, vida."
    },
    {
      "start": 673.84,
      "end": 674.32,
      "text": "Olha esse aqui."
    },
    {
      "start": 674.36,
      "end": 675.3,
      "text": "Esse aqui pegou por baixo."
    },
    {
      "start": 677.06,
      "end": 678.16,
      "text": "Rapaz, muito lindinho, hein."
    },
    {
      "start": 679.57,
      "end": 680.87,
      "text": "Machucou ele um pouco aqui também."
    },
    {
      "start": 683.53,
      "end": 687.19,
      "text": "Vamos ver se ele vai sobreviver, né, galera."
    },
    {
      "start": 690.99,
      "end": 691.51,
      "text": "É isso aí."
    },
    {
      "start": 691.97,
      "end": 706.1,
      "text": "Ó, galera, briscando, ó."
    },
    {
      "start": 714.08,
      "end": 715.24,
      "text": "Acabei de jogar agora."
    },
    {
      "start": 719.32,
      "end": 720.06,
      "text": "Enquanto não saiu..."
    },
    {
      "start": 720.06,
      "end": 720.5,
      "text": "Olha lá, ó."
    },
    {
      "start": 721.48,
      "end": 722.88,
      "text": "Enquanto não saiu nenhum frito, não, galera."
    },
    {
      "start": 723.1,
      "end": 725.92,
      "text": "Só mesmo o Michole, o Cocoroca."
    },
    {
      "start": 729.2,
      "end": 730.18,
      "text": "Mas eu não aguardo."
    },
    {
      "start": 731.83,
      "end": 732.85,
      "text": "Tô na fila aí, ó, ó."
    },
    {
      "start": 733.01,
      "end": 734.55,
      "text": "Tô na fila do gigante aí, pessoal."
    },
    {
      "start": 734.55,
      "end": 740.42,
      "text": "Vamos ver, vamos ver."
    },
    {
      "start": 748.18,
      "end": 749.1,
      "text": "Só tá roendo."
    },
    {
      "start": 750.06,
      "end": 753.36,
      "text": "Galera, o sol agora saiu bombando, hein."
    },
    {
      "start": 755.16,
      "end": 758.7,
      "text": "Tava chovendo naquela hora."
    },
    {
      "start": 759.06,
      "end": 760.24,
      "text": "Até pelo bala agora."
    },
    {
      "start": 760.94,
      "end": 763.54,
      "text": "Rapaz, ó, ó."
    },
    {
      "start": 769.06,
      "end": 769.58,
      "text": "Eita."
    },
    {
      "start": 771.23,
      "end": 772.57,
      "text": "Ainda não tá agarrado ainda, não."
    },
    {
      "start": 773.05,
      "end": 776.2,
      "text": "A gente tá quase, hein."
    },
    {
      "start": 778.98,
      "end": 779.84,
      "text": "Vamos ver, ó."
    },
    {
      "start": 780.46,
      "end": 780.74,
      "text": "Ó."
    },
    {
      "start": 784.82,
      "end": 786.9,
      "text": "Se ferrou, foi um peixe pequenininho, galera."
    },
    {
      "start": 787.54,
      "end": 787.9,
      "text": "Eita."
    },
    {
      "start": 794.13,
      "end": 794.83,
      "text": "Cadê, cadê?"
    },
    {
      "start": 794.83,
      "end": 801.33,
      "text": "Cadê aquela puxadona pra hora?"
    },
    {
      "start": 801.33,
      "end": 806.12,
      "text": "Rapaz, o tempo ficou bom, hein."
    },
    {
      "start": 808.11,
      "end": 811.82,
      "text": "Hoje tá tudo pra bater um gigante aí, mas..."
    },
    {
      "start": 811.82,
      "end": 812.86,
      "text": "Até agora, nada."
    },
    {
      "start": 813.24,
      "end": 817.56,
      "text": "Vamos ver, mas tá agora com força, hein."
    },
    {
      "start": 820.61,
      "end": 821.09,
      "text": "Rapaz."
    },
    {
      "start": 823.94,
      "end": 824.88,
      "text": "Tava chovendo."
    },
    {
      "start": 826.54,
      "end": 827.58,
      "text": "Parou até o sol."
    },
    {
      "start": 828.28,
      "end": 828.76,
      "text": "Parou."
    },
    {
      "start": 829.36,
      "end": 831.36,
      "text": "Agora o vento tá vindo de lá."
    },
    {
      "start": 832.08,
      "end": 833.32,
      "text": "Vindo pra lá, assim, ó."
    },
    {
      "start": 835.37,
      "end": 837.55,
      "text": "Que vento forte, vento frio, hein."
    },
    {
      "start": 839.58,
      "end": 840.46,
      "text": "Tu é doido."
    },
    {
      "start": 840.46,
      "end": 846.08,
      "text": "É, rapaz."
    },
    {
      "start": 847.02,
      "end": 847.54,
      "text": "Hoje..."
    },
    {
      "start": 847.54,
      "end": 851.37,
      "text": "Hoje só tá dando peixe pequeno."
    },
    {
      "start": 854.25,
      "end": 855.71,
      "text": "Fora que eu não filmei, né, galera."
    },
    {
      "start": 857.02,
      "end": 858.76,
      "text": "Muito peixe aí eu não filmei."
    },
    {
      "start": 860.16,
      "end": 860.56,
      "text": "Porque..."
    },
    {
      "start": 862.97,
      "end": 864.77,
      "text": "É..."
    },
    {
      "start": 864.77,
      "end": 866.15,
      "text": "Micholezinho pequeno."
    },
    {
      "start": 866.23,
      "end": 867.53,
      "text": "É com a coroquinha pequena."
    },
    {
      "start": 868.8,
      "end": 870.56,
      "text": "Por enquanto não rolou nenhum frito."
    },
    {
      "start": 876.73,
      "end": 878.01,
      "text": "Aí, tô comendo tudo, ó."
    },
    {
      "start": 878.01,
      "end": 879.75,
      "text": "Peladinho."
    },
    {
      "start": 880.83,
      "end": 882.25,
      "text": "Aí como é que o vento tá soprando lá."
    },
    {
      "start": 882.57,
      "end": 882.91,
      "text": "Olha lá."
    },
    {
      "start": 883.8,
      "end": 884.96,
      "text": "Os matos mexendo."
    },
    {
      "start": 887.08,
      "end": 889.2,
      "text": "Rapaz, o vento começou forte agora, hein."
    },
    {
      "start": 895.5,
      "end": 896.0,
      "text": "Isso aí."
    },
    {
      "start": 897.33,
      "end": 898.47,
      "text": "Mas vamos aguardar daí."
    },
    {
      "start": 898.69,
      "end": 899.39,
      "text": "Vamos aguardar aí."
    },
    {
      "start": 900.38,
      "end": 902.1,
      "text": "Bateu um gigante aí e rolou o frito."
    },
    {
      "start": 908.24,
      "end": 909.4,
      "text": "Pera, bateu um peixe ali."
    },
    {
      "start": 910.02,
      "end": 911.38,
      "text": "Ó, ó, ó."
    },
    {
      "start": 912.54,
      "end": 912.9,
      "text": "Não."
    },
    {
      "start": 915.76,
      "end": 916.94,
      "text": "Tinha um peixe batendo ali, ó."
    },
    {
      "start": 917.02,
      "end": 917.8,
      "text": "Ó, ó, ó."
    },
    {
      "start": 917.8,
      "end": 921.29,
      "text": "Eita, vamos ver, vamos ver, vamos ver, vamos ver, hein."
    },
    {
      "start": 923.87,
      "end": 924.53,
      "text": "Vamos ver, hein."
    },
    {
      "start": 933.65,
      "end": 934.17,
      "text": "Pera aí, galera."
    },
    {
      "start": 934.25,
      "end": 940.08,
      "text": "Mas tá agarrado."
    },
    {
      "start": 940.26,
      "end": 941.48,
      "text": "Tinha um peixe, mas agarrou agora."
    },
    {
      "start": 941.78,
      "end": 942.54,
      "text": "Ó, como é que bate."
    },
    {
      "start": 948.56,
      "end": 949.52,
      "text": "A linha tá agarrada."
    },
    {
      "start": 950.0,
      "end": 974.75,
      "text": "O peixe agarrou ali."
    },
    {
      "start": 978.44,
      "end": 980.22,
      "text": "Pessoal, o vento tá danado, hein."
    },
    {
      "start": 984.69,
      "end": 985.59,
      "text": "Tá forte, hein."
    },
    {
      "start": 987.26,
      "end": 987.82,
      "text": "Chumei."
    },
    {
      "start": 995.36,
      "end": 996.76,
      "text": "É, agarrou mesmo."
    },
    {
      "start": 1004.84,
      "end": 1005.24,
      "text": "Arrebentou."
    },
    {
      "start": 1011.1,
      "end": 1011.76,
      "text": "Arrebentou, galera."
    },
    {
      "start": 1019.14,
      "end": 1021.66,
      "text": "Arrebentou e..."
    },
    {
      "start": 1021.66,
      "end": 1022.76,
      "text": "Eu tava com o peixe."
    },
    {
      "start": 1023.38,
      "end": 1031.3,
      "text": "Eita, o vento faz demais."
    },
    {
      "start": 1046.64,
      "end": 1047.6,
      "text": "A ganaça aqui também."
    },
    {
      "start": 1047.6,
      "end": 1054.9,
      "text": "Pera aí que ele tá agarrado."
    },
    {
      "start": 1059.58,
      "end": 1060.74,
      "text": "Bom, esse aqui tá agarrado não."
    },
    {
      "start": 1062.25,
      "end": 1063.15,
      "text": "Dando os mal, né."
    },
    {
      "start": 1063.55,
      "end": 1073.78,
      "text": "Tinha uma nuvem feia ali."
    },
    {
      "start": 1075.78,
      "end": 1076.62,
      "text": "A nuvem saiu."
    },
    {
      "start": 1077.0,
      "end": 1077.88,
      "text": "Agora o vento."
    },
    {
      "start": 1078.3,
      "end": 1084.62,
      "text": "O vento e o centro."
    },
    {
      "start": 1084.72,
      "end": 1085.28,
      "text": "Tá forte."
    },
    {
      "start": 1089.41,
      "end": 1090.61,
      "text": "Tá ruim até pra jogar ali."
    },
    {
      "start": 1092.62,
      "end": 1093.2,
      "text": "Ah, esse aqui, né."
    },
    {
      "start": 1093.74,
      "end": 1098.14,
      "text": "Ó, pro palu do vento."
    },
    {
      "start": 1099.64,
      "end": 1100.08,
      "text": "Eita."
    },
    {
      "start": 1101.82,
      "end": 1102.74,
      "text": "Hoje é hoje, hein."
    },
    {
      "start": 1108.98,
      "end": 1109.66,
      "text": "Como é que fica, galera?"
    },
    {
      "start": 1113.48,
      "end": 1116.16,
      "text": "Bate, bate, mas não engole."
    },
    {
      "start": 1116.16,
      "end": 1117.28,
      "text": "Não sei, é muito pequeno."
    },
    {
      "start": 1117.4,
      "end": 1118.02,
      "text": "Ó, ó, ó."
    },
    {
      "start": 1119.81,
      "end": 1120.03,
      "text": "Viu?"
    },
    {
      "start": 1120.43,
      "end": 1122.75,
      "text": "Esse quase ficou, hein."
    },
    {
      "start": 1122.75,
      "end": 1130.65,
      "text": "Isso aí quase agarrou."
    },
    {
      "start": 1132.66,
      "end": 1133.46,
      "text": "Ó, mas o que fica?"
    },
    {
      "start": 1133.94,
      "end": 1154.47,
      "text": "Fica comendo só pela pontinha, só."
    },
    {
      "start": 1154.57,
      "end": 1155.19,
      "text": "Não bota, não."
    },
    {
      "start": 1155.37,
      "end": 1156.57,
      "text": "É porque não é peixe grande."
    },
    {
      "start": 1160.56,
      "end": 1161.5,
      "text": "Já peguei muito, galera."
    },
    {
      "start": 1161.66,
      "end": 1162.16,
      "text": "Muito..."
    },
    {
      "start": 1162.16,
      "end": 1163.61,
      "text": "Muita coisa, né."
    },
    {
      "start": 1163.65,
      "end": 1164.33,
      "text": "Eu já saltei."
    },
    {
      "start": 1168.21,
      "end": 1172.72,
      "text": "Os pelãozão todinho, mas no lugar."
    },
    {
      "start": 1174.93,
      "end": 1176.11,
      "text": "Que é peixe miúdo."
    },
    {
      "start": 1179.74,
      "end": 1181.4,
      "text": "E o suor tá ventando, hein."
    },
    {
      "start": 1190.35,
      "end": 1191.45,
      "text": "Vamos ver se ele..."
    },
    {
      "start": 1191.45,
      "end": 1195.28,
      "text": "Se ele fez, cara."
    },
    {
      "start": 1201.48,
      "end": 1201.86,
      "text": "Ó, só."
    },
    {
      "start": 1201.86,
      "end": 1207.75,
      "text": "Só mata o filhote."
    },
    {
      "start": 1212.34,
      "end": 1214.28,
      "text": "A vara fica numa tremendeira danada."
    },
    {
      "start": 1233.68,
      "end": 1234.06,
      "text": "Isso aí, galera."
    },
    {
      "start": 1234.12,
      "end": 1236.8,
      "text": "Se ele bater, ele engarrar, eu..."
    },
    {
      "start": 1236.8,
      "end": 1237.4,
      "text": "Chamo ele."
    },
    {
      "start": 1238.68,
      "end": 1239.78,
      "text": "É a pescaria de hoje."
    },
    {
