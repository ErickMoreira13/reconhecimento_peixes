      "end": 1062.47,
      "text": "Pontinha de apoio"
    },
    {
      "start": 1062.47,
      "end": 1065.27,
      "text": "Hora do almoço"
    },
    {
      "start": 1065.27,
      "end": 1067.67,
      "text": "Eu fui comemorar"
    },
    {
      "start": 1067.67,
      "end": 1070.17,
      "text": "A captura do barbado"
    },
    {
      "start": 1070.17,
      "end": 1071.93,
      "text": "Que era o único peixe que a gente podia comer"
    },
    {
      "start": 1071.93,
      "end": 1073.65,
      "text": "Ele escapou bem na hora"
    },
    {
      "start": 1073.65,
      "end": 1074.97,
      "text": "De retirar de dentro da água"
    },
    {
      "start": 1074.97,
      "end": 1076.15,
      "text": "Então antes"
    },
    {
      "start": 1076.15,
      "end": 1078.93,
      "text": "As bargadas tinham que soltar mesmo"
    },
    {
      "start": 1078.93,
      "end": 1079.77,
      "text": "Agora é hora"
    },
    {
      "start": 1079.77,
      "end": 1083.03,
      "text": "Do arrozinho com carne"
    },
    {
      "start": 1083.03,
      "end": 1084.15,
      "text": "E uma saladinha"
    },
    {
      "start": 1084.15,
      "end": 1085.47,
      "text": "É isso, gente"
    },
    {
      "start": 1085.47,
      "end": 1087.17,
      "text": "É pesca e solte"
    },
    {
      "start": 1087.17,
      "end": 1089.66,
      "text": "Quando dá para comer um peixinho a gente come"
    },
    {
      "start": 1089.66,
      "end": 1090.4,
      "text": "Quando não dá"
    },
    {
      "start": 1090.4,
      "end": 1091.48,
      "text": "Não deu"
    },
    {
      "start": 1091.48,
      "end": 1094.22,
      "text": "Se a gente pegar algum barbado"
    },
    {
      "start": 1094.22,
      "end": 1095.44,
      "text": "Algum mandubé"
    },
    {
      "start": 1095.44,
      "end": 1098.44,
      "text": "Os peixes dentro da medida"
    },
    {
      "start": 1098.44,
      "end": 1099.8,
      "text": "A gente vai comer mais tarde"
    },
    {
      "start": 1099.8,
      "end": 1101.59,
      "text": "Só que agora à tarde"
    },
    {
      "start": 1101.59,
      "end": 1102.93,
      "text": "Nós não vamos pescar esses peixes"
    },
    {
      "start": 1102.93,
      "end": 1104.55,
      "text": "Nós vamos tentar pegar as prateadas"
    },
    {
      "start": 1104.55,
      "end": 1109.02,
      "text": "Já vimos dois ou três movimentos"
    },
    {
      "start": 1109.02,
      "end": 1110.3,
      "text": "Salto"
    },
    {
      "start": 1110.3,
      "end": 1112.52,
      "text": "Então nós vamos esticar a linha"
    },
    {
      "start": 1112.52,
      "end": 1114.82,
      "text": "Agora é hora de tentar a prateada"
    },
    {
      "start": 1114.82,
      "end": 1115.94,
      "text": "Valeu"
    },
    {
      "start": 1115.94,
      "end": 1180.07,
      "text": "Ligou a agropó?"
    },
    {
      "start": 1180.15,
      "end": 1181.09,
      "text": "Ligou a agropó"
    },
    {
      "start": 1181.09,
      "end": 1182.47,
      "text": "Agropó"
    },
    {
      "start": 1182.47,
      "end": 1184.53,
      "text": "Agropó, não queria ligar não"
    },
    {
      "start": 1184.53,
      "end": 1188.5,
      "text": "Olha os olhos aí"
    },
    {
      "start": 1188.5,
      "end": 1188.98,
      "text": "Não está"
    },
    {
      "start": 1188.98,
      "end": 1192.6,
      "text": "Aola"
    },
    {
      "start": 1192.6,
      "end": 1213.81,
      "text": "Sem pulsar"
    },
    {
      "start": 1213.81,
      "end": 1219.92,
      "text": "Ele pulou até dentro da água"
    },
    {
      "start": 1219.92,
      "end": 1221.0,
      "text": "Para pegar o peixe do homem"
    },
    {
      "start": 1221.0,
