    {
      "start": 294.11,
      "end": 294.41,
      "text": "Olha aí"
    },
    {
      "start": 294.41,
      "end": 296.14,
      "text": "Bonitona, né?"
    },
    {
      "start": 296.52,
      "end": 297.39,
      "text": "Isso aí"
    },
    {
      "start": 297.39,
      "end": 301.01,
      "text": "Mostra aí"
    },
    {
      "start": 301.01,
      "end": 301.53,
      "text": "Mais pra pé"
    },
    {
      "start": 301.53,
      "end": 304.0,
      "text": "Aí, galera, ó"
    },
    {
      "start": 304.0,
      "end": 305.22,
      "text": "Soroporzona boa"
    },
    {
      "start": 305.22,
      "end": 306.0,
      "text": "Que o Matheus pegou"
    },
    {
      "start": 306.0,
      "end": 307.62,
      "text": "Na piaba, aí, ó"
    },
    {
      "start": 307.62,
      "end": 309.12,
      "text": "Filézinho de piaba"
    },
    {
      "start": 309.12,
      "end": 310.7,
      "text": "Aí, ó"
    },
    {
      "start": 310.7,
      "end": 311.97,
      "text": "Já é o quê?"
    },
    {
      "start": 312.03,
      "end": 313.41,
      "text": "Umas nove horas da noite, né?"
    },
    {
      "start": 313.63,
      "end": 314.62,
      "text": "Muito mais"
    },
    {
      "start": 314.62,
      "end": 315.92,
      "text": "Nós estamos aqui pegando"
    },
    {
      "start": 315.92,
      "end": 317.2,
      "text": "Uma soroporzinha"
    },
    {
      "start": 317.2,
      "end": 318.12,
      "text": "Pra fazer um frito"
    },
    {
      "start": 318.12,
      "end": 320.62,
      "text": "Aí, mostra aí"
    },
    {
      "start": 320.62,
      "end": 322.12,
      "text": "Vocês acham que eu tô de brincadeira, aí?"
    },
    {
      "start": 322.3,
      "end": 322.66,
      "text": "Aí, ó"
    },
    {
      "start": 322.66,
      "end": 324.18,
      "text": "Mais uma soroporzinha aí, ó"
    },
    {
      "start": 324.18,
      "end": 327.25,
      "text": "Finalizar a noite aí, ó"
    },
    {
      "start": 327.25,
      "end": 328.87,
      "text": "Daqui a pouco nós vamos embora, aí"
    },
    {
      "start": 328.87,
      "end": 331.63,
      "text": "Eu tô só pegando uma soroporzinha aí, ó"
    },
    {
      "start": 331.63,
      "end": 336.44,
      "text": "Aí, galera, ó"
    },
    {
      "start": 336.44,
      "end": 337.1,
      "text": "Meia-noite"
    },
    {
      "start": 337.1,
      "end": 338.66,
      "text": "Nós estamos aqui na beira do Corvo, ó"
    },
    {
      "start": 338.66,
      "end": 342.12,
      "text": "Encerrando a pescaria de soropor"
    },
    {
      "start": 342.12,
      "end": 345.72,
      "text": "Meia-noite, ó"
    },
    {
      "start": 345.72,
      "end": 346.86,
      "text": "Ó, só nós mesmo"
    },
    {
      "start": 346.86,
      "end": 348.1,
      "text": "Pra tá aqui nessa beira do Corvo"
    },
    {
      "start": 348.1,
      "end": 348.68,
      "text": "Agora dessa"
    },
    {
      "start": 348.68,
      "end": 349.96,
      "text": "Aqui em Santo Leopoldino"
    },
    {
      "start": 349.96,
      "end": 351.66,
      "text": "Vai só"
    },
    {
      "start": 351.66,
      "end": 355.6,
      "text": "Vamos encerrar, galera, ó"
    },
    {
      "start": 355.6,
      "end": 357.36,
      "text": "Ó, ledão aí, ó"
    },
    {
      "start": 357.36,
      "end": 357.56,
      "text": "Ó"
    },
    {
      "start": 357.56,
      "end": 359.28,
      "text": "Pegando uma soroporzinha"
    },
    {
      "start": 359.28,
      "end": 360.86,
      "text": "Deu pra pegar, né, Zé Baiano?"
    },
    {
      "start": 361.16,
      "end": 362.58,
      "text": "No município da serra, tá?"
    },
    {
      "start": 362.84,
      "end": 364.26,
      "text": "Deu pra pegar uma soroporzinha, né?"
    },
    {
      "start": 364.48,
      "end": 365.28,
      "text": "Uns quatro quilos"
    },
    {
      "start": 365.28,
      "end": 366.26,
      "text": "Deu aí, ó"
    },
    {
      "start": 366.26,
      "end": 367.42,
      "text": "Graças a Deus"
    },
    {
      "start": 367.42,
      "end": 368.74,
      "text": "Também já é meia-noite e três"
    },
    {
      "start": 368.74,
      "end": 369.84,
      "text": "Agora nós vamos ficar por aqui"
    },
    {
      "start": 369.84,
      "end": 371.38,
      "text": "Porque chega também, né?"
    },
    {
      "start": 372.44,
      "end": 373.44,
      "text": "Senão nós não aguenta, né?"
    },
    {
      "start": 374.16,
      "end": 374.74,
      "text": "Beleza, galera?"
    },
    {
      "start": 374.74,
      "end": 379.84,
      "text": "Tchau, tchau, tchau, tchau"
    }
  ],
