    },
    {
      "start": 744.45,
      "end": 745.31,
      "text": "Manhoso só"
    },
    {
      "start": 745.31,
      "end": 748.42,
      "text": "Eles dão duas puxadinhas"
    },
    {
      "start": 748.42,
      "end": 749.28,
      "text": "Se não fisgar"
    },
    {
      "start": 749.28,
      "end": 750.58,
      "text": "Não pega"
    },
    {
      "start": 750.58,
      "end": 753.88,
      "text": "Bom demais hein meus amigos"
    },
    {
      "start": 753.88,
      "end": 755.16,
      "text": "Ó"
    },
    {
      "start": 755.16,
      "end": 756.61,
      "text": "Piauzão"
    },
    {
      "start": 756.61,
      "end": 758.81,
      "text": "Bora mandar esse bitelo"
    },
    {
      "start": 758.81,
      "end": 759.21,
      "text": "Pra vida"
    },
    {
      "start": 759.21,
      "end": 763.42,
      "text": "Foi bonito"
    },
    {
      "start": 763.42,
      "end": 766.74,
      "text": "Se inscreve no canal hein"
    },
    {
      "start": 766.74,
      "end": 768.24,
      "text": "Deixa o seu like aí"
    },
    {
      "start": 768.24,
      "end": 769.14,
      "text": "Ajuda a gente"
    },
    {
      "start": 769.14,
      "end": 771.74,
      "text": "Tamo junto"
    },
    {
      "start": 771.74,
      "end": 1021.11,
      "text": "Eu fiquei só nos piaus e nas piaparas aqui"
    },
    {
      "start": 1021.11,
      "end": 1021.69,
      "text": "Sem o milho"
    },
    {
      "start": 1021.69,
      "end": 1022.83,
      "text": "Quer milho?"
    },
    {
      "start": 1024.54,
      "end": 1026.68,
      "text": "Eu fiquei só nos piaus e nas piaparas aqui hoje ó"
    },
    {
      "start": 1026.68,
      "end": 1030.56,
      "text": "Nossa"
    },
    {
      "start": 1030.56,
      "end": 1031.28,
      "text": "Que vacilado"
    },
    {
      "start": 1031.28,
      "end": 1032.52,
      "text": "Irmão volta"
    },
    {
      "start": 1032.52,
      "end": 1034.3,
      "text": "Ou então roda a lambaria ali ó"
    },
    {
      "start": 1034.3,
      "end": 1036.04,
      "text": "Bem na beiradinha ali"
    },
    {
      "start": 1036.04,
      "end": 1036.88,
      "text": "Você pega um monte de lambaria"
    },
    {
      "start": 1036.88,
      "end": 1132.92,
      "text": "Colocar essa criança no carro"
    },
    {
      "start": 1132.92,
      "end": 1133.34,
      "text": "Turma"
    },
    {
      "start": 1133.34,
      "end": 1134.58,
      "text": "Ó o riozão lá"
    },
    {
      "start": 1134.58,
      "end": 1137.3,
      "text": "Colocar aqui"
    },
    {
      "start": 1137.3,
      "end": 1140.02,
      "text": "É meus amigos"
    },
    {
      "start": 1140.02,
      "end": 1141.12,
      "text": "Fim de pescaria hein"
    },
    {
      "start": 1141.12,
      "end": 1143.08,
      "text": "Pescaria rápida"
    },
    {
      "start": 1143.08,
      "end": 1143.66,
      "text": "Mas deu bom"
    },
    {
      "start": 1143.66,
      "end": 1145.12,
      "text": "Saiu uns peixinhos aí hein"
    },
    {
      "start": 1145.12,
      "end": 1147.64,
      "text": "Espero que vocês tenham gostado"
    },
    {
      "start": 1147.64,
      "end": 1149.56,
      "text": "Fiquem ligados aí no canal do Filho Pescador"
    },
    {
      "start": 1149.56,
      "end": 1150.92,
      "text": "Que tem muita coisa boa pra vocês"
    },
    {
      "start": 1150.92,
      "end": 1152.46,
      "text": "Se você não é inscrito no canal"
    },
    {
      "start": 1152.46,
      "end": 1153.12,
      "text": "Já se inscreve"
    },
    {
      "start": 1153.12,
      "end": 1154.6,
      "text": "Deixa o seu like se você curtir"
    },
    {
      "start": 1154.6,
      "end": 1155.66,
      "text": "Deslike se não curtir"
    },
    {
      "start": 1155.66,
      "end": 1157.58,
      "text": "E tamo junto meus amigos"
    },
    {
      "start": 1157.58,
      "end": 1158.78,
      "text": "Até a próxima pescaria"
    },
    {
      "start": 1158.78,
      "end": 1159.28,
      "text": "Valeu"
    },
    {
      "start": 1159.28,
      "end": 1160.28,
      "text": "Tchau"
    }
  ],
