    },
    {
      "start": 539.87,
      "end": 540.75,
      "text": "Caramba, grande, velho."
    },
    {
      "start": 541.41,
      "end": 542.07,
      "text": "Eu tô mandolinha."
    },
    {
      "start": 542.84,
      "end": 543.18,
      "text": "Vem cá."
    },
    {
      "start": 544.76,
      "end": 545.76,
      "text": "Mais um bitelo, cara."
    },
    {
      "start": 545.76,
      "end": 548.3,
      "text": "Ô, garotão."
    },
    {
      "start": 548.38,
      "end": 549.42,
      "text": "Vem cá, que você não vai escapar, não."
    },
    {
      "start": 549.54,
      "end": 550.7,
      "text": "Esse é grande, rapaziada."
    },
    {
      "start": 551.7,
      "end": 553.28,
      "text": "Grande, mas grande com força."
    },
    {
      "start": 557.4,
      "end": 559.1,
      "text": "Tá pra dentro, rapaz."
    },
    {
      "start": 559.18,
      "end": 560.44,
      "text": "Olha o tamanho disso aqui, galera."
    },
    {
      "start": 561.44,
