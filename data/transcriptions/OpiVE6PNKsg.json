      "text": "Não, não, não, tá só na pontinha"
    },
    {
      "start": 554.18,
      "end": 555.34,
      "text": "Não, só na pontinha, tá na mão"
    },
    {
      "start": 555.34,
      "end": 557.9,
      "text": "Uh, rapaz"
    },
    {
      "start": 557.9,
      "end": 564.57,
      "text": "Agora saiu o bairro amarelo"
    },
    {
      "start": 564.57,
      "end": 574.88,
      "text": "Olha só, rapaziada"
    },
    {
      "start": 574.88,
      "end": 576.04,
      "text": "Seu força"
    },
    {
      "start": 576.04,
      "end": 577.62,
      "text": "Tava só na pelinha da boca"
    },
    {
      "start": 577.62,
      "end": 582.3,
      "text": "Isso que não pode forçar, rapaziada"
    },
    {
      "start": 582.3,
      "end": 583.04,
      "text": "Se forçar"
    },
    {
      "start": 583.04,
      "end": 585.54,
      "text": "Forçadinha mais que tava aqui"
    },
    {
      "start": 585.54,
      "end": 587.51,
      "text": "Perdi o troféu do dia"
    },
    {
      "start": 587.51,
      "end": 603.3,
      "text": "Rapaziada"
    },
    {
      "start": 603.3,
      "end": 612.67,
      "text": "Tá passeadinha pra câmera inteiro, né?"
    },
    {
      "start": 612.67,
      "end": 615.54,
      "text": "Barra de ouro aqui do Paranazão"
    },
    {
      "start": 615.54,
      "end": 617.52,
      "text": "Que coisa linda"
    },
    {
      "start": 617.52,
      "end": 619.3,
      "text": "E olha a ventania que tá longe, cara"
    },
    {
      "start": 619.3,
      "end": 622.73,
      "text": "Pra provar aí que mesmo com as adversidades"
    },
    {
      "start": 622.73,
      "end": 625.88,
      "text": "Se trabalhar direito a gente pega esses monstros, ó"
    },
    {
      "start": 625.88,
      "end": 634.0,
      "text": "Na área aí dos seus 40 e poucos centímetros"
    },
    {
      "start": 634.0,
      "end": 635.81,
      "text": "Já valeu a briga"
    },
    {
      "start": 635.81,
      "end": 637.61,
      "text": "Tchau, obrigado, meu filho"
    },
    {
      "start": 637.61,
      "end": 638.25,
      "text": "Vai pra vida"
    },
    {
      "start": 638.25,
      "end": 642.14,
      "text": "Rapaziada, ó"
    },
    {
      "start": 642.14,
      "end": 643.78,
      "text": "A esqueminha tá sendo esse daqui, galera"
    },
    {
      "start": 643.78,
      "end": 645.1,
      "text": "Tá ventando demais"
    },
    {
      "start": 645.1,
      "end": 648.8,
      "text": "O vento aqui tá jogando a gente pra cima do ponto de pesca"
    },
    {
      "start": 648.8,
      "end": 652.56,
      "text": "O Tukundaria tá tudo embaixo desses aguapés aqui, ó"
    },
    {
      "start": 652.56,
      "end": 653.46,
      "text": "E o que acontece"
    },
    {
      "start": 653.46,
      "end": 656.53,
      "text": "O esquema pra pescar tá sendo o seguinte hoje"
    },
    {
      "start": 656.53,
      "end": 657.63,
      "text": "Uma poitinha, ó"
    },
    {
      "start": 657.63,
      "end": 659.07,
      "text": "A gente poitou o caiaque bem aqui"
    },
    {
      "start": 659.07,
      "end": 661.39,
      "text": "Tá difícil pra caramba de pescar"
    },
    {
      "start": 661.39,
      "end": 663.61,
      "text": "Mas tem que dar o jeito, né?"
    },
    {
      "start": 663.67,
      "end": 665.95,
      "text": "Cês tão vendo aí que tá batendo peixe"
    },
    {
      "start": 665.95,
      "end": 667.29,
      "text": "Só continuar assistindo"
    },
    {
      "start": 667.29,
      "end": 668.95,
      "text": "Ficar parado no lugar"
    },
    {
      "start": 668.95,
      "end": 670.77,
      "text": "Porque se soltar o caiaque"
    },
    {
      "start": 670.77,
      "end": 672.77,
      "text": "Ele vai lá pro mato e vai estragar o ponto"
    },
    {
      "start": 672.77,
      "end": 674.17,
      "text": "Desse jeitinho, galera"
    },
    {
      "start": 674.17,
      "end": 675.93,
      "text": "Batendo aí numa subsuperfície"
    },
    {
      "start": 675.93,
      "end": 677.51,
      "text": "Aqui é um lugar raso"
    },
    {
      "start": 677.51,
      "end": 678.21,
      "text": "Não é muito fundo"
    },
    {
      "start": 678.21,
      "end": 680.72,
      "text": "Tô usando uma esquema transparente hoje"
    },
    {
      "start": 680.72,
      "end": 681.96,
      "text": "Tá dando bastante resultado"
    },
    {
      "start": 681.96,
      "end": 683.69,
      "text": "Isso aí, galera"
    },
    {
      "start": 683.69,
      "end": 684.55,
      "text": "Vamos pegar mais aí"
    },
    {
      "start": 684.55,
      "end": 686.15,
      "text": "Foi dois arremessos aqui"
    },
    {
      "start": 686.15,
      "end": 687.41,
      "text": "Dois aparelhos bonitos já"
    },
    {
      "start": 687.41,
      "end": 690.22,
      "text": "E tomei um tranco aqui agora também"
    },
    {
      "start": 690.22,
      "end": 691.54,
      "text": "Vamos aí que vai pegar mais"
    },
    {
      "start": 691.54,
      "end": 747.35,
      "text": "Dá pra dentro, garoto"
    },
    {
      "start": 747.35,
      "end": 758.84,
      "text": "Mais"
    },
    {
      "start": 758.84,
      "end": 760.46,
      "text": "Mais um bruto"
    },
    {
      "start": 760.46,
      "end": 762.39,
      "text": "Agora no finalzinho da tarde"
    },
    {
      "start": 762.39,
      "end": 776.04,
      "text": "Nada, isso"
    },
    {
      "start": 776.04,
      "end": 776.94,
      "text": "Foi bonito, hein?"
    },
    {
      "start": 780.74,
      "end": 782.12,
      "text": "Finalzinho da tarde agora, galera"
    },
    {
      "start": 782.12,
      "end": 783.32,
      "text": "Parou o vento"
    },
    {
      "start": 783.32,
      "end": 784.94,
      "text": "Olha só que coisa"
    },
    {
      "start": 784.94,
      "end": 802.37,
      "text": "Olha só, galera"
    },
    {
      "start": 802.37,
      "end": 804.92,
      "text": "Que coisa linda, bicho"
    },
    {
      "start": 804.92,
      "end": 806.44,
      "text": "Abre o bocone aí"
    },
    {
      "start": 806.44,
      "end": 809.69,
      "text": "Amarelão, amarelão, hein?"
    },
    {
      "start": 811.31,
      "end": 811.63,
      "text": "Coador"
    },
    {
      "start": 811.63,
      "end": 814.96,
      "text": "Coador caiu pra dentro"
    },
    {
      "start": 814.96,
      "end": 816.0,
      "text": "Vamos pegar ali, galera"
    },
    {
      "start": 816.0,
      "end": 816.78,
      "text": "Olha só"
    },
    {
      "start": 816.78,
      "end": 819.08,
      "text": "Passei na câmera mais uma vez"
    },
    {
      "start": 819.08,
      "end": 821.61,
      "text": "E vou liberar o bicho"
    },
    {
      "start": 821.61,
      "end": 824.85,
      "text": "Briga boa"
    },
    {
      "start": 824.85,
      "end": 827.62,
      "text": "Bichinho céu valente"
    },
    {
      "start": 827.62,
      "end": 832.86,
      "text": "Foi que foi, rapaziada"
    },
    {
      "start": 832.86,
      "end": 833.42,
      "text": "É isso aí"
    },
    {
      "start": 833.42,
      "end": 835.68,
      "text": "Aí vai dar bonito"
    },
    {
      "start": 835.68,
      "end": 837.92,
      "text": "Aí tem aquela viubinha"
    },
    {
      "start": 837.92,
      "end": 839.26,
      "text": "Câmera de short ali, ó"
    },
    {
      "start": 839.26,
      "end": 841.04,
      "text": "É, rapaz, ó"
    },
    {
      "start": 841.04,
      "end": 842.8,
      "text": "Eu não gosto de calça, não"
    },
    {
      "start": 842.8,
      "end": 845.38,
      "text": "Esse aqui resolve"
    },
    {
      "start": 845.38,
      "end": 849.42,
      "text": "Rapaz, mas tá judiando os pernos longos, viu?"
    },
    {
      "start": 849.86,
      "end": 850.84,
      "text": "Você tá doido"
    },
    {
      "start": 850.84,
      "end": 855.85,
      "text": "Aqui tem alho, cebola, salsinha"
    },
    {
      "start": 855.85,
      "end": 857.79,
      "text": "Os remos tá tudo ali dentro, né?"
    },
    {
      "start": 858.63,
      "end": 859.35,
      "text": "Os remos?"
    },
    {
      "start": 859.47,
      "end": 860.69,
      "text": "Tá ali dentro, guardar"
    },
    {
      "start": 860.69,
      "end": 862.11,
      "text": "Não, mas se ficar aqui não tem problema não"
    },
    {
      "start": 862.11,
      "end": 863.19,
      "text": "A gente volta e vai tá aqui"
    },
    {
      "start": 863.19,
      "end": 867.12,
      "text": "É, rapaz"
    },
    {
      "start": 867.12,
      "end": 869.08,
      "text": "É isso aí, turma"
    },
    {
      "start": 869.08,
      "end": 869.52,
      "text": "Valeu"
    },
    {
      "start": 869.52,
      "end": 870.24,
      "text": "Se inscreve lá"
    },
    {
      "start": 870.24,
      "end": 871.98,
      "text": "Tchau, tchau"
    },
    {
      "start": 871.98,
      "end": 873.02,
      "text": "Tchau, tchau"
    }
  ],
