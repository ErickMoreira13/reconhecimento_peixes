    },
    {
      "start": 411.33,
      "end": 412.33,
      "text": "Isso é rio machado."
    },
    {
      "start": 412.33,
      "end": 413.33,
      "text": "Eu amo esse lugar."
    },
    {
      "start": 413.33,
      "end": 414.33,
      "text": "Quem aguenta, gente."
    },
    {
      "start": 414.33,
      "end": 415.33,
      "text": "Nossa senhora."
    },
    {
      "start": 415.33,
      "end": 418.33,
      "text": "Tô pensando que não é pouca merda aí, ó."
    },
    {
      "start": 418.33,
      "end": 419.49,
      "text": "Cansei, tá?"
    },
    {
      "start": 419.49,
      "end": 420.49,
      "text": "Ó o nenenzinho aí, ó."
