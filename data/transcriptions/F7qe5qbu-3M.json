    },
    {
      "start": 428.97,
      "end": 429.97,
      "text": "Vira aqui."
    },
    {
      "start": 429.97,
      "end": 433.91,
      "text": "Deixa eu fazer um negócio aqui."
    },
    {
      "start": 433.91,
      "end": 434.91,
      "text": "Vem aí."
    },
    {
      "start": 434.91,
      "end": 436.91,
      "text": "Que que é um pontinho brilhando no meio do rio, Alisa?"
    },
    {
      "start": 436.91,
      "end": 438.91,
      "text": "É aeroporto de mosquita."
    },
    {
      "start": 438.91,
      "end": 439.91,
      "text": "Careca do mael."
    },
    {
      "start": 441.71,
      "end": 443.71,
      "text": "Mas tá valendo a pena, caralho."
    },
    {
      "start": 443.71,
      "end": 444.71,
      "text": "Com certeza."
    },
    {
      "start": 444.71,
      "end": 445.71,
      "text": "Benzadeus."
    },
    {
      "start": 445.71,
      "end": 446.71,
      "text": "Viagem boa."
    },
    {
      "start": 446.71,
      "end": 447.71,
      "text": "Vem de Brasília aqui."
    },
    {
      "start": 447.71,
      "end": 448.71,
      "text": "Só vê uns tambaqui, né?"
    },
    {
      "start": 448.71,
      "end": 449.71,
      "text": "Maravilha."
    },
    {
      "start": 449.71,
      "end": 450.71,
      "text": "Ó, gente, ó."
    },
    {
      "start": 450.71,
      "end": 451.71,
      "text": "É um aprendizado na minha vida."
    },
    {
      "start": 451.71,
      "end": 452.71,
      "text": "É show demais."
    },
    {
      "start": 452.71,
      "end": 453.71,
      "text": "É isso aí."
    },
    {
      "start": 453.71,
      "end": 455.71,
      "text": "Você vai vir com mais tempo pra nós ir lá no Guaporé."
    },
    {
      "start": 455.71,
      "end": 456.71,
      "text": "Aí você vai ver show."
    },
    {
      "start": 456.71,
      "end": 457.71,
      "text": "Iremos."
    },
    {
      "start": 457.71,
      "end": 458.71,
      "text": "Fé em Deus."
    },
    {
      "start": 458.71,
      "end": 460.71,
      "text": "É que agora aqui nós estamos no terreno de casa, né?"
    },
    {
      "start": 460.71,
      "end": 461.71,
      "text": "Tá bom demais."
    },
    {
      "start": 461.71,
      "end": 462.71,
      "text": "No quintal."
