    {
      "start": 360.48,
      "end": 362.15,
      "text": "Calma aí."
    },
    {
      "start": 362.15,
      "end": 363.15,
      "text": "Vamos pegar mais perto."
    },
    {
      "start": 363.15,
      "end": 364.15,
      "text": "Ele não cansou ainda não."
    },
    {
      "start": 364.15,
      "end": 365.41,
      "text": "Cansou não."
    },
    {
      "start": 365.41,
