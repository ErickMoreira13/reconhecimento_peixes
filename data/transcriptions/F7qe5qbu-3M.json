      "text": "Tamo cansar."
    },
    {
      "start": 366.41,
      "end": 367.41,
      "text": "Tem pressa não."
    },
    {
      "start": 367.41,
      "end": 368.41,
      "text": "Se perder nós já brigamos."
    },
    {
      "start": 368.41,
      "end": 369.41,
      "text": "O importante é trazer."
    },
    {
      "start": 369.41,
      "end": 373.38,
      "text": "Calma aí, meu amor."
