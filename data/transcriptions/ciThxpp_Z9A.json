    },
    {
      "start": 685.8,
      "end": 686.86,
      "text": "Para vocês aí"
    },
    {
      "start": 686.86,
      "end": 689.12,
      "text": "E muita dica de pescaria"
    },
    {
      "start": 689.12,
      "end": 689.64,
      "text": "Top"
