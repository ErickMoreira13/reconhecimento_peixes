      "end": 940.03,
      "text": "Então é isso aí"
    },
    {
      "start": 940.03,
      "end": 940.95,
      "text": "Vamos partir pra casa"
    },
    {
      "start": 940.95,
      "end": 941.61,
      "text": "Que já tá metade"
    },
    {
      "start": 941.61,
      "end": 942.39,
      "text": "Da barriga roncando"
    },
    {
      "start": 942.39,
      "end": 945.01,
      "text": "E vocês já tem o próximo vídeo, né?"
    },
    {
      "start": 945.17,
      "end": 945.53,
      "text": "Se Deus quiser"
    },
    {
      "start": 945.53,
      "end": 947.43,
      "text": "Não se esqueça de se inscrever aí"
    },
    {
      "start": 947.43,
      "end": 948.55,
      "text": "Dá aquela força pra nós, né?"
    },
    {
      "start": 948.57,
      "end": 949.25,
      "text": "Não se esqueça não"
    },
    {
      "start": 949.25,
      "end": 950.49,
      "text": "É, saindo feio de fundo"
    },
    {
      "start": 950.49,
      "end": 951.19,
      "text": "E do corpo, né?"
    },
    {
      "start": 951.19,
      "end": 952.29,
      "text": "Não se esqueça não"
    },
    {
      "start": 952.29,
      "end": 954.89,
      "text": "Não custa nada se inscrever não, né?"
    },
    {
      "start": 955.05,
      "end": 956.11,
      "text": "Custa nada, rapaz"
    },
    {
      "start": 956.11,
      "end": 957.95,
      "text": "Por metinho, meto dentro lá"
    },
    {
      "start": 957.95,
      "end": 959.57,
      "text": "A gente tem preguiça mais não"
    },
    {
      "start": 959.57,
      "end": 960.13,
      "text": "Tem não, né?"
    },
    {
      "start": 960.13,
      "end": 961.37,
      "text": "Tem não, tem não, tem não"
    },
    {
      "start": 961.37,
      "end": 961.87,
      "text": "Tem não"
    },
    {
      "start": 961.87,
      "end": 964.43,
      "text": "Né, tem preguiça de meter o dedo no sítio não"
    },
    {
      "start": 964.43,
      "end": 966.49,
      "text": "Simbora, até o próximo, se Deus quiser"
    }
  ],
