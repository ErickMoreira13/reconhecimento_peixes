      "end": 352.8,
      "text": "Ah, agora ela quer, né?"
    },
    {
      "start": 353.9,
      "end": 354.98,
      "text": "Até agora ela queria dormir."
    },
    {
      "start": 356.25,
      "end": 357.69,
      "text": "Já tá cansado, esse filho da puta."
    },
    {
      "start": 357.91,
      "end": 358.37,
      "text": "Tá, não."
    },
    {
      "start": 358.37,
      "end": 359.29,
      "text": "Tá correndo linha ainda."
    },
    {
      "start": 359.35,
      "end": 360.57,
      "text": "Tô brincando com ele dentro da água, não."
    },
    {
      "start": 360.57,
      "end": 361.33,
      "text": "Não, ele tá bem pego."
    },
    {
      "start": 361.79,
      "end": 362.37,
      "text": "Tá bem pego."
    },
    {
      "start": 363.11,
      "end": 364.11,
      "text": "Só que se você..."
    },
    {
      "start": 364.11,
      "end": 365.37,
      "text": "Espantar é perigoso, ele..."
    },
    {
      "start": 365.37,
      "end": 365.69,
      "text": "Ah, vai."
    },
    {
      "start": 365.69,
      "end": 366.31,
      "text": "É."
    },
    {
      "start": 368.55,
      "end": 369.27,
      "text": "Ó, ó."
    },
    {
      "start": 369.51,
      "end": 370.29,
      "text": "Vai, vai, homem."
    },
    {
      "start": 370.63,
      "end": 371.11,
      "text": "Aí, tá vendo?"
    },
    {
      "start": 371.53,
      "end": 373.17,
      "text": "Aí, é grande, minha."
    },
    {
      "start": 373.35,
      "end": 379.16,
      "text": "Pega no rabo dele."
    },
    {
      "start": 379.22,
      "end": 379.8,
      "text": "Pega no rabo dele."
    },
    {
      "start": 379.8,
      "end": 395.38,
      "text": "É um anzói de galho."
    },
    {
      "start": 395.42,
      "end": 396.8,
      "text": "Olha o tamanho do anzói que tá na boca dele."
    },
    {
      "start": 396.82,
      "end": 397.48,
      "text": "É, não, não, meu."
    },
    {
      "start": 397.66,
      "end": 399.86,
      "text": "Olha o tamanho do anzói que tá na boca dele."
    },
    {
      "start": 400.4,
      "end": 400.94,
      "text": "Só, ó."
    },
    {
      "start": 401.58,
      "end": 402.7,
      "text": "Bora medir o peixe."
    },
    {
      "start": 403.82,
      "end": 404.28,
      "text": "Quanto, amor?"
    },
    {
      "start": 405.1,
      "end": 405.5,
      "text": "80."
    },
    {
      "start": 405.66,
      "end": 406.6,
      "text": "80 passadas, olha lá."
    },
    {
      "start": 407.0,
      "end": 407.4,
      "text": "Ó."
    },
    {
      "start": 408.36,
      "end": 409.08,
      "text": "Olha o bichão, ó."
    },
    {
      "start": 409.66,
      "end": 410.04,
      "text": "Olha lá."
    },
    {
      "start": 410.58,
      "end": 412.18,
      "text": "Olha o tamanho da criança."
    },
    {
      "start": 412.4,
      "end": 412.52,
      "text": "Ó."
    },
    {
      "start": 413.48,
      "end": 413.86,
      "text": "Ó."
    },
    {
      "start": 413.86,
      "end": 413.92,
      "text": "Ó."
    },
    {
      "start": 415.44,
      "end": 417.04,
      "text": "Que coisa linda."
    },
    {
      "start": 418.76,
      "end": 420.18,
      "text": "Tô, troféu do dia, hein?"
    },
    {
      "start": 420.48,
      "end": 421.86,
      "text": "Equipe, mais uma vez."
    },
    {
      "start": 422.48,
      "end": 423.52,
      "text": "Casal da pesca."
    },
    {
      "start": 423.74,
      "end": 424.24,
      "text": "Pate aqui, amor."
    },
    {
      "start": 424.24,
      "end": 425.56,
      "text": "Que coisa mais linda."
    },
    {
      "start": 426.76,
      "end": 427.64,
      "text": "Tira foto, né?"
    },
    {
      "start": 427.74,
      "end": 427.94,
      "text": "Ó."
    },
    {
      "start": 428.58,
      "end": 430.0,
      "text": "A bocada do bicho."
    },
    {
      "start": 430.1,
      "end": 430.42,
      "text": "Merda."
    },
    {
      "start": 431.14,
      "end": 432.12,
      "text": "Que pega, que pega."
    },
    {
      "start": 432.32,
      "end": 432.62,
      "text": "Olha o anzói que tá na boca dele."
    },
    {
      "start": 432.66,
      "end": 433.18,
      "text": "Mostra ele, né?"
    },
    {
      "start": 433.18,
      "end": 433.44,
      "text": "Ó."
    },
    {
      "start": 433.64,
      "end": 435.18,
      "text": "E ele vê e escata, gente, ó."
    },
    {
      "start": 435.3,
      "end": 436.44,
      "text": "Esse anzói tava na boca dele, ó."
    },
    {
      "start": 436.46,
      "end": 437.54,
      "text": "Tava na boca dele, pessoal."
    },
    {
      "start": 438.62,
      "end": 439.36,
      "text": "E a gente pegou?"
    },
    {
      "start": 439.48,
      "end": 440.54,
      "text": "A Tainá pegou o que, esse anzói?"
    },
    {
      "start": 440.56,
      "end": 441.14,
      "text": "Com esse menor."
    },
    {
      "start": 441.8,
      "end": 442.48,
      "text": "Olha a diferença."
    },
    {
      "start": 442.66,
      "end": 443.26,
      "text": "De um pro outro."
    },
    {
      "start": 444.31,
      "end": 444.71,
      "text": "Caramba."
    },
    {
      "start": 444.71,
      "end": 444.83,
      "text": "Olha lá."
    },
    {
      "start": 446.03,
      "end": 447.39,
      "text": "Não, quando é pra pegar..."
    },
    {
      "start": 447.39,
      "end": 448.31,
      "text": "Não, quando é pra pegar..."
    },
    {
      "start": 448.31,
      "end": 448.97,
      "text": "Um graço a Deus."
    },
    {
      "start": 449.05,
      "end": 449.87,
      "text": "Deus abençoa."
    },
    {
      "start": 450.23,
      "end": 450.51,
      "text": "Amém."
    },
    {
      "start": 450.51,
      "end": 450.73,
      "text": "Né?"
    },
    {
      "start": 451.15,
      "end": 451.47,
      "text": "Chama."
    },
    {
      "start": 453.78,
      "end": 454.18,
      "text": "Pessoal."
    },
    {
      "start": 454.18,
      "end": 457.04,
      "text": "Depois daquele bitela que a gente pegou."
    },
    {
      "start": 457.38,
      "end": 458.02,
      "text": "Tamo aqui, ó."
    },
    {
      "start": 459.32,
      "end": 460.56,
      "text": "Em busca do próximo, né?"
    },
    {
      "start": 460.68,
      "end": 461.3,
      "text": "Do próximo, né?"
    },
    {
      "start": 461.4,
      "end": 462.16,
      "text": "É isso aí."
    },
    {
      "start": 462.62,
      "end": 463.52,
      "text": "Quem será o próximo?"
    },
    {
      "start": 464.6,
      "end": 465.1,
      "text": "A Liliane."
    },
    {
      "start": 465.74,
      "end": 466.08,
      "text": "Você viu?"
    },
    {
      "start": 466.14,
      "end": 466.96,
      "text": "A gente falou, né?"
    },
    {
      "start": 467.46,
      "end": 468.58,
      "text": "Chegamos falando que ia pegar o..."
    },
    {
      "start": 468.58,
      "end": 469.3,
      "text": "Ia pegar."
    },
    {
      "start": 469.48,
      "end": 471.24,
      "text": "O irmão do que a Liliane pegou e pegamos."
    },
    {
      "start": 471.26,
      "end": 471.84,
      "text": "E pegou."
    },
    {
      "start": 474.78,
      "end": 476.74,
      "text": "É, do menino na espadinha."
    },
    {
      "start": 476.86,
      "end": 479.26,
      "text": "Ele engoliu, assim, metade e soltou."
    },
    {
      "start": 479.34,
      "end": 480.5,
      "text": "Ele não deu conta, não."
    },
    {
      "start": 480.84,
      "end": 482.63,
      "text": "Mas a Liliane tá com pressa?"
    },
    {
