    },
    {
      "start": 725.27,
      "end": 768.24,
      "text": "E aí, pessoal"
    },
    {
      "start": 768.24,
      "end": 770.31,
      "text": "Picotadinho, ó"
    },
    {
      "start": 770.31,
      "end": 772.75,
      "text": "Só temperar e chamar no óleo"
    },
    {
      "start": 772.75,
      "end": 778.75,
      "text": "E aí, pessoal"
    },
    {
      "start": 778.75,
      "end": 781.56,
      "text": "Show, hein"
    },
    {
      "start": 781.56,
      "end": 783.38,
      "text": "É só jogar um salzinho"
    },
    {
      "start": 783.38,
      "end": 785.3,
      "text": "E botar no óleo"
    },
    {
      "start": 785.3,
      "end": 787.61,
      "text": "Acompanha aí, ó"
    },
    {
      "start": 787.61,
      "end": 800.47,
      "text": "Hoje o negócio está sofisticado aqui, ó"
    },
    {
      "start": 800.47,
      "end": 801.67,
      "text": "Parece que eu estou numa mesa"
    },
    {
      "start": 801.67,
      "end": 831.96,
      "text": "E aí, pessoal"
    },
    {
      "start": 831.96,
      "end": 834.16,
      "text": "Tirar a última partezinha aqui do frito, ó"
