    {
      "start": 680.53,
      "end": 692.72,
      "text": "Brilha, mano"
    },
    {
      "start": 692.72,
      "end": 719.72,
      "text": "Olha, um piauzinho bonito aí, ó"
    },
    {
      "start": 719.72,
      "end": 725.27,
