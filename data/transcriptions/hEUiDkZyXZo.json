      "end": 514.88,
      "text": "Segura, Davi"
    },
    {
      "start": 514.88,
      "end": 520.06,
      "text": "Bonito"
    },
    {
      "start": 520.06,
      "end": 526.68,
      "text": "Tira a criança"
    },
    {
      "start": 526.68,
      "end": 528.38,
      "text": "Aí, ó"
    },
    {
      "start": 528.38,
      "end": 529.32,
      "text": "Bonitão também"
    },
    {
      "start": 529.32,
      "end": 535.12,
      "text": "Segura, Davi"
    },
    {
      "start": 535.12,
      "end": 536.26,
      "text": "Não deixa eu ir embora, não"
    },
    {
      "start": 536.26,
      "end": 538.73,
      "text": "É, guarda"
    },
    {
      "start": 538.73,
      "end": 539.65,
      "text": "Não, deixa eu ir embora"
    },
    {
      "start": 539.65,
      "end": 541.62,
      "text": "É ruim, hein"
    },
    {
      "start": 541.62,
      "end": 546.2,
      "text": "Aí, mostra aí, pessoal"
    },
    {
      "start": 546.2,
      "end": 548.74,
      "text": "Aí, pessoal"
    },
    {
      "start": 548.74,
      "end": 551.17,
      "text": "Que é o bonito aí, ó"
    },
    {
      "start": 551.17,
      "end": 553.37,
      "text": "Show de bola"
    },
    {
      "start": 553.37,
      "end": 558.84,
      "text": "Dá para nós comer peixe com o almoço à vontade"
    },
    {
      "start": 558.84,
      "end": 559.28,
      "text": "Dá"
    },
    {
      "start": 559.28,
      "end": 560.66,
      "text": "Um chupando"
