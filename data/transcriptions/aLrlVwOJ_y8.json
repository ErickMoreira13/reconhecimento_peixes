      "text": "Caiu os cães naquele lugar aí."
    },
    {
      "start": 867.67,
      "end": 867.99,
      "text": "Certo."
    },
    {
      "start": 869.66,
      "end": 869.84,
      "text": "Tá."
    },
    {
      "start": 877.82,
      "end": 878.96,
      "text": "Um pedaço de salão, Ficci."
    },
    {
      "start": 879.2,
      "end": 880.66,
      "text": "De peixe, ele tá meio brabo, né?"
    },
    {
      "start": 881.14,
      "end": 881.5,
      "text": "Deve ver."
    },
    {
      "start": 885.27,
      "end": 885.91,
      "text": "Pão, tem aqui."
    },
    {
      "start": 889.63,
      "end": 890.93,
      "text": "Peixe, não sei se vamos pegar."
    },
    {
      "start": 891.49,
      "end": 891.79,
      "text": "Tá bom."
    },
    {
      "start": 892.66,
      "end": 893.46,
      "text": "Vamos e não vamos passar."
    },
    {
      "start": 893.52,
      "end": 893.7,
      "text": "Não."
    },
    {
      "start": 904.78,
      "end": 905.32,
      "text": "Quer pão, não?"
    },
    {
      "start": 905.84,
      "end": 906.2,
      "text": "Uhum."
    },
    {
      "start": 906.72,
      "end": 908.49,
      "text": "O?"
    },
    {
      "start": 909.45,
      "end": 910.19,
      "text": "Tá um, que que bo?"
    },
    {
      "start": 910.19,
      "end": 910.45,
      "text": "É, um, que que bo?"
    },
    {
      "start": 910.45,
      "end": 911.01,
      "text": "É, um, que que bo?"
    },
    {
      "start": 911.01,
      "end": 911.19,
      "text": "Aham."
    },
    {
      "start": 913.58,
      "end": 914.08,
      "text": "Qual é o, ó."
    },
    {
      "start": 915.13,
      "end": 916.21,
      "text": "Não, pode ir demais, então."
    },
    {
      "start": 916.39,
      "end": 916.93,
      "text": "Toma, tem aqui."
    },
    {
      "start": 919.82,
      "end": 920.42,
      "text": "Deu pobobo."
    },
    {
      "start": 921.64,
      "end": 922.06,
      "text": "Que bobo?"
    },
    {
      "start": 922.72,
      "end": 924.14,
      "text": "Ó, táfica colera o bobo doce."
    },
    {
      "start": 924.14,
      "end": 924.68,
      "text": "Uhum."
    },
    {
      "start": 924.82,
      "end": 926.62,
      "text": "Eu soube, porque não vale o que que bobo."
    },
    {
      "start": 926.62,
      "end": 927.12,
      "text": "Háhá."
    },
    {
      "start": 928.02,
      "end": 928.24,
      "text": "Háhá."
    },
    {
      "start": 928.24,
      "end": 956.46,
      "text": "É, um, que bobo."
    },
    {
      "start": 956.46,
      "end": 957.3,
      "text": "E aí, ó."
    },
    {
      "start": 957.3,
      "end": 967.86,
      "text": "E aí, ó?"
    },
    {
      "start": 967.86,
      "end": 971.88,
      "text": "Não."
    },
    {
      "start": 971.88,
      "end": 975.86,
      "text": "Mas é pintado?"
    },
    {
      "start": 975.86,
      "end": 978.15,
      "text": "Ou é jundiazinha."
    },
    {
      "start": 978.15,
      "end": 981.05,
      "text": "Ou jundiazinha, mas é..."
    },
    {
      "start": 981.05,
      "end": 983.05,
      "text": "Pintado."
    },
    {
      "start": 983.05,
      "end": 988.28,
      "text": "Ah, bonito aí."
    },
    {
      "start": 988.28,
      "end": 993.1,
      "text": "Sorte, né?"
    },
    {
      "start": 993.1,
      "end": 995.1,
      "text": "Vocês vão fritar ou não?"
    },
    {
      "start": 995.1,
      "end": 1003.37,
      "text": "Não sei o que tu quer fazer."
    },
    {
      "start": 1003.37,
      "end": 1005.37,
      "text": "Vá que nós pegamos mais uma meia luz."
    },
    {
      "start": 1005.37,
      "end": 1032.79,
      "text": "Vem chegando a noite e nada de peixe."
    },
    {
      "start": 1032.79,
      "end": 1035.34,
      "text": "O Tony que pega os bigodudos"
    },
    {
      "start": 1035.34,
      "end": 1037.34,
      "text": "e já vem pegar, mas não"
    },
    {
      "start": 1037.34,
      "end": 1056.94,
      "text": "não tá saindo."
    },
    {
      "start": 1056.94,
      "end": 1114.42,
      "text": "Não tá tendo nada."
    },
    {
      "start": 1114.42,
      "end": 1125.99,
      "text": "Tão armadas as linhas aí. Mas tá fraco, cara."
    },
    {
      "start": 1125.99,
      "end": 1129.11,
      "text": "Meu Deus."
    },
    {
      "start": 1129.11,
      "end": 1175.53,
      "text": "Fraco, fraco de peixe."
    },
    {
      "start": 1175.53,
      "end": 1178.55,
      "text": "Vou pegar uma água da"
    },
    {
      "start": 1178.55,
      "end": 1181.06,
      "text": "fontezinha aqui pro café."
    },
    {
      "start": 1191.22,
      "end": 1193.22,
      "text": "Minha água, tudo explicado, acabou."
    },
    {
      "start": 1193.22,
      "end": 1210.3,
      "text": "Um riozinho que desce, que cai aqui"
    },
    {
      "start": 1210.3,
      "end": 1225.19,
      "text": "no rio aqui do lado."
    },
    {
      "start": 1225.19,
      "end": 1257.27,
      "text": "Bom giorno, galera."
    },
    {
      "start": 1257.27,
      "end": 1261.26,
      "text": "Tem aquelas linhas que deixamos armadas ali."
    },
    {
      "start": 1261.26,
      "end": 1263.26,
      "text": "Mas pelo jeito não bateu nada, cara."
    },
    {
      "start": 1263.26,
      "end": 1270.07,
      "text": "O rio tava perfeito pra pesca, cara, mas..."
    },
    {
      "start": 1270.07,
      "end": 1311.91,
      "text": "Uma tá puxando aqui."
    },
    {
      "start": 1311.91,
      "end": 1319.77,
      "text": "Vamos ver essa aqui."
    },
    {
      "start": 1319.77,
      "end": 1336.55,
      "text": "Vou colocar uma água pro café aqui."
    },
    {
      "start": 1336.55,
      "end": 1338.55,
      "text": "Pra revistar as linhas."
    },
    {
      "start": 1338.55,
      "end": 1346.79,
      "text": "Vamos ver se tinha alguma coisa."
    },
    {
      "start": 1346.79,
      "end": 1381.75,
      "text": "Nada na primeira."
    },
    {
      "start": 1381.75,
      "end": 1396.58,
      "text": "Ah, maluco."
    },
    {
      "start": 1396.58,
      "end": 1427.83,
      "text": "Caramba."
    },
    {
      "start": 1427.83,
      "end": 1430.76,
      "text": "É o do café."
    },
    {
      "start": 1430.76,
      "end": 1450.52,
      "text": "Eu adoro cheio do café."
    },
    {
      "start": 1450.52,
      "end": 1452.52,
      "text": "Bobzinha."
    },
    {
      "start": 1452.52,
      "end": 1484.09,
      "text": "Vamos abaixar o pó."
    },
    {
      "start": 1484.09,
      "end": 1501.86,
      "text": "Vamos ser de Equador daí, galera."
    },
    {
      "start": 1501.86,
      "end": 1506.1,
      "text": "Só notição."
    },
    {
      "start": 1506.1,
      "end": 1512.74,
      "text": "Olha o cafezinho que saiu."
    },
    {
      "start": 1512.74,
      "end": 1517.21,
      "text": "Vou dar uma olhada."
    },
    {
      "start": 1517.21,
      "end": 1527.34,
      "text": "Meu..."
    },
    {
      "start": 1527.34,
      "end": 1529.34,
      "text": "Café de bilhões, cara."
    },
    {
      "start": 1529.34,
      "end": 1536.62,
      "text": "Café de bilhões."
    },
    {
      "start": 1536.62,
      "end": 1539.26,
      "text": "Não é juba?"
    },
    {
      "start": 1539.26,
      "end": 1543.69,
      "text": "Dá um oi pra galera."
    },
    {
      "start": 1543.69,
      "end": 1550.97,
      "text": "Dá um oi pra galera."
    },
    {
      "start": 1550.97,
      "end": 1552.97,
      "text": "Bob..."
    },
    {
      "start": 1552.97,
      "end": 1555.86,
      "text": "Bob não come pão."
    },
    {
      "start": 1555.86,
      "end": 1558.76,
      "text": "O juba também quer juba de pão."
    },
    {
      "start": 1558.76,
      "end": 1563.42,
      "text": "O juba come, cara."
    },
    {
      "start": 1563.42,
      "end": 1566.41,
      "text": "O Bob não come."
    },
    {
      "start": 1566.41,
      "end": 1609.37,
      "text": "O Bob ele não come."
    },
    {
      "start": 1609.37,
      "end": 1612.46,
      "text": "Ele inteira, ó."
    },
    {
      "start": 1612.46,
      "end": 1614.81,
      "text": "Ele tá inteirando."
    },
    {
      "start": 1614.81,
      "end": 1619.37,
      "text": "Tentamos, né."
    },
    {
      "start": 1619.37,
      "end": 1621.37,
      "text": "Tentamos pra próxima, então."
    }
  ],
