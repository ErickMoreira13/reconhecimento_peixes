    },
    {
      "start": 349.9,
      "end": 351.7,
      "text": "Vai embora"
    },
    {
      "start": 351.7,
      "end": 354.86,
      "text": "Não sei se a isca não tá muito pequena, galera"
    },
    {
      "start": 354.86,
      "end": 355.94,
      "text": "Um anzol muito pequeno"
    },
    {
      "start": 355.94,
      "end": 357.46,
      "text": "Mas todo mundo fala que o carapé vai do certo"
    },
    {
      "start": 357.46,
      "end": 358.3,
      "text": "É um anzolzinho pequeno"
    },
    {
      "start": 358.3,
      "end": 359.32,
      "text": "Que eu tô com aqui"
    },
    {
      "start": 359.32,
      "end": 360.28,
      "text": "Tá aqui do sul número 8"
    },
    {
      "start": 360.28,
      "end": 361.87,
      "text": "Da Gamacatus"
    },
    {
      "start": 361.87,
      "end": 363.95,
      "text": "Eu ainda quero tirar o carapé, moçada"
    },
    {
      "start": 363.95,
      "end": 364.69,
      "text": "Ó, rapaziada"
    },
    {
      "start": 364.69,
      "end": 366.07,
      "text": "Tô soltando bem pertinho das pedras"
    },
    {
      "start": 366.07,
      "end": 366.97,
      "text": "Bem encostado"
    },
    {
      "start": 366.97,
      "end": 369.17,
      "text": "A manha que eu passo pra vocês"
    },
    {
      "start": 369.17,
      "end": 370.23,
      "text": "É quando a isca cai lá"
    },
    {
      "start": 370.23,
      "end": 372.33,
      "text": "Não fica recolhendo e esticando a linha"
    },
    {
      "start": 372.33,
      "end": 373.35,
      "text": "Cada vez que afrouxa"
    },
    {
      "start": 373.35,
      "end": 375.13,
      "text": "Se a linha dá uma afrouxada"
    },
    {
      "start": 375.13,
      "end": 376.27,
      "text": "Deixa ela meio afrouxinha"
    },
    {
      "start": 376.27,
      "end": 377.89,
      "text": "E cada vez que você estica"
    },
    {
      "start": 377.89,
      "end": 379.21,
      "text": "O chumbo vai correr um pouquinho"
    },
    {
      "start": 379.21,
      "end": 379.93,
      "text": "Correr um pouquinho"
    },
    {
      "start": 379.93,
      "end": 381.91,
      "text": "E até ele cair numa fenda de pedra"
    },
    {
      "start": 381.91,
      "end": 382.85,
      "text": "E você perder o chumbo"
    },
    {
      "start": 382.85,
      "end": 384.03,
      "text": "Tô utilizando aqui, ó"
    },
    {
      "start": 384.03,
      "end": 384.57,
      "text": "Um chumbo"
    },
    {
      "start": 384.57,
      "end": 386.19,
      "text": "Que é um jig head velho"
    },
    {
      "start": 386.19,
      "end": 387.45,
      "text": "Eu não tinha chumbo pequeno"
    },
    {
      "start": 387.45,
      "end": 388.67,
      "text": "Então eu peguei um jig head"
    },
    {
      "start": 388.67,
      "end": 390.03,
      "text": "De 25, 30 gramas"
    },
    {
      "start": 390.03,
      "end": 390.55,
      "text": "Velho"
    },
    {
      "start": 390.55,
      "end": 391.59,
      "text": "E cortei, ó"
    },
    {
      "start": 391.59,
      "end": 392.61,
      "text": "Uma cabeça de chumbo"
    },
    {
      "start": 392.61,
      "end": 393.83,
      "text": "Aí ficou um chumbo de bola"
    },
    {
      "start": 393.83,
      "end": 394.35,
      "text": "Tá vendo?"
    },
    {
      "start": 395.03,
      "end": 396.31,
      "text": "Chicotinho com dois anzóis"
    },
    {
      "start": 396.31,
      "end": 398.45,
      "text": "E ultralightzinho, moçada"
    },
    {
      "start": 398.45,
      "end": 399.65,
      "text": "Vamos trocar esse camarão"
    },
    {
      "start": 399.65,
      "end": 400.85,
      "text": "E vamos ver se pegamos mais aí"
    },
    {
      "start": 400.85,
      "end": 401.29,
      "text": "Vamos lá"
    },
    {
      "start": 401.29,
      "end": 402.13,
      "text": "Vamos lá, turma"
    },
    {
      "start": 402.13,
      "end": 404.98,
      "text": "Mais uma soltadinha"
    },
    {
      "start": 404.98,
      "end": 409.71,
      "text": "Até agora não perdi nenhum chicotinho"
    },
    {
      "start": 409.71,
      "end": 411.31,
      "text": "Tô achando isso demais"
    },
    {
      "start": 411.31,
      "end": 416.49,
      "text": "Soltei pertinho das pedras de novo"
    },
    {
      "start": 416.49,
      "end": 417.57,
      "text": "Ó, que nem eu falo"
    },
    {
      "start": 417.57,
      "end": 418.73,
      "text": "Quando a onda vem aqui, ó"
    },
    {
      "start": 418.73,
      "end": 420.77,
      "text": "Eu afrouxo a vara, ó"
    },
    {
      "start": 420.77,
      "end": 424.11,
      "text": "Não fico esticando a linha direto"
    },
    {
      "start": 424.11,
      "end": 425.87,
      "text": "Eu deixo sempre a linha um pouco mais solta mesmo"
    },
    {
      "start": 425.87,
      "end": 428.98,
      "text": "Isso evita bastante que o chumbo corra no fundo"
    },
    {
      "start": 428.98,
      "end": 429.76,
      "text": "E que engate a linha"
    },
    {
      "start": 429.76,
      "end": 434.2,
      "text": "Deixa sempre a linha meio embarrigadinha"
    },
    {
      "start": 434.2,
      "end": 437.92,
      "text": "E aqui eu também tô usando uma linha fina, né"
    },
    {
      "start": 437.92,
      "end": 438.88,
      "text": "Apesar do chumbo ser leve"
    },
    {
      "start": 438.88,
      "end": 440.14,
      "text": "Mas a linha fina"
    },
    {
      "start": 440.14,
      "end": 442.14,
      "text": "Acaba tendo bem pouco atrito com a correnteza aí"
    },
    {
      "start": 442.14,
      "end": 444.24,
      "text": "E a maré também agora tá bem fraquinha"
    },
    {
      "start": 444.24,
      "end": 445.18,
      "text": "Isso é muito importante"
    },
    {
      "start": 445.18,
      "end": 456.0,
      "text": "É"
    },
    {
      "start": 456.0,
      "end": 458.02,
      "text": "Tava demorando"
    },
    {
      "start": 458.02,
      "end": 462.24,
      "text": "Tava demorando pra ele aparecer"
    },
    {
      "start": 462.24,
      "end": 465.22,
      "text": "Aí, galera"
    },
    {
      "start": 465.22,
      "end": 466.08,
      "text": "Ó, o baiacuzinho"
    },
    {
      "start": 466.08,
      "end": 468.29,
      "text": "Só pra comer nossa pernada"
    },
    {
      "start": 468.29,
      "end": 471.39,
      "text": "Imaginei que era ele quando bateu ali já"
    },
    {
      "start": 471.39,
      "end": 472.33,
      "text": "Tipo da batida"
    },
    {
      "start": 472.33,
      "end": 475.24,
      "text": "Aí, turmada"
    },
    {
      "start": 475.24,
      "end": 476.88,
      "text": "Vai lá, baiacuzinho"
    },
    {
      "start": 476.88,
      "end": 478.53,
      "text": "Põe-se embora"
    },
    {
      "start": 478.53,
      "end": 480.77,
      "text": "Isso tem muito aqui nas pedras também, galera"
    },
    {
      "start": 480.77,
      "end": 484.81,
      "text": "Aí, galera"
    },
    {
      "start": 484.81,
      "end": 485.61,
      "text": "Ó, o Fabiano ali, ó"
    },
    {
      "start": 485.61,
      "end": 487.23,
      "text": "O Fabiano já pegou uns dois roubalinhos"
    },
    {
      "start": 487.23,
      "end": 491.52,
      "text": "Agora vamos ver se é roubalo"
    },
    {
      "start": 491.52,
      "end": 491.9,
      "text": "O que que é?"
    },
    {
      "start": 491.98,
      "end": 492.78,
      "text": "Opa, bateu aqui também"
    },
    {
      "start": 492.78,
      "end": 495.0,
      "text": "Ai, caramba"
    },
    {
      "start": 495.0,
      "end": 495.98,
      "text": "Aí, ó"
    },
    {
      "start": 495.98,
      "end": 497.06,
      "text": "Mais um roubalinho, moçada"
    },
    {
      "start": 497.06,
      "end": 497.7,
      "text": "Olha lá, o Fabiano"
    },
    {
      "start": 497.7,
      "end": 500.12,
      "text": "E eu engatei pela primeira vez"
    },
    {
      "start": 500.12,
      "end": 501.54,
      "text": "E o peixe tá fisgado aqui, galera"
    },
    {
      "start": 501.54,
      "end": 505.44,
      "text": "Torcendo pra que o peixinho"
    },
    {
      "start": 505.44,
      "end": 508.1,
      "text": "Consiga me soltar da pedra"
    },
    {
      "start": 508.1,
      "end": 509.92,
      "text": "Feva, né?"
    },
    {
      "start": 511.75,
      "end": 513.35,
      "text": "Aí, o Fabiano mandou o pevinho pra vida"
    },
    {
      "start": 513.35,
      "end": 516.76,
      "text": "Tentar dar uma estilingadinha"
    },
    {
      "start": 516.76,
      "end": 528.51,
      "text": "É"
    },
    {
      "start": 528.51,
      "end": 529.37,
      "text": "Foi embora"
    },
    {
      "start": 529.37,
      "end": 529.99,
      "text": "Estourou"
    },
    {
      "start": 529.99,
      "end": 534.87,
      "text": "Estourou, pesada"
    },
    {
      "start": 534.87,
      "end": 538.61,
      "text": "Cortou na pedra aí"
    },
    {
      "start": 538.61,
      "end": 545.94,
      "text": "Vamos lá, turma"
    },
    {
      "start": 545.94,
      "end": 547.62,
      "text": "Arremessei um pouquinho mais fora agora"
    },
    {
      "start": 547.62,
      "end": 549.2,
      "text": "Pra ver"
    },
    {
      "start": 549.2,
      "end": 553.24,
      "text": "Passeado"
    },
    {
      "start": 553.24,
      "end": 554.64,
      "text": "Tô fazendo vários testes aí"
    },
    {
      "start": 554.64,
      "end": 556.08,
      "text": "Tentando pegar essas caras fevas"
    },
    {
      "start": 556.08,
      "end": 557.98,
      "text": "Se alguém tiver alguma dica"
    },
    {
      "start": 557.98,
      "end": 559.34,
      "text": "Deixa nos comentários aí, moçada"
    },
    {
      "start": 559.34,
      "end": 560.68,
      "text": "Dica de maré"
    },
    {
      "start": 560.68,
      "end": 561.16,
      "text": "Lua"
    },
    {
      "start": 561.16,
      "end": 562.52,
      "text": "Que elas costumam pegar mais"
    },
    {
      "start": 562.52,
      "end": 564.34,
      "text": "E aqui tem muita coisa"
    },
    {
      "start": 564.34,
      "end": 565.46,
      "text": "Só eu não vejo ninguém"
    },
    {
      "start": 565.46,
      "end": 566.66,
      "text": "Pegar elas aqui"
    },
    {
      "start": 566.66,
      "end": 569.33,
      "text": "Então eu quis vir fazer esse teste aí"
    },
    {
      "start": 569.33,
      "end": 570.97,
      "text": "Pra ver se conseguimos arrancar umazinha"
    },
    {
      "start": 570.97,
      "end": 571.41,
      "text": "Pelo menos"
    },
    {
      "start": 571.41,
      "end": 573.29,
      "text": "Turma"
    },
    {
      "start": 573.29,
      "end": 574.53,
      "text": "Vocês não conseguem ver"
    },
    {
      "start": 574.53,
      "end": 575.63,
      "text": "Eu acho na pedra ali, ó"
    },
    {
      "start": 575.63,
      "end": 576.47,
      "text": "Paraty"
    },
    {
      "start": 576.47,
      "end": 577.47,
      "text": "Bastante paraty"
    },
    {
      "start": 577.47,
      "end": 578.67,
      "text": "Não sei se tá dando pra ver"
    },
    {
      "start": 578.67,
      "end": 579.49,
      "text": "Por causa dos reflexos"
    },
    {
      "start": 579.49,
      "end": 580.83,
      "text": "Mas lá embaixo, moçada"
    },
    {
      "start": 580.83,
      "end": 582.25,
      "text": "Tem cada carapeba"
    },
    {
      "start": 582.25,
      "end": 583.51,
      "text": "Que elas passam ali"
    },
    {
      "start": 583.51,
      "end": 584.69,
      "text": "O prateadão grandão"
    },
    {
      "start": 584.69,
      "end": 585.83,
      "text": "Cada uma"
    },
    {
      "start": 585.83,
      "end": 586.43,
      "text": "Lá tem uns paraty"
    },
    {
      "start": 586.43,
      "end": 587.85,
      "text": "Em cima daquela pedrinha da esquerda"
    },
    {
      "start": 587.85,
      "end": 589.49,
      "text": "Mas olha que eu arremessei aqui"
    },
    {
      "start": 589.49,
      "end": 590.49,
      "text": "Eu soltei em cima de uma pedra"
    },
    {
      "start": 590.49,
      "end": 590.81,
      "text": "Aqui, ó"
    },
    {
      "start": 590.81,
      "end": 591.87,
      "text": "Ao redor dessa pedra"
    },
    {
      "start": 591.87,
      "end": 592.71,
      "text": "Passa cada uma"
    },
    {
      "start": 592.71,
      "end": 593.17,
      "text": "Que medo"
    },
    {
      "start": 593.17,
      "end": 596.74,
      "text": "É só as grandonas, turma"
    },
    {
      "start": 596.74,
      "end": 596.94,
      "text": "Ó"
    },
    {
      "start": 596.94,
      "end": 598.16,
      "text": "Peixinho batendo aqui"
    },
    {
      "start": 598.16,
      "end": 615.59,
      "text": "Aí, moçada"
    },
    {
      "start": 615.59,
      "end": 615.95,
      "text": "Ó"
    },
    {
      "start": 615.95,
      "end": 617.65,
      "text": "Aí, ó"
    },
    {
      "start": 617.65,
      "end": 620.43,
      "text": "A primeirazinha veio"
    },
    {
      "start": 620.43,
      "end": 622.17,
      "text": "Mas é uma pequenininha, galera"
    },
    {
      "start": 622.17,
      "end": 622.41,
      "text": "Ó"
    },
    {
      "start": 622.41,
      "end": 624.25,
      "text": "É esse peixe que eu tô procurando"
    },
    {
      "start": 624.25,
      "end": 625.41,
      "text": "Só que as grandonas, galera"
    },
    {
      "start": 625.41,
      "end": 626.51,
      "text": "Tem cada uma aqui"
    },
    {
      "start": 626.51,
      "end": 627.93,
      "text": "Que é um tilapão"
    },
    {
      "start": 627.93,
      "end": 628.91,
      "text": "Aí, ó"
    },
    {
      "start": 628.91,
      "end": 629.69,
      "text": "Pequenininha veio"
    },
    {
      "start": 629.69,
      "end": 630.92,
      "text": "Vai lá"
    },
    {
      "start": 630.92,
      "end": 632.1,
      "text": "Vai pra vida, garoto"
    },
    {
      "start": 632.1,
      "end": 633.86,
      "text": "Eu quero"
    },
    {
      "start": 633.86,
      "end": 636.04,
      "text": "As irmãs mais velhas"
    },
    {
      "start": 636.04,
      "end": 638.07,
      "text": "Jogar lá de novo"
    },
    {
      "start": 638.07,
      "end": 638.73,
      "text": "Eu tenho jogado um pouquinho"
    },
    {
      "start": 638.73,
      "end": 639.53,
      "text": "Mais fora agora"
    },
    {
      "start": 639.53,
      "end": 642.55,
      "text": "Vamos ver"
    },
    {
      "start": 642.55,
      "end": 644.03,
      "text": "Vamos ver se lá fora"
    },
    {
      "start": 644.03,
      "end": 646.2,
      "text": "Quem sabe elas peguem"
    },
    {
      "start": 646.2,
      "end": 648.72,
      "text": "Aí, a nossa primeira"
    },
    {
      "start": 648.72,
      "end": 670.7,
      "text": "Olha aqui, turma"
    },
    {
      "start": 670.7,
      "end": 672.67,
      "text": "Olha aí, turma"
    },
    {
      "start": 672.67,
      "end": 678.74,
      "text": "Quem é que veio no camarão morto?"
    },
    {
      "start": 679.12,
      "end": 679.34,
      "text": "Ó"
    },
    {
      "start": 679.34,
      "end": 681.42,
      "text": "O balinho, galera"
    },
    {
      "start": 681.42,
      "end": 683.54,
      "text": "Vambora, garoto"
    },
    {
      "start": 683.54,
      "end": 688.7,
      "text": "E aí"
    },
    {
      "start": 688.7,
      "end": 689.3,
      "text": "Tchau"
    },
    {
      "start": 689.64,
      "end": 690.42,
      "text": "Tchau"
    },
    {
      "start": 690.42,
      "end": 691.3,
      "text": "Tchau"
    },
    {
      "start": 691.3,
      "end": 691.38,
      "text": "Tchau"
    },
    {
      "start": 691.38,
      "end": 691.42,
      "text": "Tchau"
    },
    {
      "start": 691.42,
      "end": 691.72,
      "text": "Tchau"
    }
