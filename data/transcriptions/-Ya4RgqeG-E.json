      "text": "Mas..."
    },
    {
      "start": 1013.5,
      "end": 1014.04,
      "text": "Está difícil."
    },
    {
      "start": 1014.14,
      "end": 1015.6,
      "text": "Começo de pescaria é assim mesmo, né?"
    },
    {
      "start": 1016.65,
      "end": 1017.91,
      "text": "É esses vídeos aí."
    },
    {
      "start": 1019.68,
      "end": 1023.29,
      "text": "Vocês viram que o primeiro vídeo já tinha pouco peixe."
