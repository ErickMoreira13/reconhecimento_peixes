    {
      "start": 1060.41,
      "end": 1061.21,
      "text": "Abraço para vocês."
    },
    {
      "start": 1062.64,
      "end": 1064.26,
      "text": "Pessoal que não é inscrito."
    },
    {
      "start": 1064.34,
      "end": 1065.88,
      "text": "Eu estive olhando lá essa semana."
    },
    {
      "start": 1068.08,
      "end": 1071.82,
      "text": "Mais de 70% do pessoal que assiste não é inscrito, galera."
    },
    {
      "start": 1073.14,
      "end": 1074.78,
      "text": "Não atrapalha nada se inscrever no canal."
    },
    {
      "start": 1074.94,
      "end": 1076.1,
      "text": "Tem um vídeo por semana."
    },
    {
      "start": 1076.26,
      "end": 1078.02,
      "text": "Então não fica mandando nada."
    },
    {
      "start": 1078.18,
      "end": 1079.7,
      "text": "A gente não tem exceção de saco."
