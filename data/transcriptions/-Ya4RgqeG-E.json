      "start": 839.68,
      "end": 840.72,
      "text": "Baile do Piauçu."
    },
    {
      "start": 844.09,
      "end": 844.73,
      "text": "Olha aí, galera."
    },
    {
      "start": 846.88,
      "end": 847.6,
      "text": "É osso, hein?"
    },
    {
      "start": 850.34,
      "end": 851.66,
      "text": "Desde as seis da manhã."
    },
    {
      "start": 851.66,
      "end": 854.0,
      "text": "Longe de casa para caramba."
    },
    {
      "start": 854.44,
      "end": 858.64,
      "text": "Para esperar puxar um bendito de um Piauçu."
    },
    {
      "start": 860.59,
      "end": 861.73,
      "text": "Eu não ia pescar aqui."
    },
    {
      "start": 862.47,
      "end": 864.67,
      "text": "O lugar que a gente ia pescar está fechado."
    },
    {
      "start": 864.75,
      "end": 865.75,
      "text": "Não deixaram pescar lá."
    },
    {
      "start": 866.88,
      "end": 868.14,
      "text": "Aí eu consegui esse lugar aqui."
    },
    {
      "start": 868.18,
      "end": 870.2,
      "text": "Um amigo me trouxe aí."
    },
    {
      "start": 871.92,
      "end": 872.58,
      "text": "E vocês viram aí."
    },
    {
      "start": 872.64,
      "end": 874.94,
      "text": "Puxou até agora esse Piauçu."
    },
    {
      "start": 875.48,
      "end": 875.8,
      "text": "Só."
    },
    {
      "start": 876.36,
      "end": 877.02,
      "text": "Uma piranha."
    },
    {
      "start": 878.65,
      "end": 879.71,
      "text": "E era um peixe bonito, hein?"
    },
    {
      "start": 879.71,
      "end": 882.01,
      "text": "Pena que a gente não conhece o lugar."
    },
    {
      "start": 882.23,
      "end": 884.37,
      "text": "Agora o cara me falou que aqui é cheio de raiz embaixo."
    },
    {
      "start": 885.01,
      "end": 886.85,
      "text": "Se fisgar aqui tem que correr para lá."
    },
    {
      "start": 887.59,
      "end": 888.35,
      "text": "Para tentar tirar."
    },
    {
      "start": 890.27,
      "end": 890.91,
      "text": "Agora é tentar."
    },
    {
      "start": 891.37,
      "end": 891.81,
      "text": "Agora são..."
    },
    {
      "start": 892.41,
      "end": 893.09,
      "text": "Vê que horas são?"
    },
    {
      "start": 896.78,
      "end": 897.98,
      "text": "Três e meia da tarde."
    },
    {
      "start": 898.6,
      "end": 898.82,
      "text": "Entendeu?"
    },
    {
      "start": 898.82,
      "end": 901.87,
      "text": "Puxou um Piauçu."
    },
    {
      "start": 901.87,
      "end": 904.15,
      "text": "Um Piauçu."
    },
    {
      "start": 904.15,
      "end": 905.65,
      "text": "Vamos esperar mais um pouco aí, né?"
    },
    {
      "start": 906.59,
      "end": 907.13,
      "text": "Quem sabe."
    },
    {
      "start": 909.38,
      "end": 909.88,
      "text": "Torce aí."
    },
    {
      "start": 910.56,
      "end": 912.5,
      "text": "Torce para nós aí ver se sai mais isso."
    },
    {
      "start": 913.08,
      "end": 931.68,
      "text": "Uma puxada."
    },
    {
      "start": 931.84,
      "end": 934.78,
      "text": "Mas eu não sei se não era piranha."
    },
    {
      "start": 935.2,
      "end": 935.92,
      "text": "Mas..."
    },
    {
      "start": 935.92,
      "end": 936.42,
      "text": "Bati."
