      "text": "E deixando o seu like."
    },
    {
      "start": 1042.71,
      "end": 1046.0,
      "text": "Mesmo que esses vídeos que não tem muito peixe."
    },
    {
      "start": 1046.08,
      "end": 1047.04,
      "text": "Mas pescaria é assim mesmo."
    },
    {
      "start": 1047.12,
      "end": 1047.82,
      "text": "Vocês sabem disso."
    },
    {
      "start": 1048.66,
      "end": 1050.4,
      "text": "A hora que começar a sair vai ter peixe."
    },
    {
      "start": 1050.46,
      "end": 1051.36,
      "text": "Vai ter Pia Para."
