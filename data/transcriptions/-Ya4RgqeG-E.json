      "text": "Entendeu?"
    },
    {
      "start": 1080.65,
      "end": 1082.85,
      "text": "Então se inscreve no canal lá."
    },
    {
      "start": 1082.89,
      "end": 1083.69,
      "text": "Se você que gostou."
