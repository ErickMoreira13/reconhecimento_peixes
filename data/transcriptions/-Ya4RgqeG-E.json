    },
    {
      "start": 937.14,
      "end": 939.75,
      "text": "Não deu certo."
    },
    {
      "start": 940.25,
      "end": 943.78,
      "text": "Não é aquela descida de peixe grande, hein?"
    },
    {
      "start": 947.91,
      "end": 948.85,
      "text": "Tem mais 20 minutos."
    },
    {
      "start": 949.27,
      "end": 965.15,
      "text": "Vai começar a arrumar as coisas para ir embora."
    },
    {
      "start": 965.29,
      "end": 966.78,
      "text": "Porque..."
    },
    {
      "start": 966.78,
      "end": 967.86,
      "text": "Longe de casa."
    },
    {
      "start": 968.84,
      "end": 970.72,
      "text": "Galera, eu estou perto de Santa Maria da Serra."
    },
    {
      "start": 972.86,
      "end": 973.9,
      "text": "Saí cedinho."
    },
    {
      "start": 975.28,
      "end": 976.14,
      "text": "Cheguei e comecei a pescar."
    },
    {
      "start": 976.22,
      "end": 977.26,
      "text": "Acho que era umas 6 e meia."
    },
    {
      "start": 979.07,
      "end": 979.77,
      "text": "Pouca ação."
    },
    {
      "start": 979.87,
      "end": 981.69,
      "text": "Mas pouca, pouca, pouca ação."
    },
    {
      "start": 983.88,
      "end": 984.24,
      "text": "Vocês viram."
    },
    {
      "start": 984.3,
      "end": 985.18,
      "text": "O rapaz lá pegou..."
    },
    {
      "start": 985.18,
      "end": 987.16,
      "text": "Estava ali pegou um Piauçu também."
    },
    {
      "start": 987.68,
      "end": 988.6,
      "text": "Acabou escapando."
    },
    {
      "start": 988.66,
      "end": 989.58,
      "text": "Entrou na raiz também."
    },
    {
      "start": 991.86,
      "end": 992.9,
      "text": "E eu fisguei aquele..."
    },
    {
      "start": 992.9,
      "end": 993.94,
      "text": "Olha, era grande o Piauçu."
    },
    {
      "start": 993.96,
      "end": 994.5,
      "text": "É um Piauçu, viu, galera."
    },
    {
      "start": 995.85,
      "end": 996.95,
      "text": "Era um Piauçu bonito."
    },
    {
      "start": 998.63,
      "end": 999.47,
      "text": "Tem mais 20 minutos."
    },
    {
      "start": 999.55,
      "end": 999.93,
      "text": "Quem sabe."
    },
    {
      "start": 1001.9,
