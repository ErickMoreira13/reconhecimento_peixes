    },
    {
      "start": 1026.85,
      "end": 1028.72,
      "text": "Mas o que vai fazer, né?"
    },
    {
      "start": 1029.4,
      "end": 1029.82,
      "text": "É assim."
    },
    {
      "start": 1029.82,
      "end": 1030.54,
      "text": "Começo é assim."
    },
    {
      "start": 1030.66,
      "end": 1031.42,
      "text": "Rio sujo."
