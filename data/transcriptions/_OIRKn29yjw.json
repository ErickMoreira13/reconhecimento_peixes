    {
      "start": 845.28,
      "end": 847.46,
      "text": "Nove e trinta e sete."
    },
    {
      "start": 847.46,
      "end": 848.46,
      "text": "Encontramos Renan."
    },
    {
      "start": 848.46,
      "end": 851.78,
      "text": "Ele falou que tava tendo umas ações do tucunaré."
    },
    {
      "start": 851.78,
      "end": 858.1,
      "text": "Vamos bater um pouco de tucunaré nesse espraiado que tem o drop."
    },
    {
      "start": 858.1,
      "end": 860.1,
      "text": "Meu pai também tá ali com o Rafa."
    },
    {
