      "end": 501.71,
      "text": "Eles são avexados, viu?"
    },
    {
      "start": 502.09,
      "end": 503.09,
      "text": "Hoje está bom, viu?"
    },
    {
      "start": 503.71,
      "end": 506.11,
      "text": "Hoje está bom para eles."
    },
    {
      "start": 506.43,
      "end": 506.87,
      "text": "Joga."
    },
    {
      "start": 506.87,
      "end": 508.98,
      "text": "Ele já pega, louco."
    },
    {
      "start": 510.82,
      "end": 511.52,
      "text": "Bora lá de novo."
    },
    {
      "start": 523.68,
      "end": 524.06,
      "text": "Vai."
    },
    {
      "start": 525.4,
      "end": 529.48,
      "text": "Quero que gaste um pialvar aqui para ver a tacada dele."
    },
    {
      "start": 529.96,
      "end": 544.23,
      "text": "Vou fazer uma pureza bem aqui agora."
    },
    {
      "start": 544.95,
      "end": 546.29,
      "text": "Tem um chumbinho a chumbar dele."
    },
    {
      "start": 546.47,
      "end": 547.49,
      "text": "Essa rachadinha."
    },
    {
      "start": 550.71,
      "end": 553.85,
      "text": "Eu vou só aprontar aqui com isso."
    },
    {
      "start": 559.81,
      "end": 561.45,
      "text": "Eu sei que essa linha aqui não vai aguentar."
    },
    {
      "start": 564.21,
      "end": 565.13,
      "text": "O que eu achei aqui?"
    },
    {
      "start": 565.13,
      "end": 566.45,
      "text": "Um mendei uma na outra."
    },
    {
      "start": 567.42,
      "end": 568.28,
      "text": "Só para ver, né?"
    },
    {
      "start": 569.64,
      "end": 570.52,
      "text": "Bora lá, né, galera?"
    },
    {
      "start": 570.62,
      "end": 570.88,
      "text": "De novo."
    },
    {
      "start": 583.96,
      "end": 585.08,
      "text": "Olha o meu tio que pegou ali, pessoal."
    },
    {
      "start": 585.08,
      "end": 587.52,
      "text": "Bora filmar ele pegando esse aí."
    },
    {
      "start": 594.86,
      "end": 595.12,
      "text": "Olha aí."
    },
    {
      "start": 595.46,
      "end": 596.14,
      "text": "Pialvara."
    },
    {
      "start": 596.38,
      "end": 596.86,
      "text": "Pialvara."
    },
    {
      "start": 600.86,
      "end": 601.1,
      "text": "Olha."
    },
    {
      "start": 601.44,
      "end": 602.14,
      "text": "Na linha de mão."
    },
    {
      "start": 608.63,
      "end": 608.93,
      "text": "Olha aí."
    },
    {
      "start": 611.48,
      "end": 613.12,
      "text": "Ah, moleque, velho."
    },
    {
      "start": 615.95,
      "end": 619.18,
      "text": "Na maceota."
    },
    {
      "start": 622.76,
      "end": 623.08,
      "text": "Olha aí."
    },
    {
      "start": 623.56,
      "end": 624.27,
      "text": "Olha o bichão."
    },
    {
      "start": 625.69,
      "end": 626.29,
      "text": "Eu do tamanho."
    },
    {
      "start": 626.73,
      "end": 627.19,
      "text": "Olha, olha."
    },
    {
      "start": 627.45,
      "end": 628.07,
      "text": "Era para esconder."
    },
    {
      "start": 628.07,
      "end": 629.17,
      "text": "Rapaz, foi."
    },
    {
      "start": 630.17,
      "end": 630.57,
      "text": "Pronto."
    },
    {
      "start": 630.57,
      "end": 632.39,
      "text": "É, ia saltar mesmo, né?"
    },
    {
      "start": 632.45,
      "end": 633.61,
      "text": "Eu já ia saltar."
    },
    {
      "start": 633.69,
      "end": 634.35,
      "text": "Nem esperou."
    },
    {
      "start": 634.37,
      "end": 635.91,
      "text": "Mas deu uma pressa demais."
    },
    {
      "start": 637.91,
      "end": 639.33,
      "text": "Aê, vasqueira."
    }
  ],
