      "end": 1240.8,
      "text": "Eu peguei cinco."
    },
    {
      "start": 1241.02,
      "end": 1242.78,
      "text": "E o meu amigo Vinícius pegou cinco também."
    },
    {
      "start": 1243.14,
      "end": 1243.96,
      "text": "Graças a Deus."
    },
    {
      "start": 1244.2,
      "end": 1245.08,
      "text": "A pescaria foi boa."
    },
    {
      "start": 1246.85,
      "end": 1249.23,
      "text": "Curte, comenta aí, tá?"
    },
    {
      "start": 1249.33,
      "end": 1250.95,
      "text": "Se inscreva no canal, nos ajude, tá?"
    },
    {
      "start": 1251.96,
      "end": 1252.46,
      "text": "E é isso aí."
    },
    {
      "start": 1252.56,
      "end": 1253.64,
      "text": "Que Deus abençoe a todos."
    },
    {
      "start": 1253.74,
      "end": 1254.32,
      "text": "Até a próxima."
    },
    {
      "start": 1254.68,
      "end": 1255.8,
      "text": "Finalizando essa pescaria."
    },
    {
      "start": 1255.92,
