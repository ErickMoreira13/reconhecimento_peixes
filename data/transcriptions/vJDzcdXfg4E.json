      "text": "Tchau."
    },
    {
      "start": 1256.56,
      "end": 1311.9,
      "text": "Aqui, pessoal."
    },
    {
      "start": 1312.3,
      "end": 1313.42,
      "text": "Finalizando o vídeo aqui, ó."
    },
    {
      "start": 1313.42,
      "end": 1315.18,
      "text": "Essa foi a peixada de hoje."
    },
    {
      "start": 1315.7,
