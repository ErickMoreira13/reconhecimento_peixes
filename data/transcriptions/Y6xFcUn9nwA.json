      "text": "O canal no YouTube"
    },
    {
      "start": 788.61,
      "end": 789.27,
      "text": "Porque é isso aí"
    },
    {
      "start": 789.27,
      "end": 790.65,
      "text": "Que faz com que a gente"
    },
    {
      "start": 790.65,
