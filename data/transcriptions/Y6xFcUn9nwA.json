      "start": 701.61,
      "end": 702.91,
      "text": "Dá aquela mergulhada"
    },
    {
      "start": 702.91,
      "end": 703.91,
      "text": "Tu falou que não tem coragem"
    },
    {
      "start": 703.91,
      "end": 705.15,
      "text": "Mas comigo você vai"
    },
    {
      "start": 705.15,
      "end": 706.23,
      "text": "Se eu te levar, você vai"
    },
    {
      "start": 706.23,
      "end": 707.15,
      "text": "Beleza, irmão?"
    },
    {
      "start": 707.49,
      "end": 708.15,
      "text": "Um abração"
    },
    {
      "start": 708.15,
      "end": 709.43,
      "text": "Cláudio Oliveira"
    },
    {
      "start": 709.43,
      "end": 710.11,
      "text": "E Adriana"
    },
    {
      "start": 710.11,
      "end": 710.61,
      "text": "Valeu?"
    },
    {
      "start": 710.97,
      "end": 711.29,
      "text": "Abração"
    },
    {
      "start": 711.29,
      "end": 713.19,
      "text": "Pessoal, espero que vocês tenham gostado, hein?"
    },
    {
      "start": 713.63,
      "end": 714.91,
      "text": "Tá aí o salve pra toda a galera"
    },
    {
      "start": 714.91,
      "end": 717.03,
      "text": "Não sei se eu dei o salve pra todo mundo"
    },
    {
      "start": 717.03,
      "end": 718.93,
      "text": "Queria dar o salve pra todos"
    },
    {
      "start": 718.93,
      "end": 720.43,
      "text": "Foi o máximo que eu pude fazer"
    },
    {
      "start": 720.43,
      "end": 722.61,
      "text": "Mas eu vou fazer melhor, tá, pessoal?"
    },
    {
      "start": 722.95,
      "end": 723.87,
      "text": "Eu vou anotando aí"
    },
    {
      "start": 723.87,
      "end": 725.77,
      "text": "Toda vez que eu ver o comentário"
    },
    {
      "start": 725.77,
      "end": 726.91,
      "text": "Eu pego o caderno"
    },
    {
      "start": 726.91,
      "end": 727.45,
      "text": "Eu vou anotando"
    },
    {
      "start": 727.45,
      "end": 729.05,
      "text": "Pra não deixar passar batido, tá, pessoal?"
    },
    {
      "start": 729.39,
      "end": 731.23,
      "text": "E os demais que eu não citei, pessoal"
    },
    {
      "start": 731.23,
      "end": 732.59,
      "text": "Foi por causa disso"
    },
    {
      "start": 732.59,
      "end": 736.13,
      "text": "Eu já tinha feito essa listinha, né?"
    },
    {
      "start": 736.63,
      "end": 737.87,
      "text": "Mas eu quero deixar bem claro"
    },
    {
      "start": 737.87,
      "end": 739.25,
      "text": "Lembra aí, pessoal"
    },
    {
      "start": 739.25,
      "end": 739.83,
      "text": "No comentário"
    },
    {
      "start": 739.83,
      "end": 740.19,
      "text": "Lembra aí"
    },
    {
      "start": 740.19,
      "end": 740.63,
      "text": "Cadê André?"
    },
    {
      "start": 740.71,
      "end": 741.21,
      "text": "Meu salve"
    },
    {
      "start": 741.21,
      "end": 741.91,
      "text": "Que o Foto não falou"
    },
    {
      "start": 741.91,
      "end": 742.79,
      "text": "Meu salve e tal"
    },
    {
      "start": 742.79,
      "end": 744.57,
      "text": "Eu vou deixar o salve pra toda a galera"
    },
    {
      "start": 744.57,
      "end": 746.03,
      "text": "Não quero deixar ninguém de fora, tá, pessoal?"
    },
    {
      "start": 746.39,
      "end": 747.13,
      "text": "Um abração aí"
    },
    {
      "start": 747.13,
      "end": 748.93,
      "text": "Espero que vocês tenham gostado desse vídeo aí"
    },
    {
      "start": 748.93,
      "end": 749.85,
      "text": "Tá, pessoal?"
    },
    {
      "start": 750.21,
      "end": 750.87,
      "text": "Agora a gente está"
    },
    {
      "start": 750.87,
      "end": 752.31,
      "text": "Num período de chuva ainda"
    },
    {
      "start": 752.31,
      "end": 753.63,
      "text": "Não sei que milagre de Deus, né?"
    },
    {
      "start": 754.15,
      "end": 755.15,
      "text": "Deu uns verãozinhos aí"
    },
    {
      "start": 755.15,
      "end": 755.81,
      "text": "Uns dias de sol"
    },
    {
      "start": 755.81,
      "end": 757.19,
      "text": "E aí eu aproveitei pra gente"
    },
    {
      "start": 757.19,
      "end": 758.61,
      "text": "Trazer mais um vídeo novo pra vocês"
    },
    {
      "start": 758.61,
      "end": 761.33,
      "text": "E não se esquece"
    },
    {
      "start": 761.33,
      "end": 762.39,
      "text": "Pra quem não é inscrito"
    },
    {
      "start": 762.39,
      "end": 764.13,
      "text": "Se inscreve aí, pessoal"
    },
    {
      "start": 764.13,
      "end": 765.59,
      "text": "Pro vovô e pra vovó aí"
    },
    {
      "start": 765.59,
      "end": 767.51,
      "text": "Que não sabe se inscrever"
    },
    {
      "start": 767.51,
      "end": 770.27,
      "text": "Pede aí pro filho, pro neto"
    },
    {
      "start": 770.27,
      "end": 771.37,
      "text": "Inscreve aí, pô"
    },
    {
      "start": 771.37,
      "end": 772.83,
      "text": "No canal do André Oliveira aí"
    },
    {
      "start": 772.83,
      "end": 773.49,
      "text": "Pesca Sub"
    },
    {
      "start": 773.49,
      "end": 774.43,
      "text": "Beleza?"
    },
    {
      "start": 775.07,
      "end": 776.19,
      "text": "Se inscreve aí, moçada"
    },
    {
      "start": 776.19,
      "end": 776.97,
      "text": "Deixa o like"
    },
    {
      "start": 776.97,
      "end": 778.13,
      "text": "Muito importante, pessoal"
    },
    {
      "start": 778.13,
      "end": 779.71,
      "text": "Tem muita gente vendo os vídeos"
    },
    {
      "start": 779.71,
      "end": 780.75,
      "text": "Mas não está deixando o like"
    },
    {
      "start": 780.75,
