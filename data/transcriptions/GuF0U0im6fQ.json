      "start": 652.13,
      "end": 653.41,
      "text": "Ó"
    },
    {
      "start": 653.41,
      "end": 654.76,
      "text": "Tá vendo?"
    },
    {
      "start": 655.53,
      "end": 656.07,
      "text": "Por quê?"
    },
    {
      "start": 656.79,
      "end": 658.33,
      "text": "Porque você segura o peixe na ceva"
    },
    {
      "start": 658.33,
      "end": 660.69,
      "text": "Se você parar de jogar trato"
    },
    {
      "start": 660.69,
      "end": 662.36,
      "text": "Ó"
    },
    {
      "start": 662.36,
      "end": 665.68,
      "text": "Tô com esse lapinho aí já, ó"
    },
    {
      "start": 665.68,
      "end": 666.96,
      "text": "Moeu toda a cara"
    },
    {
      "start": 666.96,
      "end": 675.12,
      "text": "Se você não jogar um tratinho na água"
    },
    {
      "start": 675.12,
      "end": 676.62,
      "text": "O peixe come ali o que tem e vaza"
    },
    {
      "start": 676.62,
      "end": 676.98,
      "text": "Entendeu?"
    },
    {
      "start": 677.62,
      "end": 679.2,
      "text": "Então é bom ter uma raçãozinha de coelho"
    },
    {
      "start": 679.2,
      "end": 681.62,
      "text": "Você ir jogando uns grãozinhos de vez em quando"
    },
    {
      "start": 681.62,
      "end": 683.34,
      "text": "Vai segurando o peixe"
    },
    {
      "start": 683.34,
      "end": 736.35,
      "text": "Aí, meus amigos, ó"
    },
    {
      "start": 736.35,
      "end": 739.05,
      "text": "Olha aí que fim de tarde maravilhoso, ó"
    },
    {
      "start": 739.05,
      "end": 741.96,
      "text": "Água paradinha, ó"
    },
    {
      "start": 741.96,
      "end": 744.2,
      "text": "Joguei mais um tratinho na água aí"
    },
    {
      "start": 744.2,
      "end": 745.35,
      "text": "Ó"
    },
    {
      "start": 745.35,
      "end": 748.77,
      "text": "Vê se não, pega uma silapinha aí"
    },
    {
      "start": 748.77,
      "end": 749.07,
      "text": "Ó"
    },
    {
      "start": 749.07,
      "end": 752.69,
      "text": "A varona aqui já deu uma carregada bonita ali, ó"
    },
    {
      "start": 752.69,
      "end": 756.15,
      "text": "Ó"
    },
    {
      "start": 756.15,
      "end": 757.87,
      "text": "A boia também tá mexendo ali, ó"
    },
    {
      "start": 757.87,
      "end": 759.27,
      "text": "Tá vendo?"
    },
    {
      "start": 760.84,
      "end": 761.76,
      "text": "Joguei um tratinho aí"
    },
    {
      "start": 761.76,
      "end": 762.34,
      "text": "O peixe em coa"
    },
    {
      "start": 762.34,
      "end": 763.24,
      "text": "Ó"
    },
    {
      "start": 763.24,
      "end": 765.04,
      "text": "Perdi, você viu, né?"
    },
    {
      "start": 766.24,
      "end": 767.2,
      "text": "Perdi, moçada"
    },
    {
      "start": 767.2,
      "end": 769.3,
      "text": "Vamos ver aqui na boia"
    },
    {
      "start": 769.3,
      "end": 772.56,
      "text": "Na boia tem onde lá"
    },
    {
      "start": 772.56,
      "end": 785.36,
      "text": "Tá puxando na..."
    },
    {
      "start": 785.36,
      "end": 786.86,
      "text": "O peixe tá puxando bem na massa"
    },
    {
      "start": 786.86,
      "end": 788.16,
      "text": "A massa aqui"
    },
    {
      "start": 788.16,
      "end": 849.84,
      "text": "Aí, moçada"
    },
    {
      "start": 849.84,
      "end": 853.94,
      "text": "Pescaria de tilápia aqui finalizada"
    },
    {
      "start": 853.94,
      "end": 858.27,
      "text": "Agora nós vamos atrás das traírias"
    },
    {
      "start": 858.27,
      "end": 864.34,
      "text": "Beleza?"
    },
    {
      "start": 865.88,
      "end": 866.56,
      "text": "Separei..."
    },
    {
      "start": 866.56,
      "end": 868.56,
      "text": "Separei três tilapinhas boas pra me levar"
    },
    {
      "start": 868.56,
      "end": 870.5,
      "text": "Os pequenininhos, sortei tudo"
    },
    {
      "start": 870.5,
      "end": 879.34,
      "text": "Agora vamos mudar a traia"
    },
    {
      "start": 879.34,
      "end": 881.78,
      "text": "E vamos atrás das traírias"
    },
    {
      "start": 881.78,
      "end": 883.74,
      "text": "Beleza?"
    },
    {
      "start": 891.96,
      "end": 892.8,
      "text": "Dá uma olhada nisso"
    },
    {
      "start": 892.8,
      "end": 902.58,
      "text": "Mostrar a tilapinha pra você ali"
    },
    {
      "start": 902.58,
      "end": 903.24,
      "text": "Chegando ali"
    },
    {
      "start": 903.24,
      "end": 906.28,
      "text": "Então se você gostou do vídeo"
    },
    {
      "start": 906.28,
      "end": 909.44,
      "text": "Deixa um joinha pra nós"
    },
    {
      "start": 909.44,
      "end": 911.5,
      "text": "Compartilha, se inscreve"
    },
    {
      "start": 911.5,
      "end": 912.85,
      "text": "Beleza?"
    },
    {
      "start": 914.08,
      "end": 915.1,
      "text": "Pescar traírias agora"
    },
    {
      "start": 915.1,
      "end": 920.72,
      "text": "Peguei três, seu Zé"
    },
    {
      "start": 920.72,
      "end": 921.34,
      "text": "Seu Zé aí, ó"
    },
    {
      "start": 921.34,
      "end": 927.29,
      "text": "Pegou isso?"
    },
    {
      "start": 931.4,
      "end": 932.06,
      "text": "Seu Zé"
    },
    {
      "start": 932.06,
      "end": 935.95,
      "text": "Aqui, ó"
    },
    {
      "start": 935.95,
      "end": 940.07,
      "text": "Guardar as coisas aqui"
    },
    {
      "start": 940.07,
      "end": 949.33,
      "text": "Guardar essas coisas aqui"
    },
    {
      "start": 949.33,
      "end": 962.27,
      "text": "E vamos atrás das traírias"
    },
    {
      "start": 962.27,
      "end": 972.42,
      "text": "Deixa eu mostrar"
    },
    {
      "start": 972.42,
      "end": 980.88,
      "text": "Separei três tilapinhas nesse porte aqui, ó"
    },
    {
      "start": 980.88,
