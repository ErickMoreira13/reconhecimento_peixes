    {
      "start": 42.6,
      "end": 45.71,
      "text": "É um pouco para cima do salto do Guamirangue"
    },
    {
      "start": 45.71,
      "end": 48.21,
      "text": "Para quem pesca aqui para a região de Guaramirim"
