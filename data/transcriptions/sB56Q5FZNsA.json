    {
      "start": 23.58,
      "end": 29.36,
      "text": "Enchei o carro aqui, ó o riozão"
    },
    {
      "start": 29.36,
      "end": 32.44,
      "text": "Só que eu tenho que ter um barranquinho meio lazarento aqui"
    },
    {
      "start": 32.44,
      "end": 35.41,
      "text": "Baita de um barranco, o pessoal joga lixo aqui, ó"
    },
    {
      "start": 35.41,
      "end": 38.7,
      "text": "Eita, caramba, é foda, né?"
    },
    {
      "start": 38.96,
      "end": 39.5,
      "text": "Fazer o que?"
    },
    {
      "start": 40.98,
      "end": 42.6,
      "text": "Olha o rio, aqui o rio fica bem grande"
