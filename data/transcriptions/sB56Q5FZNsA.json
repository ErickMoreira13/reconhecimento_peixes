    {
      "start": 88.85,
      "end": 90.59,
      "text": "Na verdade eu quero pescar aqui um pouquinho"
    },
    {
      "start": 90.59,
      "end": 91.41,
      "text": "Para eu pegar os lambari"
    },
    {
      "start": 91.41,
      "end": 94.25,
      "text": "Depois eu vou descer mais ali para a leão que pega mesmo"
    },
    {
      "start": 94.25,
      "end": 94.79,
      "text": "Vou lá pular"
    },
    {
      "start": 94.79,
      "end": 97.76,
      "text": "Porém que tem uma balsa tirando areia aqui"
