      "text": "E tem o adesivo no canal aqui, ó."
    },
    {
      "start": 271.69,
      "end": 272.55,
      "text": "Não pode faltar, né?"
    },
    {
      "start": 272.77,
      "end": 272.97,
      "text": "Ó."
    },
    {
      "start": 273.65,
      "end": 274.37,
      "text": "Ó, toma."
    },
    {
      "start": 275.07,
      "end": 275.63,
      "text": "Com certeza."
    },
    {
      "start": 275.63,
      "end": 277.26,
      "text": "E ó o riozão."
    },
    {
      "start": 277.36,
      "end": 278.58,
      "text": "Vamos ver se pegou um pouquinho d'água."
    },
    {
      "start": 279.93,
      "end": 281.11,
      "text": "Chuva bastante deu."
    },
    {
      "start": 281.21,
      "end": 285.13,
      "text": "Agora, pra pegar água mesmo, precisa chover muito lá pra cima, né?"
    },
    {
      "start": 285.15,
      "end": 287.11,
      "text": "Pra tudo poder pegar um volume."
    },
    {
      "start": 287.25,
      "end": 288.89,
      "text": "Mas sempre dá uma mexidinha assim."
    },
    {
      "start": 289.65,
      "end": 289.87,
      "text": "É."
    },
    {
      "start": 290.03,
      "end": 291.49,
      "text": "Parece que não pegou muita água, né?"
    },
    {
      "start": 292.64,
      "end": 293.26,
      "text": "Mas tá bom."
    },
    {
      "start": 293.6,
      "end": 295.1,
      "text": "Pelo menos dá uma mexida na água."
    },
    {
      "start": 295.2,
      "end": 296.22,
      "text": "Dá uma oxigenada."
    },
    {
      "start": 297.32,
      "end": 297.72,
      "text": "E bora."
    },
    {
      "start": 297.96,
      "end": 298.28,
      "text": "Espera."
    },
    {
      "start": 298.28,
      "end": 299.88,
      "text": "Compramos o gás."
    },
    {
      "start": 300.2,
      "end": 300.58,
      "text": "Compraram?"
    },
    {
      "start": 300.68,
      "end": 301.06,
      "text": "Comprou."
    },
    {
      "start": 301.32,
      "end": 301.68,
      "text": "Aí, ó."
    },
    {
      "start": 302.04,
      "end": 302.86,
      "text": "Minhoca, moçada."
    },
    {
      "start": 302.94,
      "end": 304.24,
      "text": "Agora sim não vai garantir o peixe."
    },
    {
      "start": 304.9,
      "end": 305.9,
      "text": "Os meninos tão rodando."
    },
    {
      "start": 306.0,
      "end": 306.42,
      "text": "E agora vai?"
    },
    {
      "start": 307.46,
      "end": 308.6,
      "text": "Bora, bora, bora, bora."
    },
    {
      "start": 308.66,
      "end": 310.58,
      "text": "Passaram poção que hoje rende, hein."
    },
    {
      "start": 311.4,
      "end": 313.02,
      "text": "Pegar o frito, hein, da janta, hein."
    },
    {
      "start": 313.5,
      "end": 314.36,
      "text": "Eu garanto um."
    },
    {
      "start": 314.96,
      "end": 315.9,
      "text": "Fez se vira do resto."
    },
    {
      "start": 316.04,
      "end": 317.98,
      "text": "Eu vou esperar um pouco até o ano passado, né?"
    },
    {
      "start": 318.34,
      "end": 324.12,
      "text": "Eu vim baixando agora."
    },
    {
      "start": 324.38,
      "end": 325.1,
      "text": "Baixou firme?"
    },
    {
      "start": 325.1,
      "end": 330.69,
      "text": "Rapaz, não tá pego, não, né?"
    },
    {
      "start": 331.39,
      "end": 332.19,
      "text": "Parece que tá pego."
    },
    {
      "start": 332.55,
      "end": 333.42,
      "text": "Tá quieto."
    },
    {
      "start": 333.82,
      "end": 334.04,
      "text": "Hã?"
    },
    {
      "start": 336.06,
      "end": 336.94,
      "text": "Será, meu Deus?"
    },
    {
      "start": 338.32,
      "end": 340.4,
      "text": "Será que o Ananinha vai tirar o dedo na pescaria?"
    },
    {
      "start": 340.66,
      "end": 341.62,
      "text": "Pegou mesmo, Ananinha."
    },
    {
      "start": 341.86,
      "end": 342.32,
      "text": "Poxa."
    },
    {
      "start": 342.62,
      "end": 342.9,
      "text": "Hã?"
    },
    {
      "start": 343.98,
      "end": 344.42,
      "text": "Pegou?"
    },
    {
      "start": 344.76,
      "end": 345.04,
      "text": "Cabeça."
    },
    {
      "start": 345.7,
      "end": 346.1,
      "text": "Pegou."
    },
    {
      "start": 346.16,
      "end": 346.8,
      "text": "Olha lá, olha lá."
    },
    {
      "start": 347.14,
      "end": 347.96,
      "text": "Pegou, moço."
    },
    {
      "start": 348.18,
      "end": 349.24,
      "text": "Ah, rapaz."
    },
    {
      "start": 350.06,
      "end": 350.86,
      "text": "Mandi, moço."
    },
    {
      "start": 351.66,
      "end": 352.64,
      "text": "Dá ele aqui, dá ele aqui."
    },
    {
      "start": 354.0,
      "end": 354.64,
      "text": "Ninguinho, ó."
    },
    {
      "start": 356.01,
      "end": 356.77,
      "text": "Fala que não."
    },
    {
      "start": 357.77,
      "end": 359.51,
      "text": "Aqui você tá no barco do Jumim Zanqueta."
    },
    {
      "start": 359.77,
      "end": 360.99,
      "text": "Aqui pega mesmo."
    },
    {
      "start": 362.18,
      "end": 362.98,
      "text": "Aqui é boca quente."
    },
    {
      "start": 363.7,
      "end": 364.54,
      "text": "Vou soltar, hein, Ananinha."
    },
    {
      "start": 365.0,
      "end": 365.94,
      "text": "Aí, moçada, ó."
    },
    {
      "start": 366.14,
      "end": 366.54,
      "text": "Mandizinho."
    },
    {
      "start": 366.6,
      "end": 367.04,
      "text": "Tá filmando?"
    },
    {
      "start": 367.08,
      "end": 368.22,
      "text": "Tá piscando, luzinha vermelha?"
    },
    {
      "start": 369.02,
      "end": 369.36,
      "text": "Aí, ó."
    },
    {
      "start": 369.7,
      "end": 370.06,
      "text": "Mandizinho."
    },
    {
      "start": 370.82,
      "end": 371.68,
      "text": "Vai pra vida, bichinho."
    },
    {
      "start": 372.12,
      "end": 372.98,
      "text": "Foi que nem uma flecha."
    },
    {
      "start": 373.58,
      "end": 374.64,
      "text": "Já está aqui, pega mais, Ananinha."
    },
    {
      "start": 374.7,
      "end": 374.96,
      "text": "Pera aí."
    },
    {
      "start": 375.32,
      "end": 376.58,
      "text": "Seguimos aqui, rapaziada, ó."
    },
    {
      "start": 377.78,
      "end": 378.84,
      "text": "Já mudamos de ponto."
    },
    {
      "start": 378.94,
      "end": 380.42,
      "text": "Já encostamos perto do barranco."
    },
    {
      "start": 381.33,
      "end": 382.73,
      "text": "Famoso barranco vermelho, né?"
    },
    {
      "start": 383.45,
      "end": 385.73,
      "text": "Que costuma sair peixe, mas..."
    },
    {
      "start": 385.73,
      "end": 387.93,
      "text": "Já apoiamos ali pra cima, ali pra baixo."
    },
    {
      "start": 388.23,
      "end": 388.59,
      "text": "Aqui."
    },
    {
      "start": 389.82,
      "end": 390.42,
      "text": "E..."
    },
    {
      "start": 390.42,
      "end": 391.92,
      "text": "Tá bem parado."
    },
    {
      "start": 392.02,
      "end": 393.6,
      "text": "Agora tá dando uma desliscadinha aqui."
    },
    {
      "start": 393.7,
      "end": 396.54,
      "text": "Uma hora ou outra dá uma cutucadinha, mas bem..."
    },
    {
      "start": 396.54,
      "end": 398.1,
      "text": "Peixinho pequeno, mordendo a isca."
    },
    {
      "start": 398.74,
      "end": 399.74,
      "text": "Eu tô com tuvira."
    },
    {
      "start": 400.52,
      "end": 401.46,
      "text": "Natália com lambarii."
    },
    {
      "start": 401.52,
      "end": 402.38,
      "text": "Ananinha com lambarii."
    },
    {
      "start": 403.56,
      "end": 403.92,
      "text": "Vamos ver."
    },
    {
      "start": 403.92,
      "end": 405.42,
      "text": "Se sai alguma..."
    },
    {
      "start": 405.42,
      "end": 408.06,
      "text": "Se sai alguma coisa daqui a pouco."
    },
    {
      "start": 408.81,
      "end": 410.43,
      "text": "Até agora é só um mandio da Ananinha."
    },
    {
      "start": 410.43,
      "end": 412.39,
      "text": "O Cast e o Luiz estão rodando lá em cima."
    },
    {
      "start": 412.39,
      "end": 416.64,
      "text": "Mas eu acho que não pegaram nada, porque não ouvi nenhum piteiro ainda."
    },
    {
      "start": 417.57,
      "end": 418.77,
      "text": "E o dia tá indo embora."
    },
    {
      "start": 419.31,
      "end": 421.52,
      "text": "Como eu falei, a pescaria é bem curta, né?"
    },
    {
      "start": 422.55,
      "end": 422.89,
      "text": "Mas..."
    },
    {
      "start": 422.89,
      "end": 424.41,
      "text": "Tamo tentando."
    },
    {
      "start": 426.19,
      "end": 427.21,
      "text": "Se sair vocês vão ver aí."
    },
    {
      "start": 427.79,
      "end": 428.65,
      "text": "Moçada do céu."
    },
    {
      "start": 428.73,
      "end": 429.91,
      "text": "Deu uma mandada aqui agora."
    },
    {
      "start": 430.83,
      "end": 431.73,
      "text": "Nós tava distraído."
    },
    {
      "start": 431.97,
      "end": 432.73,
      "text": "Ó, ó, ó."
    },
    {
      "start": 432.73,
      "end": 434.74,
      "text": "Aí, Ananinha."
    },
    {
      "start": 435.62,
      "end": 436.88,
      "text": "Eu travei, Ananinha."
    },
    {
      "start": 436.96,
      "end": 437.8,
      "text": "Não sei você, viu?"
    },
    {
      "start": 439.06,
      "end": 440.62,
      "text": "Eu não sei você, Ananinha."
    },
    {
      "start": 441.04,
      "end": 442.24,
      "text": "Porque aqui, moço..."
    },
    {
      "start": 442.24,
      "end": 444.66,
      "text": "Aqui não é afisgado, não, moço."
    },
    {
      "start": 445.83,
      "end": 446.19,
      "text": "Piranha."
    },
    {
      "start": 446.67,
      "end": 448.33,
      "text": "Ah, um olho gordo da bexiga."
    },
    {
      "start": 449.27,
      "end": 449.67,
      "text": "Piranha."
    },
    {
      "start": 449.91,
      "end": 450.93,
      "text": "Olha aí o tamanho da piranha."
    },
    {
      "start": 451.49,
      "end": 453.41,
      "text": "Ó, ó o tamanho do barbado."
    },
    {
      "start": 453.75,
      "end": 455.33,
      "text": "Ó o tamanho do barbadão, meu amigo."
    },
    {
      "start": 455.81,
      "end": 457.25,
      "text": "Ó o tamanho do barbadão, meu amigo."
    },
    {
      "start": 457.75,
      "end": 459.15,
      "text": "Ó o tamanho do barbadão, meu amigo."
    },
    {
      "start": 460.27,
      "end": 461.61,
      "text": "Fih, aqui pega mesmo."
    },
    {
      "start": 461.61,
      "end": 463.43,
      "text": "Aí, ô, os pés de rato."
    },
    {
      "start": 463.83,
      "end": 465.23,
      "text": "Nossa, os pés de rato."
    },
    {
      "start": 466.16,
      "end": 466.68,
      "text": "Aí, ó."
    },
    {
      "start": 467.58,
      "end": 468.12,
      "text": "Ih, rapaz."
    },
    {
      "start": 468.18,
      "end": 469.6,
      "text": "Olha a mordida que ele tomou, Natália."
    },
    {
      "start": 470.84,
      "end": 471.32,
      "text": "Cicatrizando, ó."
    },
    {
      "start": 471.32,
      "end": 471.5,
      "text": "É."
    },
    {
      "start": 472.7,
      "end": 473.72,
      "text": "Demorou, mas saiu, ó."
    },
    {
      "start": 473.96,
      "end": 475.28,
      "text": "Se tem o pequeno, tem o grande, né?"
    },
    {
      "start": 475.88,
      "end": 478.42,
      "text": "E olha a mordida que ele tomou aqui, mas já, ó, cicatrizado."
    },
    {
      "start": 478.8,
      "end": 479.04,
      "text": "É."
    },
    {
      "start": 479.84,
      "end": 480.46,
      "text": "Vai embora."
    },
    {
      "start": 480.72,
      "end": 481.42,
      "text": "Vai embora, bicho."
    },
    {
      "start": 481.66,
      "end": 482.8,
      "text": "Eita, ignorância."
    },
    {
      "start": 482.92,
      "end": 483.84,
      "text": "Saiu que nem uma flecha."
    },
    {
      "start": 484.84,
      "end": 485.94,
      "text": "Bora que agora nem morre, hein?"
    },
    {
      "start": 486.8,
      "end": 487.36,
      "text": "Pega mais."
    },
    {
      "start": 489.54,
      "end": 490.0,
      "text": "Aí, pessoal."
    },
    {
      "start": 490.06,
      "end": 490.84,
      "text": "Agora vamos rodar."
    },
    {
      "start": 491.04,
      "end": 492.52,
      "text": "Natália tá com boia, Ananinhas."
    },
    {
      "start": 492.52,
      "end": 493.94,
      "text": "Sem castor."
    },
    {
      "start": 494.04,
      "end": 500.37,
      "text": "E eu com castor, três opções pro peixe escolher a melhor delas."
    },
    {
      "start": 501.01,
      "end": 501.83,
      "text": "Ó a boia, Natália."
    },
    {
      "start": 502.47,
      "end": 503.39,
      "text": "Ó a boia, Natália."
    },
    {
      "start": 504.09,
      "end": 505.23,
      "text": "Deve ser a tuvira, né?"
    },
    {
      "start": 507.08,
      "end": 507.56,
      "text": "É."
    },
    {
      "start": 509.6,
      "end": 509.82,
      "text": "Bom."
    },
    {
      "start": 510.2,
      "end": 510.58,
      "text": "Vamos ver."
    },
    {
      "start": 510.78,
      "end": 511.58,
      "text": "Saiu alguma coisa."
    },
    {
      "start": 511.68,
      "end": 513.12,
      "text": "No poção, não puxa."
    },
    {
      "start": 513.16,
      "end": 513.58,
      "text": "Não puxa."
    },
    {
      "start": 513.64,
      "end": 515.16,
      "text": "Aquele barbadinho, mandido, Ananinhas."
    },
    {
      "start": 515.24,
      "end": 515.5,
      "text": "E só."
    },
    {
      "start": 516.08,
      "end": 517.0,
      "text": "Castelo e Luiz tão ali."
    },
    {
      "start": 517.76,
      "end": 518.22,
      "text": "Vamos ver."
    },
    {
      "start": 518.4,
      "end": 519.3,
      "text": "Se sai alguma coisa."
    },
    {
      "start": 519.46,
      "end": 520.22,
      "text": "Tomara que saia."
    },
    {
      "start": 520.38,
      "end": 520.68,
      "text": "Vamos ver."
    },
    {
      "start": 520.68,
      "end": 524.83,
      "text": "Ah, piranha."
    },
    {
      "start": 530.16,
      "end": 531.28,
      "text": "Tá mordendo aqui, moçomar."
    },
    {
      "start": 531.36,
      "end": 532.04,
      "text": "Acho que é piranha."
    },
    {
      "start": 541.38,
      "end": 542.26,
      "text": "Tá rodando aqui."
    },
    {
      "start": 542.34,
      "end": 542.64,
      "text": "Vamos ver."
    },
    {
      "start": 543.53,
      "end": 544.53,
      "text": "Se entra alguma coisa."
    },
    {
      "start": 546.07,
      "end": 547.57,
      "text": "Ele pega, puxa e solta."
    },
    {
      "start": 548.54,
      "end": 548.8,
      "text": "Ó."
    },
    {
      "start": 549.85,
      "end": 550.97,
      "text": "Pega, puxa e solta."
    },
    {
      "start": 551.25,
      "end": 551.47,
      "text": "Ó."
    },
    {
      "start": 551.93,
      "end": 552.37,
      "text": "Ó."
    },
    {
      "start": 554.0,
      "end": 555.92,
      "text": "Deve ser peixinho pequeno com a isca na boca."
    },
    {
      "start": 556.14,
      "end": 556.34,
      "text": "Ó."
    },
    {
      "start": 556.56,
      "end": 556.72,
      "text": "Ó."
    },
    {
      "start": 557.18,
      "end": 559.41,
      "text": "Tem que esperar."
    },
    {
      "start": 560.46,
      "end": 561.32,
      "text": "Esperar engolir."
    },
    {
      "start": 561.82,
      "end": 563.2,
      "text": "Às vezes o grande vem e junta."
    },
    {
      "start": 564.06,
      "end": 564.32,
      "text": "Ó."
    },
    {
      "start": 564.32,
      "end": 565.7,
      "text": "Ai, ai, meu Deus do céu."
    },
    {
      "start": 568.15,
      "end": 568.45,
      "text": "Ó."
    },
    {
      "start": 568.45,
      "end": 569.91,
      "text": "Que caramba."
    },
    {
      "start": 571.9,
      "end": 573.02,
      "text": "Deve ser barbado."
    },
    {
      "start": 573.12,
      "end": 574.6,
      "text": "Se fosse piranha, já tinha devorado."
    },
    {
      "start": 575.12,
      "end": 575.32,
      "text": "Ó."
    },
    {
      "start": 577.0,
      "end": 578.08,
      "text": "Vou deixar aí."
    },
    {
      "start": 578.24,
      "end": 579.42,
      "text": "Às vezes o grande vem e pega."
    },
    {
      "start": 580.1,
      "end": 580.3,
      "text": "Ó."
    },
    {
      "start": 580.78,
      "end": 583.31,
      "text": "E a vontade de fisgar."
    },
    {
      "start": 584.21,
      "end": 584.43,
      "text": "Ó."
    },
    {
      "start": 585.13,
      "end": 585.39,
      "text": "Ó."
    },
    {
      "start": 586.66,
      "end": 587.44,
      "text": "Correndo pro lado."
    },
    {
      "start": 588.37,
      "end": 589.63,
      "text": "Vou mandar o braço."
    },
    {
      "start": 591.42,
      "end": 591.94,
      "text": "Nossa."
    },
    {
      "start": 593.47,
      "end": 593.71,
      "text": "Aí."
    },
    {
      "start": 594.17,
      "end": 594.61,
      "text": "Peguei."
    },
    {
      "start": 595.44,
      "end": 595.96,
      "text": "Peguei."
    },
    {
      "start": 595.96,
      "end": 596.24,
      "text": "Ó."
    },
    {
      "start": 602.17,
