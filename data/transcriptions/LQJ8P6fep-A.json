      "text": "Rancho do Pescador Viagens"
    },
    {
      "start": 676.02,
      "end": 677.54,
      "text": "Vai trazer você"
    },
    {
      "start": 677.54,
      "end": 679.14,
      "text": "Numa estrutura"
    },
    {
      "start": 679.14,
      "end": 679.84,
      "text": "Olha"
    },
    {
      "start": 679.84,
      "end": 681.16,
      "text": "É uma estrutura simples"
    },
    {
      "start": 681.16,
      "end": 682.66,
      "text": "Mas ela é justinha"
    },
    {
      "start": 682.66,
      "end": 685.06,
      "text": "O atendimento é de primeira"
    },
    {
      "start": 685.06,
      "end": 687.56,
      "text": "E aqui realmente pega muito peixe"
    },
    {
      "start": 687.56,
      "end": 689.58,
      "text": "E a grande vantagem"
    },
    {
      "start": 689.58,
      "end": 690.48,
      "text": "Aqui no barco"
    },
    {
      "start": 690.48,
      "end": 691.42,
      "text": "Dona Socorro"
    },
    {
      "start": 691.42,
      "end": 692.5,
      "text": "Você pode pescar"
    },
    {
      "start": 692.5,
      "end": 693.26,
      "text": "Tucunaré"
    },
    {
      "start": 693.26,
      "end": 694.88,
      "text": "Essa semana a gente pegou"
    },
    {
      "start": 694.88,
      "end": 695.98,
      "text": "Muito pirarucu"
    },
    {
      "start": 695.98,
      "end": 697.84,
      "text": "E também tem isso aqui"
    },
    {
      "start": 697.84,
      "end": 698.66,
      "text": "Pirarara"
    },
    {
      "start": 698.66,
      "end": 699.46,
      "text": "Piraíba"
    },
    {
      "start": 699.46,
      "end": 701.02,
      "text": "Aqui atende"
    },
    {
      "start": 701.02,
      "end": 701.78,
      "text": "Todo mundo"
    },
    {
      "start": 701.78,
      "end": 702.44,
      "text": "Tem peixe"
    },
    {
      "start": 702.44,
      "end": 704.14,
      "text": "Pra todos os gostos"
    },
    {
      "start": 704.14,
      "end": 705.08,
      "text": "Acabou não"
    },
    {
      "start": 705.08,
      "end": 706.2,
      "text": "Vamos ajeitar"
    },
    {
      "start": 706.2,
      "end": 707.76,
      "text": "Colocar a isca"
    },
    {
      "start": 707.76,
      "end": 708.84,
      "text": "Anzol na água"
    },
    {
      "start": 708.84,
      "end": 709.94,
      "text": "A gente vai sair"
    },
    {
      "start": 709.94,
      "end": 710.8,
      "text": "Pro intervalo"
    },
    {
      "start": 710.8,
      "end": 711.64,
      "text": "Mas daqui um pouquinho"
    },
    {
      "start": 711.64,
      "end": 712.62,
      "text": "A gente tá de volta"
