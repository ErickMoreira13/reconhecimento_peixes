    },
    {
      "start": 882.21,
      "end": 883.67,
      "text": "Jaú pintado e cachara"
    },
    {
      "start": 883.67,
      "end": 884.75,
      "text": "Usando pedaço de peixe"
    },
    {
      "start": 884.75,
      "end": 885.83,
      "text": "Já na Amazônia"
    },
    {
      "start": 885.83,
      "end": 886.53,
      "text": "Pedaço de peixe"
    },
    {
      "start": 886.53,
      "end": 887.21,
      "text": "É muito eficiente"
    },
    {
      "start": 887.21,
      "end": 887.93,
      "text": "Pra pirarara"
    },
    {
      "start": 887.93,
