    },
    {
      "start": 889.21,
      "end": 890.55,
      "text": "Piraíba"
    },
    {
      "start": 890.55,
      "end": 891.59,
      "text": "As diferenças aí"
    },
    {
      "start": 891.59,
      "end": 892.53,
      "text": "Já dei o recado"
    },
    {
      "start": 892.53,
      "end": 893.17,
      "text": "Pra vocês do canal"
    },
    {
      "start": 893.17,
      "end": 894.11,
      "text": "Espero que tenham gostado"
    },
    {
      "start": 894.11,
      "end": 894.73,
      "text": "Aqui do vídeo"
    },
    {
      "start": 894.73,
      "end": 896.01,
      "text": "Compartilhando"
    },
    {
      "start": 896.01,
      "end": 896.71,
      "text": "Se inscrevendo"
    },
    {
      "start": 896.71,
