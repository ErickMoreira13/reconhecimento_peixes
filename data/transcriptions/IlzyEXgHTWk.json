    },
    {
      "start": 864.45,
      "end": 865.55,
      "text": "Eu pego mais"
    },
    {
      "start": 865.55,
      "end": 867.79,
      "text": "Mas isso é um próximo vídeo"
    },
    {
      "start": 867.79,
      "end": 868.63,
      "text": "Tava beliscando ali"
    },
    {
      "start": 868.63,
      "end": 869.13,
      "text": "Minha outra vara"
    },
    {
      "start": 869.13,
      "end": 869.93,
      "text": "Que tava com ela na mão"
    },
    {
      "start": 869.93,
