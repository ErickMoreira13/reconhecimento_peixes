      "end": 844.65,
      "text": "Olha a boca do bicho"
    },
    {
      "start": 844.65,
      "end": 846.98,
      "text": "Tá aí amigos"
    },
    {
      "start": 846.98,
      "end": 848.5,
      "text": "Vou soltar eles"
    },
    {
      "start": 848.5,
      "end": 849.34,
      "text": "Ele"
    },
    {
      "start": 849.34,
      "end": 852.36,
      "text": "Que o vídeo é curtinho"
    },
    {
      "start": 852.36,
      "end": 853.26,
      "text": "O pessoal gosta de"
    },
    {
      "start": 853.26,
      "end": 854.38,
      "text": "Papuft"
    },
    {
      "start": 854.38,
      "end": 856.36,
      "text": "Então quem ganhou o campeonato"
    },
    {
      "start": 856.36,
      "end": 859.06,
      "text": "Quem apostou na isca branca"
    },
    {
      "start": 859.06,
      "end": 859.94,
      "text": "Ganhou a isca branca"
    },
    {
      "start": 859.94,
      "end": 860.84,
      "text": "Sabe o que eu vou fazer?"
    },
    {
      "start": 860.96,
      "end": 862.2,
      "text": "Vou continuar pescando aqui"
    },
    {
      "start": 862.2,
