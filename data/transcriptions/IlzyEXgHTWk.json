    },
    {
      "start": 876.73,
      "end": 877.25,
      "text": "Pedal de peixe"
    },
    {
      "start": 877.25,
      "end": 878.57,
      "text": "Embora no Pantanal"
    },
    {
      "start": 878.57,
      "end": 879.31,
      "text": "Você tem uma ideia"
    },
    {
      "start": 879.31,
      "end": 879.93,
      "text": "Como é diferente"
