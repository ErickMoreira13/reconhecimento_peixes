    {
      "start": 272.25,
      "end": 272.87,
      "text": "Tá bom?"
    },
    {
      "start": 273.75,
      "end": 274.45,
      "text": "Acompanha a gente"
    },
    {
      "start": 274.45,
      "end": 275.29,
      "text": "Deus abençoe a todos"
    },
    {
      "start": 275.29,
      "end": 276.55,
      "text": "Se você ainda não é inscrito"
    },
    {
      "start": 276.55,
      "end": 277.91,
      "text": "Se inscreva no canal"
    },
    {
      "start": 277.91,
      "end": 279.71,
      "text": "Porque aqui nós temos pescaria verdade"
    },
    {
      "start": 279.71,
      "end": 281.09,
      "text": "E conteúdo de qualidade"
    },
    {
      "start": 281.09,
      "end": 281.95,
      "text": "Tô por aqui, hein?"
    },
    {
      "start": 281.95,
      "end": 285.67,
      "text": "Tomei muita chuva, tá, gente?"
    },
    {
      "start": 285.87,
      "end": 287.13,
      "text": "Olha lá pra trás, como é que tá, ó"
