    {
      "start": 258.61,
      "end": 259.93,
      "text": "Pra ajudar as plantações"
    },
    {
      "start": 259.93,
      "end": 263.13,
      "text": "É bom pra prosperidade do povo, né?"
    },
    {
      "start": 263.13,
      "end": 265.55,
      "text": "E nós ficamos somente na ansiedade"
    },
    {
      "start": 265.55,
      "end": 266.39,
      "text": "Querendo pescar"
