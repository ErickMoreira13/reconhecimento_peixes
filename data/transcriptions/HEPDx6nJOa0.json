      "start": 311.76,
      "end": 314.57,
      "text": "Tá vendo?"
    },
    {
      "start": 316.23,
      "end": 317.71,
      "text": "Já tá na caixa, já, hein?"
    },
    {
      "start": 317.71,
      "end": 318.93,
      "text": "Já tá no máximo, já"
    },
    {
      "start": 318.93,
      "end": 321.55,
      "text": "Água muito barrenta, pessoal"
    },
    {
      "start": 321.55,
      "end": 323.27,
      "text": "Muito barrenta mesmo"
