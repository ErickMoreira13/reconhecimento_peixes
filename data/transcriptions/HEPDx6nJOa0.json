    {
      "start": 551.89,
      "end": 553.73,
      "text": "Tava na boquinha dela"
    },
    {
      "start": 553.73,
      "end": 566.74,
      "text": "Eu vou buscar ela"
    },
    {
      "start": 566.74,
      "end": 590.78,
      "text": "Gente do céu"
    },
    {
      "start": 590.78,
      "end": 591.76,
      "text": "Que tilápia bonita"
    },
    {
      "start": 591.76,
