      "start": 330.58,
      "end": 331.36,
      "text": "Ó"
    },
    {
      "start": 331.36,
      "end": 332.34,
      "text": "Tá vendo?"
    },
    {
      "start": 332.9,
      "end": 334.06,
      "text": "Ou que vai cair ainda"
    },
    {
      "start": 334.06,
      "end": 334.84,
      "text": "Então, pessoal"
    },
    {
      "start": 334.84,
      "end": 336.59,
      "text": "Fica ligado aí"
    },
    {
      "start": 336.59,
      "end": 338.81,
      "text": "Vou mostrar mais pra baixo aí"
    },
    {
      "start": 338.81,
      "end": 339.93,
      "text": "Como é que tá a Itapina"
    },
    {
      "start": 339.93,
      "end": 340.89,
      "text": "Tá bom?"
    },
    {
      "start": 341.11,
      "end": 342.19,
      "text": "Como é que tá a Fontenelle"
    },
    {
      "start": 342.19,
      "end": 343.89,
      "text": "Mas a água tá barrendo"
    },
    {
      "start": 343.89,
      "end": 356.12,
      "text": "Aí, meu povo"
    },
    {
      "start": 356.12,
      "end": 358.42,
      "text": "Eu tô aqui na ponte"
    },
    {
      "start": 358.42,
      "end": 359.98,
      "text": "Na fazenda Fontenelle, hein?"
    },
    {
      "start": 430.42,
      "end": 431.08,
      "text": "Tá aí, ó"
    },
    {
      "start": 431.08,
      "end": 434.71,
      "text": "Rio Doce"
    },
    {
      "start": 434.71,
      "end": 435.79,
      "text": "Fazenda Fontenelle"
    },
    {
      "start": 435.79,
      "end": 438.69,
      "text": "Aqui é o pesqueiro do Ingá"
    },
    {
      "start": 438.69,
      "end": 441.64,
      "text": "Ali é da Dona Virginia"
    },
    {
      "start": 441.64,
      "end": 446.48,
      "text": "Fazenda Fontenelle"
    },
    {
      "start": 446.48,
      "end": 449.27,
      "text": "E o bambuzal ali, ó"
    },
    {
      "start": 449.27,
      "end": 518.26,
      "text": "Tamanho dessa tilápia, gente"
    },
    {
      "start": 518.26,
      "end": 526.44,
      "text": "Ai, ai, ai"
    },
    {
      "start": 526.44,
      "end": 527.44,
      "text": "Perdi"
    },
    {
      "start": 527.44,
      "end": 528.44,
      "text": "Foi embora"
    },
    {
      "start": 528.44,
      "end": 533.31,
      "text": "É, gente"
    },
    {
      "start": 533.31,
      "end": 534.13,
      "text": "Falar pra você, hein?"
    },
    {
      "start": 537.82,
      "end": 538.86,
      "text": "Falar pra vocês, tá?"
    },
    {
      "start": 543.24,
      "end": 544.36,
      "text": "Se tem um ou tem mais, né?"
    },
    {
      "start": 544.44,
      "end": 544.66,
      "text": "Então"
    },
    {
      "start": 544.66,
      "end": 546.14,
      "text": "Bora partir pra cima"
    },
    {
      "start": 546.14,
      "end": 548.38,
      "text": "Caramba"
    },
    {
      "start": 548.38,
      "end": 550.13,
      "text": "Logo hoje"
    },
    {
      "start": 550.13,
      "end": 551.17,
      "text": "Que eu não trouxe"
    },
    {
      "start": 551.17,
      "end": 551.89,
      "text": "Meu passaguá"
