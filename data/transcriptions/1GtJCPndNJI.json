      "text": "Aí, ó."
    },
    {
      "start": 1134.04,
      "end": 1134.72,
      "text": "Faz, faz."
    },
    {
      "start": 1136.23,
      "end": 1137.09,
      "text": "Feito não, é costa."
    },
    {
      "start": 1137.17,
      "end": 1137.87,
      "text": "Treino de costa."
    },
    {
      "start": 1138.65,
      "end": 1139.31,
      "text": "Confundindo aqui."
    },
    {
      "start": 1139.53,
      "end": 1140.69,
      "text": "Tem que virar pra lá, ó."
    },
    {
      "start": 1140.71,
      "end": 1141.79,
      "text": "Treino de costas."
    },
    {
      "start": 1141.95,
      "end": 1142.29,
      "text": "Lá, ó."
    },
    {
      "start": 1144.58,
      "end": 1145.5,
      "text": "Olha lá o caminhonete lá, ó."
    },
    {
      "start": 1147.57,
      "end": 1149.39,
      "text": "Olha lá o porto, a caminhoneta."
    },
    {
      "start": 1149.53,
      "end": 1149.91,
      "text": "Tá lá."
    },
    {
      "start": 1153.94,
      "end": 1155.5,
      "text": "Agora eu tô remando vocês vindo."
    },
    {
      "start": 1156.16,
      "end": 1157.28,
      "text": "Olha lá o caminhonete lá."
    },
    {
      "start": 1157.36,
      "end": 1158.46,
      "text": "Não dá pra ver muito bem, mas tá lá."
    },
    {
      "start": 1158.46,
      "end": 1160.84,
      "text": "Eu dou duas e dá uma."
    },
    {
      "start": 1160.9,
      "end": 1161.14,
      "text": "Pera aí."
    },
    {
      "start": 1172.23,
      "end": 1173.17,
      "text": "Remar, uma e duas."
    },
    {
      "start": 1175.3,
      "end": 1175.98,
      "text": "Concentrado, hein?"
    },
    {
      "start": 1176.08,
      "end": 1177.22,
      "text": "É, é, alinhado."
    },
    {
      "start": 1177.3,
      "end": 1177.9,
      "text": "Isso."
    },
    {
      "start": 1182.34,
      "end": 1183.9,
      "text": "Equilíbrio, equilíbrio na remada."
    },
    {
      "start": 1184.1,
      "end": 1184.74,
      "text": "Tem que me apagar."
    },
    {
      "start": 1193.7,
      "end": 1194.22,
      "text": "Equilíbrio."
    },
    {
      "start": 1194.56,
      "end": 1195.06,
      "text": "Como é que é?"
    },
    {
      "start": 1195.44,
      "end": 1195.88,
      "text": "Sintonia."
    },
    {
      "start": 1195.88,
      "end": 1197.68,
      "text": "Sintonia."
    },
    {
      "start": 1197.68,
      "end": 1197.76,
      "text": "Sintonia."
    },
    {
      "start": 1199.84,
      "end": 1200.24,
      "text": "Sintonia."
    },
    {
      "start": 1200.36,
      "end": 1200.9,
      "text": "Vai chover, não?"
    },
    {
      "start": 1201.98,
      "end": 1203.38,
      "text": "Não vai chover, não, moço."
    },
    {
      "start": 1204.47,
      "end": 1205.15,
      "text": "Aonde você quer?"
    },
    {
      "start": 1205.95,
      "end": 1206.99,
      "text": "Vai chover mais pra lá, ó."
    },
    {
      "start": 1209.38,
      "end": 1210.52,
      "text": "Não vai chover, não, moço."
    },
    {
      "start": 1212.15,
      "end": 1212.91,
      "text": "Vai mais."
    },
    {
      "start": 1218.47,
      "end": 1221.13,
      "text": "Rapaz, se não tiver cachorro debaixo desses matos aqui, moço."
    },
    {
      "start": 1221.55,
      "end": 1221.69,
      "text": "Ó."
    },
    {
      "start": 1224.1,
      "end": 1224.88,
      "text": "Tá perto da árvore, lá."
    },
    {
      "start": 1229.74,
      "end": 1230.1,
      "text": "Será?"
    },
    {
      "start": 1230.1,
      "end": 1238.09,
      "text": "Não, não."
    },
    {
      "start": 1238.17,
      "end": 1239.21,
      "text": "Mas pode ir mais pra cá, sim, ó."
    },
    {
      "start": 1243.38,
      "end": 1243.98,
      "text": "Eu não sei..."
    },
    {
      "start": 1243.98,
      "end": 1247.56,
      "text": "Eu não sei se ele vai parar aqui na poita, pois é, porque não tem corredeira."
    },
    {
      "start": 1249.05,
      "end": 1250.03,
      "text": "Ai, que lugar top, bicho."
    },
    {
      "start": 1253.06,
      "end": 1253.6,
      "text": "Que bom, hein?"
    },
    {
      "start": 1254.74,
      "end": 1255.66,
      "text": "Mais ali, assim, ó."
    },
    {
      "start": 1255.66,
      "end": 1266.45,
      "text": "É, garotinha, a chuva veio mesmo."
    },
    {
      "start": 1266.97,
      "end": 1268.67,
      "text": "Olha aí, ó, meus remadores profissionais."
    },
    {
      "start": 1270.89,
      "end": 1272.21,
      "text": "A chuva veio mesmo, ó, o Daniel."
    },
    {
      "start": 1272.53,
      "end": 1273.27,
      "text": "Tá com frio, Daniel?"
    },
    {
      "start": 1274.48,
      "end": 1275.86,
      "text": "Eu tô com o joelho tremendo também, hein?"
    },
    {
      "start": 1277.92,
      "end": 1279.22,
      "text": "Ó lá, o barraco lá, lá."
    },
    {
      "start": 1279.34,
      "end": 1280.54,
      "text": "O carro tá lá, ó."
    },
    {
      "start": 1282.22,
      "end": 1283.74,
      "text": "Só me afina a força positiva."
    },
    {
      "start": 1283.82,
      "end": 1285.66,
      "text": "Um, dois, um, dois, um, dois."
    },
    {
      "start": 1286.12,
      "end": 1293.23,
      "text": "Coisa maciosa aqui pra não queimar mesmo."
    },
    {
      "start": 1294.15,
      "end": 1295.21,
      "text": "Ó, potência."
    },
    {
      "start": 1295.89,
      "end": 1296.57,
      "text": "Ah, potência."
    },
    {
      "start": 1298.5,
      "end": 1301.14,
      "text": "Não, eu tava aqui com remarca cadeirinho, tio."
    },
    {
      "start": 1301.14,
      "end": 1303.43,
      "text": "Nossa, que..."
    },
    {
      "start": 1303.43,
      "end": 1306.53,
      "text": "Eu joguei o braço lá pra pegar essa parte quebrou aqui do bicho que tá."
    },
    {
      "start": 1309.61,
      "end": 1310.51,
      "text": "Ah, a chuva tá parando, né?"
    },
    {
      "start": 1311.01,
      "end": 1311.73,
      "text": "Vamos voltar a pescar?"
    },
    {
      "start": 1312.33,
      "end": 1314.33,
      "text": "Todo moiado com frio agora, você tá doido."
    },
    {
      "start": 1314.35,
      "end": 1314.73,
      "text": "É doido, hein?"
    },
    {
      "start": 1315.45,
      "end": 1316.85,
      "text": "Ali é fundo, ali, ó, aquela beirada."
    },
    {
      "start": 1318.52,
      "end": 1320.28,
      "text": "É doido, é potência no rem, hein, menino?"
    },
    {
      "start": 1328.03,
      "end": 1328.91,
      "text": "Mostra o tamanho do rem."
    },
    {
      "start": 1331.21,
      "end": 1333.05,
      "text": "Quebrou no meio, pra fazer o quê, né?"
    },
    {
      "start": 1337.92,
      "end": 1341.84,
      "text": "Tá doido."
    },
    {
      "start": 1341.84,
      "end": 1348.34,
      "text": "É, que bom que o celular é prova d'água, né?"
    },
    {
      "start": 1349.18,
      "end": 1351.76,
      "text": "Nem te falo, eu não derrubei o celular dentro do viveiro lá no Guaporé."
    },
    {
      "start": 1351.82,
      "end": 1352.48,
      "text": "Eu tenho certeza."
    },
    {
      "start": 1352.48,
      "end": 1354.38,
      "text": "Ele caiu dentro do viveiro, cheio d'água."
    },
    {
      "start": 1354.54,
      "end": 1356.18,
      "text": "É, prova d'água mesmo?"
    },
    {
      "start": 1356.2,
      "end": 1360.1,
      "text": "É nada, eu tirei cinco segundos lá dentro d'água, é a regra dos cinco segundos."
    },
    {
      "start": 1360.54,
      "end": 1361.88,
      "text": "O meu caiu no banheiro da escola."
    },
    {
      "start": 1362.44,
      "end": 1363.96,
      "text": "Olha aí, ó, revelações, ó."
    },
    {
      "start": 1366.62,
      "end": 1367.62,
      "text": "Ó a Draga, ó a Draga."
    },
    {
      "start": 1374.66,
      "end": 1375.34,
      "text": "Tô te estressei."
    },
    {
      "start": 1376.08,
      "end": 1376.76,
      "text": "Eu, eu, eu."
    },
    {
      "start": 1377.12,
      "end": 1377.96,
      "text": "Pegar o rabi."
    },
    {
      "start": 1379.38,
      "end": 1380.18,
      "text": "Pegou não, pô."
    },
    {
      "start": 1381.16,
      "end": 1383.06,
      "text": "Só relu, a louca manetona."
    },
    {
      "start": 1384.39,
      "end": 1385.53,
      "text": "Você devolveu o tempo de Deus."
    },
    {
      "start": 1385.73,
      "end": 1421.08,
      "text": "Olha, Daniel."
    },
    {
      "start": 1424.08,
      "end": 1425.1,
      "text": "Confirmazinho, né?"
    },
    {
      "start": 1425.1,
      "end": 1426.18,
      "text": "Sei que queria ir embora, hein?"
    },
    {
      "start": 1428.43,
      "end": 1429.45,
      "text": "Pagando lá em cima."
    },
    {
      "start": 1429.93,
      "end": 1547.8,
      "text": "O Beto falou que vai ficar com os peixes."
    },
    {
      "start": 1548.18,
      "end": 1549.96,
      "text": "Mano, os peixes dele lá, ó."
    },
    {
      "start": 1551.58,
      "end": 1553.02,
      "text": "Deu bastante peixinha, mas olha só."
    },
    {
      "start": 1555.52,
      "end": 1556.88,
      "text": "Tá arrumando por ordem ainda, ó."
    },
    {
      "start": 1557.14,
      "end": 1557.32,
      "text": "Ó."
    },
    {
      "start": 1557.7,
      "end": 1559.07,
      "text": "Que pesca, moleque."
    },
    {
      "start": 1559.07,
      "end": 1559.29,
      "text": "Ó."
    },
    {
      "start": 1568.53,
      "end": 1569.65,
      "text": "É, nada."
    },
    {
      "start": 1569.65,
