      "start": 908.56,
      "end": 909.56,
      "text": "Olha o foco."
    },
    {
      "start": 909.56,
      "end": 910.56,
      "text": "É."
    },
    {
      "start": 910.56,
      "end": 911.56,
      "text": "Faltou show aí mesmo."
    },
    {
      "start": 911.56,
      "end": 912.56,
      "text": "Lá bem."
    },
    {
      "start": 912.56,
      "end": 914.78,
      "text": "Um."
    },
    {
      "start": 914.78,
      "end": 915.78,
      "text": "Só mergulhar mais."
    },
    {
      "start": 915.78,
      "end": 920.07,
      "text": "Você é louco, Max."
    },
    {
      "start": 920.07,
      "end": 921.07,
      "text": "Que delícia, velho."
    },
    {
      "start": 921.07,
      "end": 922.81,
      "text": "Acabou de temperar."
    },
    {
      "start": 922.81,
      "end": 924.94,
      "text": "Que delícia, nossa."
    },
    {
      "start": 924.94,
      "end": 926.94,
      "text": "Você deixa curtir mesmo o gelinho?"
    },
    {
      "start": 926.94,
      "end": 927.94,
      "text": "Hum."
    },
    {
      "start": 927.94,
      "end": 933.62,
      "text": "Cortou um golão, né?"
    },
    {
      "start": 939.72,
      "end": 941.4,
      "text": "Um golão pra vocês tudo aí, chanados."
    },
    {
      "start": 944.99,
      "end": 945.85,
      "text": "Acabou a conversa, parece."
    },
    {
      "start": 946.31,
      "end": 948.68,
      "text": "Tá conversando, parece que parou."
    },
    {
      "start": 951.26,
      "end": 951.98,
      "text": "Nossa senhora."
    },
    {
      "start": 956.73,
      "end": 962.09,
      "text": "Pia, a mulher está com fome."
    },
    {
      "start": 965.25,
      "end": 985.67,
      "text": "A pressão foi lá em cima."
    },
    {
      "start": 990.09,
      "end": 990.93,
      "text": "Vise, ele corre."
    },
    {
      "start": 994.69,
      "end": 997.39,
      "text": "Ele passa mal um trem desse aí, viu?"
    },
    {
      "start": 999.73,
      "end": 1000.53,
      "text": "Nossa senhora."
    },
    {
      "start": 1002.06,
      "end": 1004.1,
      "text": "Passarinho todo dia, ele vem de Itália, sabiazinha."
    },
    {
      "start": 1011.38,
      "end": 1011.78,
      "text": "Cada."
    },
    {
      "start": 1011.78,
      "end": 1014.28,
      "text": "Aí, os trem estão abastecidos, já comemos."
    },
    {
      "start": 1015.65,
      "end": 1016.99,
      "text": "Agora, aperta o botão."
    },
    {
      "start": 1018.82,
      "end": 1019.26,
      "text": "Puxa aqui."
    },
    {
      "start": 1025.45,
      "end": 1027.15,
      "text": "Ui, quase que vai minha vara pra dentro d'água."
    },
    {
      "start": 1027.67,
      "end": 1028.71,
      "text": "Rapaz do céu."
    },
    {
      "start": 1030.11,
      "end": 1032.05,
      "text": "Nós cortou um pedacinho."
    },
    {
      "start": 1032.55,
      "end": 1128.74,
      "text": "Tirado uma pescaria."
    },
    {
      "start": 1129.06,
      "end": 1129.7,
      "text": "Meu Deus do céu."
    },
    {
      "start": 1130.94,
      "end": 1131.78,
      "text": "Olha como é que tá as traias."
    },
    {
      "start": 1132.14,
      "end": 1136.1,
      "text": "Do sol."
    },
    {
      "start": 1140.26,
      "end": 1141.7,
      "text": "Se vira, se vira."
    },
    {
      "start": 1142.04,
      "end": 1144.22,
      "text": "Não tá com fome?"
    },
    {
      "start": 1145.48,
      "end": 1147.58,
      "text": "Ô meu Deus do céu, que canseira de remar."
    },
    {
      "start": 1151.97,
      "end": 1152.73,
      "text": "É, janta, é isso aí."
    },
    {
      "start": 1152.73,
      "end": 1159.48,
      "text": "É, tudo eu que bebi, né?"
    },
    {
      "start": 1159.56,
      "end": 1159.76,
      "text": "Olha lá."
    },
    {
      "start": 1159.86,
      "end": 1161.18,
      "text": "Só vai jogar uma latinha no meu caiaque."
    },
    {
      "start": 1163.34,
      "end": 1163.82,
      "text": "Olha aí."
    },
    {
      "start": 1165.48,
      "end": 1166.68,
      "text": "Vamos lá, quase isso aí, cara."
    },
    {
      "start": 1169.1,
      "end": 1169.66,
      "text": "Desenvolvimento."
    },
    {
      "start": 1171.48,
      "end": 1172.54,
      "text": "Olha o vídeo chegando na final."
    },
    {
      "start": 1174.58,
      "end": 1174.94,
      "text": "Cheinha."
    },
    {
      "start": 1175.88,
      "end": 1176.8,
      "text": "Lógico que eu quero."
    },
    {
      "start": 1177.63,
      "end": 1178.17,
      "text": "Não vou negar."
    },
    {
      "start": 1185.85,
      "end": 1186.47,
      "text": "É isso aí, galera."
    },
    {
      "start": 1187.21,
      "end": 1188.25,
      "text": "Obrigado por ter assistido aí."
    },
    {
      "start": 1189.1,
      "end": 1189.66,
      "text": "Tudo de bom."
    },
    {
      "start": 1190.34,
      "end": 1191.96,
      "text": "E até a próxima pescaria."
    },
    {
      "start": 1191.96,
      "end": 1193.14,
      "text": "Tchau, obrigado."
    }
  ],
