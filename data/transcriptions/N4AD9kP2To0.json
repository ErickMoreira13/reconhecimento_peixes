    {
      "start": 325.27,
      "end": 327.37,
      "text": "E outra danada do piapara"
    },
    {
      "start": 327.37,
      "end": 329.31,
      "text": "Não sei muito certo"
    },
    {
      "start": 329.31,
      "end": 332.01,
      "text": "Mas eu acho que é proibido"
    },
    {
      "start": 332.01,
      "end": 334.41,
      "text": "Soltar a rede no rio pardo"
    },
    {
      "start": 334.41,
      "end": 338.37,
      "text": "Pelo menos durante um trecho aqui"
    },
    {
      "start": 338.37,
      "end": 339.69,
      "text": "É proibido"
    },
    {
      "start": 339.69,
      "end": 341.09,
      "text": "E a gente tá vendo"
    },
    {
      "start": 341.09,
      "end": 344.87,
      "text": "Grande incidência de redes no rio pardo"
    },
    {
      "start": 344.87,
      "end": 348.63,
      "text": "E depois que eles começaram a soltar essas redes"
    },
    {
      "start": 348.63,
      "end": 350.89,
      "text": "O peixe diminuiu bastante"
    },
    {
      "start": 350.89,
      "end": 353.01,
      "text": "Lá tava fazendo boas capturas"
    },
    {
      "start": 353.01,
      "end": 355.07,
      "text": "Mas já tem alguns dias"
    },
    {
      "start": 355.07,
      "end": 358.95,
      "text": "Que tem visto bastante rede no rio pardo"
    },
    {
      "start": 358.95,
      "end": 362.35,
      "text": "Se alguém tiver a instrução disso"
    },
    {
      "start": 362.35,
      "end": 364.73,
      "text": "Que é proibido soltar a rede lá"
    },
    {
      "start": 364.73,
      "end": 366.17,
      "text": "Que faça"
    },
    {
      "start": 366.17,
      "end": 368.49,
      "text": "Porque eu realmente sou leigo"
    },
    {
      "start": 368.49,
      "end": 369.65,
      "text": "Mas acredito sim"
    },
    {
      "start": 369.65,
      "end": 371.71,
      "text": "Que é proibido a pesca de rede"
    },
    {
      "start": 371.71,
      "end": 373.75,
      "text": "No pardo nesse trecho"
    },
    {
      "start": 373.75,
      "end": 376.86,
      "text": "Que alguém tome alguma providência"
    },
    {
      "start": 376.86,
      "end": 379.14,
      "text": "E fale"
    },
    {
      "start": 379.14,
      "end": 381.64,
      "text": "E todo mundo comente sobre isso"
    },
    {
      "start": 381.64,
      "end": 382.46,
      "text": "Pra que não"
    },
    {
      "start": 382.46,
      "end": 384.8,
      "text": "Que é um dos berçários nossos também"
    },
    {
      "start": 384.8,
      "end": 386.72,
      "text": "Pra que não faça essa pesca lá"
    },
    {
      "start": 386.72,
      "end": 388.66,
      "text": "A danada do Piapara"
    },
    {
      "start": 388.66,
      "end": 390.38,
      "text": "É nesse cunho hoje"
    },
    {
      "start": 390.38,
      "end": 392.86,
      "text": "Protegendo os mananciais"
    },
    {
      "start": 392.86,
      "end": 394.48,
      "text": "De peixes"
    },
    {
      "start": 394.48,
      "end": 395.38,
      "text": "Os mananciais"
    },
    {
      "start": 395.38,
      "end": 396.18,
      "text": "Que eu falo assim"
    },
    {
      "start": 396.18,
      "end": 398.54,
      "text": "Aonde se reproduz os peixes"
    },
    {
      "start": 398.54,
      "end": 401.62,
      "text": "E aonde que é o berçário do Rio Grande"
    },
    {
      "start": 401.62,
      "end": 403.82,
      "text": "Nada contra os profissionais"
    },
    {
      "start": 403.82,
      "end": 405.46,
      "text": "Que eles pesquem"
    },
    {
      "start": 405.46,
      "end": 408.52,
      "text": "O profissional pesque no leito do rio"
    },
    {
      "start": 408.52,
      "end": 410.18,
      "text": "Com as normas devidas"
    },
    {
      "start": 410.18,
      "end": 413.1,
      "text": "Que eles necessitam disso pra sobreviver"
    },
    {
      "start": 413.1,
      "end": 415.5,
      "text": "Mas que não façam coisas erradas"
    },
    {
      "start": 415.5,
      "end": 417.8,
      "text": "Segue aí a dica da Segundona"
    },
    {
      "start": 417.8,
      "end": 419.06,
      "text": "Com a grande dica"
    },
    {
      "start": 419.06,
      "end": 420.36,
      "text": "De como fazer"
    },
    {
      "start": 420.36,
      "end": 422.64,
      "text": "Um trato pras curimbas"
    },
    {
      "start": 422.64,
      "end": 423.74,
      "text": "Essa semana"
    },
    {
      "start": 423.74,
      "end": 426.02,
      "text": "Vai ter peixe na ponta da linha"
    },
    {
      "start": 426.02,
      "end": 427.48,
      "text": "Peixe de ceva"
    },
    {
      "start": 427.48,
      "end": 428.72,
      "text": "Peixe diferente"
    },
    {
      "start": 428.72,
      "end": 430.24,
      "text": "Valeu galera"
    },
    {
      "start": 430.24,
      "end": 431.56,
      "text": "Galera"
    },
    {
      "start": 431.56,
      "end": 432.74,
      "text": "Dica da Segundona"
    },
    {
      "start": 432.74,
      "end": 434.04,
      "text": "E a dica da Segundona"
    },
    {
      "start": 434.04,
      "end": 434.42,
      "text": "Hoje"
    },
    {
      "start": 434.42,
      "end": 436.08,
      "text": "Época de frio"
    },
    {
      "start": 436.08,
      "end": 437.44,
      "text": "A gente já relatou"
    },
    {
      "start": 437.44,
      "end": 439.62,
      "text": "Esse peixe que deve aparecer aí"
    },
    {
      "start": 439.62,
      "end": 440.74,
      "text": "Constantemente agora"
    },
    {
      "start": 440.74,
      "end": 441.9,
      "text": "Enquanto tiver o frio"
    },
    {
      "start": 441.9,
      "end": 443.24,
      "text": "Um peixe de ceva"
    },
    {
      "start": 443.24,
      "end": 444.48,
      "text": "É a senhora curimba"
    },
    {
      "start": 444.48,
      "end": 447.08,
      "text": "E pra fazer a captura"
    },
    {
      "start": 447.08,
      "end": 448.54,
      "text": "Seja nos batelões"
    },
    {
      "start": 448.54,
      "end": 449.58,
      "text": "Seja de barco"
    },
    {
      "start": 449.58,
      "end": 451.28,
      "text": "Passa Tarsísio vai demonstrar aí"
    },
    {
      "start": 451.28,
      "end": 453.48,
      "text": "Uma pelota de barro"
    },
    {
      "start": 453.48,
      "end": 455.46,
      "text": "Com farelo de arroz"
    },
    {
      "start": 455.46,
      "end": 456.74,
      "text": "Sangue"
    },
    {
      "start": 456.74,
      "end": 457.9,
      "text": "E terra"
    },
    {
      "start": 457.9,
      "end": 458.74,
      "text": "Né Passa Tarsísio"
    },
    {
      "start": 458.74,
      "end": 460.5,
      "text": "Olha aí ela antes"
    },
    {
      "start": 460.5,
      "end": 462.12,
      "text": "Depois o Tarsísio"
    },
    {
      "start": 462.12,
      "end": 463.76,
      "text": "Molha ela com sangue"
    },
    {
      "start": 463.76,
      "end": 464.08,
      "text": "Né"
    },
    {
      "start": 464.08,
      "end": 466.78,
      "text": "E joga no local"
    },
    {
      "start": 466.78,
      "end": 467.74,
      "text": "Aí as pelotas"
    },
    {
      "start": 467.74,
      "end": 468.0,
      "text": "Né"
    },
    {
      "start": 468.0,
      "end": 469.08,
      "text": "Vamos fazer"
    },
    {
      "start": 469.08,
      "end": 470.04,
      "text": "Deixar bem claro"
    },
    {
      "start": 470.04,
      "end": 470.86,
      "text": "O sangue"
    },
    {
      "start": 470.86,
      "end": 471.56,
      "text": "Que a gente usa"
    },
    {
      "start": 471.56,
      "end": 472.18,
      "text": "É o sangue"
    },
    {
      "start": 472.18,
      "end": 472.84,
      "text": "Ceva"
    },
    {
      "start": 472.84,
      "end": 473.68,
      "text": "Em litro"
    },
    {
      "start": 473.68,
      "end": 474.56,
      "text": "Que tem lá"
    },
    {
      "start": 474.56,
      "end": 475.24,
      "text": "No comercial"
    },
    {
      "start": 475.24,
      "end": 475.98,
      "text": "Piapara"
    },
    {
      "start": 475.98,
      "end": 476.26,
      "text": "Né"
    },
    {
      "start": 476.26,
      "end": 477.84,
      "text": "Porque é um sangue"
    },
    {
      "start": 477.84,
      "end": 478.68,
      "text": "Legalizado"
    },
    {
      "start": 478.68,
      "end": 478.88,
      "text": "Né"
    },
    {
      "start": 478.88,
      "end": 479.92,
      "text": "Os outros sangues"
    },
    {
      "start": 479.92,
      "end": 481.42,
      "text": "Às vezes são de matadores"
    },
    {
      "start": 481.42,
      "end": 482.24,
      "text": "Candestinos"
    },
    {
      "start": 482.24,
      "end": 483.36,
      "text": "Você pode estar"
    },
    {
      "start": 483.36,
      "end": 483.78,
      "text": "Né"
    },
    {
      "start": 483.78,
      "end": 485.08,
      "text": "Então o certo"
    },
    {
      "start": 485.08,
      "end": 486.18,
      "text": "É comprar o sangue"
    },
    {
      "start": 486.18,
      "end": 487.22,
      "text": "Que é legalizado"
    },
    {
      "start": 487.22,
      "end": 488.2,
      "text": "Que ele é o sangue"
    },
    {
      "start": 488.2,
      "end": 489.04,
      "text": "De boi mesmo"
    },
    {
      "start": 489.04,
      "end": 490.06,
      "text": "E olha aí"
    },
    {
      "start": 490.06,
      "end": 491.02,
      "text": "O Passa Tarsísio"
    },
    {
      "start": 491.02,
      "end": 492.82,
      "text": "Fazendo a pelota"
    },
    {
      "start": 492.82,
      "end": 494.1,
      "text": "Na dica da Segundona"
    },
    {
      "start": 494.1,
      "end": 495.78,
      "text": "Mostrando como se servam"
    },
    {
      "start": 495.78,
      "end": 496.62,
      "text": "As curimbas"
    },
    {
      "start": 496.62,
      "end": 496.92,
      "text": "Né"
    },
    {
      "start": 496.92,
      "end": 497.62,
      "text": "Olha aí"
    },
    {
      "start": 497.62,
      "end": 499.73,
      "text": "Pegando"
    },
    {
      "start": 499.73,
      "end": 501.49,
      "text": "Aqui já tem um saco"
    },
    {
      "start": 501.49,
      "end": 502.35,
      "text": "Também amarrado"
    },
    {
      "start": 502.35,
      "end": 502.91,
      "text": "Né Tarsísio"
    },
    {
      "start": 502.91,
      "end": 505.71,
      "text": "Com terra e farelo"
    },
    {
      "start": 505.71,
      "end": 507.01,
      "text": "E a mistura aqui"
    },
    {
      "start": 507.01,
      "end": 508.01,
      "text": "Aí ó"
    },
    {
      "start": 508.01,
      "end": 509.57,
      "text": "É farelo com terra"
    },
    {
      "start": 509.57,
      "end": 510.37,
      "text": "E depois ele dá"
    },
    {
      "start": 510.37,
      "end": 511.85,
      "text": "Uma liga nela"
    },
    {
      "start": 511.85,
      "end": 513.39,
      "text": "Com água e sangue"
    },
    {
      "start": 513.39,
      "end": 514.19,
      "text": "Né isso Tarsísio"
    },
    {
      "start": 514.19,
      "end": 514.53,
      "text": "Isso"
    },
    {
      "start": 514.53,
      "end": 516.19,
      "text": "Então a dica da Segundona"
    },
    {
      "start": 516.19,
      "end": 517.73,
      "text": "Mostrando pra vocês"
    },
    {
      "start": 517.73,
      "end": 520.07,
      "text": "Como se serva"
    },
    {
      "start": 520.07,
      "end": 521.51,
      "text": "A curimba"
    },
    {
      "start": 521.51,
      "end": 522.65,
      "text": "Nesse tempo"
    },
    {
      "start": 522.65,
      "end": 524.05,
      "text": "Agora que é o tempo dela"
    },
    {
      "start": 524.05,
      "end": 525.75,
      "text": "Valeu galera"
    }
  ],
  "duracao_seg": 585.31,
  "idioma_detectado": "pt"
}