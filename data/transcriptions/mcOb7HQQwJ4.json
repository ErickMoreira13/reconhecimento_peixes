    {
      "start": 615.6,
      "end": 616.22,
      "text": "Olha o teu pé."
    },
    {
      "start": 620.99,
      "end": 622.89,
      "text": "Cuidado, Marta, ela morre demais."
    },
    {
      "start": 623.03,
      "end": 623.47,
      "text": "Cuidado."
    },
    {
      "start": 624.07,
      "end": 625.41,
      "text": "Eita, ela não pode fazer isso."
    },
    {
      "start": 626.05,
      "end": 627.91,
      "text": "Dá pra fazer isso, que é pequenininha."
    },
    {
      "start": 630.21,
      "end": 631.28,
      "text": "Ah, que legal."
    },
    {
      "start": 633.9,
      "end": 635.8,
      "text": "Marta, não bota a mão, não, idiota."
    },
    {
      "start": 636.22,
      "end": 636.46,
      "text": "Olha."
    },
    {
      "start": 638.58,
      "end": 639.86,
      "text": "Pelo menos virou a isca."
    },
    {
      "start": 640.16,
      "end": 640.64,
      "text": "Olha aí, ó."
    },
    {
      "start": 641.02,
      "end": 641.61,
      "text": "Com sangue."
    },
    {
      "start": 641.65,
      "end": 643.09,
      "text": "E, Marta, pelo menos ela pega o piranha."
    },
    {
      "start": 644.17,
      "end": 646.21,
      "text": "Não, agora virou a isca pra pegar o grande."
    },
    {
      "start": 650.12,
      "end": 650.34,
      "text": "É."
    },
    {
      "start": 651.54,
      "end": 653.46,
      "text": "A gente vai pegar o grande e a Carinho de novo."
    },
    {
      "start": 653.9,
      "end": 654.62,
      "text": "E eu gravando."
    },
    {
      "start": 655.06,
      "end": 663.68,
      "text": "É bandido."
    },
    {
      "start": 664.2,
      "end": 665.42,
      "text": "Todo mundo pega um peixe bonito."
    },
    {
      "start": 665.42,
      "end": 666.92,
      "text": "Olha aí, um peixe de couro, minha filha."
    },
    {
      "start": 667.06,
      "end": 668.36,
      "text": "Oi, todo mundo pega um peixe bonito."
    },
    {
      "start": 668.46,
      "end": 668.86,
      "text": "Foi bonito."
    },
    {
      "start": 668.96,
      "end": 670.08,
      "text": "Passa pro LTT, tem esporão."
    },
    {
      "start": 670.1,
      "end": 670.78,
      "text": "Não, não quero, não."
    },
    {
      "start": 671.06,
      "end": 671.4,
      "text": "Ah, não."
    },
    {
      "start": 671.52,
      "end": 672.88,
      "text": "Eu tiro aqui, tem um alicate."
    },
    {
      "start": 673.9,
      "end": 674.3,
      "text": "Cuidado."
    },
    {
      "start": 675.68,
      "end": 676.84,
      "text": "E aí, minha filha?"
    },
    {
      "start": 676.96,
      "end": 677.58,
      "text": "Olha esse aí."
    },
    {
      "start": 677.74,
      "end": 678.36,
      "text": "O que você acha isso?"
    },
    {
      "start": 678.76,
      "end": 679.26,
      "text": "Na frente?"
    },
    {
      "start": 679.58,
      "end": 679.92,
      "text": "O quê?"
    },
    {
      "start": 680.4,
      "end": 682.41,
      "text": "Leva pra barba dele."
    },
    {
      "start": 682.73,
      "end": 683.45,
      "text": "Da espinal, né?"
    },
    {
      "start": 683.83,
      "end": 684.59,
      "text": "Esse aqui é?"
    },
    {
      "start": 684.99,
      "end": 689.06,
      "text": "É pequenininho ele."
    },
    {
      "start": 690.24,
      "end": 690.78,
      "text": "Novinho, né?"
    },
    {
      "start": 698.58,
      "end": 699.7,
      "text": "E aí, meu bem, nada."
    },
    {
      "start": 699.7,
      "end": 703.96,
      "text": "Deixa ele pegar uma alinhada e que ele volta."
    },
    {
      "start": 706.01,
      "end": 706.45,
      "text": "É o quê?"
    },
    {
      "start": 706.55,
      "end": 706.95,
      "text": "Milho, é?"
    },
    {
      "start": 707.35,
      "end": 716.43,
      "text": "É só um pouquinho da frente."
    },
    {
      "start": 719.48,
      "end": 720.96,
      "text": "É só pra desgrudar o olho no nó."
    },
    {
      "start": 722.88,
      "end": 723.24,
      "text": "Oxe."
    },
    {
      "start": 723.72,
      "end": 724.32,
      "text": "Olha o olho."
    },
    {
      "start": 724.56,
      "end": 726.08,
      "text": "Pegou a linha de alguém, da Carinha."
    },
    {
      "start": 727.29,
      "end": 727.89,
      "text": "Olha a Carinha."
    },
    {
      "start": 727.89,
      "end": 747.89,
      "text": "Galerinha, vocês viram aí como é que foi a nossa pescaria."
    },
    {
      "start": 747.99,
      "end": 749.09,
      "text": "Não rendeu muita coisa."
    },
    {
      "start": 749.95,
      "end": 753.29,
      "text": "As convidadas é que pegou os peixes, garantiu a janta e o almoço."
    },
    {
      "start": 754.69,
      "end": 755.43,
      "text": "E foi isso aí."
    },
    {
      "start": 755.43,
