      "end": 988.12,
      "text": "O povo quer ver o virote."
    },
    {
      "start": 988.22,
      "end": 989.06,
      "text": "Aí, Alexandre."
    },
    {
      "start": 989.89,
      "end": 990.21,
      "text": "Ô."
    },
    {
      "start": 991.78,
      "end": 993.06,
      "text": "Você é tainha, Gerardo?"
    },
    {
      "start": 995.15,
      "end": 997.79,
      "text": "E ela tá com a tainha na mão falando que é virote, rapaz?"
    },
    {
      "start": 1000.32,
      "end": 1001.96,
      "text": "Ela tava cheia de fogo."
    },
    {
      "start": 1005.12,
      "end": 1005.62,
      "text": "Aí, ó."
    },
    {
      "start": 1005.62,
      "end": 1006.76,
      "text": "A tarrafinha do homem aí, ó."
    },
    {
      "start": 1006.76,
      "end": 1006.94,
      "text": "Ó."
    },
    {
      "start": 1008.0,
      "end": 1009.62,
      "text": "A tarrafinha de 10 par, mano."
    },
    {
      "start": 1009.62,
      "end": 1015.2,
      "text": "Aí, ó."
    },
    {
      "start": 1015.2,
      "end": 1015.7,
      "text": "Tá vendo, ó."
    },
    {
      "start": 1016.0,
      "end": 1016.22,
      "text": "Aí, ó."
    },
    {
      "start": 1016.22,
      "end": 1018.14,
      "text": "É o barquinho que o nosso amigo Alexandre fabricou, ó."
    },
    {
      "start": 1019.0,
      "end": 1019.56,
      "text": "Cadê, Gerardo?"
    },
    {
      "start": 1019.6,
      "end": 1020.76,
      "text": "O virote até agora não achou, pô?"
    },
    {
      "start": 1021.0,
      "end": 1021.5,
      "text": "Tá demais."
    },
    {
      "start": 1023.96,
      "end": 1025.22,
      "text": "Tem mais umas tainha aí, ó."
    },
    {
      "start": 1025.26,
      "end": 1025.88,
      "text": "Levanta aí, ó."
    },
    {
      "start": 1026.3,
      "end": 1026.66,
      "text": "Aí, ó."
    },
    {
      "start": 1026.66,
      "end": 1027.34,
      "text": "O virote aí, ó."
    },
    {
      "start": 1027.62,
      "end": 1028.3,
      "text": "Cachote aí, ó."
    },
    {
      "start": 1028.68,
      "end": 1029.82,
      "text": "Essa daqui tá sem ovo."
    },
    {
      "start": 1029.92,
      "end": 1030.56,
      "text": "Aí, nós..."
    },
    {
      "start": 1030.56,
      "end": 1032.68,
      "text": "Mas é isso aí, pessoal."
    },
    {
      "start": 1032.72,
      "end": 1033.48,
      "text": "Aí a peixada aí, ó."
    },
    {
      "start": 1033.76,
      "end": 1034.72,
      "text": "Valeu, valeu, valeu, valeu."
    },
    {
      "start": 1034.82,
