    {
      "start": 1482.38,
      "end": 1484.28,
      "text": "No camarão."
    },
    {
      "start": 1484.64,
      "end": 1484.84,
      "text": "Viu?"
    },
    {
      "start": 1485.52,
      "end": 1486.94,
      "text": "E o sambiquezinho aqui verde."
    },
    {
      "start": 1487.3,
      "end": 1487.74,
      "text": "Pequenininho."
    },
    {
      "start": 1488.4,
      "end": 1489.22,
      "text": "Tá pegando também."
    },
    {
      "start": 1490.82,
      "end": 1491.44,
      "text": "Mas olha o tamanho."
    },
    {
      "start": 1491.6,
      "end": 1492.98,
      "text": "Jogou a isca toda de fora agora."
    },
    {
      "start": 1494.76,
      "end": 1495.16,
      "text": "Aí."
    },
    {
      "start": 1495.82,
      "end": 1496.62,
      "text": "Vem aqui agora."
    },
    {
      "start": 1496.72,
      "end": 1497.26,
      "text": "Pede de mim aqui."
    },
    {
      "start": 1501.33,
      "end": 1501.89,
      "text": "Olha lá."
    },
    {
      "start": 1506.5,
      "end": 1508.58,
      "text": "Mas eu vou ajeitar as coisas aqui pra cair fora."
    },
    {
      "start": 1508.64,
      "end": 1509.44,
      "text": "Não vou esperar mais não."
    },
    {
      "start": 1509.9,
      "end": 1511.54,
      "text": "Vou esperar a maré arriar aqui pra poder..."
    },
    {
      "start": 1512.45,
      "end": 1513.93,
      "text": "Tentar ali de novo no poço ali."
    },
    {
      "start": 1513.93,
      "end": 1515.43,
      "text": "Mas pelo jeito aqui..."
    },
    {
      "start": 1515.43,
      "end": 1518.13,
      "text": "Pelo jeito aqui não vai dar certo não."
    },
    {
      "start": 1519.6,
      "end": 1519.88,
      "text": "Olha lá."
    },
    {
      "start": 1520.99,
