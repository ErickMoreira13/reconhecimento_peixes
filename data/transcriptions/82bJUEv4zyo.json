      "text": "Mas a pescaria me deu um grande ânimo."
    },
    {
      "start": 1441.7,
      "end": 1443.0,
      "text": "Eu já pescava desde pequeno."
    },
    {
      "start": 1443.42,
      "end": 1444.48,
      "text": "Mas eu não tive acidente."
    },
    {
      "start": 1444.9,
      "end": 1445.7,
      "text": "Fiquei com limitação."
    },
    {
      "start": 1445.78,
      "end": 1446.68,
      "text": "Não quis pescar mais."
    },
    {
      "start": 1447.24,
      "end": 1448.2,
      "text": "Mas graças a Deus."
    },
    {
      "start": 1448.8,
      "end": 1449.88,
      "text": "Me deu o dobro da vida."
    },
    {
      "start": 1450.2,
      "end": 1452.88,
      "text": "E me deu uma força pra poder voltar à minha pescaria."
    },
    {
      "start": 1452.96,
      "end": 1453.24,
      "text": "Beleza?"
    },
    {
      "start": 1453.72,
      "end": 1454.1,
      "text": "Valeu."
    },
    {
      "start": 1454.1,
      "end": 1456.06,
      "text": "Um abraço."
    },
    {
      "start": 1457.66,
      "end": 1458.02,
      "text": "Galera."
    },
    {
      "start": 1459.51,
      "end": 1461.09,
      "text": "Jogou a isca toda pro lado de fora."
    },
    {
      "start": 1462.76,
      "end": 1463.18,
      "text": "Olha lá."
    },
    {
      "start": 1465.76,
      "end": 1466.28,
      "text": "Aqui lá."
    },
    {
      "start": 1466.4,
      "end": 1467.04,
      "text": "Virou tudo ali."
    },
    {
      "start": 1467.18,
      "end": 1467.88,
      "text": "Ali é a isca."
    },
    {
      "start": 1469.87,
      "end": 1470.25,
      "text": "Olha lá."
    },
    {
      "start": 1472.46,
      "end": 1473.96,
      "text": "Só que tem muita isca."
    },
    {
      "start": 1474.0,
      "end": 1474.76,
      "text": "Muita isca mesmo."
    },
    {
      "start": 1474.86,
      "end": 1475.66,
      "text": "Aí o que tá acontecendo."
    },
    {
      "start": 1476.54,
      "end": 1478.98,
      "text": "É dificilmente tá pegando nas fechitingas."
    },
    {
      "start": 1479.08,
      "end": 1481.5,
      "text": "Tá pegando mais no..."
    },
    {
      "start": 1481.5,
      "end": 1482.38,
      "text": "No..."
