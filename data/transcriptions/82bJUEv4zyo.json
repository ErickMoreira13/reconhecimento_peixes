      "text": "Tudo na beirada os bichos aí."
    },
    {
      "start": 1525.42,
      "end": 1525.86,
      "text": "Beleza?"
    },
    {
      "start": 1526.88,
      "end": 1527.52,
      "text": "Tamo junto."
    },
    {
      "start": 1528.84,
      "end": 1529.68,
      "text": "Olha lá o bicho lá."
    },
    {
      "start": 1530.89,
      "end": 1532.09,
      "text": "Um monte de isca."
    },
    {
      "start": 1532.55,
      "end": 1533.97,
      "text": "Chega a estar tremendo a água."
    },
    {
      "start": 1535.22,
      "end": 1535.56,
      "text": "Beleza?"
    },
    {
      "start": 1535.94,
      "end": 1536.38,
      "text": "Valeu."
    },
    {
      "start": 1536.56,
      "end": 1537.1,
      "text": "Galera, ó."
    },
    {
      "start": 1538.09,
      "end": 1538.63,
      "text": "Aí, ó."
    },
    {
      "start": 1540.44,
