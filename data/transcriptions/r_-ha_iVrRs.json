      "end": 528.09,
      "text": "Ainda tem toda essa porção aqui ainda, ó"
    },
    {
      "start": 528.09,
      "end": 529.37,
      "text": "Olha que bonito"
    },
    {
      "start": 529.37,
      "end": 537.08,
      "text": "Aí, porção ozona, hein?"
    },
    {
      "start": 538.35,
      "end": 539.41,
      "text": "Rapaz do céu"
    },
    {
      "start": 539.41,
      "end": 542.3,
      "text": "Aí, ó"
    },
    {
      "start": 542.3,
      "end": 543.26,
      "text": "Já vai"
    },
    {
      "start": 543.26,
      "end": 546.0,
      "text": "Já dá uma escorriguinha ali, ó"
    },
    {
      "start": 546.0,
      "end": 548.95,
      "text": "E já vai jogar aqui, já, ó"
    },
    {
      "start": 548.95,
      "end": 549.89,
      "text": "Vendo a bacia"
    },
    {
      "start": 549.89,
      "end": 550.65,
      "text": "Olha as bolinhas"
    },
    {
      "start": 550.65,
      "end": 553.72,
      "text": "Que bolinha top, cara"
    },
    {
      "start": 553.72,
      "end": 557.39,
      "text": "Dá trabalho enrolar"
    },
    {
      "start": 557.39,
      "end": 559.77,
      "text": "Mas o resultado é fatal"
    },
    {
      "start": 559.77,
      "end": 572.94,
      "text": "Aí, agora já vai jogar"
    },
    {
      "start": 572.94,
      "end": 574.72,
      "text": "Mais a última remessa, ó"
    },
    {
      "start": 574.72,
      "end": 576.61,
      "text": "Última remessinha"
    },
    {
      "start": 576.61,
      "end": 584.85,
      "text": "Cozinhar a última remessa"
    },
    {
      "start": 584.85,
      "end": 585.57,
      "text": "E já era"
    },
    {
      "start": 585.57,
      "end": 608.44,
      "text": "Só jogar uma água"
    },
    {
      "start": 608.44,
      "end": 610.42,
      "text": "Bem gelada, ó"
    },
    {
      "start": 610.42,
      "end": 613.98,
      "text": "Põe a escumadeira aqui"
    },
    {
      "start": 613.98,
      "end": 615.94,
      "text": "Aí a própria escumadeira, ó"
    },
    {
      "start": 615.94,
      "end": 616.88,
      "text": "Meu pai já vai"
    },
    {
      "start": 616.88,
      "end": 618.88,
      "text": "Escorrer as bolinhas"
    },
    {
      "start": 618.88,
      "end": 619.6,
      "text": "Olha lá, ó"
    },
    {
      "start": 619.6,
      "end": 620.85,
      "text": "Só pra"
    },
    {
      "start": 620.85,
      "end": 622.39,
      "text": "Elas ficarem firminhas, ó"
    },
    {
      "start": 622.39,
      "end": 625.5,
      "text": "Olha lá, ó"
    },
    {
      "start": 625.5,
      "end": 626.08,
      "text": "Olha isso"
    },
    {
      "start": 626.08,
      "end": 632.32,
      "text": "Bolinha de milho"
    },
    {
      "start": 632.32,
      "end": 635.43,
      "text": "Que chique, hein?"
    },
    {
      "start": 635.43,
      "end": 637.35,
      "text": "Bolinha de milho, hein?"
    },
    {
      "start": 637.69,
      "end": 638.55,
      "text": "Olha como ela quica"
    },
    {
      "start": 638.55,
      "end": 639.66,
      "text": "Ó"
    },
    {
      "start": 639.66,
      "end": 641.49,
      "text": "Bolinha de milho"
    },
    {
      "start": 641.49,
      "end": 643.52,
      "text": "Ih, é isso?"
    },
    {
      "start": 645.64,
      "end": 646.92,
      "text": "Deixa eu emprestar a escumadeira"
    },
    {
      "start": 646.92,
      "end": 647.12,
      "text": "Vai"
    },
    {
      "start": 647.12,
      "end": 648.72,
      "text": "Soltar elas aqui"
    },
    {
      "start": 648.72,
      "end": 651.45,
      "text": "Aí você já tira a última remessa"
    },
    {
      "start": 651.45,
      "end": 652.79,
      "text": "Não, já escorre ela também"
    },
    {
      "start": 652.79,
      "end": 656.16,
      "text": "Vou desligar o fogo"
    },
    {
      "start": 656.16,
      "end": 657.86,
      "text": "É o contrário"
    },
    {
      "start": 657.86,
      "end": 658.14,
      "text": "Aí"
    },
    {
      "start": 658.14,
      "end": 660.8,
      "text": "Já desligou"
    },
    {
      "start": 660.8,
      "end": 663.9,
      "text": "Já tira a última remessinha"
    },
    {
      "start": 663.9,
      "end": 665.36,
      "text": "Dá uma mexidinha só"
    },
    {
      "start": 665.36,
      "end": 666.28,
      "text": "Pra aproveitar, né?"
    },
    {
      "start": 675.21,
      "end": 676.93,
      "text": "Vamos dar o último choque térmico, ó"
    },
    {
      "start": 676.93,
      "end": 677.83,
      "text": "Ó"
    },
    {
      "start": 677.83,
      "end": 678.97,
      "text": "Água gelada"
    },
    {
      "start": 678.97,
      "end": 680.79,
      "text": "Direto no forno de mira"
    },
    {
      "start": 680.79,
      "end": 683.6,
      "text": "E escorrer"
    },
    {
      "start": 683.6,
      "end": 686.24,
      "text": "Aí agora nós vamos armazenar ela"
    },
    {
      "start": 686.24,
      "end": 688.19,
      "text": "Vou mostrar pra vocês"
    },
    {
      "start": 688.19,
      "end": 689.63,
      "text": "Quando nós armazenas"
    },
    {
      "start": 689.63,
      "end": 691.97,
      "text": "Não precisa armazenar na geladeira"
    },
    {
      "start": 691.97,
      "end": 693.77,
      "text": "Só se você quiser armazenar na geladeira"
    },
    {
      "start": 693.77,
      "end": 696.11,
      "text": "A gente armazena as nossas bolinhas fora, menino"
    },
    {
      "start": 696.11,
      "end": 699.1,
      "text": "Aí, ó"
    },
    {
      "start": 699.1,
      "end": 702.52,
      "text": "Vou pegar aqui um recipiente"
    },
    {
      "start": 702.52,
      "end": 705.08,
      "text": "Agora aqui, ó"
    },
    {
      "start": 705.08,
      "end": 706.84,
      "text": "Vamos jogar as bolinhas"
    },
    {
      "start": 706.84,
      "end": 708.96,
      "text": "Ó, põe aqui pra que já arrasta tudo elas"
    },
    {
      "start": 708.96,
      "end": 709.36,
      "text": "Ó"
    },
    {
      "start": 709.36,
      "end": 710.62,
      "text": "Ele dá uma enxugada aqui"
    },
    {
      "start": 710.62,
      "end": 713.94,
      "text": "Ó, vamos jogar as bolinhas lá, ó"
    },
    {
      "start": 713.94,
      "end": 715.64,
      "text": "Sem dó mesmo"
    },
    {
      "start": 715.64,
      "end": 716.9,
      "text": "Ó, como elas quicam"
    },
    {
      "start": 716.9,
      "end": 720.68,
      "text": "Agora nós vamos jogar um pouco de fubá"
    },
    {
      "start": 720.68,
      "end": 725.41,
      "text": "Pra pegar um pouquinho de fubá aqui, ó"
    },
    {
      "start": 725.41,
      "end": 729.17,
      "text": "Nós vamos dar uma pulverizada de fubá nelas"
    },
    {
      "start": 729.17,
      "end": 733.74,
      "text": "Esse fubá aqui é para armazenar, né?"
    },
    {
      "start": 733.74,
      "end": 735.14,
      "text": "É, tá bom, cara"
    },
    {
      "start": 735.14,
      "end": 739.32,
      "text": "Ele vai sugar um pouco da umidade delas também, ó"
    },
    {
      "start": 739.32,
      "end": 741.0,
      "text": "Olha lá, ó"
    },
    {
      "start": 741.0,
      "end": 745.46,
      "text": "Olha que bonito que ficou"
    },
    {
      "start": 745.46,
      "end": 749.23,
      "text": "Aí agora é só deixar esfriar"
    },
    {
      "start": 749.23,
      "end": 751.89,
      "text": "Elas dá uma secada bem"
    },
    {
      "start": 751.89,
      "end": 754.91,
      "text": "E vamos armazenar em qualquer potinho assim, ó"
    },
    {
      "start": 754.91,
      "end": 756.61,
      "text": "Ele tá pronto com a sua pescaria"
    },
    {
      "start": 756.61,
      "end": 758.99,
      "text": "E piaute, lata, piapara"
    },
    {
      "start": 758.99,
      "end": 761.09,
      "text": "É uma isca que pega no rio"
    },
    {
      "start": 761.09,
      "end": 762.43,
      "text": "Lagoa"
    },
    {
      "start": 762.43,
      "end": 764.03,
      "text": "Lago pesqueiro"
    },
    {
      "start": 764.03,
      "end": 767.49,
      "text": "Porque ela é feita com o próprio milho, rapaziada"
    },
    {
      "start": 767.49,
      "end": 769.33,
      "text": "Você pode usar espiga"
    },
    {
      "start": 769.33,
      "end": 772.49,
      "text": "Pode usar esse milho de latinha"
    },
    {
      "start": 772.49,
      "end": 773.73,
      "text": "Milho de caixinha"
    },
    {
      "start": 773.73,
      "end": 776.83,
      "text": "Você pode fazer o que você quiser, né, pai?"
    },
    {
      "start": 777.27,
      "end": 778.23,
      "text": "Aí, rapaziada"
    },
    {
      "start": 778.23,
      "end": 780.13,
      "text": "Essa foi a dica de hoje"
    },
    {
      "start": 780.13,
      "end": 782.51,
      "text": "Olha que bolinha chique, hein?"
    },
    {
      "start": 782.77,
      "end": 784.05,
      "text": "Massa feita de milho, hein?"
    },
    {
      "start": 784.49,
      "end": 785.73,
      "text": "Massinha de milho, hein?"
    },
    {
      "start": 785.73,
      "end": 786.33,
      "text": "Sim"
    },
    {
      "start": 786.33,
      "end": 787.37,
      "text": "A bolinha de milho, ó"
    },
    {
      "start": 787.37,
      "end": 788.63,
      "text": "Simples, fácil"
    },
    {
      "start": 788.63,
      "end": 789.69,
      "text": "Top de fazer, hein?"
    },
    {
      "start": 791.12,
      "end": 792.04,
      "text": "E rápido, né, pai?"
    },
    {
      "start": 792.14,
      "end": 792.46,
      "text": "Rápido"
    },
    {
      "start": 792.46,
      "end": 793.92,
      "text": "Só demora um pouco pra enrolar, né?"
    },
    {
      "start": 794.14,
      "end": 795.46,
      "text": "É, não problema nem enrolar, né?"
    },
    {
      "start": 795.84,
      "end": 797.26,
      "text": "É, fica soltinho"
    },
    {
      "start": 797.26,
      "end": 798.66,
      "text": "Pronto pra pesca"
    },
    {
      "start": 798.66,
      "end": 800.68,
      "text": "Deixa esfriar um pouquinho"
    },
    {
      "start": 800.68,
      "end": 802.38,
      "text": "E só armazenar"
    },
    {
      "start": 802.38,
      "end": 805.13,
      "text": "E quem gostou, rapaziada"
    },
    {
      "start": 805.13,
      "end": 805.91,
      "text": "Curte"
    },
    {
      "start": 805.91,
      "end": 806.95,
      "text": "Compartilhe"
    },
    {
      "start": 806.95,
      "end": 808.55,
      "text": "E até a próxima"
    },
    {
      "start": 808.55,
      "end": 810.35,
      "text": "Inscreva-se no nosso canal"
    },
    {
      "start": 810.35,
      "end": 811.43,
      "text": "Abraço"
    }
  ],
