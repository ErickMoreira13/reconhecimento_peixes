      "end": 1441.08,
      "text": "A tinda, né?"
    },
    {
      "start": 1441.32,
      "end": 1441.96,
      "text": "Fuginha marota"
    },
    {
      "start": 1441.96,
      "end": 1445.48,
      "text": "Fuginha sem vento"
    },
    {
      "start": 1445.48,
      "end": 1447.16,
      "text": "Só demora para vir, né?"
    },
    {
      "start": 1447.86,
      "end": 1448.62,
      "text": "Também demora para ir"
    },
    {
      "start": 1448.62,
      "end": 1455.11,
      "text": "Eu não estou achando ruim, não"
    },
    {
      "start": 1455.11,
      "end": 1456.27,
      "text": "Aqui embaixo"
    },
    {
      "start": 1456.27,
      "end": 1456.91,
      "text": "Dessas árvores aqui"
    },
    {
      "start": 1456.91,
      "end": 1459.44,
      "text": "Não tem vento"
    },
    {
      "start": 1459.44,
      "end": 1461.36,
      "text": "Não tem perigo, não?"
    },
    {
      "start": 1461.62,
      "end": 1469.72,
      "text": "Não"
    },
    {
      "start": 1469.72,
      "end": 1470.64,
      "text": "Vai ficar susto"
    },
    {
      "start": 1470.64,
      "end": 1486.04,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1486.04,
      "end": 1486.06,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1486.06,
      "end": 1488.13,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1488.13,
      "end": 1489.13,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1489.13,
      "end": 1492.88,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1492.88,
      "end": 1494.74,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1494.74,
      "end": 1495.74,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1495.74,
      "end": 1527.62,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1527.62,
      "end": 1528.62,
      "text": "Tá uma madeira bonita"
    },
    {
      "start": 1528.62,
      "end": 2178.55,
      "text": "Acho que a pau tem cheiro, viu?"
    },
    {
      "start": 2179.26,
      "end": 2179.8,
      "text": "Cheiro, não tá?"
    },
    {
      "start": 2180.36,
      "end": 2180.52,
      "text": "Cheiro"
    },
    {
      "start": 2180.52,
      "end": 2180.84,
      "text": "Cheiro"
    },
    {
      "start": 2180.84,
      "end": 2182.38,
      "text": "Coraçãozinho"
    },
    {
      "start": 2182.38,
      "end": 2189.84,
      "text": "Isso aí, pessoal"
    },
    {
      "start": 2189.84,
      "end": 2190.92,
      "text": "Nosso almoço já está no jeito"
    },
    {
      "start": 2190.92,
      "end": 2191.6,
      "text": "Arroz"
    },
    {
      "start": 2191.6,
      "end": 2192.88,
      "text": "Tem um franguinho aqui"
    },
    {
      "start": 2192.88,
      "end": 2193.92,
      "text": "Que a Esther mandou para nós"
    },
    {
      "start": 2193.92,
      "end": 2195.48,
      "text": "Um tomate"
    },
    {
      "start": 2195.48,
      "end": 2196.9,
      "text": "E aqui já o coraçãozinho"
    },
    {
      "start": 2196.9,
      "end": 2198.32,
      "text": "Já está no jeito"
    },
    {
      "start": 2198.32,
      "end": 2199.9,
      "text": "Daquele modelo"
    },
    {
      "start": 2199.9,
      "end": 2201.4,
      "text": "Sapecadinho"
    },
    {
      "start": 2201.4,
      "end": 2203.18,
      "text": "Então, bora comer"
    },
    {
      "start": 2203.18,
      "end": 2204.82,
      "text": "Vamos servir ali"
    },
    {
      "start": 2204.82,
      "end": 2206.42,
      "text": "Mandar ver"
    },
    {
      "start": 2206.42,
      "end": 2208.74,
      "text": "E aí"
    },
    {
      "start": 2208.74,
      "end": 2211.67,
      "text": "Tá matando um grau, hein?"
    },
    {
      "start": 2212.13,
      "end": 2212.69,
      "text": "Bonito, não tá?"
    },
    {
      "start": 2213.11,
      "end": 2213.47,
      "text": "Tope"
    },
    {
      "start": 2213.47,
      "end": 2214.91,
      "text": "Sapecadinho, no jeito"
    },
    {
      "start": 2214.91,
      "end": 2215.81,
      "text": "Isso aí"
    },
    {
      "start": 2215.81,
      "end": 2217.37,
      "text": "Agora eu vou matar quem está nos matando, né?"
    },
    {
      "start": 2217.61,
      "end": 2217.85,
      "text": "Bora"
    },
    {
      "start": 2217.85,
      "end": 2221.86,
      "text": "Essa faca está cega"
    },
    {
      "start": 2221.86,
      "end": 2223.46,
      "text": "Tá, tá vindo"
    },
    {
      "start": 2223.46,
      "end": 2227.26,
      "text": "Isso aí, bora lá almoçar, né?"
    },
    {
      "start": 2227.3,
      "end": 2228.1,
      "text": "Olha meu prato aí"
    },
    {
      "start": 2228.1,
      "end": 2230.24,
      "text": "Tota, pô, a moca já está agarrada ali"
    },
    {
      "start": 2230.24,
      "end": 2232.08,
      "text": "Bora almoçar"
    },
    {
      "start": 2232.08,
      "end": 2234.84,
      "text": "E a chuva não desiste, né?"
    },
    {
      "start": 2235.44,
      "end": 2235.72,
      "text": "Não"
    },
    {
      "start": 2235.72,
      "end": 2333.04,
      "text": "E estamos aqui engatados no coraçãozinho"
    },
    {
      "start": 2333.04,
      "end": 2334.99,
      "text": "O prato, a moca está lá"
    },
    {
      "start": 2334.99,
      "end": 2338.31,
      "text": "Fora"
    },
    {
      "start": 2338.31,
      "end": 2341.1,
      "text": "Porque depois de pronto não serve para guardar, né?"
    },
    {
      "start": 2341.32,
      "end": 2341.5,
      "text": "Não"
    },
    {
      "start": 2341.5,
      "end": 2342.73,
      "text": "Tem que comer"
    },
    {
      "start": 2342.73,
      "end": 2346.24,
      "text": "Depois que"
    },
    {
      "start": 2346.24,
      "end": 2348.98,
      "text": "Depois que conzinha não nasce mais, né?"
    },
    {
      "start": 2348.98,
      "end": 2349.48,
      "text": "Uhum"
    },
    {
      "start": 2349.48,
      "end": 2352.13,
      "text": "É, comeu arroz, comeu, comeu tudo"
    },
    {
      "start": 2352.13,
      "end": 2356.71,
      "text": "É isso aí"
    },
    {
      "start": 2356.71,
      "end": 2357.57,
      "text": "Vamos"
    },
    {
      "start": 2357.57,
      "end": 2359.31,
      "text": "Desmontar o acampamento"
    },
    {
      "start": 2359.31,
      "end": 2360.78,
      "text": "Porque"
    },
    {
      "start": 2360.78,
      "end": 2363.38,
      "text": "Tá vindo outra chuva"
    },
    {
      "start": 2363.38,
      "end": 2366.46,
      "text": "Ih, lá não pegou peixe ainda"
    },
    {
      "start": 2366.46,
      "end": 2366.7,
      "text": "Então"
    },
    {
      "start": 2366.7,
      "end": 2368.26,
      "text": "Acredito que nem vai pegar"
    },
    {
      "start": 2368.26,
      "end": 2368.52,
      "text": "Porque"
    },
    {
      "start": 2368.52,
      "end": 2371.09,
      "text": "Se tá vindo outra chuva"
    },
    {
      "start": 2371.09,
      "end": 2372.75,
      "text": "Vai chover muito mais"
    },
    {
      "start": 2372.75,
      "end": 2375.08,
      "text": "Pode desmontar aqui"
    },
    {
      "start": 2375.08,
      "end": 2377.31,
      "text": "Esse barraco que nós fizemos"
    },
    {
      "start": 2377.31,
      "end": 2378.31,
      "text": "Para nós só almoçar"
    },
    {
      "start": 2378.31,
      "end": 2379.17,
      "text": "Pelo jeito, né?"
    },
    {
      "start": 2382.14,
      "end": 2382.78,
      "text": "Pode desmontar"
    },
    {
      "start": 2382.78,
      "end": 2383.56,
      "text": "As coisas já estão aí"
    },
    {
      "start": 2383.56,
      "end": 2385.8,
      "text": "Pode montar aqui"
    },
    {
      "start": 2385.8,
      "end": 2386.4,
      "text": "Que lá vem água"
    },
    {
      "start": 2386.4,
      "end": 2387.88,
      "text": "Mas o franco acha que está azul"
    },
    {
      "start": 2387.88,
      "end": 2388.56,
      "text": "Olha lá"
    },
    {
      "start": 2388.56,
      "end": 2389.26,
      "text": "É"
    },
    {
      "start": 2389.26,
      "end": 2391.23,
      "text": "Água demais"
    },
    {
      "start": 2391.23,
      "end": 2391.53,
      "text": "Então"
    },
    {
      "start": 2391.53,
      "end": 2392.69,
      "text": "Vamos desmontar aqui"
    },
    {
      "start": 2392.69,
      "end": 2393.17,
      "text": "Para nós ir embora"
    },
    {
      "start": 2393.17,
      "end": 2395.81,
      "text": "Fizemos aqui mais uma paradinha"
    },
    {
      "start": 2395.81,
      "end": 2397.31,
      "text": "Vamos pescar mais um pouquinho aqui"
    },
    {
      "start": 2397.31,
      "end": 2399.17,
      "text": "Vou dar uma isquinha"
    },
    {
      "start": 2399.17,
      "end": 2401.4,
      "text": "Mais ou menos"
    },
    {
      "start": 2401.4,
      "end": 2403.79,
      "text": "Agora ver se nós pegamos peixe"
    },
    {
      "start": 2403.79,
      "end": 2405.34,
      "text": "Acompanhe"
    },
    {
      "start": 2405.34,
      "end": 2410.14,
      "text": "Puxa, amor"
    },
    {
      "start": 2410.14,
      "end": 2413.95,
      "text": "Peixe está ferrado"
    },
    {
      "start": 2413.95,
      "end": 2419.18,
      "text": "Ó, quem veio"
    },
    {
      "start": 2419.18,
      "end": 2425.42,
      "text": "Peixe apareceu, amor"
    },
    {
      "start": 2425.42,
      "end": 2430.13,
      "text": "Bom, hein"
    },
    {
      "start": 2430.13,
      "end": 2439.44,
      "text": "Aí sim, amor"
    },
    {
      "start": 2439.44,
      "end": 2441.72,
      "text": "Tava falando nele"
    },
    {
      "start": 2441.72,
      "end": 2442.62,
      "text": "Apareceu"
    },
    {
      "start": 2442.62,
      "end": 2443.5,
      "text": "Acabamos de falar, né?"
    },
    {
      "start": 2444.75,
      "end": 2445.75,
      "text": "Reblão, menino"
    },
    {
      "start": 2445.75,
      "end": 2450.74,
      "text": "Olha o outro"
    },
    {
      "start": 2450.74,
      "end": 2451.2,
      "text": "Olha o outro"
    },
    {
      "start": 2451.2,
      "end": 2451.5,
      "text": "Olha o outro"
    },
    {
      "start": 2451.5,
      "end": 2456.36,
      "text": "É"
    },
    {
      "start": 2456.36,
      "end": 2460.14,
      "text": "Aí, turma"
    },
    {
      "start": 2460.14,
      "end": 2463.75,
      "text": "Isso aí, garoto"
    },
    {
      "start": 2463.75,
      "end": 2466.19,
      "text": "Bora pro próximo"
    },
    {
      "start": 2466.19,
      "end": 2468.94,
      "text": "É isso aí, ó"
    },
    {
      "start": 2468.94,
      "end": 2470.8,
      "text": "Por isso que não pode desistir"
    },
    {
      "start": 2470.8,
      "end": 2472.24,
      "text": "Pegamos um peixe"
    },
    {
      "start": 2472.24,
      "end": 2474.34,
      "text": "Pena que nós já almoçou"
    },
    {
      "start": 2474.34,
      "end": 2475.96,
      "text": "Nós vamos com ele outra hora"
    },
    {
      "start": 2475.96,
      "end": 2477.82,
      "text": "Pensa que ele vai escapar?"
    },
    {
      "start": 2478.08,
      "end": 2478.5,
      "text": "Vai não"
    },
    {
      "start": 2478.5,
      "end": 2480.98,
      "text": "É isso aí"
    },
    {
      "start": 2480.98,
      "end": 2483.02,
      "text": "Vamos buscar outro"
    },
    {
      "start": 2483.02,
      "end": 2484.04,
      "text": "Já jogou de novo lá"
    },
    {
      "start": 2484.04,
      "end": 2487.62,
      "text": "Bora ver quem vai ser o sortudo"
    },
    {
      "start": 2487.62,
      "end": 2488.52,
      "text": "Pegar mais um"
    },
    {
      "start": 2488.52,
      "end": 2489.3,
      "text": "A chuva espalhou"
    },
    {
      "start": 2489.3,
      "end": 2490.94,
      "text": "A chuva foi embora, né?"
    },
    {
      "start": 2491.3,
      "end": 2494.19,
      "text": "Estamos aqui na ativa"
    },
    {
      "start": 2494.19,
      "end": 2498.42,
      "text": "Esse relógio dele é de hora em hora"
    },
    {
      "start": 2498.42,
      "end": 2500.47,
      "text": "Pitando"
    },
    {
      "start": 2500.47,
      "end": 2501.13,
      "text": "Quatro horas"
    },
    {
      "start": 2501.13,
      "end": 2503.26,
      "text": "A cedra"
    },
    {
      "start": 2503.26,
      "end": 2506.7,
      "text": "Acompanha aí"
    },
    {
      "start": 2506.7,
      "end": 2520.54,
      "text": "Tá aí?"
    },
    {
      "start": 2527.47,
      "end": 2528.63,
      "text": "Só experimentou e soltou"
    },
    {
      "start": 2528.63,
      "end": 2538.96,
      "text": "Capivara"
    },
    {
      "start": 2538.96,
      "end": 2541.72,
      "text": "As capivarinhas"
    },
    {
      "start": 2541.72,
      "end": 2542.46,
      "text": "Vem descendo"
    },
    {
      "start": 2542.46,
      "end": 2564.23,
      "text": "Puxou naquela cabecinha"
    },
    {
      "start": 2564.23,
      "end": 2564.45,
      "text": "Do lado"
    },
    {
      "start": 2564.45,
      "end": 2574.66,
      "text": "Até às vezes consegue subir ali"
    },
    {
      "start": 2574.66,
      "end": 2600.61,
      "text": "Peixe, amor"
    },
    {
      "start": 2600.61,
      "end": 2601.65,
      "text": "Pega o peixe"
    },
    {
      "start": 2601.65,
      "end": 2604.13,
      "text": "Esse cerveja aí"
    },
    {
      "start": 2604.13,
      "end": 2604.97,
      "text": "Você não quer pegar, não"
    },
    {
      "start": 2604.97,
      "end": 2619.11,
      "text": "É um briscado no meu também"
    },
    {
      "start": 2619.11,
      "end": 2631.18,
      "text": "É isso aí, meus amigos"
    },
    {
      "start": 2631.18,
      "end": 2632.18,
      "text": "Agora nós vamos embora"
    },
    {
      "start": 2632.18,
      "end": 2632.62,
      "text": "Pra casa"
    },
    {
      "start": 2632.62,
      "end": 2633.98,
      "text": "Chegamos aqui no último ponto"
    },
    {
      "start": 2633.98,
      "end": 2634.82,
      "text": "Aqui de pescaria"
    },
    {
      "start": 2634.82,
      "end": 2635.88,
      "text": "Vamos embora"
    },
    {
      "start": 2635.88,
      "end": 2637.82,
      "text": "E vamos partir pra outra pescaria aí"
    },
    {
      "start": 2637.82,
      "end": 2639.54,
      "text": "Deus quiser vai dar certo"
    },
    {
      "start": 2639.54,
      "end": 2641.34,
      "text": "Bora lá"
    },
    {
      "start": 2641.34,
      "end": 2644.0,
      "text": "É isso aí, meus amigos"
    },
    {
      "start": 2644.0,
      "end": 2645.04,
      "text": "Canova fora d'água"
    },
    {
      "start": 2645.04,
      "end": 2646.28,
      "text": "Vamos ajeitar ali pra nós"
    },
    {
      "start": 2646.28,
      "end": 2648.35,
      "text": "Caminhar no rumo de casa"
    },
    {
      "start": 2648.35,
      "end": 2649.94,
      "text": "É isso aí"
    },
    {
      "start": 2649.94,
      "end": 2651.5,
      "text": "Bora lá"
    },
    {
      "start": 2651.5,
      "end": 2652.93,
      "text": "É isso aí"
    },
    {
      "start": 2652.93,
      "end": 2654.13,
      "text": "Carretinho reengatado"
    },
    {
      "start": 2654.13,
      "end": 2654.93,
      "text": "Bora lá, né?"
    },
    {
      "start": 2655.96,
      "end": 2656.84,
      "text": "Partiu casa"
    },
    {
      "start": 2656.84,
      "end": 2657.32,
      "text": "E aí"
    },
    {
      "start": 2657.32,
      "end": 2657.34,
      "text": "E aí"
    },
    {
      "start": 2657.34,
      "end": 2657.4,
      "text": "E aí"
    },
    {
      "start": 2657.4,
      "end": 2657.96,
      "text": "E aí"
    }
  ],
