      "start": 1114.48,
      "end": 1116.02,
      "text": "Elas subiram e invadiram aí, ó."
    },
    {
      "start": 1117.26,
      "end": 1118.16,
      "text": "Deve tá puro."
    },
    {
      "start": 1118.24,
      "end": 1119.88,
      "text": "Deve ter ficado lotado de piranha aqui."
    },
    {
      "start": 1120.74,
      "end": 1122.04,
      "text": "E essas aí são brabos, hein."
    },
    {
      "start": 1123.37,
      "end": 1123.63,
      "text": "Ó."
    },
    {
      "start": 1123.89,
      "end": 1124.37,
      "text": "Esse carro."
    },
    {
      "start": 1124.55,
      "end": 1125.67,
      "text": "Uma barizinha pequena."
    },
    {
      "start": 1128.46,
      "end": 1128.96,
      "text": "Aqui, ó."
    },
    {
      "start": 1129.08,
      "end": 1130.08,
      "text": "Vai no lambo dele."
    },
    {
      "start": 1134.8,
      "end": 1135.0,
      "text": "Ó."
    },
    {
      "start": 1135.0,
      "end": 1137.0,
      "text": "Vou armar ali de novo."
    },
    {
      "start": 1137.5,
      "end": 1141.44,
      "text": "Armar ali de novo que o frito tá saindo."
    },
    {
      "start": 1143.11,
      "end": 1145.69,
      "text": "Lá pra baixo, quando secar mais, eu vou voltar lá."
    },
    {
      "start": 1146.75,
      "end": 1147.43,
      "text": "Vai ficar bom."
    },
    {
      "start": 1151.25,
      "end": 1152.21,
      "text": "É pra lá, galinha."
    },
    {
      "start": 1152.37,
      "end": 1153.37,
      "text": "Tem nada pra vocês aqui, não."
    },
    {
      "start": 1153.37,
      "end": 1157.25,
      "text": "Agora é pra começar a hora boa."
    },
    {
      "start": 1166.33,
      "end": 1167.51,
      "text": "Tem que retalhar aqui, ó."
    },
    {
      "start": 1169.12,
      "end": 1170.3,
      "text": "Quebrar as espinhas nela."
    },
    {
      "start": 1170.7,
      "end": 1189.52,
      "text": "Tá ajudando não, mas..."
    },
    {
      "start": 1189.52,
      "end": 1190.62,
      "text": "Essa outra piranha aqui, ó."
    },
    {
      "start": 1190.62,
      "end": 1191.94,
      "text": "Decidi fazer o filézinho, ó."
    },
    {
      "start": 1192.56,
      "end": 1193.54,
      "text": "Já tirei de um lado."
    },
    {
      "start": 1195.12,
      "end": 1196.18,
      "text": "Tirar aqui do outro, ó."
    },
    {
      "start": 1197.32,
      "end": 1197.64,
      "text": "Aqui, ó."
    },
    {
      "start": 1197.64,
      "end": 1198.92,
      "text": "Dois filézinhos de piranha."
    },
    {
      "start": 1198.92,
      "end": 1200.91,
      "text": "Só vou vir aqui, ó."
    },
    {
      "start": 1202.94,
      "end": 1206.27,
      "text": "Retalhar o filé pra quebrar a espinha."
    },
    {
      "start": 1225.19,
      "end": 1226.33,
      "text": "E aí, tão servido?"
    },
    {
      "start": 1227.3,
      "end": 1227.52,
      "text": "Ó."
    },
    {
      "start": 1227.88,
      "end": 1228.36,
      "text": "Vermelhinho."
    },
    {
      "start": 1229.02,
      "end": 1231.22,
      "text": "Mas primeiro tem que ter um suquinho pra acompanhar, né."
    },
    {
      "start": 1236.51,
      "end": 1237.37,
      "text": "Agora sim."
    },
    {
      "start": 1243.06,
      "end": 1243.94,
      "text": "Filézinho de piranha."
    },
    {
      "start": 1247.97,
      "end": 1248.23,
      "text": "Hum."
    },
    {
      "start": 1252.28,
      "end": 1252.78,
      "text": "Bom demais."
    },
    {
      "start": 1257.14,
      "end": 1257.84,
      "text": "Cadê meu tio?"
    },
    {
      "start": 1260.95,
      "end": 1261.17,
      "text": "Não."
    },
    {
      "start": 1264.81,
      "end": 1266.79,
      "text": "Pensa no peixe gostoso dessa piranha, filézinho."
    },
    {
      "start": 1267.53,
      "end": 1267.75,
      "text": "Não."
    },
    {
      "start": 1269.14,
      "end": 1270.12,
      "text": "Tá tendo formigueiro."
    },
    {
      "start": 1271.29,
      "end": 1272.23,
      "text": "Não dá pra..."
    },
    {
      "start": 1272.23,
      "end": 1272.37,
      "text": "Tá."
    }
  ],
