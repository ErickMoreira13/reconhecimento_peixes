      "text": "Segura ele aqui que eu vou levar pra ali"
    },
    {
      "start": 873.65,
      "end": 874.23,
      "text": "Bora"
    },
    {
      "start": 874.23,
      "end": 875.68,
      "text": "Vamos ali, gente"
    },
    {
      "start": 875.68,
      "end": 876.36,
      "text": "Vamos levar pra barranca"
    },
    {
      "start": 876.36,
      "end": 877.44,
      "text": "Fazer a soltura, hein"
    },
    {
      "start": 877.44,
      "end": 881.26,
      "text": "Tá bom"
    },
    {
      "start": 881.26,
      "end": 882.32,
      "text": "Vou soltar ele aqui"
    },
    {
      "start": 882.32,
      "end": 885.22,
      "text": "Aí, gente"
    },
    {
      "start": 885.22,
      "end": 888.14,
      "text": "Vamos fazer a medição do gigante aqui agora, ó"
    },
    {
      "start": 888.14,
      "end": 889.82,
      "text": "Mais um troféu de ouro"
    },
    {
      "start": 889.82,
      "end": 897.98,
      "text": "Olha o tamanho do bichão"
    },
    {
      "start": 897.98,
      "end": 900.66,
      "text": "Noventa e cinco centímetros, gente"
    },
    {
      "start": 900.66,
      "end": 902.2,
      "text": "Noventa e cinco centímetros"
    },
    {
      "start": 902.2,
      "end": 903.42,
      "text": "Só que é largo demais, ó"
    },
    {
      "start": 903.42,
      "end": 905.5,
      "text": "Olha a largura desse tambaqui, gente"
    },
    {
      "start": 905.5,
      "end": 906.5,
      "text": "Olha que maravilha"
    },
    {
      "start": 906.5,
      "end": 909.18,
      "text": "Nossa"
    },
    {
      "start": 909.18,
      "end": 911.02,
      "text": "Bom demais"
    },
    {
      "start": 911.02,
      "end": 915.62,
      "text": "Ô, gente"
    },
    {
      "start": 915.62,
      "end": 916.14,
      "text": "Melhor hora"
    },
    {
      "start": 916.14,
      "end": 918.09,
      "text": "Que existe agora, ó"
    },
    {
      "start": 918.09,
      "end": 920.59,
      "text": "Olha aqui o tamanho desse tambaqui, galera"
    },
    {
      "start": 920.59,
      "end": 922.01,
      "text": "Olha aí"
    },
    {
      "start": 922.01,
      "end": 923.87,
      "text": "O tamanho desse tambaqui, gente"
    },
    {
      "start": 923.87,
      "end": 926.01,
      "text": "Não aguento segurar ele, ó"
    },
    {
      "start": 926.01,
      "end": 927.84,
      "text": "Mais um gigante pego"
    },
    {
      "start": 927.84,
      "end": 929.44,
      "text": "Graças a Deus"
    },
    {
      "start": 929.44,
      "end": 930.74,
      "text": "Olha aí"
    },
    {
      "start": 930.74,
      "end": 932.88,
      "text": "Olha o tamanho desse tambaqui"
    },
    {
      "start": 932.88,
      "end": 935.21,
      "text": "Agora"
    },
    {
      "start": 935.21,
      "end": 936.71,
      "text": "Olha aí a largura dele"
    },
    {
      "start": 936.71,
      "end": 937.99,
      "text": "Amarelão"
    },
    {
      "start": 937.99,
      "end": 938.33,
      "text": "Lindo"
    },
    {
      "start": 938.33,
      "end": 940.3,
      "text": "Mais um pra vida"
    },
    {
      "start": 940.3,
      "end": 942.15,
      "text": "Graças a Deus"
    },
    {
      "start": 942.15,
      "end": 944.14,
      "text": "Vai, vai pra vida"
    },
    {
      "start": 944.14,
      "end": 946.04,
      "text": "Foi pra vida"
    },
    {
      "start": 946.04,
      "end": 948.02,
      "text": "Ô, companheiro"
    },
    {
      "start": 948.02,
      "end": 948.56,
      "text": "Vem, hein"
    },
    {
      "start": 948.56,
      "end": 950.34,
      "text": "Nossa senhora"
    },
    {
      "start": 950.34,
      "end": 951.46,
      "text": "Bom de mar da conta"
    },
    {
      "start": 951.46,
      "end": 954.08,
      "text": "Pega uma pra nós aí, companheiro"
    },
    {
      "start": 954.08,
      "end": 955.14,
      "text": "Bora"
    },
    {
      "start": 955.14,
      "end": 956.26,
      "text": "Mas merece, senhor"
    },
    {
      "start": 956.26,
      "end": 956.64,
      "text": "Merece?"
    },
    {
      "start": 956.64,
      "end": 958.02,
      "text": "Só bebe cerveja"
    },
    {
      "start": 958.02,
      "end": 959.04,
      "text": "Quem peca tambaqui"
    },
    {
      "start": 959.04,
      "end": 960.76,
      "text": "Ô, a parceria foi foda, não foi?"
    },
    {
      "start": 961.86,
      "end": 962.64,
      "text": "Vou pegar um par"
    },
    {
      "start": 962.64,
      "end": 963.32,
      "text": "Aí, rapaz"
    },
    {
      "start": 963.32,
      "end": 964.94,
      "text": "Nós perdemos dois gigantes hoje, hein"
    },
    {
      "start": 964.94,
      "end": 965.72,
      "text": "Mas tirou dois"
    },
    {
      "start": 965.72,
      "end": 966.66,
      "text": "Mas tirou dois, né?"
    },
    {
      "start": 967.16,
      "end": 967.66,
      "text": "Tá bom"
    },
    {
      "start": 967.66,
      "end": 968.28,
      "text": "Aí, gente"
    },
    {
      "start": 968.28,
      "end": 969.78,
      "text": "Você não sabe a satisfação que eu tô aqui"
    },
    {
      "start": 969.78,
      "end": 971.76,
      "text": "O meu companheiro Diego de Goiatuba"
    },
    {
      "start": 971.76,
      "end": 973.2,
      "text": "A meta do nosso tá boa"
    },
    {
      "start": 973.2,
      "end": 974.54,
      "text": "Tá excelente, né?"
    },
    {
      "start": 975.25,
      "end": 975.83,
      "text": "Aí, ó"
    },
    {
      "start": 975.83,
      "end": 976.57,
      "text": "Segundo, ó"
    },
    {
      "start": 976.57,
      "end": 978.54,
      "text": "De Antártica gelada"
    },
    {
      "start": 978.54,
      "end": 980.81,
      "text": "Vamos brindar, né, companheiro?"
    },
    {
      "start": 983.18,
      "end": 984.06,
      "text": "Isso aí, gente, ó"
    },
    {
      "start": 984.06,
      "end": 986.08,
      "text": "Dezessete do dois"
    },
    {
      "start": 986.08,
      "end": 986.84,
      "text": "Segunda-feira"
    },
    {
      "start": 986.84,
      "end": 988.32,
      "text": "Às quinze e quarenta e um da tarde"
    },
    {
      "start": 988.32,
      "end": 989.18,
      "text": "Tamo aqui de boa"
    },
    {
      "start": 989.18,
      "end": 990.08,
      "text": "Três e quarenta agora"
    },
    {
      "start": 990.08,
      "end": 991.0,
      "text": "Três e quarenta"
    },
    {
      "start": 991.0,
      "end": 991.02,
      "text": "Três e quarenta"
    },
    {
      "start": 991.02,
      "end": 992.06,
      "text": "Foi produtivo"
    },
    {
      "start": 992.06,
      "end": 992.68,
      "text": "Foi pelo horário"
    },
    {
      "start": 992.68,
      "end": 994.04,
      "text": "Agora aí nós vamos atrás das curvinhas"
    },
    {
      "start": 994.04,
      "end": 994.62,
      "text": "Dos barbados?"
    },
    {
      "start": 996.04,
      "end": 996.62,
      "text": "Tardezinha, né?"
    },
    {
      "start": 996.72,
      "end": 997.1,
      "text": "Ei, gente"
    },
    {
      "start": 997.1,
      "end": 997.94,
      "text": "Peça esportiva"
    },
    {
      "start": 997.94,
      "end": 998.5,
      "text": "Top"
    },
    {
      "start": 998.5,
      "end": 1003.14,
      "text": "E o Paranaíba não falha não, né?"
    },
    {
      "start": 1003.93,
      "end": 1004.23,
      "text": "Não"
    },
    {
      "start": 1004.23,
      "end": 1004.87,
      "text": "Aqui no Paranaíba"
    },
    {
      "start": 1004.87,
      "end": 1005.63,
      "text": "Não puxa é"
    },
    {
      "start": 1005.63,
      "end": 1008.03,
      "text": "Tem que tacar as correias apertadas"
    },
    {
      "start": 1008.03,
      "end": 1008.55,
      "text": "No Goiás"
    },
    {
      "start": 1008.55,
      "end": 1009.83,
      "text": "O Goiás tem muito peixe ainda, não tem?"
    },
    {
      "start": 1009.83,
      "end": 1010.15,
      "text": "Tem"
    },
    {
      "start": 1010.15,
      "end": 1011.43,
      "text": "Maravilha"
    },
    {
      "start": 1011.43,
      "end": 1012.91,
      "text": "Tem que ter gente que preserva"
    },
    {
      "start": 1012.91,
      "end": 1013.97,
      "text": "Tem que preservar, né, galera?"
    },
    {
      "start": 1014.19,
      "end": 1014.95,
      "text": "É, isso aí"
    },
    {
      "start": 1014.95,
      "end": 1018.2,
      "text": "Bom demais, meu povo"
    },
    {
      "start": 1018.2,
      "end": 1018.84,
      "text": "Tamo junto"
    }
