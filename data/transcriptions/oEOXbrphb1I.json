    },
    {
      "start": 524.7,
      "end": 525.36,
      "text": "Solta o bicho lá."
    },
    {
      "start": 525.36,
      "end": 527.21,
      "text": "Olha que ele tá com fôlego."
    },
    {
      "start": 528.67,
      "end": 530.21,
      "text": "Boa, garoto."
    },
    {
      "start": 531.03,
      "end": 532.07,
      "text": "Tamo junto."
    },
    {
      "start": 538.39,
      "end": 539.95,
      "text": "Nossa, o que é matrinchar atrás da outra aqui?"
    },
    {
      "start": 547.92,
      "end": 550.86,
      "text": "Essa garantainha aqui é boa, viu?"
    },
    {
      "start": 550.86,
      "end": 553.37,
      "text": "É, moça."
    },
    {
      "start": 553.49,
      "end": 555.85,
      "text": "Essa isquinha aqui é espinazinho mesmo, viu?"
