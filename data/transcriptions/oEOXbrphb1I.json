    {
      "start": 558.14,
      "end": 558.44,
      "text": "Só."
    },
    {
      "start": 558.44,
      "end": 577.76,
      "text": "Soltou, você viu, né?"
    },
    {
      "start": 580.92,
      "end": 581.88,
      "text": "Fala os passaguais aí, Vitinho."
    },
    {
      "start": 589.23,
      "end": 590.41,
      "text": "É, sim, dourado, hein?"
    },
    {
      "start": 593.04,
      "end": 593.26,
      "text": "É."
    },
    {
      "start": 596.0,
      "end": 597.1,
      "text": "Vai cortar, tá sem lida."
