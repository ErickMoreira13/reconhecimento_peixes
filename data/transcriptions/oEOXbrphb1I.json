    },
    {
      "start": 503.07,
      "end": 503.59,
      "text": "Pode ir?"
    },
    {
      "start": 503.81,
      "end": 504.93,
      "text": "Filma com seu laço também, pra vocês perem."
    },
    {
      "start": 511.92,
      "end": 512.48,
      "text": "Fala aí, Vitinho."
    },
    {
      "start": 512.56,
      "end": 513.4,
      "text": "Qual que é a emoção, irmão?"
    },
    {
      "start": 513.44,
      "end": 513.92,
      "text": "Você tá doido."
    },
    {
      "start": 513.94,
      "end": 514.56,
      "text": "Primeiro dourado."
    },
    {
      "start": 514.78,
      "end": 515.56,
      "text": "Primeiro douradinho."
    },
    {
      "start": 515.62,
      "end": 516.52,
      "text": "Rio de sono aí, galera."
    },
    {
      "start": 516.66,
      "end": 517.12,
      "text": "Rio de sono."
    },
    {
      "start": 517.78,
      "end": 518.7,
      "text": "Solta o bicho lá, Vitinho."
    },
    {
      "start": 518.74,
      "end": 519.36,
      "text": "Solta o bicho, né?"
    },
    {
      "start": 519.36,
