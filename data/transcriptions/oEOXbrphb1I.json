      "end": 601.71,
      "text": "Ó."
    },
    {
      "start": 602.21,
      "end": 609.64,
      "text": "Na lirinha, velho."
    },
    {
      "start": 609.86,
      "end": 611.18,
      "text": "Ah, corta não, vagabundo."
    },
    {
      "start": 612.24,
