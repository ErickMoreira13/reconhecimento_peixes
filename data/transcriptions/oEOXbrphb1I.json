    {
      "start": 498.51,
      "end": 498.91,
      "text": "Sou."
    },
    {
      "start": 499.35,
      "end": 500.01,
      "text": "Fazer a soltura?"
    },
    {
      "start": 500.27,
      "end": 501.09,
      "text": "Solta o bicho aqui, ó."
    },
    {
      "start": 501.65,
      "end": 502.35,
