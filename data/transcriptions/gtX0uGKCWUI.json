    },
    {
      "start": 1066.31,
      "end": 1069.19,
      "text": "Vágio"
    },
    {
      "start": 1069.19,
      "end": 1073.77,
      "text": "E sai um peixe"
    },
    {
      "start": 1073.77,
      "end": 1074.89,
      "text": "Sai mais um alô aí, hein"
    },
    {
      "start": 1074.89,
      "end": 1075.21,
      "text": "Fabio"
    },
    {
      "start": 1075.21,
      "end": 1076.83,
      "text": "Eu nem sei onde eu falei"
