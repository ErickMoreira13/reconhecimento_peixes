    {
      "start": 1165.17,
      "end": 1166.97,
      "text": "No Franco"
    },
    {
      "start": 1166.97,
      "end": 1167.57,
      "text": "Com Grozelho"
    },
    {
      "start": 1167.57,
      "end": 1168.11,
