    },
    {
      "start": 993.77,
      "end": 996.15,
      "text": "No franco com groselho"
    },
    {
      "start": 996.15,
      "end": 996.69,
      "text": "Mas, tá mais"
    },
    {
      "start": 996.69,
      "end": 997.85,
      "text": "É na minhoca mesmo"
    },
    {
      "start": 997.85,
      "end": 1000.4,
      "text": "Acho que é por causa do movimento"
    },
    {
      "start": 1000.4,
      "end": 1002.71,
      "text": "Chama atenção"
    },
    {
      "start": 1002.71,
