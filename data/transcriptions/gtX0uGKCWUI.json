      "start": 783.44,
      "end": 787.6,
      "text": "Vou mostrar pra vocês ali"
    },
    {
      "start": 787.6,
      "end": 790.35,
      "text": "Eu fiz um tantinho bom"
    },
    {
      "start": 790.35,
      "end": 793.67,
      "text": "Aqui, família"
    },
    {
      "start": 793.67,
      "end": 794.49,
      "text": "Falei pra vocês"
    },
    {
      "start": 794.49,
      "end": 797.43,
      "text": "Você corta ele em cubinho"
    },
    {
      "start": 797.43,
      "end": 797.85,
      "text": "Certo?"
    },
    {
      "start": 798.96,
      "end": 799.84,
      "text": "Coloca no sol"
    },
    {
      "start": 799.84,
      "end": 803.02,
      "text": "Corta ele em cubinho"
    },
    {
      "start": 803.02,
      "end": 805.08,
      "text": "E coloca groselha"
    },
    {
      "start": 805.08,
      "end": 806.12,
      "text": "E deixa de um dia pro outro"
    },
    {
      "start": 806.12,
      "end": 807.06,
      "text": "A cor que fica"
    },
    {
      "start": 807.06,
      "end": 808.62,
      "text": "Ó"
    },
    {
      "start": 808.62,
      "end": 811.44,
      "text": "A mão tá limpinha"
    },
    {
      "start": 811.44,
      "end": 812.24,
      "text": "Não é uma beleza"
    },
    {
      "start": 812.24,
      "end": 813.82,
      "text": "Mas é"
    },
    {
      "start": 813.82,
      "end": 815.08,
      "text": "Eu fiz uma tantadinha bom"
    },
    {
      "start": 815.08,
      "end": 816.28,
      "text": "Aqui tem o que?"
    },
    {
      "start": 817.39,
      "end": 818.51,
      "text": "Dois bifinhos"
    },
    {
      "start": 818.51,
      "end": 821.31,
      "text": "Comprei em bife mesmo"
    },
    {
      "start": 821.31,
      "end": 823.27,
      "text": "Cortei os pedacinhos"
    },
    {
      "start": 823.27,
      "end": 824.93,
      "text": "Cara, não sai a cor"
    },
    {
      "start": 824.93,
      "end": 828.03,
      "text": "E nem o cheiro"
    },
    {
      "start": 828.03,
      "end": 829.41,
      "text": "E fica docinho o frango"
    },
    {
      "start": 829.41,
      "end": 831.83,
      "text": "Tá puxando pra caramba"
    },
    {
      "start": 831.83,
      "end": 832.57,
      "text": "Nesse também, viu?"
    },
    {
      "start": 833.09,
      "end": 834.09,
      "text": "Ó uma dica aí"
    },
    {
      "start": 834.09,
      "end": 848.08,
      "text": "Mas, ô"
    },
    {
      "start": 848.08,
      "end": 852.11,
      "text": "A criadinha"
    },
    {
      "start": 852.11,
      "end": 854.87,
      "text": "Maior que os outros"
    },
    {
      "start": 854.87,
      "end": 863.77,
      "text": "Cargume aqui, pra mim"
    },
    {
      "start": 863.77,
      "end": 875.98,
      "text": "Ai, duro"
    },
    {
      "start": 875.98,
      "end": 877.78,
      "text": "Aí, ó"
    },
    {
      "start": 877.78,
      "end": 882.54,
      "text": "Aqui a gente coloca"
    },
    {
      "start": 882.54,
      "end": 884.12,
      "text": "Bem minhoca, né?"
    },
    {
      "start": 884.18,
      "end": 885.18,
      "text": "Bastantinha minhoca"
    },
    {
      "start": 885.18,
      "end": 888.93,
      "text": "Puxa, não"
    },
    {
      "start": 888.93,
      "end": 892.1,
      "text": "Pode ficar de miseria"
    },
    {
      "start": 892.1,
      "end": 892.36,
      "text": "Com"
    },
    {
      "start": 892.36,
      "end": 894.9,
      "text": "Com isca, não"
    },
    {
      "start": 894.9,
      "end": 896.41,
      "text": "Aí, ó"
    },
    {
      "start": 896.41,
      "end": 900.67,
      "text": "Ai, duro"
    },
    {
      "start": 900.67,
      "end": 902.33,
      "text": "Saiu um peixe"
    },
    {
      "start": 902.33,
      "end": 903.17,
      "text": "Saiu mais um alô"
    },
    {
      "start": 903.17,
      "end": 903.79,
      "text": "Aí, hein, família"
    },
    {
      "start": 903.79,
      "end": 905.43,
      "text": "Eu nem sei onde eu parei"
    },
    {
      "start": 905.43,
      "end": 906.07,
      "text": "Aqui, de novo"
    },
    {
      "start": 906.07,
      "end": 908.18,
      "text": "Mas, vamos lá"
    },
    {
      "start": 908.18,
      "end": 909.48,
      "text": "Luiz Claudio Mariano"
    },
    {
      "start": 909.48,
      "end": 911.42,
      "text": "Viviane Amâncio"
    },
    {
      "start": 911.42,
      "end": 912.9,
      "text": "David Silva"
    },
    {
      "start": 912.9,
      "end": 914.86,
      "text": "Pedro Velino"
    },
    {
      "start": 914.86,
      "end": 915.82,
      "text": "Pescador"
    },
    {
      "start": 915.82,
      "end": 916.68,
      "text": "Fala, Pedro"
    },
    {
      "start": 916.68,
      "end": 919.34,
      "text": "Elisa Martins"
    },
    {
      "start": 919.34,
      "end": 921.21,
      "text": "Manzola"
    },
    {
      "start": 921.21,
      "end": 923.07,
      "text": "De Sete Lagos"
    },
    {
      "start": 923.07,
      "end": 924.53,
      "text": "E o Sidney"
    },
    {
      "start": 924.53,
      "end": 926.72,
      "text": "Certo?"
    },
    {
      "start": 929.29,
      "end": 930.69,
      "text": "Amigo, quem estiver gostando aí"
    },
    {
      "start": 930.69,
      "end": 931.89,
      "text": "Se inscreve"
    },
    {
      "start": 931.89,
      "end": 932.83,
      "text": "Deixa um joinha aí"
    },
    {
      "start": 932.83,
      "end": 934.55,
      "text": "Compartilha com a galera"
    },
    {
      "start": 934.55,
      "end": 935.75,
      "text": "Pra ajudar o canal aí"
    },
    {
      "start": 935.75,
      "end": 938.0,
      "text": "A dar uma crescida"
    },
    {
      "start": 938.0,
      "end": 940.93,
      "text": "E tem mais uma galera"
    },
    {
      "start": 940.93,
      "end": 944.13,
      "text": "Que tá sempre com nós aí também"
    },
    {
      "start": 944.13,
      "end": 945.57,
      "text": "O Flávio Becker"
    },
    {
      "start": 945.57,
      "end": 946.35,
      "text": "O Anísio"
    },
    {
