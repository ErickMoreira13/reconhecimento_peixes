    },
    {
      "start": 1169.27,
      "end": 1171.2,
      "text": "Acho que é por causa"
    },
    {
      "start": 1171.2,
      "end": 1171.82,
      "text": "Do movimento"
    },
    {
      "start": 1171.82,
      "end": 1174.26,
      "text": "A gente dá uma tensão"
    },
    {
      "start": 1174.26,
      "end": 1193.56,
      "text": "Aí, família"
    },
    {
      "start": 1193.56,
      "end": 1204.44,
      "text": "Tá pequenininho"
    },
    {
      "start": 1204.44,
      "end": 1205.4,
      "text": "Vamos soltar ele"
    },
    {
      "start": 1205.4,
      "end": 1207.9,
      "text": "Vamos soltar o bichinho"
    },
    {
      "start": 1207.9,
      "end": 1230.9,
      "text": "Foi, boa"
    },
    {
      "start": 1230.9,
      "end": 1234.75,
      "text": "Viu que bonitinho, família"
    },
    {
      "start": 1234.75,
      "end": 1235.77,
      "text": "Esse é fiotinho"
    },
    {
      "start": 1235.77,
      "end": 1236.67,
      "text": "Tem que soltar, né"
    },
    {
      "start": 1236.67,
      "end": 1239.4,
      "text": "Continuar a pescaria aí"
    },
    {
      "start": 1239.4,
      "end": 1260.67,
      "text": "Aê, mano"
    },
    {
      "start": 1260.67,
      "end": 1263.11,
      "text": "Nossa"
    },
    {
      "start": 1263.11,
      "end": 1263.99,
      "text": "Esse eu peguei"
    },
    {
      "start": 1263.99,
      "end": 1265.07,
      "text": "Nem foi pela boca"
    },
    {
      "start": 1265.07,
      "end": 1265.81,
      "text": "Foi por baixo"
    },
    {
      "start": 1265.81,
      "end": 1273.73,
      "text": "Até pra pegar"
    },
    {
      "start": 1273.73,
      "end": 1276.91,
      "text": "Aê"
    },
    {
      "start": 1276.91,
      "end": 1287.86,
      "text": "A turma"
    },
    {
      "start": 1287.86,
      "end": 1289.14,
      "text": "Tá pegando bastante peixe"
    },
    {
      "start": 1289.14,
      "end": 1289.8,
      "text": "Lá do outro lado"
    },
    {
      "start": 1289.8,
      "end": 1292.99,
      "text": "Rapaziada"
    },
    {
      "start": 1292.99,
      "end": 1294.05,
      "text": "Você não fica muito tempo"
    },
    {
      "start": 1294.05,
      "end": 1294.93,
      "text": "Sem ação aqui"
    },
    {
      "start": 1294.93,
      "end": 1296.09,
      "text": "Toda hora, puxa"
    },
    {
      "start": 1296.09,
      "end": 1298.31,
      "text": "Pocinho que é o ouro"
    },
    {
      "start": 1298.31,
      "end": 1304.3,
      "text": "Ai, viu"
    },
    {
      "start": 1304.3,
      "end": 1328.08,
      "text": "Vai sair"
    },
    {
      "start": 1328.08,
      "end": 1329.38,
      "text": "Como é que tá bonito"
    },
    {
      "start": 1329.38,
      "end": 1330.28,
      "text": "Esse peixe"
    },
    {
      "start": 1330.28,
      "end": 1335.86,
      "text": "Cheio de bolinha"
    },
    {
      "start": 1335.86,
      "end": 1338.77,
      "text": "Tem uns lugares"
    },
    {
      "start": 1338.77,
      "end": 1339.55,
      "text": "Que o pessoal fala"
    },
    {
      "start": 1339.55,
      "end": 1341.35,
      "text": "Que é chamado de pintado, né"
    },
    {
      "start": 1341.35,
      "end": 1343.05,
      "text": "Em algumas regiões"
    },
    {
      "start": 1343.05,
      "end": 1345.93,
      "text": "Muito bonitinho"
    },
    {
      "start": 1345.93,
      "end": 1352.39,
      "text": "Cabeça do bicho"
