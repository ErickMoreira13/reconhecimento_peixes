    },
    {
      "start": 1023.26,
      "end": 1032.24,
      "text": "Cardume aqui, Fabio"
    },
    {
      "start": 1032.24,
      "end": 1033.06,
      "text": "Vamos lá"
    },
    {
      "start": 1033.06,
      "end": 1047.69,
