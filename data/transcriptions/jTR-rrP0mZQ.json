    {
      "start": 569.73,
      "end": 570.53,
      "text": "Que a gente vai jogar na brasa"
    },
    {
      "start": 570.53,
      "end": 571.19,
      "text": "Daqui a pouco"
    },
    {
      "start": 571.19,
      "end": 573.76,
      "text": "Falar em brasa"
    },
    {
      "start": 573.76,
      "end": 574.66,
      "text": "A gente vai já fazer o fogo"
    },
    {
      "start": 574.66,
      "end": 579.14,
      "text": "Já fazer"
    },
    {
      "start": 579.14,
      "end": 580.25,
      "text": "Dois tiros"
    },
    {
      "start": 580.25,
      "end": 580.89,
      "text": "Qual é o que vocês querem"
    },
    {
      "start": 580.89,
      "end": 581.49,
      "text": "Que eu derrubo"
    },
    {
      "start": 581.49,
      "end": 586.2,
      "text": "Ô Amazonazão bonito"
    },
    {
      "start": 586.2,
      "end": 616.46,
      "text": "É primo"
    },
    {
      "start": 616.46,
      "end": 616.82,
      "text": "Pelo visto"
    },
    {
      "start": 616.82,
      "end": 617.96,
      "text": "O almoço hoje vai ser"
    },
    {
      "start": 617.96,
      "end": 618.9,
      "text": "Só por conta da tarrafa"
    },
    {
      "start": 618.9,
      "end": 620.99,
      "text": "Porque os pescadores de linha"
    },
    {
      "start": 620.99,
      "end": 621.71,
      "text": "Estão foda"
    },
    {
      "start": 621.71,
      "end": 624.93,
      "text": "Você não vira cobra não?"
    },
    {
      "start": 625.37,
      "end": 625.91,
      "text": "Não vi não"
    },
    {
      "start": 625.91,
      "end": 628.83,
      "text": "Tinha um jacarézinho lá"
    },
    {
      "start": 628.83,
      "end": 630.67,
      "text": "Tivesse levado a carabina"
    },
    {
      "start": 630.67,
      "end": 632.27,
      "text": "Não é açaí"
    },
    {
      "start": 632.27,
      "end": 632.91,
      "text": "É"
    },
    {
      "start": 632.91,
      "end": 634.67,
      "text": "Ele não era muito pequenininho não"
    },
    {
      "start": 634.67,
      "end": 637.75,
      "text": "Já era um adolescente já"
    },
    {
      "start": 637.75,
      "end": 644.59,
      "text": "Ele é o pescador mirim"
    },
    {
      "start": 644.59,
      "end": 646.57,
      "text": "Riscando ali o anzol dele"
    },
    {
      "start": 646.57,
      "end": 648.15,
      "text": "Para jogar no rio"
    },
    {
      "start": 648.15,
      "end": 651.23,
      "text": "Pula mais dentro d'água"
    },
    {
      "start": 651.23,
      "end": 651.93,
      "text": "Que pesca"
    },
    {
      "start": 651.93,
      "end": 654.09,
      "text": "Mas só se ele buscar o peixe"
    },
    {
      "start": 654.09,
      "end": 654.87,
      "text": "Lá no fundo do rio"
    },
    {
      "start": 654.87,
      "end": 658.29,
      "text": "Esses daqui vão já para a brasa"
    },
    {
      "start": 658.29,
      "end": 663.36,
      "text": "Tudo é na cura aqui"
    },
    {
      "start": 663.36,
      "end": 666.76,
      "text": "São muito ruim na brasa"
    },
    {
      "start": 666.76,
      "end": 667.18,
      "text": "Esses daqui"
    },
    {
      "start": 667.18,
      "end": 673.66,
      "text": "O assado aqui já está na brasa"
    },
    {
      "start": 673.66,
      "end": 675.24,
      "text": "Daqui a pouco a gente comeu"
    },
    {
      "start": 675.24,
      "end": 687.37,
      "text": "Daqui a pouco está estralando"
    },
    {
      "start": 687.37,
      "end": 696.1,
      "text": "Cadê o pescador?"
    },
    {
      "start": 700.73,
      "end": 702.21,
      "text": "Eu agora a tarrafa aberta"
    },
    {
      "start": 702.21,
      "end": 706.97,
      "text": "Eu vim pegar o peixe que eu estava fechado"
    },
    {
      "start": 706.97,
      "end": 716.85,
      "text": "Ai desgrama"
    },
    {
      "start": 716.85,
      "end": 722.24,
      "text": "Olha os bichos tão bonitos"
    },
    {
      "start": 722.24,
      "end": 729.62,
      "text": "Vamos simbora"
    },
    {
      "start": 729.62,
      "end": 737.86,
      "text": "Pegar um tambaquia"
    },
    {
      "start": 737.86,
      "end": 739.44,
      "text": "Tambaquia"
    },
    {
      "start": 739.44,
      "end": 745.24,
      "text": "É pegar um boto desse jeito"
    },
    {
      "start": 745.24,
      "end": 747.71,
      "text": "Olha aí o assado dos caras"
    },
    {
      "start": 747.71,
      "end": 748.37,
      "text": "Será que está bom?"
    },
    {
      "start": 750.11,
      "end": 751.11,
      "text": "É desgrama"
    },
    {
      "start": 751.11,
      "end": 753.95,
      "text": "Só o aracu na brasa"
    },
    {
      "start": 753.95,
      "end": 755.09,
      "text": "E o vinagretinho"
    },
    {
      "start": 755.09,
      "end": 756.9,
      "text": "Será que está bom vinagrete?"
    },
    {
      "start": 758.62,
      "end": 760.06,
      "text": "Está me batendo a garganta"
    },
    {
      "start": 760.06,
      "end": 760.6,
      "text": "Tu vai ver"
    },
    {
      "start": 760.6,
      "end": 762.91,
      "text": "E aqui"
    },
    {
      "start": 762.91,
      "end": 768.02,
      "text": "O gulho está bom também"
    },
    {
      "start": 768.02,
      "end": 773.46,
      "text": "Só que me moe"
    },
    {
      "start": 773.46,
      "end": 775.68,
      "text": "Mozinho"
    },
    {
      "start": 775.68,
      "end": 785.45,
      "text": "Isso aqui deu uma colherada"
    },
    {
      "start": 785.45,
      "end": 786.47,
      "text": "No vinagrete com o pimento"
    },
    {
      "start": 786.47,
      "end": 787.59,
      "text": "Que parece que ardeu"
    },
    {
      "start": 787.59,
      "end": 789.45,
      "text": "Não está ardendo muito"
    },
    {
      "start": 789.45,
      "end": 800.96,
      "text": "Olha o assado do Gustavo Lima"
    },
    {
      "start": 800.96,
      "end": 801.7,
      "text": "Embaixador"
    },
    {
      "start": 801.7,
      "end": 805.63,
      "text": "Dizendo que vai para a igreja"
    },
    {
      "start": 805.63,
      "end": 807.11,
      "text": "Vai é porra"
    },
    {
      "start": 807.11,
      "end": 809.25,
      "text": "Olha aí rapaziada"
    },
    {
      "start": 809.25,
      "end": 812.18,
      "text": "Terminando a nossa pescaria de hoje"
    },
    {
      "start": 812.18,
      "end": 814.41,
      "text": "Não deu tão bom"
    },
    {
      "start": 814.41,
      "end": 815.99,
      "text": "Porque a pescaria de linha"
    },
    {
      "start": 815.99,
      "end": 817.63,
      "text": "Não estava muito propícia hoje"
    },
    {
      "start": 817.63,
      "end": 819.33,
      "text": "Não estava dando muito peixe de couro"
    },
    {
      "start": 819.33,
      "end": 822.06,
      "text": "Só deu lucro mesmo na tarrafa"
    },
    {
      "start": 822.06,
      "end": 823.34,
      "text": "Que meu primo trouxe"
    },
    {
      "start": 823.34,
      "end": 826.09,
      "text": "Inclusive o peixe que a gente comeu no almoço"
    },
    {
      "start": 826.09,
      "end": 826.37,
      "text": "Foi"
    },
    {
      "start": 826.37,
      "end": 829.71,
      "text": "Foram todos pegos na tarrafa"
    },
    {
      "start": 829.71,
      "end": 832.32,
      "text": "Se a gente fosse depender do"
    },
    {
      "start": 832.32,
      "end": 835.64,
      "text": "Se a gente fosse depender da pesca de linha"
    },
    {
      "start": 835.64,
      "end": 836.84,
      "text": "A gente estava lascado hoje"
    },
    {
      "start": 836.84,
      "end": 838.72,
      "text": "Mas é isso aí"
    },
    {
      "start": 838.72,
      "end": 842.18,
      "text": "O que vale é a aventura aqui"
    },
    {
      "start": 842.18,
      "end": 844.15,
      "text": "Passar o dia que"
    },
    {
      "start": 844.15,
      "end": 846.71,
      "text": "A gente está junto"
    },
    {
      "start": 846.71,
      "end": 847.65,
      "text": "Da natureza aqui"
    },
    {
      "start": 847.65,
      "end": 848.11,
      "text": "Melhor que"
    },
    {
      "start": 848.11,
      "end": 849.75,
      "text": "Cidade"
    },
    {
      "start": 849.75,
      "end": 851.34,
      "text": "A gente passa o dia"
    },
    {
      "start": 851.34,
      "end": 852.2,
      "text": "O dia não"
    },
    {
      "start": 852.2,
      "end": 853.16,
      "text": "A semana eu estou na cidade"
    },
    {
      "start": 853.16,
      "end": 853.86,
      "text": "Fim de semana"
    },
    {
      "start": 853.86,
      "end": 855.51,
      "text": "A gente quer saber disso"
    },
    {
      "start": 855.51,
      "end": 856.05,
      "text": "Natureza"
    },
    {
      "start": 856.05,
      "end": 856.95,
      "text": "A gente quer saber do mato"
    },
    {
      "start": 856.95,
      "end": 858.59,
      "text": "É isso aí"
    },
    {
      "start": 858.59,
      "end": 860.4,
      "text": "Quem gostou"
    },
    {
      "start": 860.4,
      "end": 862.76,
      "text": "Continua acompanhando nossos vídeos"
    },
    {
      "start": 862.76,
      "end": 863.42,
      "text": "Deixa o like"
    },
    {
      "start": 863.42,
      "end": 864.34,
      "text": "Segue aí"
    },
    {
      "start": 864.34,
      "end": 864.92,
      "text": "Quem não segue"
    },
    {
      "start": 864.92,
      "end": 866.62,
      "text": "Tamo junto rapaziada"
    },
    {
      "start": 866.62,
      "end": 867.08,
      "text": "Obrigado"
    },
    {
      "start": 867.08,
      "end": 870.84,
      "text": "Pronto"
    },
    {
      "start": 870.84,
      "end": 871.66,
      "text": "Final de pescaria"
    },
    {
      "start": 871.66,
      "end": 872.84,
      "text": "É hora da travessia de volta"
    },
    {
      "start": 872.84,
      "end": 874.72,
      "text": "Vamos embora"
    }
