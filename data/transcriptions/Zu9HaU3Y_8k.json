    {
      "start": 624.87,
      "end": 627.39,
      "text": "Essa aqui é a graúda"
    },
    {
      "start": 627.39,
      "end": 629.15,
      "text": "Mas a outra ainda é maior ainda"
    },
    {
      "start": 629.15,
      "end": 632.16,
      "text": "A lagosta vermelha"
    },
    {
      "start": 632.16,
      "end": 633.46,
      "text": "O ouro do mar"
    },
    {
      "start": 633.46,
      "end": 635.42,
      "text": "Segura aí, meu pai"
    },
    {
      "start": 635.42,
      "end": 638.39,
      "text": "Olha o tamanho dessa graudona aqui, galera"
    },
    {
      "start": 638.39,
      "end": 641.52,
      "text": "Olha o tamanho da lagosta"
    },
    {
      "start": 641.52,
      "end": 645.33,
      "text": "Essa aqui é o ouro do mar"
    },
    {
      "start": 645.33,
      "end": 648.51,
      "text": "A lagosta vermelha"
    },
    {
      "start": 648.51,
      "end": 650.46,
      "text": "Eita, Jesus"
    },
    {
      "start": 650.46,
      "end": 652.02,
      "text": "Multiplica, Jesus"
    },
    {
      "start": 652.02,
      "end": 655.3,
      "text": "Já puxamos aí umas 18 armadilhas"
    },
    {
      "start": 655.3,
      "end": 658.46,
      "text": "E agora que subiu duas lagostas grandes"
    },
    {
      "start": 658.46,
      "end": 660.62,
      "text": "Mas assim, aos pouquinhos"
    },
    {
      "start": 660.62,
      "end": 662.1,
      "text": "Nós vamos agradecendo a Jesus"
    },
    {
      "start": 662.1,
      "end": 664.76,
      "text": "Porque nós não deixamos nada aqui"
    },
    {
      "start": 664.76,
      "end": 666.46,
      "text": "E a glória é para Jesus"
    },
    {
      "start": 666.46,
      "end": 668.16,
      "text": "O pouquinho que a gente tira"
    },
    {
      "start": 668.16,
      "end": 669.3,
      "text": "A gente agradece"
    },
    {
      "start": 669.3,
      "end": 671.74,
      "text": "Segura aí, meu pai"
    },
    {
      "start": 671.74,
      "end": 673.58,
      "text": "Eita, Jesus"
    },
    {
      "start": 673.58,
      "end": 675.26,
      "text": "Multiplica e manda mais"
    },
    {
      "start": 675.26,
      "end": 679.46,
      "text": "Espera, não"
    },
    {
      "start": 679.46,
      "end": 683.36,
      "text": "Aí, galera"
    },
    {
      "start": 683.36,
      "end": 686.58,
      "text": "Tá saindo"
    },
    {
      "start": 686.58,
      "end": 688.5,
      "text": "O ouro do mar"
    },
    {
      "start": 688.5,
      "end": 689.52,
      "text": "Tá saindo"
    },
    {
      "start": 689.52,
      "end": 692.76,
      "text": "Graças a Deus, galera"
    },
    {
      "start": 692.76,
      "end": 695.15,
      "text": "Saiu mais dois aí"
    },
    {
      "start": 695.15,
      "end": 695.65,
      "text": "Vou tirar"
    },
    {
      "start": 695.65,
      "end": 697.86,
      "text": "Tirar aqui"
    },
    {
      "start": 697.86,
      "end": 699.48,
      "text": "A lagosta"
    },
    {
      "start": 699.48,
      "end": 702.86,
      "text": "Que é o ouro do mar"
    },
    {
      "start": 702.86,
      "end": 703.44,
      "text": "Galera"
    },
    {
      "start": 703.44,
      "end": 704.64,
      "text": "Já tá saindo aí"
    },
    {
      "start": 704.64,
      "end": 706.96,
      "text": "Umas unidades aí"
    },
    {
      "start": 706.96,
      "end": 708.42,
      "text": "Graças a Deus"
    },
    {
      "start": 708.42,
      "end": 713.44,
      "text": "Tem um poivo mesmo aqui"
    },
    {
      "start": 713.44,
      "end": 720.46,
      "text": "Aí, galera"
    },
    {
      "start": 720.46,
      "end": 722.2,
      "text": "Tamanho da lagostona"
    },
    {
      "start": 722.2,
      "end": 725.02,
      "text": "Glória a Deus"
    },
    {
      "start": 725.02,
      "end": 731.25,
      "text": "A gente achou uma lagostinha aqui"
    },
    {
      "start": 731.25,
      "end": 736.87,
      "text": "A gente vai voltar a riar a cangai"
    },
    {
      "start": 736.87,
      "end": 741.7,
      "text": "Aí, galera"
    },
    {
      "start": 741.7,
      "end": 744.92,
      "text": "Mais uma lagosta da graúda"
    },
    {
      "start": 744.92,
      "end": 747.56,
      "text": "Graças a Deus"
    },
    {
      "start": 747.56,
      "end": 751.81,
      "text": "Aí, rapaziada"
    },
    {
      "start": 751.81,
      "end": 752.53,
      "text": "Coisa linda"
    },
    {
      "start": 752.53,
      "end": 752.97,
      "text": "Vai dela"
    },
    {
      "start": 752.97,
      "end": 753.93,
      "text": "Tira o material aí"
    },
    {
      "start": 753.93,
      "end": 754.61,
      "text": "A armadilha"
    },
    {
      "start": 754.61,
      "end": 756.37,
      "text": "Show de bola"
    },
    {
      "start": 756.37,
      "end": 759.66,
      "text": "Pescaria da lagosta"
    },
    {
      "start": 759.66,
      "end": 762.61,
      "text": "Agora a gente vai botar aqui, ó"
    },
    {
      "start": 762.61,
      "end": 763.29,
      "text": "Dentro desse"
    },
    {
      "start": 763.29,
      "end": 765.25,
      "text": "Desse saco aqui"
    },
    {
      "start": 765.25,
      "end": 766.91,
      "text": "Que a gente chama de surrão, galera"
    },
    {
      "start": 766.91,
      "end": 768.55,
      "text": "Que é feito de palha de"
    },
    {
      "start": 768.55,
      "end": 770.67,
      "text": "Qual é essa palha aí, pai?"
    },
    {
      "start": 770.81,
      "end": 771.29,
      "text": "É feita?"
    },
    {
      "start": 772.4,
      "end": 774.24,
      "text": "Palha de carnaúba, galera"
    },
    {
      "start": 774.24,
      "end": 775.24,
      "text": "Carnaúbeira"
    },
    {
      "start": 775.24,
      "end": 776.74,
      "text": "A lagosta fica"
    },
    {
      "start": 776.74,
      "end": 778.27,
      "text": "Fica bem fresquinha"
    },
    {
      "start": 778.79,
      "end": 780.21,
      "text": "O Deu, a bicha aí"
    },
    {
      "start": 780.21,
      "end": 780.81,
      "text": "Que eu pego aqui"
    },
    {
      "start": 780.81,
      "end": 784.46,
      "text": "Também mais uma zoada"
    },
    {
      "start": 784.46,
      "end": 790.16,
      "text": "Com vocês vir aí, né?"
    },
    {
      "start": 790.22,
      "end": 791.48,
      "text": "A gente já puxou umas"
    },
    {
      "start": 791.48,
      "end": 793.74,
      "text": "Trinta manzuar"
    },
    {
      "start": 793.74,
      "end": 796.85,
      "text": "Armadilha dessas aqui"
    },
    {
      "start": 796.85,
      "end": 797.57,
      "text": "Agora a gente tá"
    },
    {
      "start": 797.57,
      "end": 798.43,
      "text": "Noutra parte"
    },
    {
      "start": 798.43,
      "end": 802.93,
      "text": "E a pegada é essa, galera"
    },
    {
      "start": 802.93,
      "end": 803.33,
      "text": "Até"
    },
    {
      "start": 803.33,
      "end": 805.58,
      "text": "No final do dia aí"
    },
    {
      "start": 805.58,
      "end": 805.92,
      "text": "Nós vamos"
    },
    {
      "start": 805.92,
      "end": 807.89,
      "text": "Pegar daqui"
    },
    {
      "start": 807.89,
      "end": 823.38,
      "text": "Vem limpa"
    },
    {
      "start": 823.38,
      "end": 824.32,
      "text": "Vem nada não"
    },
    {
      "start": 824.32,
      "end": 830.91,
      "text": "Aí, pessoal"
    },
    {
      "start": 830.91,
      "end": 832.31,
      "text": "Acabamos a primeira fila"
    },
    {
      "start": 832.31,
      "end": 833.39,
      "text": "De material aí, ó"
    },
    {
      "start": 833.39,
      "end": 834.17,
      "text": "De armadilha"
    },
    {
      "start": 834.17,
      "end": 836.59,
      "text": "Quase quarenta armadilhas"
    },
    {
      "start": 836.59,
      "end": 837.19,
      "text": "A gente pegou"
    },
    {
      "start": 837.19,
      "end": 838.99,
      "text": "Duas lagostas grandes, galera"
    },
    {
      "start": 838.99,
      "end": 840.25,
      "text": "Tá certo?"
    },
    {
      "start": 840.25,
      "end": 842.35,
      "text": "Esse foi o nosso começo do trabalho"
    },
    {
      "start": 842.35,
      "end": 843.57,
      "text": "Ainda tem muito trabalho"
    },
    {
      "start": 843.57,
      "end": 844.67,
      "text": "Pela frente ainda"
    },
    {
      "start": 844.67,
      "end": 846.15,
      "text": "É..."
    },
    {
      "start": 846.15,
      "end": 847.43,
      "text": "Primeira fila agora"
    },
    {
      "start": 847.43,
      "end": 848.59,
      "text": "Vamos pra outra fila"
    },
    {
      "start": 848.59,
      "end": 849.29,
      "text": "De manzuar"
    },
    {
      "start": 849.29,
      "end": 851.37,
      "text": "Mas agora a gente vai começar"
    },
    {
      "start": 851.37,
      "end": 853.39,
      "text": "A soltar as armadilhas"
    },
    {
      "start": 853.39,
      "end": 854.01,
      "text": "De novo"
    },
    {
      "start": 854.01,
      "end": 854.99,
      "text": "No outro local"
    },
    {
      "start": 854.99,
      "end": 857.35,
      "text": "Aí a gente renova as iscas"
    },
    {
      "start": 857.35,
      "end": 859.19,
      "text": "Coloca novas iscas aí"
    },
    {
      "start": 859.19,
      "end": 860.35,
      "text": "Pra começar os trabalhos"
    },
    {
      "start": 860.35,
      "end": 861.85,
      "text": "Agora vamos trouxer o barco"
    },
    {
      "start": 861.85,
      "end": 863.39,
      "text": "Mudar de direção"
    },
    {
      "start": 863.39,
      "end": 863.63,
      "text": "Ó"
    },
    {
      "start": 863.63,
      "end": 865.31,
      "text": "Meu pai já tá"
    },
    {
      "start": 865.31,
      "end": 866.65,
      "text": "Trouxendo o barco ali, ó"
    },
    {
      "start": 866.65,
      "end": 868.56,
      "text": "Darlan já vem com"
    },
    {
      "start": 868.56,
      "end": 870.46,
      "text": "Com outro contrapeso aqui"
    },
    {
      "start": 870.46,
      "end": 871.4,
      "text": "Que é o..."
    },
    {
      "start": 871.4,
      "end": 872.18,
      "text": "O..."
    },
    {
      "start": 872.18,
      "end": 873.32,
      "text": "Um saco de areia"
    },
    {
      "start": 873.32,
      "end": 875.0,
      "text": "Pra fazer o contrapeso"
    },
    {
      "start": 875.0,
      "end": 876.0,
      "text": "Da vela, galera"
    },
    {
      "start": 876.0,
      "end": 876.58,
      "text": "Tá certo?"
    },
    {
      "start": 877.04,
      "end": 878.26,
      "text": "Porque quando o vento"
    },
    {
      "start": 878.26,
      "end": 879.78,
      "text": "Bate a favor da vela"
    },
    {
      "start": 879.78,
      "end": 881.34,
      "text": "Tem que ter um contrapeso"
    },
    {
      "start": 881.34,
      "end": 882.96,
      "text": "A favor do barco"
    },
    {
      "start": 882.96,
      "end": 884.84,
      "text": "Aqui no lado oposto"
    },
    {
      "start": 884.84,
      "end": 885.44,
      "text": "Da vela"
    },
    {
      "start": 885.44,
      "end": 886.18,
      "text": "Senão o barco"
    },
    {
      "start": 886.18,
      "end": 887.06,
      "text": "Acaba virando"
    },
    {
      "start": 887.06,
      "end": 888.32,
      "text": "Pra outro lado"
    },
    {
      "start": 888.32,
      "end": 888.82,
      "text": "Tá certo?"
    },
    {
      "start": 889.28,
      "end": 889.84,
      "text": "E é isso aí"
    },
    {
      "start": 889.84,
      "end": 890.44,
      "text": "A gente continua"
    },
    {
      "start": 890.44,
      "end": 891.62,
      "text": "Com o nosso trabalho aqui"
    },
    {
      "start": 891.62,
      "end": 894.34,
      "text": "Já já a gente vai começar"
    },
    {
      "start": 894.34,
      "end": 895.9,
      "text": "A nova fila de manzuar"
    },
    {
      "start": 895.9,
      "end": 897.78,
      "text": "Procura das lagostas"
    },
    {
      "start": 897.78,
      "end": 898.5,
      "text": "Vamos lá"
    },
    {
      "start": 898.5,
      "end": 903.08,
      "text": "Agora estamos na parte de"
    },
    {
      "start": 903.08,
      "end": 906.57,
      "text": "Jogar as armadilhas"
    },
    {
      "start": 906.57,
      "end": 907.81,
      "text": "No mar novamente, gente"
    },
    {
      "start": 907.81,
      "end": 908.55,
      "text": "A gente puxou"
    },
    {
      "start": 908.55,
      "end": 909.01,
      "text": "O primeiro"
    },
    {
      "start": 909.01,
      "end": 911.01,
      "text": "Primeiro afilo de material"
    },
    {
      "start": 911.01,
      "end": 912.31,
      "text": "De armadilha, né"
    },
    {
      "start": 912.31,
      "end": 914.16,
      "text": "Que é as cangaia"
    },
    {
      "start": 914.16,
      "end": 916.58,
      "text": "Ela vai pro mar"
    },
    {
      "start": 916.58,
      "end": 918.38,
      "text": "Que Deus abençoe"
    },
    {
      "start": 918.38,
      "end": 921.88,
      "text": "Toma procura da lagosta, galera"
    },
    {
      "start": 921.88,
      "end": 923.22,
      "text": "Pescaria artesanal"
    },
    {
      "start": 923.22,
      "end": 925.78,
      "text": "Essa daqui é a verdadeira pescaria"
    },
    {
      "start": 925.78,
      "end": 927.52,
      "text": "Artesanal da lagosta"
    },
    {
      "start": 927.52,
      "end": 928.86,
      "text": "No Ceará, gente, ó"
    },
    {
      "start": 928.86,
      "end": 932.35,
      "text": "Pescaria"
    },
    {
      "start": 932.35,
      "end": 934.05,
      "text": "De manzuar"
    },
    {
      "start": 934.05,
      "end": 935.33,
      "text": "De cangaia"
    },
    {
      "start": 935.33,
      "end": 941.42,
      "text": "Olha só como são feitas as armadilhas"
    },
    {
      "start": 941.42,
      "end": 943.76,
      "text": "Tem duas entradas"
    },
    {
      "start": 943.76,
      "end": 945.66,
      "text": "Que a lagosta entra aqui, gente"
    },
    {
      "start": 945.66,
      "end": 947.32,
      "text": "E tem um acesso aqui, ó"
    },
    {
      "start": 947.32,
      "end": 949.28,
      "text": "Que ela não consegue mais voltar"
    },
    {
      "start": 949.28,
      "end": 951.18,
      "text": "É colocada uma isca"
    },
    {
      "start": 951.18,
      "end": 952.48,
      "text": "No meio do manzuar"
    },
    {
      "start": 952.48,
      "end": 953.3,
      "text": "Da cangaia"
    },
    {
      "start": 953.3,
      "end": 954.98,
      "text": "Então essa isca"
    },
    {
      "start": 954.98,
      "end": 956.48,
      "text": "Ela atrai a lagosta"
    },
    {
      "start": 956.48,
      "end": 958.06,
      "text": "A lagosta entra"
    },
    {
      "start": 958.06,
      "end": 959.84,
      "text": "Pra comer dentro da armadilha"
    },
    {
      "start": 959.84,
      "end": 961.24,
      "text": "E não consegue sair mais"
    },
    {
      "start": 961.24,
      "end": 963.3,
      "text": "E a gente arma"
    },
    {
      "start": 963.3,
      "end": 965.52,
      "text": "Essas armadilhas"
    },
    {
      "start": 965.52,
      "end": 968.04,
      "text": "Com cabeça de bagre"
    },
    {
      "start": 968.04,
      "end": 969.98,
      "text": "Couro de boi, galera"
    },
    {
      "start": 969.98,
      "end": 970.58,
      "text": "É"
    },
    {
      "start": 970.58,
      "end": 972.22,
      "text": "Tocinho de porco"
    },
    {
      "start": 972.22,
      "end": 973.3,
      "text": "É"
    },
    {
      "start": 973.3,
      "end": 974.78,
      "text": "Coco"
    },
    {
      "start": 974.78,
      "end": 976.02,
      "text": "São iscas, galera"
    },
    {
      "start": 976.02,
      "end": 976.34,
      "text": "Aqui"
    },
    {
      "start": 976.34,
      "end": 977.72,
      "text": "E chamou a atenção"
    },
    {
      "start": 977.72,
      "end": 979.14,
      "text": "Da lagosta"
    },
    {
      "start": 979.14,
      "end": 979.76,
      "text": "Tá certo?"
    },
    {
      "start": 980.7,
      "end": 982.02,
      "text": "Então a gente tá terminando"
    },
    {
      "start": 982.02,
      "end": 982.46,
      "text": "Já aqui"
    },
    {
      "start": 982.46,
      "end": 984.08,
      "text": "De armar, né"
    },
    {
      "start": 984.08,
      "end": 985.42,
      "text": "As armadilhas novamente"
    },
    {
      "start": 985.42,
      "end": 987.22,
      "text": "E vamos pra outra parte"
    },
    {
      "start": 987.22,
      "end": 987.78,
      "text": "De material"
    },
    {
      "start": 987.78,
      "end": 1000.76,
      "text": "É isso aí, galera"
    },
    {
      "start": 1000.76,
      "end": 1002.36,
      "text": "Depois aí de um dia"
    },
