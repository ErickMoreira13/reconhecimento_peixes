    },
    {
      "start": 732.38,
      "end": 734.68,
      "text": "Então graças a Deus, galera"
    },
    {
      "start": 734.68,
      "end": 736.5,
      "text": "A raia muito grande"
    },
    {
      "start": 736.5,
      "end": 737.6,
      "text": "Muito, muito grande"
    },
    {
      "start": 737.6,
      "end": 738.02,
      "text": "Mas"
    },
    {
      "start": 738.02,
      "end": 739.86,
      "text": "O mais"
    },
    {
      "start": 739.86,
      "end": 741.86,
      "text": "O principal é a vida dela, né?"
    },
    {
      "start": 741.94,
      "end": 743.72,
      "text": "Garantir a sobrevivência"
    },
    {
      "start": 743.72,
      "end": 744.98,
      "text": "E tem um monte de filhotas"
    },
    {
      "start": 744.98,
      "end": 746.32,
      "text": "Ela botou um bem aqui"
    },
    {
      "start": 746.32,
      "end": 747.24,
      "text": "Quando a gente soltou"
    },
    {
      "start": 747.24,
      "end": 748.66,
      "text": "Ela botou um"
    },
    {
      "start": 748.66,
      "end": 749.92,
