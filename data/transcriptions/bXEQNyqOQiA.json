    },
    {
      "start": 749.92,
      "end": 751.94,
      "text": "Então não tinha como a gente levar"
    },
    {
      "start": 751.94,
      "end": 753.3,
      "text": "Um peixe desse de forma nenhuma"
    },
    {
      "start": 753.3,
      "end": 754.6,
      "text": "Deus vai mandar outro já, já"
    },
    {
      "start": 754.6,
      "end": 755.26,
      "text": "Com fé em Deus"
    },
    {
      "start": 755.26,
      "end": 756.69,
      "text": "Fé em Deus"
    },
    {
      "start": 756.69,
      "end": 758.73,
      "text": "Deus vai mandar outro pra gente"
    },
    {
      "start": 758.73,
      "end": 761.83,
      "text": "A raia muito, muito, muito grande mesmo"
