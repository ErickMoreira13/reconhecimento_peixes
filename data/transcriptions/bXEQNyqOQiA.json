    {
      "start": 729.44,
      "end": 730.68,
      "text": "Olha, olha"
    },
    {
      "start": 730.68,
      "end": 731.14,
      "text": "Foi embora"
    },
    {
      "start": 731.14,
      "end": 732.38,
