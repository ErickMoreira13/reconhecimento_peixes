    },
    {
      "start": 789.1,
      "end": 792.0,
      "text": "Será que é bom eu recolher a minha vara?"
    },
    {
      "start": 793.88,
      "end": 794.1,
      "text": "Oi"
    },
    {
      "start": 794.1,
      "end": 797.59,
