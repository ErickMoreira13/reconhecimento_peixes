      "text": "Então vamos soltar"
    },
    {
      "start": 722.42,
      "end": 724.26,
      "text": "E a melhor opção é soltar"
    },
    {
      "start": 724.26,
      "end": 725.28,
      "text": "Olha, galera"
    },
    {
      "start": 725.28,
      "end": 725.86,
      "text": "Um filhotinho"
    },
    {
      "start": 725.86,
      "end": 726.52,
      "text": "Ela botou ali"
    },
    {
      "start": 726.52,
      "end": 727.46,
