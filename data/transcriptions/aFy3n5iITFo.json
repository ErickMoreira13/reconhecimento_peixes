      "end": 1393.82,
      "text": "Nunca vi isso na minha vida."
    },
    {
      "start": 1394.69,
      "end": 1395.31,
      "text": "O que, Murilo?"
    },
    {
      "start": 1396.39,
      "end": 1396.77,
      "text": "Triplay."
    },
    {
      "start": 1397.31,
      "end": 1397.87,
      "text": "Vivi."
    },
    {
      "start": 1398.11,
      "end": 1399.77,
      "text": "Ah, pra ver isso aqui."
    },
    {
      "start": 1400.37,
      "end": 1402.79,
      "text": "Três feras da pesca."
    },
    {
      "start": 1403.54,
      "end": 1404.06,
      "text": "Triplex."
    },
    {
      "start": 1404.06,
      "end": 1437.51,
      "text": "No meio do turbilhão aqui, garoto."
    },
    {
      "start": 1438.03,
      "end": 1439.13,
      "text": "Ó, peixão, hein?"
    },
    {
      "start": 1441.2,
      "end": 1441.72,
      "text": "Peixão."
    },
    {
      "start": 1445.01,
      "end": 1446.95,
      "text": "Deixar ele me jogar na corredeira aqui dá problema."
    },
    {
      "start": 1467.02,
      "end": 1467.64,
      "text": "Peixe bonito."
    },
    {
      "start": 1468.67,
      "end": 1469.69,
      "text": "Jogou fora da boca."
    },
    {
      "start": 1479.07,
      "end": 1479.55,
      "text": "Quadrada."
    },
    {
      "start": 1480.05,
      "end": 1541.8,
      "text": "Agora, estamos subindo uma corredeira aqui."
    },
    {
      "start": 1543.32,
      "end": 1544.8,
      "text": "Precisamos pular na água pra subir."
    },
    {
      "start": 1546.2,
      "end": 1547.64,
      "text": "Mas já estamos quase terminando."
    },
    {
      "start": 1550.79,
      "end": 1551.47,
      "text": "Bora com a gente."
    },
    {
      "start": 1552.01,
      "end": 1614.74,
      "text": "Queria aventura?"
    },
    {
      "start": 1615.22,
      "end": 1616.84,
      "text": "Queria aventura também, ó."
    },
    {
      "start": 1618.76,
      "end": 1620.18,
      "text": "Já tô achando que tá da hora, hein?"
    },
    {
      "start": 1620.18,
      "end": 1622.9,
      "text": "Tô achando que vai poder fazer mais desses."
    },
    {
      "start": 1623.02,
      "end": 1624.2,
      "text": "Quem que você quiser fazer amanhã?"
    },
    {
      "start": 1624.2,
      "end": 1633.17,
      "text": "Com as dificuldades de quase que você não consegue."
    },
    {
      "start": 1633.31,
      "end": 1633.89,
      "text": "Fala alto."
    },
    {
      "start": 1634.03,
      "end": 1634.55,
      "text": "No limite."
    },
    {
      "start": 1634.77,
      "end": 1635.65,
      "text": "É, tem a aventura."
    },
    {
      "start": 1635.95,
      "end": 1636.41,
      "text": "Não, mano."
    },
    {
      "start": 1636.59,
      "end": 1637.25,
      "text": "10%..."
    },
    {
      "start": 1637.25,
      "end": 1638.09,
      "text": "Já deu certo aqui."
    },
    {
      "start": 1640.73,
      "end": 1642.41,
      "text": "Mas 10% você já roda."
    },
    {
      "start": 1643.47,
      "end": 1647.24,
      "text": "E tá no nível bom."
    },
    {
      "start": 1675.28,
      "end": 1675.92,
      "text": "Aí, pessoal."
    },
    {
      "start": 1676.14,
      "end": 1679.08,
      "text": "Já saímos da água já praticamente no escuro."
    },
    {
      "start": 1680.76,
      "end": 1685.28,
      "text": "Dessa vez nós estamos acampados lá na casa do meu amigo Vivi."
    },
    {
      "start": 1685.28,
      "end": 1690.54,
      "text": "E aí, como nós estávamos passando aqui pela vila, já aproveitamos pra gente já jantar logo."
    },
    {
      "start": 1691.88,
      "end": 1693.48,
      "text": "E pensa no lugar da comida boa."
    },
    {
      "start": 1694.24,
      "end": 1695.7,
      "text": "Aqui no restaurante do Zil."
    },
    {
      "start": 1697.51,
      "end": 1699.57,
      "text": "Você paga um valor e come à vontade."
    },
    {
      "start": 1699.73,
      "end": 1701.11,
      "text": "Hoje até a vizinha tinha ali."
    },
    {
      "start": 1701.25,
      "end": 1702.87,
      "text": "Que hoje eu vou comer igual gente grande."
    },
    {
      "start": 1703.23,
      "end": 1704.05,
      "text": "Pensa na fome."
    },
    {
      "start": 1704.87,
      "end": 1705.15,
      "text": "E aí, ó."
    },
    {
      "start": 1705.31,
      "end": 1705.77,
      "text": "Se liga."
    },
    {
      "start": 1705.77,
      "end": 1712.08,
      "text": "Cozidão, carne frita, arroz e feijão."
    },
    {
      "start": 1713.14,
      "end": 1715.6,
      "text": "E ainda vem uma peca de banana."
    },
    {
      "start": 1716.44,
      "end": 1717.82,
      "text": "E eu ainda sou abusado."
    },
    {
      "start": 1717.88,
      "end": 1718.66,
      "text": "Ainda pedi uma banana."
    },
    {
      "start": 1718.9,
      "end": 1719.68,
      "text": "Tá sim, é uma vontade."
    },
    {
      "start": 1719.8,
      "end": 1721.58,
      "text": "E agora não tá bem badinha não."
    },
    {
      "start": 1722.56,
      "end": 1724.56,
      "text": "Quem gosta de comida com banana sou eu."
    },
    {
      "start": 1725.82,
      "end": 1726.22,
      "text": "Bora."
    },
    {
      "start": 1726.46,
      "end": 1728.38,
      "text": "Vocês me dão licença que eu vou jantar."
    }
