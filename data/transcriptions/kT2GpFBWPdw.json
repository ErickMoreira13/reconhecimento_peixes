    },
    {
      "start": 884.33,
      "end": 885.95,
      "text": "Do negão"
    },
    {
      "start": 885.95,
      "end": 888.33,
      "text": "Do polaco"
    },
    {
      "start": 888.33,
      "end": 899.91,
      "text": "Tem água ali?"
    },
    {
      "start": 900.91,
      "end": 901.85,
      "text": "Põe dessa aí"
    },
    {
      "start": 901.85,
      "end": 902.57,
      "text": "De cima"
    },
    {
      "start": 902.57,
      "end": 925.98,
      "text": "Pai que tamanho de traíra, hein?"
    },
    {
      "start": 928.13,
      "end": 928.87,
      "text": "Beleza pessoal"
    },
    {
      "start": 928.87,
      "end": 930.62,
      "text": "Vamos correr com eles"
    },
    {
      "start": 930.62,
      "end": 933.98,
      "text": "Vamos pegar os filhotinhos aí"
    },
    {
      "start": 933.98,
      "end": 935.18,
      "text": "Um pouco vai para o abate"
    },
    {
      "start": 935.18,
      "end": 936.46,
      "text": "Um pouco os filhotinhos vai para o outro"
    },
    {
      "start": 936.46,
      "end": 937.14,
      "text": "Represa"
    },
    {
      "start": 937.14,
      "end": 939.77,
      "text": "Começa a faltar oxigênese"
    },
    {
      "start": 939.77,
      "end": 940.21,
      "text": "Morre"
    },
    {
      "start": 940.21,
      "end": 940.73,
      "text": "É"
    },
    {
      "start": 940.73,
      "end": 941.63,
      "text": "Vamos correr"
    },
    {
      "start": 941.63,
      "end": 944.25,
      "text": "Vamos levar eles daqui para lá"
    },
    {
      "start": 944.25,
      "end": 946.16,
      "text": "Deixa eu desligar aqui"
    },
    {
      "start": 946.16,
      "end": 948.02,
      "text": "Preciso dar uma mão para eles aqui, galera"
    },
    {
      "start": 948.02,
      "end": 950.65,
      "text": "E depois a gente mostra para vocês aí"
    },
    {
      "start": 950.65,
      "end": 951.41,
      "text": "A limpeza dos"
    },
    {
      "start": 951.41,
      "end": 952.87,
      "text": "Dos que vai para o abate"
    },
    {
      "start": 952.87,
      "end": 957.46,
      "text": "A soltaça"
    },
    {
      "start": 957.46,
      "end": 960.05,
      "text": "Soltar aqui que vai levar para a limpeza mais tarde"
    },
    {
      "start": 960.05,
      "end": 963.53,
      "text": "Olha o tamanho da bitela, pessoal"
    },
    {
      "start": 963.53,
      "end": 963.75,
      "text": "Oi"
    },
    {
      "start": 963.75,
      "end": 966.99,
      "text": "Oi, sim, mano"
    },
    {
      "start": 966.99,
      "end": 977.43,
      "text": "Olha o pacuco"
    },
    {
      "start": 977.43,
      "end": 979.97,
      "text": "Vai soltar o pacuco também?"
    },
    {
      "start": 989.83,
      "end": 991.61,
      "text": "Eita, bichão, bruto, hein?"
    },
    {
      "start": 993.96,
      "end": 994.88,
      "text": "Não é dessa vez que ele vai"
    },
    {
      "start": 994.88,
      "end": 995.54,
      "text": "Com a panela"
    },
    {
      "start": 995.54,
      "end": 996.56,
      "text": "Não foi?"
    },
    {
      "start": 996.64,
      "end": 997.92,
      "text": "Vai crescer mais um golinho ainda"
    },
    {
      "start": 997.92,
      "end": 1003.54,
      "text": "A gente está com a limpeza"
    },
    {
      "start": 1003.54,
      "end": 1005.38,
      "text": "Fica aí, bitela"
    },
    {
      "start": 1005.38,
      "end": 1035.36,
      "text": "Eita, bichão"
    }
  ],
