      "text": "E o chute vai me espiar."
    },
    {
      "start": 790.06,
      "end": 794.38,
      "text": "Não mereço."
    },
    {
      "start": 796.28,
      "end": 798.46,
      "text": "Peguei o almoço e fritei os peixes."
    },
    {
      "start": 798.56,
      "end": 799.32,
      "text": "Ah, pescador."
    },
    {
      "start": 799.32,
      "end": 800.22,
      "text": "Esse é o chute, velho."
    },
    {
      "start": 800.22,
      "end": 807.26,
      "text": "Tem que conhecer, né?"
    },
    {
      "start": 813.73,
      "end": 814.33,
      "text": "Está bom, cara."
    },
    {
      "start": 814.95,
      "end": 815.23,
      "text": "Está bom?"
    },
    {
      "start": 815.47,
      "end": 822.45,
      "text": "Está bom mesmo."
    },
    {
      "start": 823.72,
      "end": 825.24,
      "text": "Não ficou salgado aqui no meu peloco."
    },
    {
      "start": 825.72,
      "end": 826.76,
      "text": "Não, está bem bom."
    },
    {
      "start": 826.76,
      "end": 829.32,
      "text": "Aquele saldo que o Fernando Zé Fora é muito fino."
    },
    {
      "start": 829.9,
      "end": 830.68,
      "text": "Ah, é velho demais."
    },
    {
      "start": 831.52,
      "end": 839.38,
      "text": "Vamos almoçar depois."
    },
    {
      "start": 840.52,
      "end": 841.42,
      "text": "Uma palida de novo."
    },
    {
      "start": 861.42,
      "end": 867.3,
      "text": "Vou soltar um jundiazinho aqui, já que fizemos a fritada."
    },
    {
      "start": 868.49,
      "end": 869.43,
      "text": "Sobrou uns aí, ó."
    },
    {
      "start": 869.43,
      "end": 869.65,
      "text": "Um."
    },
    {
      "start": 870.31,
      "end": 871.13,
      "text": "Um para a vida."
    },
    {
      "start": 871.13,
      "end": 885.29,
      "text": "Um, dois, três, quatro, cinco."
    },
    {
      "start": 885.45,
      "end": 888.33,
      "text": "Vou segurar um pintado e um jundiazinho para fazer isso."
    },
    {
      "start": 910.06,
      "end": 910.94,
      "text": "Perdi, cara."
    },
    {
      "start": 911.24,
      "end": 912.84,
      "text": "Perdi a primeira corrida."
    },
    {
      "start": 914.35,
      "end": 914.55,
      "text": "Ó."
    },
    {
      "start": 914.97,
      "end": 919.94,
      "text": "Ó."
    },
    {
      "start": 920.66,
      "end": 921.04,
      "text": "Ó."
    },
    {
      "start": 921.52,
      "end": 923.01,
      "text": "Ó."
    },
    {
      "start": 924.46,
      "end": 925.64,
      "text": "Ai, ai, ai, ai."
    },
    {
      "start": 927.45,
      "end": 935.5,
      "text": "Opa, que chuva."
    },
    {
      "start": 936.18,
      "end": 941.8,
      "text": "Está pintado, vem cabeceão."
    },
    {
      "start": 948.11,
      "end": 949.05,
      "text": "É jundiazinho."
    },
    {
      "start": 949.05,
      "end": 950.05,
      "text": "É rei de feio."
    },
    {
      "start": 950.13,
      "end": 950.75,
      "text": "É rei de feio."
    },
    {
      "start": 957.53,
      "end": 958.43,
      "text": "Vai dar para largar."
    },
    {
      "start": 958.93,
      "end": 964.9,
      "text": "Foi que é um raio."
    },
    {
      "start": 1005.31,
      "end": 1005.97,
      "text": "E mais um."
    },
    {
      "start": 1005.97,
      "end": 1031.98,
      "text": "O que tem de jundiaz desse porte aqui, cara."
    },
    {
      "start": 1034.32,
      "end": 1034.92,
      "text": "Bastante."
    },
    {
      "start": 1040.14,
      "end": 1040.64,
      "text": "Vem, Martiano."
    },
    {
      "start": 1045.32,
      "end": 1046.62,
      "text": "Eu peguei dois pequenos aqui."
    },
    {
      "start": 1046.94,
      "end": 1048.46,
      "text": "Eu acho que o Jardim não foi para o outro."
    },
    {
      "start": 1051.35,
      "end": 1052.17,
      "text": "Pegou ali, gente."
    },
    {
      "start": 1053.22,
      "end": 1054.7,
      "text": "Peguei dois e escapou dois."
    },
    {
      "start": 1056.21,
      "end": 1058.67,
      "text": "Eu queria pegar um grandão."
    },
    {
      "start": 1059.17,
      "end": 1060.31,
      "text": "Tentar mais aqui debaixo."
    },
    {
      "start": 1065.66,
      "end": 1075.04,
      "text": "Vai para a vida, bigodinho."
    },
    {
      "start": 1081.8,
      "end": 1082.94,
      "text": "Mais um bom aqui."
    },
    {
      "start": 1088.86,
      "end": 1090.18,
      "text": "Bom mesmo, gurujá."
    },
    {
      "start": 1091.6,
      "end": 1092.84,
      "text": "Bom mesmo, pescador."
    },
    {
      "start": 1093.34,
      "end": 1103.27,
      "text": "Puxando."
    },
    {
      "start": 1103.61,
      "end": 1213.57,
      "text": "Puxando demais, cara."
    },
    {
      "start": 1213.57,
      "end": 1216.26,
      "text": "As duas varas, cara."
    },
    {
      "start": 1216.32,
      "end": 1217.82,
      "text": "Não sai nem qual cuidar."
    },
    {
      "start": 1228.54,
      "end": 1229.26,
      "text": "Meu Deus."
    },
    {
      "start": 1233.18,
      "end": 1234.92,
      "text": "Vamos ao patrocinador do canal."
    },
    {
      "start": 1236.66,
      "end": 1238.34,
      "text": "Pensou em móveis sob medida?"
    },
    {
      "start": 1239.35,
      "end": 1240.93,
      "text": "Lembrou Saldão Móveis."
    },
    {
      "start": 1242.34,
      "end": 1244.12,
      "text": "Com duas lojas em Antônio Prado."
    },
    {
      "start": 1244.22,
      "end": 1246.14,
      "text": "Uma na frente da Brigada Militar."
    },
    {
      "start": 1246.14,
      "end": 1249.12,
      "text": "E a outra a 200 metros do tribo de Caxias."
    },
    {
      "start": 1251.22,
      "end": 1252.14,
      "text": "Saldão Móveis."
    },
    {
      "start": 1252.14,
      "end": 1289.56,
      "text": "Vai para a vida."
    },
    {
      "start": 1293.03,
      "end": 1299.55,
      "text": "Eu vi quando eu cheguei e não viu hoje que a água estava ótima."
    },
    {
      "start": 1299.77,
      "end": 1300.51,
      "text": "Está aí."
    },
    {
      "start": 1300.63,
      "end": 1300.93,
      "text": "Está aí."
    },
    {
      "start": 1301.05,
      "end": 1301.19,
      "text": "Você vê?"
    },
    {
      "start": 1301.43,
      "end": 1301.67,
      "text": "Olha."
    },
    {
      "start": 1302.47,
      "end": 1305.31,
      "text": "Perdi, será?"
    },
    {
      "start": 1307.22,
      "end": 1307.74,
      "text": "Perdi."
    },
    {
      "start": 1307.98,
      "end": 1308.38,
      "text": "Quanto?"
    },
    {
      "start": 1308.92,
      "end": 1312.13,
      "text": "Vamos ver quanto vai demorar para puxar aqui na minhoca."
    },
    {
      "start": 1313.06,
      "end": 1313.94,
      "text": "Larguei agora."
    },
    {
      "start": 1314.36,
      "end": 1323.02,
      "text": "Vocês veem que hoje eles estão a mil por hora os peixes."
    },
    {
      "start": 1323.46,
      "end": 1333.66,
      "text": "Faz uns 10 segundos que eu joguei."
    },
    {
      "start": 1333.66,
      "end": 1339.31,
      "text": "Puxou."
    },
    {
      "start": 1339.43,
      "end": 1340.61,
      "text": "Primeira pegada já deu."
    },
    {
      "start": 1342.17,
      "end": 1345.23,
      "text": "Nem 15 segundos para eles encontrar isca."
    },
    {
      "start": 1349.79,
      "end": 1350.29,
      "text": "Olha aí."
    },
    {
      "start": 1352.32,
      "end": 1352.88,
      "text": "Escapou."
    },
    {
      "start": 1353.4,
      "end": 1353.92,
      "text": "Filho."
    },
    {
      "start": 1354.18,
      "end": 1374.26,
      "text": "Vai para a vida."
    },
    {
      "start": 1384.95,
      "end": 1385.63,
      "text": "Aqui o bicho."
    },
    {
      "start": 1388.11,
      "end": 1389.25,
      "text": "Mais um pintado."
    },
    {
      "start": 1389.61,
      "end": 1420.66,
      "text": "Acho que saiu mais um bom."
    },
    {
      "start": 1452.61,
      "end": 1454.01,
      "text": "Está chegando perto da noite."
    },
    {
      "start": 1454.23,
      "end": 1455.67,
      "text": "Vamos encerrar a pescaria por aí."
    },
    {
      "start": 1457.58,
      "end": 1458.48,
      "text": "Beleza, pescadores?"
    },
    {
      "start": 1459.41,
      "end": 1461.27,
      "text": "Não se esquece de se inscrever aí no canal."
    },
    {
      "start": 1461.69,
      "end": 1462.97,
      "text": "E deixar um like aí, beleza?"
    },
    {
      "start": 1464.26,
      "end": 1466.08,
      "text": "Grande abraço aí para todo mundo."
    },
    {
      "start": 1467.36,
      "end": 1467.8,
      "text": "Valeu."
    }
