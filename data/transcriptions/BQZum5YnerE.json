      "start": 694.96,
      "end": 695.96,
      "text": "Enrola, enrola."
    },
    {
      "start": 695.96,
      "end": 696.96,
      "text": "Ó."
    },
    {
      "start": 696.96,
      "end": 697.96,
      "text": "Abaixa e enrola."
    },
    {
      "start": 697.96,
      "end": 698.96,
      "text": "É um piausu."
    },
    {
      "start": 698.96,
      "end": 700.25,
      "text": "Aí."
    },
    {
      "start": 700.25,
      "end": 701.25,
      "text": "Pera aí."
    },
    {
      "start": 701.25,
      "end": 704.11,
      "text": "Pera aí."
    },
    {
      "start": 704.11,
      "end": 705.11,
      "text": "Traz ele aqui."
    },
    {
      "start": 705.11,
      "end": 712.04,
      "text": "Pera aí que não vai arrebentar a chumbada."
    },
    {
      "start": 712.04,
      "end": 715.53,
      "text": "Então, galera."
    },
    {
      "start": 715.53,
      "end": 716.53,
