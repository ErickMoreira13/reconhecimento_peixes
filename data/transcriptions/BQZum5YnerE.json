    {
      "start": 1104.43,
      "end": 1105.84,
      "text": "Minhoca."
    },
    {
      "start": 1105.84,
      "end": 1106.84,
      "text": "Dá alicate, hein."
    },
    {
      "start": 1106.84,
      "end": 1113.73,
      "text": "Até comendo."
