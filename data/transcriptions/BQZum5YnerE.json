    {
      "start": 1124.29,
      "end": 1125.29,
      "text": "Ó."
    },
    {
      "start": 1125.29,
      "end": 1126.8,
      "text": "Pra vida."
    },
    {
      "start": 1126.8,
      "end": 1131.26,
      "text": "Vou correr dele."
    },
    {
      "start": 1131.26,
      "end": 1203.05,
      "text": "Pega um passagua lá, velho."
    },
    {
      "start": 1203.05,
      "end": 1204.63,
      "text": "Ah, para."
    },
    {
      "start": 1204.63,
      "end": 1210.88,
      "text": "Pertinho de nós aqui."
    },
    {
      "start": 1210.88,
      "end": 1212.84,
      "text": "Vê se eu leve ela pra lá."
    },
    {
      "start": 1212.84,
      "end": 1215.74,
      "text": "Ixi, ela tá com uma mordida nas costas."
    },
    {
      "start": 1215.74,
      "end": 1222.21,
      "text": "Comigo, hein."
    },
    {
      "start": 1222.21,
      "end": 1224.95,
      "text": "Só deixar que eu vou tentar tirar ela assim."
