    },
    {
      "start": 718.14,
      "end": 719.14,
      "text": "Começou a encher."
    },
    {
      "start": 719.14,
      "end": 721.74,
      "text": "Começou a encostar."
    },
    {
      "start": 721.74,
      "end": 722.74,
      "text": "Vai ter que soltar ele, né."
    },
    {
      "start": 722.74,
      "end": 724.25,
      "text": "Dá uns 30."
    },
    {
      "start": 724.25,
      "end": 725.25,
      "text": "Acho que dá."
    },
    {
      "start": 725.25,
      "end": 726.57,
      "text": "Não dá?"
    },
    {
      "start": 726.57,
      "end": 730.1,
      "text": "Dá."
    },
    {
      "start": 730.1,
      "end": 731.1,
      "text": "Tá bonita ali, ó."
    },
    {
      "start": 731.1,
      "end": 732.32,
      "text": "Piauzão."
    },
    {
      "start": 732.32,
      "end": 733.32,
      "text": "Num milho esse."
    },
    {
      "start": 733.32,
      "end": 735.32,
      "text": "Na massinha tá também, mas essa taguara tá esperta."
    },
    {
      "start": 735.32,
      "end": 737.48,
      "text": "Vou ajeitar ela aqui e depois na volta."
    },
    {
      "start": 737.48,
      "end": 742.93,
      "text": "Não, vai."
    },
    {
      "start": 742.93,
      "end": 743.93,
      "text": "Continua."
    },
    {
      "start": 743.93,
      "end": 744.93,
      "text": "Só não bambiar ali."
    },
    {
      "start": 744.93,
      "end": 747.7,
      "text": "Vamos piar o sul de novo, galera."
    },
    {
      "start": 747.7,
      "end": 748.7,
      "text": "Vou passar a guara aqui."
    },
    {
      "start": 748.7,
      "end": 754.98,
      "text": "Taguara."
    },
    {
      "start": 754.98,
      "end": 755.98,
      "text": "Que tamanho."
    },
    {
      "start": 755.98,
      "end": 757.01,
      "text": "Vai piar, pá."
    },
    {
      "start": 757.01,
      "end": 758.01,
      "text": "Nossa."
    },
    {
      "start": 758.01,
      "end": 759.01,
      "text": "Que tamanho de taguara."
    },
    {
      "start": 759.01,
      "end": 762.22,
      "text": "Calma."
    },
    {
      "start": 762.22,
      "end": 763.22,
      "text": "Que doidura."
    },
    {
      "start": 763.22,
      "end": 765.22,
      "text": "Olha o tamanho da taguara."
    },
    {
      "start": 765.22,
      "end": 768.47,
      "text": "Que que é isso?"
    },
    {
      "start": 768.47,
      "end": 769.47,
      "text": "Ó."
    },
    {
      "start": 769.47,
      "end": 770.47,
      "text": "A pescadora."
    },
    {
      "start": 770.47,
      "end": 773.47,
      "text": "A pescadora hoje tá pegando de tudo."
    },
    {
      "start": 773.47,
      "end": 774.63,
      "text": "Ó."
    },
    {
      "start": 774.63,
      "end": 775.63,
      "text": "Vai dejeitar aqui, galera."
    },
    {
      "start": 775.63,
      "end": 777.63,
      "text": "Daqui a pouco nós volto com mais peixe aí."
    },
    {
      "start": 777.63,
      "end": 779.2,
      "text": "Getúro ferrou."
    },
    {
      "start": 779.2,
      "end": 780.2,
      "text": "Olha lá."
    },
    {
      "start": 780.2,
      "end": 782.36,
      "text": "Vai ver que que é."
    },
    {
      "start": 782.36,
      "end": 783.36,
      "text": "Vai salsicha, gente?"
    },
    {
      "start": 783.36,
      "end": 787.91,
      "text": "Senão tá guarona."
    },
    {
      "start": 787.91,
      "end": 790.71,
      "text": "Senão não vai conversar."
    },
    {
      "start": 790.71,
      "end": 793.15,
      "text": "Ó."
    },
    {
      "start": 793.15,
      "end": 795.88,
      "text": "Rapaz, hoje tá bom demais."
    },
    {
      "start": 795.88,
      "end": 796.88,
      "text": "Compete mais."
    },
    {
      "start": 796.88,
      "end": 803.87,
      "text": "Um pouco mais volta."
    },
    {
      "start": 803.87,
      "end": 808.81,
      "text": "Pega lá, Getúro."
    },
    {
      "start": 808.81,
      "end": 809.81,
      "text": "Aí galera, ó."
    },
    {
      "start": 809.81,
      "end": 810.81,
      "text": "Essa guarinha."
    },
    {
      "start": 810.81,
      "end": 812.52,
      "text": "Fiquei pequenininha."
    },
    {
      "start": 812.52,
      "end": 814.76,
      "text": "Deixa eu soltar."
    },
    {
      "start": 814.76,
      "end": 828.08,
      "text": "Ó."
    },
    {
      "start": 828.08,
      "end": 829.08,
      "text": "Pegou ao vivo."
    },
    {
      "start": 829.08,
      "end": 830.08,
      "text": "Ha."
    },
    {
      "start": 830.08,
      "end": 831.44,
      "text": "Grande, hein."
    },
    {
      "start": 831.44,
      "end": 832.44,
      "text": "Dá aflição."
    },
    {
      "start": 832.44,
      "end": 834.44,
      "text": "Essa aí tá com aflição bem apertada."
    },
    {
      "start": 834.44,
      "end": 835.44,
      "text": "Não para a vara não."
    },
    {
      "start": 835.44,
      "end": 836.44,
      "text": "Que se bambiar a linha, vai embora."
    },
    {
      "start": 836.44,
      "end": 843.24,
      "text": "Galera, hoje tá saindo umas taguara grande aqui, viu?"
    },
    {
      "start": 843.24,
      "end": 845.31,
      "text": "Saiu o Piaçu grande."
    },
    {
      "start": 845.31,
      "end": 846.31,
      "text": "Saiu o taguara grande."
    },
    {
      "start": 846.31,
      "end": 847.31,
      "text": "Olha o tamanho."
    },
    {
      "start": 847.31,
      "end": 853.17,
      "text": "Ó."
    },
    {
      "start": 853.17,
      "end": 858.36,
      "text": "Já."
    },
    {
      "start": 858.36,
      "end": 859.36,
      "text": "Tá com dois anzolzinhos."
    },
    {
      "start": 859.36,
      "end": 861.39,
      "text": "É perigoso."
    },
    {
      "start": 861.39,
      "end": 870.77,
      "text": "Dá lindo."
    },
    {
      "start": 870.77,
      "end": 871.77,
      "text": "Com dois anzolzinhos."
    },
    {
      "start": 871.77,
      "end": 892.74,
      "text": "É perigoso."
    },
    {
      "start": 892.74,
      "end": 893.74,
      "text": "Tá muito mesmo."
    },
    {
      "start": 893.74,
      "end": 901.59,
      "text": "Tá perigoso."
    },
    {
      "start": 901.59,
      "end": 913.79,
      "text": "Tem taguara, viu?"
    },
    {
      "start": 913.79,
      "end": 915.14,
      "text": "O pescadinho."
    },
    {
      "start": 915.14,
      "end": 916.14,
      "text": "O pescadinho, pô."
    },
    {
      "start": 916.14,
      "end": 920.15,
      "text": "Ó."
    },
    {
      "start": 920.15,
      "end": 950.84,
      "text": "Já não brigou, hein."
    },
    {
      "start": 950.84,
      "end": 951.84,
      "text": "Cansa aí, bichinho."
    },
    {
      "start": 951.84,
      "end": 965.0,
      "text": "O que?"
    },
    {
      "start": 965.0,
      "end": 981.33,
      "text": "Trabalho com o milho."
    },
    {
      "start": 981.33,
      "end": 983.49,
      "text": "Aquela lá que ele pegou, ó."
    },
    {
      "start": 983.49,
      "end": 986.49,
      "text": "Mas é só taguara monstra mesmo."
    },
    {
      "start": 986.49,
      "end": 989.26,
      "text": "Só taguarão servido, ó."
    },
    {
      "start": 989.26,
      "end": 991.41,
      "text": "Bonito, hein."
    },
    {
      "start": 991.41,
      "end": 996.52,
      "text": "Vai pegar mais um aqui."
    },
    {
      "start": 996.52,
      "end": 997.52,
      "text": "Só na minhoquinha."
    },
    {
      "start": 997.52,
      "end": 999.52,
      "text": "Na massinha, você tá roubando."
    },
    {
      "start": 999.52,
      "end": 1004.0,
      "text": "Pescarinha no meio."
    },
    {
      "start": 1004.0,
      "end": 1005.0,
      "text": "Quase no meio do rio, ó."
    },
    {
      "start": 1005.0,
      "end": 1015.9,
      "text": "Aqui, aqui tá cheio de piau, ó."
    },
    {
      "start": 1015.9,
      "end": 1016.9,
      "text": "Piau."
    },
    {
      "start": 1016.9,
      "end": 1017.9,
      "text": "Bananinha."
    },
    {
      "start": 1017.9,
      "end": 1021.84,
      "text": "Dois anzol."
    },
    {
      "start": 1021.84,
      "end": 1022.84,
      "text": "É perigoso."
    },
    {
      "start": 1022.84,
      "end": 1025.12,
      "text": "Já."
    },
    {
      "start": 1025.12,
      "end": 1029.52,
      "text": "Deu, hein."
    },
    {
      "start": 1029.52,
      "end": 1030.52,
      "text": "É besta."
    },
    {
      "start": 1030.52,
      "end": 1052.04,
      "text": "Uh, galera, ó."
    },
    {
      "start": 1052.04,
      "end": 1053.61,
      "text": "Ha, ha."
    },
    {
      "start": 1053.61,
      "end": 1054.61,
      "text": "Cebão pra lá."
    },
    {
      "start": 1054.61,
      "end": 1057.38,
      "text": "Vista com cara de piau sul."
    },
    {
      "start": 1057.38,
      "end": 1059.6,
      "text": "Piauzinho sul, rapaz."
    },
    {
      "start": 1059.6,
      "end": 1061.5,
      "text": "Desceu esse."
    },
    {
      "start": 1061.5,
      "end": 1062.5,
      "text": "Encostou ele."
    },
    {
      "start": 1062.5,
      "end": 1064.36,
      "text": "Piau a sul ganha."
    },
    {
      "start": 1064.36,
      "end": 1066.36,
      "text": "Encostou o bicho de novo."
    },
    {
      "start": 1066.36,
      "end": 1072.84,
      "text": "Cebão."
    },
    {
      "start": 1072.84,
      "end": 1083.44,
      "text": "Cebão."
    },
    {
      "start": 1083.44,
      "end": 1087.07,
      "text": "Essa pedra aqui, ele entra lá embaixo."
    },
    {
      "start": 1087.07,
      "end": 1089.07,
      "text": "Ah, não sei daí."
    },
    {
      "start": 1089.07,
      "end": 1090.07,
      "text": "Ah, sei daí."
    },
    {
      "start": 1090.07,
      "end": 1093.22,
      "text": "Não, vai pra lá, não."
    },
    {
      "start": 1093.22,
      "end": 1097.29,
      "text": "Piauzus."
    },
    {
      "start": 1097.29,
      "end": 1098.29,
      "text": "Um brabo só."
    },
    {
      "start": 1098.29,
      "end": 1100.12,
      "text": "Piau sul, Getulo."
    },
    {
      "start": 1100.12,
      "end": 1101.12,
      "text": "Agora, ó."
    },
    {
      "start": 1101.12,
      "end": 1104.43,
      "text": "Na minhoquinha."
