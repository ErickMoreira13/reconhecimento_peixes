      "start": 1224.95,
      "end": 1225.95,
      "text": "Sem..."
    },
    {
      "start": 1225.95,
      "end": 1227.46,
      "text": "Vou tentar tirar."
    },
    {
      "start": 1227.46,
      "end": 1230.46,
      "text": "Ela só vai virar uma bagunça no passagua."
    },
    {
      "start": 1230.46,
      "end": 1236.95,
      "text": "Aí, deu uma mordida nas costas dela."
    },
    {
      "start": 1236.95,
      "end": 1238.2,
      "text": "Galera, essa aqui."
    },
    {
      "start": 1238.2,
      "end": 1242.6,
      "text": "Essa aqui é bonita, viu."
    },
    {
      "start": 1242.6,
      "end": 1243.6,
      "text": "Da medida."
    },
    {
      "start": 1243.6,
      "end": 1246.04,
      "text": "Bonita."
    },
    {
      "start": 1246.04,
      "end": 1247.04,
      "text": "Deixa eu mostrar aqui."
    },
    {
      "start": 1247.04,
      "end": 1251.54,
      "text": "Vamos ver uma mordida nela."
    },
    {
      "start": 1251.54,
      "end": 1252.54,
      "text": "Isso aí, galera."
    },
    {
      "start": 1252.54,
      "end": 1253.54,
      "text": "Vou rejeitar aqui."
    },
    {
      "start": 1253.54,
      "end": 1254.54,
      "text": "Depois ela tá voltando aí."
    },
    {
      "start": 1254.54,
      "end": 1280.85,
      "text": "Tchau, Getulo."
    },
    {
      "start": 1280.85,
      "end": 1282.27,
      "text": "Ó o trairão."
    },
    {
      "start": 1282.27,
      "end": 1283.27,
      "text": "Ó o trairão, Getulo."
    },
    {
      "start": 1283.27,
      "end": 1284.27,
      "text": "Nossa."
    },
    {
      "start": 1284.27,
      "end": 1285.27,
      "text": "O tamanho do traíra."
    },
    {
      "start": 1285.27,
      "end": 1286.27,
      "text": "Nossa."
    },
    {
      "start": 1286.27,
      "end": 1287.65,
      "text": "Getulo."
    },
    {
      "start": 1287.65,
      "end": 1289.81,
      "text": "O trairão vem aqui, ó."
    },
    {
      "start": 1289.81,
      "end": 1293.47,
      "text": "Nossa."
    },
    {
      "start": 1293.47,
      "end": 1306.37,
      "text": "Galera, hoje tá bom, viu."
    },
    {
      "start": 1306.37,
      "end": 1308.37,
      "text": "Nossa taguara que monstro."
    },
    {
      "start": 1308.37,
      "end": 1309.37,
      "text": "Ó."
    },
    {
      "start": 1309.37,
      "end": 1317.03,
      "text": "Tem que completar o frito ali."
    },
    {
      "start": 1317.03,
      "end": 1322.39,
      "text": "Quatro taguarona e dois piaus."
    },
    {
      "start": 1322.39,
      "end": 1323.39,
      "text": "Três piauszão."
    },
    {
      "start": 1323.39,
      "end": 1324.39,
      "text": "Põe do taguarona."
    },
    {
      "start": 1324.39,
      "end": 1329.46,
      "text": "Credo, mas esse é grande, né."
    },
    {
      "start": 1329.46,
      "end": 1330.65,
      "text": "Isso aí."
    },
    {
      "start": 1330.65,
      "end": 1331.65,
      "text": "Já nós vamos."
    },
    {
      "start": 1331.65,
      "end": 1335.28,
      "text": "Aqui é pequena."
    },
    {
      "start": 1335.28,
      "end": 1338.27,
      "text": "Peguei aquela maior lá."
    },
    {
      "start": 1338.27,
      "end": 1340.27,
      "text": "E vou soltar essa menor aqui."
    },
    {
      "start": 1340.27,
      "end": 1342.27,
      "text": "Ficar com a maior pra fazer um clipe lá."
    },
    {
      "start": 1342.27,
      "end": 1344.3,
      "text": "Vou levar um peixinho também, né."
    },
    {
      "start": 1344.3,
      "end": 1345.75,
      "text": "Aí, ó."
    },
    {
      "start": 1345.75,
      "end": 1346.75,
      "text": "Bora."
    },
    {
      "start": 1346.75,
      "end": 1347.75,
      "text": "Ó esse bonita."
    },
    {
      "start": 1347.75,
      "end": 1348.94,
      "text": "Isso aí."
    },
    {
      "start": 1348.94,
      "end": 1363.2,
      "text": "Você viu se a trairona vem atrás?"
    },
    {
      "start": 1363.2,
      "end": 1386.12,
      "text": "Esse foi o peixe bom."
    },
    {
      "start": 1386.12,
      "end": 1390.86,
      "text": "Aquela aí, ó."
    },
    {
      "start": 1390.86,
      "end": 1393.24,
      "text": "Cara."
    },
    {
      "start": 1393.24,
      "end": 1394.24,
      "text": "É piauszú."
    },
    {
      "start": 1394.24,
      "end": 1395.24,
      "text": "Piauszú."
    },
    {
      "start": 1395.24,
      "end": 1407.32,
      "text": "Ele é bravo, né."
    },
    {
      "start": 1407.32,
      "end": 1408.32,
      "text": "Aí, ó."
    },
    {
      "start": 1408.32,
      "end": 1409.32,
      "text": "Cuidado."
    },
    {
      "start": 1409.32,
      "end": 1410.38,
      "text": "Deixa eu tirar."
    },
    {
      "start": 1410.38,
      "end": 1411.38,
      "text": "Deixa eu só entrar aqui."
    },
    {
      "start": 1411.38,
      "end": 1436.28,
      "text": "Pegou mais uma."
    },
    {
      "start": 1436.28,
      "end": 1482.09,
      "text": "A água cobriu tudo."
    },
    {
      "start": 1482.09,
      "end": 1484.44,
      "text": "E fica perigosa a pescada agora."
    },
    {
      "start": 1484.44,
      "end": 1486.12,
      "text": "A gente tá finalizando aqui."
    },
    {
      "start": 1486.12,
      "end": 1487.12,
      "text": "Foi uma pescaria boa."
    },
    {
      "start": 1487.12,
      "end": 1488.12,
      "text": "Seu bastante peixe."
    },
    {
      "start": 1488.12,
      "end": 1490.24,
      "text": "Verei lá o Getúlio."
    },
    {
      "start": 1490.24,
      "end": 1491.24,
      "text": "Falou um alô."
    },
    {
      "start": 1491.24,
      "end": 1494.29,
      "text": "Deixa aquele like."
    },
    {
      "start": 1494.29,
      "end": 1497.88,
      "text": "Até a próxima aí."
    },
    {
      "start": 1497.88,
      "end": 1498.88,
      "text": "É nóis."
    }
  ],
