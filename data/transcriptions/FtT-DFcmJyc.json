    {
      "start": 772.56,
      "end": 775.04,
      "text": "Agradecer meus amigos aqui, ó"
    },
    {
      "start": 775.04,
      "end": 777.64,
      "text": "Não sei se dá para ver aí"
    },
    {
      "start": 777.64,
      "end": 778.44,
