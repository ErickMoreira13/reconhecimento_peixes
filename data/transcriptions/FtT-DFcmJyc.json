    },
    {
      "start": 682.92,
      "end": 683.94,
      "text": "Da época do ano"
    },
    {
      "start": 683.94,
      "end": 685.14,
      "text": "Que os teus amigos"
    },
    {
      "start": 685.14,
      "end": 685.52,
      "text": "Estão pescando"
    },
    {
      "start": 685.52,
      "end": 685.88,
      "text": "Porém, você está"
    },
    {
      "start": 685.88,
      "end": 686.84,
      "text": "Estão fazendo uma pescaria boa, né?"
    },
    {
      "start": 687.08,
      "end": 687.48,
      "text": "Está, então"
    },
    {
      "start": 687.48,
      "end": 688.84,
      "text": "Uma pescaria está razoável"
    },
    {
      "start": 688.84,
      "end": 690.02,
      "text": "Você concorda que a"
    },
    {
      "start": 690.02,
