    },
    {
      "start": 701.29,
      "end": 702.65,
      "text": "E muito triquezinho, né?"
    },
    {
      "start": 702.71,
      "end": 703.83,
      "text": "E a gente achou os peixes bons"
    },
    {
      "start": 703.83,
      "end": 704.65,
      "text": "Aqui no gig, ó"
    },
    {
      "start": 704.65,
      "end": 707.93,
      "text": "Cinco, seis metros de profundidade, ó"
    },
    {
      "start": 707.93,
      "end": 710.06,
      "text": "Não tenho"
    },
    {
      "start": 710.06,
      "end": 712.06,
      "text": "Eu não tenho sonaro no barco, tá?"
    },
    {
      "start": 712.06,
      "end": 712.34,
