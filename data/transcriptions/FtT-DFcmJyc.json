    },
    {
      "start": 713.92,
      "end": 715.8,
      "text": "De soltar o gig e tal"
    },
    {
      "start": 715.8,
      "end": 717.42,
      "text": "Outro peixe bonito aqui, ó"
    },
    {
      "start": 717.42,
      "end": 718.64,
      "text": "Esse aqui foi"
    },
    {
      "start": 718.64,
      "end": 720.14,
