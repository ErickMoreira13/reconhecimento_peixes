    },
    {
      "start": 672.93,
      "end": 673.89,
      "text": "Será que é um amarelo?"
    },
    {
      "start": 674.43,
      "end": 676.05,
      "text": "Não é azul não"
    },
    {
      "start": 676.05,
      "end": 679.74,
      "text": "Outro azul bonito, hein?"
    },
    {
      "start": 679.74,
      "end": 681.38,
      "text": "Oi, Edvaldo"
    },
    {
      "start": 681.38,
      "end": 682.2,
      "text": "Pela situação que está"
    },
    {
      "start": 682.2,
      "end": 682.92,
