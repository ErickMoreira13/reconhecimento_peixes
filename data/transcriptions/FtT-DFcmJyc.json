      "text": "É só um gig"
    },
    {
      "start": 639.29,
      "end": 641.49,
      "text": "Olha como ele sai"
    },
    {
      "start": 641.49,
      "end": 643.54,
      "text": "Aí, saiu"
    },
    {
      "start": 643.54,
      "end": 645.87,
      "text": "Não adianta apavorar"
    },
    {
      "start": 645.87,
      "end": 647.27,
      "text": "Porque é um azul só"
    },
    {
      "start": 647.27,
      "end": 649.12,
      "text": "Está na boca dele"
    },
    {
      "start": 649.12,
      "end": 649.92,
      "text": "Se precisar entrar na água"
    },
    {
      "start": 649.92,
      "end": 650.68,
      "text": "A gente entra"
    },
    {
      "start": 650.68,
      "end": 652.32,
      "text": "Aí, olha"
    },
    {
      "start": 652.32,
      "end": 654.45,
      "text": "O bicho é brabo"
    },
    {
      "start": 654.45,
      "end": 657.18,
      "text": "No gig é brabo"
    },
    {
      "start": 657.18,
      "end": 657.84,
      "text": "Esse aqui eu vou encerrar"
    },
    {
      "start": 657.84,
      "end": 658.74,
      "text": "Minha brincadeira"
    },
    {
      "start": 658.74,
      "end": 659.22,
      "text": "Com meus amigos"
    },
    {
      "start": 659.22,
      "end": 659.78,
      "text": "Hoje aqui"
    },
    {
      "start": 659.78,
      "end": 661.4,
      "text": "Foi bom demais"
    },
    {
      "start": 661.4,
      "end": 663.4,
      "text": "Olha, vem a bicho"
    },
    {
      "start": 663.4,
      "end": 665.18,
      "text": "Olha, olha bem do fundo mesmo"
    },
    {
      "start": 665.18,
      "end": 665.38,
      "text": "Olha"
    },
    {
      "start": 665.38,
      "end": 670.42,
      "text": "O tamanho do azul"
    },
    {
      "start": 670.42,
      "end": 672.93,
