    },
    {
      "start": 2015.43,
      "end": 2017.44,
      "text": "Amarrar a corda aqui"
    },
    {
      "start": 2017.44,
      "end": 2018.68,
      "text": "Vou só esperar o fogo"
    },
    {
      "start": 2018.68,
      "end": 2020.14,
      "text": "Pegar mesmo"
    },
    {
      "start": 2020.14,
      "end": 2021.1,
      "text": "Ficar bem bonito"
    },
    {
      "start": 2021.1,
      "end": 2024.48,
      "text": "Pra não ficar queimando tudo"
    },
    {
      "start": 2024.48,
      "end": 2079.27,
      "text": "Tá ela aqui"
    },
    {
      "start": 2079.27,
      "end": 2080.55,
      "text": "Que ela tá lá perto do fogo"
    },
    {
      "start": 2082.04,
      "end": 2082.72,
      "text": "Olha a mulher"
    },
    {
      "start": 2082.72,
      "end": 2086.75,
      "text": "Pronto"
    },
    {
      "start": 2086.75,
      "end": 2088.51,
      "text": "Fica aí, tá?"
    },
    {
      "start": 2177.7,
      "end": 2179.58,
      "text": "Vou deixar isso aqui virar uma graxinha"
    },
    {
      "start": 2179.58,
      "end": 2182.94,
      "text": "E aí depois eu volto"
    },
    {
      "start": 2182.94,
      "end": 2186.29,
      "text": "Eu já ia esquecendo"
    },
    {
      "start": 2186.29,
      "end": 2188.57,
      "text": "O personagem principal dessa receita"
    },
    {
      "start": 2188.57,
      "end": 2190.66,
      "text": "Banana da terra"
    },
    {
      "start": 2190.66,
      "end": 2194.23,
      "text": "Corta ela assim de comprido"
    },
    {
      "start": 2194.23,
      "end": 2197.6,
      "text": "Igual o peixe"
    },
    {
      "start": 2197.6,
      "end": 2235.34,
      "text": "Gente, eu deixei ele aqui no fogo mais baixo"
    },
    {
      "start": 2235.34,
      "end": 2235.74,
      "text": "E agora"
    },
    {
      "start": 2235.74,
      "end": 2237.76,
      "text": "Vou botar a tampa"
    },
    {
      "start": 2237.76,
      "end": 2240.38,
      "text": "Porque eu quero que ele cozinhe assim"
    },
    {
      "start": 2240.38,
      "end": 2241.32,
      "text": "Na manha"
    },
    {
      "start": 2241.32,
      "end": 2243.51,
      "text": "Não pode ser muito rápido"
    },
    {
      "start": 2243.51,
      "end": 2277.28,
      "text": "Isso aqui"
    },
    {
      "start": 2277.28,
      "end": 2279.84,
      "text": "Eu vou deixar ele aqui de ladinho"
    },
    {
      "start": 2279.84,
      "end": 2283.88,
      "text": "Só pra ele continuar quente"
    },
    {
      "start": 2283.88,
      "end": 2286.95,
      "text": "Mas não cozinhar mais"
    },
    {
      "start": 2286.95,
      "end": 2288.39,
      "text": "Ainda tá fervendo"
    },
    {
      "start": 2288.39,
      "end": 2290.43,
      "text": "Ele tá doido"
    },
    {
      "start": 2290.43,
      "end": 2291.01,
      "text": "Agora eu vou"
    },
    {
      "start": 2291.01,
      "end": 2292.98,
      "text": "Partir pro arroz"
    },
    {
      "start": 2292.98,
      "end": 2347.35,
      "text": "Pessoal, eu vou tomar um banho ali primeiro"
    },
    {
      "start": 2347.35,
      "end": 2348.33,
      "text": "Antes de jantar"
    },
    {
      "start": 2348.33,
      "end": 2363.04,
      "text": "Chegou a hora"
    },
    {
      "start": 2363.04,
      "end": 2363.62,
      "text": "Já"
    },
    {
      "start": 2363.62,
      "end": 2365.94,
      "text": "Tô bem cansada"
    },
    {
      "start": 2365.94,
      "end": 2369.6,
      "text": "Chegou a hora da"
    },
    {
      "start": 2369.6,
      "end": 2370.84,
      "text": "Da jantinha, né?"
    },
    {
      "start": 2372.62,
      "end": 2373.12,
      "text": "Vamos lá"
    },
    {
      "start": 2373.12,
      "end": 2374.6,
      "text": "Colocar aqui o arrozinho"
    },
    {
      "start": 2374.6,
      "end": 2380.48,
      "text": "Gente, quando eu fico"
    },
    {
      "start": 2380.48,
      "end": 2382.6,
      "text": "Enfadada durante o dia"
    },
    {
      "start": 2382.6,
      "end": 2383.16,
      "text": "Assim, ó"
    },
    {
      "start": 2383.16,
      "end": 2385.64,
      "text": "Até mesmo lá em casa"
    },
    {
      "start": 2385.64,
      "end": 2387.24,
      "text": "Eu não sou de comer muito"
    },
    {
      "start": 2387.24,
      "end": 2390.44,
      "text": "Um pouquinho de arroz"
    },
    {
      "start": 2390.44,
      "end": 2394.02,
      "text": "E agora a estrela da noite"
    },
    {
      "start": 2394.02,
      "end": 2396.4,
      "text": "Mas antes eu vou colocar aqui logo"
    },
    {
      "start": 2396.4,
      "end": 2397.42,
      "text": "Um pouquinho de farinha"
    },
    {
      "start": 2397.42,
      "end": 2400.53,
      "text": "Farinha de farofa"
    },
    {
      "start": 2400.53,
      "end": 2401.83,
      "text": "Uma farinha mais fina"
    },
    {
      "start": 2401.83,
      "end": 2406.25,
      "text": "Faziam alguns dias"
    },
    {
      "start": 2406.25,
      "end": 2407.83,
      "text": "Que eu tava com muita vontade"
    },
    {
      "start": 2407.83,
      "end": 2408.33,
      "text": "De comer"
    },
    {
      "start": 2408.33,
      "end": 2410.33,
      "text": "Esse peixe na banana"
    },
    {
      "start": 2410.33,
      "end": 2411.25,
      "text": "Ó"
    },
    {
      "start": 2411.25,
      "end": 2413.41,
      "text": "Colocar logo uma banana"
    },
    {
      "start": 2413.41,
      "end": 2416.85,
      "text": "Um pouco do caldo"
    },
    {
      "start": 2416.85,
      "end": 2419.9,
      "text": "Olha só"
    },
    {
      "start": 2419.9,
      "end": 2427.97,
      "text": "Agora eu vou me sentar ali no barco"
    },
    {
      "start": 2427.97,
      "end": 2441.66,
      "text": "Meu Deus, que peixe gostoso"
    },
    {
      "start": 2441.66,
      "end": 2479.14,
      "text": "Bom dia!"
    },
    {
      "start": 2479.98,
      "end": 2480.9,
      "text": "Olha só"
    },
    {
      "start": 2480.9,
      "end": 2483.44,
      "text": "Sol já tá brilhando ali atrás"
    },
    {
      "start": 2483.44,
      "end": 2485.78,
      "text": "São sete horas da manhã"
    },
    {
      "start": 2485.78,
      "end": 2487.8,
      "text": "E o que acontece?"
    },
    {
      "start": 2489.0,
      "end": 2489.9,
      "text": "Partiu casa"
    },
    {
      "start": 2489.9,
      "end": 2491.84,
      "text": "Já tô aqui, ó"
    },
    {
      "start": 2491.84,
      "end": 2492.36,
      "text": "Com as coisas"
    },
    {
      "start": 2492.36,
      "end": 2494.18,
      "text": "Me organizando aqui no barco"
    },
    {
      "start": 2494.18,
      "end": 2496.2,
      "text": "Já pudei ir pra casa"
    },
    {
      "start": 2496.2,
      "end": 2498.9,
      "text": "E eu cheguei ao fim"
    },
    {
      "start": 2498.9,
      "end": 2500.48,
      "text": "De mais um vídeo aqui do canal"
    },
    {
      "start": 2500.48,
      "end": 2501.56,
      "text": "Gostaria de pedir"
    },
    {
      "start": 2501.56,
      "end": 2503.16,
      "text": "Carinhosamente pra vocês"
    },
    {
      "start": 2503.16,
      "end": 2505.38,
      "text": "Que vocês não saiam desse vídeo"
    },
    {
      "start": 2505.38,
      "end": 2506.4,
      "text": "Sem deixar um like"
    },
    {
      "start": 2506.4,
      "end": 2508.22,
      "text": "Dá muito trabalho"
    },
    {
      "start": 2508.22,
      "end": 2509.78,
      "text": "Fazer um vídeo desse de acampamento"
    },
    {
      "start": 2509.78,
      "end": 2511.42,
      "text": "Vídeo que vocês gostam de assistir"
    },
    {
      "start": 2511.42,
      "end": 2512.4,
      "text": "Então"
    },
    {
      "start": 2512.4,
      "end": 2514.2,
      "text": "Se você ainda não é inscrito"
    },
    {
      "start": 2514.2,
      "end": 2515.7,
      "text": "Já se inscreve no meu canal"
    },
    {
      "start": 2515.7,
      "end": 2516.98,
      "text": "Pescadora Amazônica"
    },
    {
      "start": 2516.98,
      "end": 2518.3,
      "text": "E não sai do vídeo"
    },
    {
      "start": 2518.3,
      "end": 2519.68,
      "text": "Sem deixar o like, tá bom?"
    },
    {
      "start": 2519.96,
      "end": 2521.68,
      "text": "Isso é o que faz a plataforma"
    },
    {
      "start": 2521.68,
      "end": 2523.76,
      "text": "Indicar o meu vídeo"
    },
    {
      "start": 2523.76,
      "end": 2525.58,
      "text": "Pra você assistir de novo"
    },
    {
      "start": 2525.58,
      "end": 2526.86,
      "text": "E entregar o meu vídeo"
    },
    {
      "start": 2526.86,
      "end": 2528.1,
      "text": "Pra outras pessoas também"
    },
    {
      "start": 2528.1,
      "end": 2529.94,
      "text": "Um beijo no coração"
    },
    {
      "start": 2529.94,
      "end": 2531.5,
      "text": "E um, dois, três e"
    },
    {
      "start": 2531.5,
      "end": 2532.9,
      "text": "Xepo!"
    },
    {
      "start": 2533.26,
      "end": 2534.78,
      "text": "Acho que a missão foi cumprida, hein?"
    },
    {
      "start": 2535.28,
