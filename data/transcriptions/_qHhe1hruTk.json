      "text": "Quer pegar?"
    },
    {
      "start": 1045.66,
      "end": 1048.0,
      "text": "As bichinhas tá comendo até no fundo."
    },
    {
      "start": 1048.48,
      "end": 1054.04,
      "text": "Olha o molinete."
    },
    {
      "start": 1054.1,
