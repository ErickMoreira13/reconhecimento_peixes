      "text": "Vou tirar elas"
    },
    {
      "start": 609.76,
      "end": 611.76,
      "text": "E é isso aí"
    },
    {
      "start": 611.76,
      "end": 612.26,
      "text": "Vamos lá"
    },
    {
      "start": 612.26,
      "end": 633.96,
      "text": "O peixe tá ali, galera"
    },
    {
      "start": 633.96,
      "end": 634.62,
      "text": "Na frente"
    },
    {
      "start": 634.62,
      "end": 676.7,
      "text": "Joguei em cima do mangue"
    },
    {
      "start": 676.7,
      "end": 682.54,
      "text": "Fui quase no mesmo local"
    },
    {
      "start": 682.54,
      "end": 684.16,
      "text": "Onde a gente pegou o peixinho"
    },
    {
      "start": 684.16,
      "end": 691.3,
      "text": "Peixinho ali"
    },
    {
      "start": 691.3,
      "end": 695.46,
      "text": "Que eu cobri o mangue"
    },
    {
      "start": 695.46,
      "end": 696.08,
      "text": "Esse aqui, ó"
    },
    {
      "start": 696.08,
      "end": 699.46,
      "text": "Mas ainda veio peixe, hein, rapaziada"
    },
    {
      "start": 699.46,
      "end": 701.44,
      "text": "Veio um peixinho"
    },
    {
      "start": 701.44,
      "end": 706.89,
      "text": "Ainda veio um peixinho legal aqui, ó"
    },
    {
      "start": 706.89,
      "end": 708.12,
      "text": "Ó"
    },
    {
      "start": 708.12,
      "end": 709.5,
      "text": "Aquilo aqui, ó"
    },
    {
      "start": 709.5,
      "end": 711.08,
      "text": "Coisa linda"
    },
    {
      "start": 711.08,
      "end": 714.12,
      "text": "É esse aqui mesmo"
    },
    {
      "start": 714.12,
      "end": 716.65,
      "text": "Peixinho da malha quatro, né?"
    },
    {
      "start": 722.09,
      "end": 722.79,
      "text": "Peixe pulando aí"
    },
    {
      "start": 722.79,
      "end": 723.61,
      "text": "Na frente aí, hein?"
    },
    {
      "start": 726.16,
      "end": 726.94,
      "text": "Tem uns menores"
    },
    {
      "start": 726.94,
      "end": 727.88,
      "text": "Vou soltar, né?"
    },
    {
      "start": 728.95,
      "end": 730.33,
      "text": "Como tá saindo uns maiorzinhos"
    },
    {
      "start": 730.33,
      "end": 732.73,
      "text": "Então esses menores"
    },
    {
      "start": 732.73,
      "end": 733.51,
      "text": "Vou tá liberando"
    },
    {
      "start": 733.51,
      "end": 737.05,
      "text": "Já pegamos frito também, né?"
    },
    {
      "start": 737.05,
      "end": 741.16,
      "text": "Vou esconder aqui atrás"
    },
    {
      "start": 741.16,
      "end": 742.5,
      "text": "Desse arbusto aqui, ó"
    },
    {
      "start": 742.5,
      "end": 745.94,
      "text": "Pra o peixe não me sentir aqui"
    },
    {
      "start": 745.94,
      "end": 747.34,
      "text": "Vou limpar a tarrafa"
    },
    {
      "start": 747.34,
      "end": 749.64,
      "text": "Esperar um cardume legal, ó"
    },
    {
      "start": 749.64,
      "end": 753.78,
      "text": "Pronta, né?"
    },
    {
      "start": 760.56,
      "end": 761.2,
      "text": "Caiu"
    },
    {
      "start": 761.2,
      "end": 764.73,
      "text": "A espreita do movimento do peixe agora, né?"
    },
    {
      "start": 789.92,
      "end": 791.14,
      "text": "Ressoiu bem aqui"
    },
    {
      "start": 791.14,
      "end": 793.7,
      "text": "Aí pulando"
    },
    {
      "start": 793.7,
      "end": 796.9,
      "text": "Me atrasei um pouco"
    },
    {
      "start": 796.9,
      "end": 797.56,
      "text": "Mas o peixe"
    },
    {
      "start": 797.56,
      "end": 799.78,
      "text": "Rebojeu bem aqui"
    },
    {
      "start": 799.78,
      "end": 800.44,
      "text": "Uns maior"
    },
    {
      "start": 800.44,
      "end": 806.28,
      "text": "Devagarzinho aqui, ó"
    },
    {
      "start": 806.28,
      "end": 807.74,
      "text": "Veio bastante peixinho, viu, galera?"
    },
    {
      "start": 808.88,
      "end": 810.18,
      "text": "Olha a quantidade que veio aí"
    },
    {
      "start": 810.18,
      "end": 810.9,
      "text": "Nesse lança"
    },
    {
      "start": 810.9,
      "end": 813.56,
      "text": "O carduminho, galera"
    },
    {
      "start": 813.56,
      "end": 815.49,
      "text": "Menina"
    },
    {
      "start": 815.49,
      "end": 817.03,
      "text": "Agora eu acertei um lancinho, viu?"
    },
    {
      "start": 819.14,
      "end": 819.7,
      "text": "Aí, ó"
    },
    {
      "start": 819.7,
      "end": 821.61,
      "text": "E nem rebojou"
    },
    {
      "start": 821.61,
      "end": 822.07,
      "text": "Nem nada"
    },
    {
      "start": 822.07,
      "end": 823.75,
      "text": "Só deu uma mexidinha ali, né?"
    },
    {
      "start": 825.26,
      "end": 826.64,
      "text": "Esse aqui é do peixinho menor"
    },
    {
      "start": 826.64,
      "end": 827.6,
      "text": "Da malha três"
    },
    {
      "start": 827.6,
      "end": 830.37,
      "text": "E eu vou tirar ele todo"
    },
    {
      "start": 830.37,
      "end": 833.1,
      "text": "Pra fazer isquinha, galera"
    },
    {
      "start": 833.1,
      "end": 833.86,
      "text": "Pra comer"
    },
    {
      "start": 833.86,
      "end": 835.36,
      "text": "Pra fazer isca"
    },
    {
      "start": 835.36,
      "end": 839.71,
      "text": "Espero que vocês compreendam, né?"
    },
    {
      "start": 841.55,
      "end": 841.95,
      "text": "Já"
    },
    {
      "start": 841.95,
      "end": 843.29,
      "text": "Às vezes a gente compra"
    },
    {
      "start": 843.29,
      "end": 844.23,
      "text": "O camarão, galera"
    },
    {
      "start": 844.23,
      "end": 844.97,
      "text": "Mas o"
    },
    {
      "start": 844.97,
      "end": 847.89,
      "text": "O camarão"
    },
    {
      "start": 847.89,
      "end": 849.09,
      "text": "Acaba sendo mais"
    },
    {
      "start": 849.09,
      "end": 850.05,
      "text": "Caro, né?"
    },
    {
      "start": 851.02,
      "end": 851.98,
      "text": "A gente tem que comprar"
    },
    {
      "start": 851.98,
      "end": 852.84,
      "text": "Então pra gente"
    },
    {
      "start": 852.84,
      "end": 853.94,
      "text": "Fica mais viável"
    },
    {
      "start": 853.94,
      "end": 856.4,
      "text": "A isquinha da Sauna"
    },
    {
      "start": 856.4,
      "end": 858.5,
      "text": "Tá bom?"
    },
    {
      "start": 858.58,
      "end": 859.38,
      "text": "Muitas pessoas aí"
    },
    {
      "start": 859.38,
      "end": 860.22,
      "text": "Comentam aí"
    },
    {
      "start": 860.22,
      "end": 861.74,
      "text": "Por que a gente pega esses peixinhos"
    },
    {
      "start": 861.74,
      "end": 865.3,
      "text": "Mas eu já tenho esclarecido a vocês"
    },
    {
      "start": 865.3,
      "end": 866.56,
      "text": "Que é pra fazer isquinha"
    },
    {
      "start": 866.56,
      "end": 868.29,
      "text": "Pra pegar"
    },
    {
      "start": 868.29,
      "end": 869.81,
      "text": "Pra pescar nas marambaia"
    },
    {
      "start": 869.81,
      "end": 870.41,
      "text": "Tá bom?"
    },
    {
      "start": 871.44,
      "end": 872.34,
      "text": "Olha que coisa linda"
    },
    {
      "start": 872.34,
      "end": 875.43,
      "text": "Olha o lance aí"
    },
    {
      "start": 875.43,
      "end": 876.85,
      "text": "O cardumão agora"
    },
    {
      "start": 876.85,
      "end": 878.13,
      "text": "Que saiu, rapaziada"
    },
    {
      "start": 878.13,
      "end": 881.46,
      "text": "E agora vem bastante peixe mesmo"
    },
    {
      "start": 881.46,
      "end": 881.7,
      "text": "Viu?"
    },
    {
      "start": 887.88,
      "end": 888.84,
      "text": "Bastante peixe"
    },
    {
      "start": 888.84,
      "end": 895.44,
      "text": "É aí, cara"
    },
    {
      "start": 895.44,
      "end": 897.67,
      "text": "É que eu já venho fileirada"
    },
    {
      "start": 897.67,
      "end": 904.82,
      "text": "É isso aí"
    },
    {
      "start": 904.82,
      "end": 905.88,
      "text": "Vou tirar o peixinho"
    },
    {
      "start": 905.88,
      "end": 906.62,
      "text": "E vamos"
    },
    {
      "start": 906.62,
      "end": 908.42,
      "text": "Fazer o retorno"
    },
    {
      "start": 908.42,
      "end": 909.48,
      "text": "Pra gente entrar"
    },
    {
      "start": 909.48,
      "end": 910.7,
      "text": "E tá rafiando por lá"
    },
    {
      "start": 910.7,
      "end": 917.34,
      "text": "Agora vamos"
    },
    {
      "start": 917.34,
      "end": 919.6,
      "text": "Partir pro nosso preparo"
    },
    {
      "start": 919.6,
      "end": 924.76,
      "text": "Peguei um peixinho legal, galera"
    },
    {
      "start": 924.76,
      "end": 925.3,
      "text": "Não sei se"
    },
    {
      "start": 925.3,
      "end": 925.94,
      "text": "Ó"
    },
    {
      "start": 925.94,
      "end": 928.05,
      "text": "Mais pra dentro aí, ó"
    },
    {
      "start": 928.05,
      "end": 931.3,
      "text": "E a gente vai tá separando"
    },
    {
      "start": 931.3,
      "end": 933.7,
      "text": "Agora o peixinho"
    },
    {
      "start": 933.7,
      "end": 934.88,
      "text": "Pra fazer o frito, né?"
    },
    {
      "start": 934.94,
      "end": 935.32,
      "text": "De hoje"
    },
    {
      "start": 935.32,
      "end": 957.94,
      "text": "Coisa linda"
    },
    {
      "start": 957.94,
      "end": 961.13,
      "text": "Não vou tá comendo todos eles"
    },
    {
      "start": 961.13,
      "end": 962.81,
      "text": "Mas mostrei a vocês aqui"
    },
    {
      "start": 962.81,
      "end": 963.51,
      "text": "Os dos maiores"
    },
    {
      "start": 963.51,
      "end": 964.55,
      "text": "Que a gente pegou hoje"
    },
    {
      "start": 964.55,
      "end": 968.23,
      "text": "Agora a gente vai consertar ele aqui"
    },
    {
      "start": 968.23,
      "end": 968.35,
      "text": "Ó"
    },
    {
      "start": 968.35,
      "end": 969.15,
      "text": "Na beira d'água"
    },
    {
      "start": 969.15,
      "end": 971.13,
      "text": "E já vai limpar eles aqui mesmo"
    },
    {
      "start": 971.13,
      "end": 977.04,
      "text": "Peixinho fresco, galera"
    },
    {
      "start": 977.04,
      "end": 978.2,
      "text": "Facilita muito"
    },
    {
      "start": 978.2,
      "end": 979.86,
      "text": "A limpeza"
    },
    {
      "start": 979.86,
      "end": 981.26,
      "text": "Que a escaminha é mole, né?"
    },
    {
      "start": 981.46,
      "end": 982.46,
      "text": "Molinha, molinha"
    },
    {
      "start": 982.46,
      "end": 983.79,
      "text": "Ó"
    },
    {
      "start": 983.79,
      "end": 985.55,
      "text": "Usando uma faquinha de serrilha"
    },
    {
      "start": 985.55,
      "end": 987.64,
      "text": "De serrinha, né?"
    },
    {
      "start": 1005.17,
      "end": 1006.27,
      "text": "Já joga aqui, ó"
    },
    {
      "start": 1006.27,
      "end": 1008.06,
      "text": "As vísceras"
    },
    {
      "start": 1008.06,
      "end": 1010.44,
      "text": "Pra alimentar as arraias"
    },
    {
      "start": 1010.44,
      "end": 1011.28,
      "text": "E os siri"
    },
    {
      "start": 1011.28,
      "end": 1078.55,
      "text": "Limpinho, gente, ó"
    },
    {
      "start": 1078.55,
      "end": 1081.78,
      "text": "Sauninha fresquinha, limpinha"
    },
    {
      "start": 1081.78,
      "end": 1083.92,
      "text": "Agora vamos deixar ela"
    },
    {
      "start": 1083.92,
      "end": 1086.28,
      "text": "Ficar ela bem sequinha"
    },
    {
      "start": 1086.28,
      "end": 1087.24,
      "text": "Sem água"
    },
    {
      "start": 1087.24,
      "end": 1089.41,
      "text": "Jogar aquele salzinho"
    },
    {
      "start": 1089.41,
      "end": 1090.37,
      "text": "Pra temperar"
    },
    {
      "start": 1090.37,
      "end": 1092.77,
      "text": "E começar a nossa friturinha"
    },
    {
      "start": 1092.77,
      "end": 1093.77,
      "text": "Nossa almoço"
    },
    {
      "start": 1093.77,
      "end": 1094.55,
      "text": "Ó, coisa linda"
    },
    {
      "start": 1094.55,
      "end": 1096.54,
      "text": "Que delícia"
    },
    {
      "start": 1096.54,
      "end": 1107.19,
      "text": "Fazer um foguinho, minha gente"
    },
    {
      "start": 1107.19,
      "end": 1107.93,
      "text": "Agora, né?"
    },
    {
      "start": 1108.39,
      "end": 1111.68,
      "text": "Pra preparar o nosso"
    },
    {
      "start": 1111.68,
      "end": 1114.24,
      "text": "Torradinho"
    },
    {
      "start": 1114.24,
      "end": 1115.8,
      "text": "Já botei uma busca aqui, ó"
    },
    {
      "start": 1115.8,
      "end": 1117.16,
      "text": "Fazer uma fumacinha"
    },
    {
      "start": 1117.16,
      "end": 1120.46,
      "text": "Agora eu vou torar uns gravetinhos desse aqui, ó"
    },
    {
      "start": 1120.46,
      "end": 1125.13,
      "text": "Pra tentar incendiar ela aqui"
    },
    {
      "start": 1125.13,
      "end": 1134.18,
      "text": "Os gravetos mais fininhos que puder aí"
    },
    {
      "start": 1134.18,
      "end": 1135.42,
      "text": "Que é melhor ainda"
    },
    {
      "start": 1135.42,
      "end": 1136.12,
      "text": "Sequinho"
    },
    {
      "start": 1136.12,
      "end": 1149.31,
      "text": "Aí lá"
    },
    {
      "start": 1149.31,
      "end": 1150.75,
      "text": "Temos fogo, gente"
    },
    {
      "start": 1150.75,
      "end": 1163.3,
      "text": "Agora já cortei umas lenhazinhas maiores aqui"
    },
    {
      "start": 1163.3,
      "end": 1163.7,
      "text": "Mais"
    },
    {
      "start": 1163.7,
      "end": 1165.96,
      "text": "Mais firmezinha, ó"
    },
    {
      "start": 1165.96,
      "end": 1168.84,
      "text": "Pra gente incendiar ela"
    },
    {
      "start": 1168.84,
      "end": 1170.88,
      "text": "Depois de pronta"
    },
    {
      "start": 1170.88,
      "end": 1171.36,
      "text": "Aí, ó"
    },
    {
      "start": 1171.36,
      "end": 1175.39,
      "text": "Tá a grelha"
    },
    {
      "start": 1175.39,
      "end": 1179.5,
      "text": "Já tô com o meu peixinho preparado"
    },
    {
      "start": 1179.5,
      "end": 1188.2,
      "text": "Agora já vamos pra fritura"
    },
    {
      "start": 1188.2,
      "end": 1190.62,
      "text": "Frigideirazinha"
    },
    {
      "start": 1190.62,
      "end": 1191.46,
      "text": "Óleo"
    },
    {
      "start": 1191.46,
      "end": 1195.0,
      "text": "Peixe já tá prontinho"
    },
    {
      "start": 1195.0,
      "end": 1196.91,
      "text": "Já vou botar aqui"
    },
    {
      "start": 1196.91,
      "end": 1201.18,
      "text": "Pra inaugurar a frigideirazinha nova aí, ó"
    },
    {
      "start": 1201.18,
      "end": 1203.32,
      "text": "Antiaderente"
    },
    {
      "start": 1203.32,
      "end": 1204.78,
      "text": "Fazer uma fritura bem legal"
    },
    {
      "start": 1204.78,
      "end": 1282.67,
      "text": "Almocinho tá pronto, minha gente"
    },
    {
      "start": 1282.67,
      "end": 1283.77,
      "text": "Coisa linda"
    },
    {
      "start": 1283.77,
      "end": 1286.53,
      "text": "Farinhazinha de mandioca"
    },
    {
      "start": 1286.53,
      "end": 1303.01,
      "text": "Aí, ó"
    },
    {
      "start": 1303.01,
      "end": 1305.52,
      "text": "Coisa que tá linda, galera"
    },
    {
      "start": 1305.52,
      "end": 1307.95,
      "text": "Aceboladazinha"
    },
    {
      "start": 1307.95,
      "end": 1311.35,
      "text": "Agora vamos jogar a farinhazinha por cima"
    },
    {
      "start": 1311.35,
      "end": 1313.25,
      "text": "Pra fazer aquela farofa"
    },
    {
      "start": 1313.25,
      "end": 1336.04,
      "text": "Adeus"
    },
    {
      "start": 1336.04,
      "end": 1343.22,
      "text": "Tão servidos, rapaziada"
    },
    {
      "start": 1343.22,
      "end": 1344.38,
      "text": "Tá prontinho agora"
    },
    {
      "start": 1344.38,
      "end": 1345.16,
      "text": "Nosso peixinho"
    },
    {
      "start": 1345.16,
      "end": 1348.9,
      "text": "Nossos amiguinhos já chegaram"
    },
    {
      "start": 1348.9,
      "end": 1350.28,
      "text": "É os cãozinhos aqui da"
    },
    {
      "start": 1350.28,
      "end": 1353.18,
      "text": "Dessa área"
    },
    {
      "start": 1353.18,
      "end": 1355.49,
      "text": "Aí, os amiguinhos aqui"
    },
    {
      "start": 1355.49,
      "end": 1357.03,
      "text": "Querendo comer com a gente, né"
    },
    {
      "start": 1357.03,
