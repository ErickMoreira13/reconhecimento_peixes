      "text": "Obrigado, Jesus"
    },
    {
      "start": 1359.28,
      "end": 1360.88,
      "text": "Pelo esse almoço de hoje"
    },
    {
      "start": 1360.88,
      "end": 1365.09,
      "text": "Tá bom"
    },
    {
      "start": 1365.09,
