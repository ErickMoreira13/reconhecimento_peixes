    {
      "start": 587.36,
      "end": 590.02,
      "text": "Não deve ser isso que ele não tá deixando."
    },
    {
      "start": 594.25,
      "end": 595.63,
      "text": "Olha aí, agora ficou certo."
    },
    {
      "start": 596.21,
      "end": 606.63,
      "text": "Já ouviu que o prazer."
    },
    {
      "start": 606.79,
      "end": 611.74,
      "text": "E aí, meus amigos, que engolhou até o talo, ó."
    },
    {
      "start": 612.2,
      "end": 623.21,
      "text": "Mais um, Sraí."
    },
    {
      "start": 623.65,
      "end": 625.23,
      "text": "Que filha estrala, Sraí."
    },
    {
      "start": 625.23,
      "end": 633.0,
      "text": "Olha aí, ó."
    },
    {
      "start": 637.71,
      "end": 637.95,
      "text": "Hã?"
    },
    {
      "start": 638.21,
      "end": 638.61,
      "text": "Sraí."
    },
    {
      "start": 638.61,
      "end": 639.39,
      "text": "Só tá brava, né?"
    },
    {
      "start": 649.81,
      "end": 650.97,
      "text": "Tá brava."
    },
    {
      "start": 659.2,
      "end": 659.46,
      "text": "Opa."
    },
    {
      "start": 659.8,
      "end": 678.22,
      "text": "É isso aí, galera."
    },
    {
      "start": 678.36,
      "end": 680.82,
      "text": "Mais um final de pescareia."
    },
    {
      "start": 681.75,
      "end": 682.53,
      "text": "Meus amigos."
    },
    {
      "start": 682.99,
      "end": 685.86,
      "text": "Pescaria hoje de Curvina foi top."
    },
    {
      "start": 686.26,
      "end": 687.48,
      "text": "Demoramos pra achar."
    },
    {
      "start": 688.43,
      "end": 691.05,
      "text": "Mas graças a Deus encontramos as brutas."
    },
    {
      "start": 691.71,
      "end": 693.23,
      "text": "A gente só tá indo embora, meus amigos."
    },
    {
      "start": 693.33,
      "end": 693.77,
      "text": "Porque, ó."
    },
    {
      "start": 694.49,
      "end": 696.83,
      "text": "O tempo começou a fechar."
    },
    {
      "start": 697.11,
      "end": 698.91,
      "text": "Mas tem uns barcos ali."
    },
    {
      "start": 699.21,
      "end": 701.31,
      "text": "Mas melhor a gente se prevenir."
    },
    {
      "start": 701.71,
      "end": 704.25,
      "text": "Então a gente já tá indo embora."
    },
    {
      "start": 704.47,
      "end": 704.75,
      "text": "Tá bom?"
    },
    {
      "start": 705.17,
      "end": 706.45,
      "text": "Deu bom demais a conta."
    },
    {
      "start": 706.61,
      "end": 707.75,
      "text": "Pegamos a cota aí."
    },
    {
      "start": 708.31,
      "end": 709.87,
      "text": "Foi show de bola."
    },
    {
      "start": 710.51,
      "end": 711.67,
      "text": "E aí, minha sogrinha."
    },
    {
      "start": 711.77,
      "end": 712.39,
      "text": "Se você gostou."
    },
    {
      "start": 712.39,
      "end": 714.53,
      "text": "Muito, muito, muito."
    },
    {
      "start": 714.65,
      "end": 719.19,
      "text": "Ó, tamo indo com o nosso tanquinho aqui cheio de peixe."
    },
    {
      "start": 719.37,
      "end": 719.73,
      "text": "Aí."
    },
    {
      "start": 721.73,
      "end": 722.67,
      "text": "Graças a Deus."
    },
    {
      "start": 723.15,
      "end": 725.05,
      "text": "Deu bom demais a conta, meus amigos."
    },
    {
      "start": 725.13,
      "end": 725.47,
      "text": "Tá bom?"
    },
    {
      "start": 725.47,
      "end": 727.53,
      "text": "Galera, é isso aí."
    },
    {
      "start": 727.67,
      "end": 729.03,
      "text": "Mais um final de aventura."
    },
    {
      "start": 729.13,
      "end": 730.49,
      "text": "Mais um final de pescaria."
    },
    {
      "start": 730.83,
      "end": 730.95,
      "text": "Tá?"
    },
    {
      "start": 731.61,
      "end": 735.79,
      "text": "Quem não for inscrito no canal Danilo na Pesca, convido a vocês a se inscreverem no canal."
    },
    {
      "start": 735.99,
      "end": 736.29,
      "text": "Tá bom?"
    },
    {
      "start": 736.39,
      "end": 737.35,
      "text": "Se inscreva no canal."
    },
    {
      "start": 737.53,
      "end": 738.15,
      "text": "Deixa seu like."
    },
    {
      "start": 738.29,
      "end": 739.65,
      "text": "Ative o sininho de notificação."
    },
    {
      "start": 739.65,
      "end": 742.27,
      "text": "Que isso é muito importante para nós."
    },
    {
      "start": 742.87,
      "end": 744.59,
      "text": "E é fazer parte da nossa família."
    },
    {
      "start": 745.39,
      "end": 748.45,
      "text": "Que Deus abençoe a vida de cada um de vocês."
    },
    {
      "start": 748.75,
      "end": 749.83,
      "text": "Um grande abraço."
    },
    {
      "start": 749.99,
      "end": 750.77,
      "text": "E fui!"
    },
    {
      "start": 751.27,
      "end": 752.35,
      "text": "Até logo, meus amigos."
    },
    {
      "start": 752.47,
      "end": 754.61,
      "text": "Deus abençoe a vida de cada um de vocês."
    },
    {
      "start": 755.29,
      "end": 756.29,
      "text": "Tamo junto!"
