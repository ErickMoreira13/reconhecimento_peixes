      "text": "Vou tomar ozinho"
    },
    {
      "start": 682.3,
      "end": 685.05,
      "text": "Parece ser igual mesmo"
    },
    {
      "start": 685.05,
      "end": 685.91,
      "text": "Olha aí"
    },
    {
      "start": 685.91,
      "end": 689.27,
      "text": "E os bichos tá gordo, cara"
    },
    {
      "start": 689.27,
      "end": 692.23,
      "text": "Bicho tá gordo"
    },
    {
      "start": 692.23,
      "end": 698.83,
      "text": "Ó, jogou água na minha cara"
    },
    {
      "start": 698.83,
      "end": 701.05,
      "text": "Vambora"
    },
    {
      "start": 701.05,
      "end": 702.09,
      "text": "Mais um aí"
    },
    {
      "start": 702.09,
      "end": 704.8,
      "text": "A quantidade de peixe eu tô ganhando do meu pai"
    },
    {
      "start": 704.8,
      "end": 705.94,
      "text": "Como sempre"
    },
    {
      "start": 705.94,
      "end": 707.3,
      "text": "Vai, tamo junto"
    },
    {
      "start": 707.3,
      "end": 707.86,
      "text": "É isso aí"
    },
    {
      "start": 707.86,
      "end": 709.52,
      "text": "E aí, gente"
    },
    {
      "start": 709.52,
      "end": 710.74,
      "text": "Deu uma trocada de lugar"
    },
    {
      "start": 710.74,
      "end": 711.82,
      "text": "Eu já estava ali"
    },
    {
      "start": 711.82,
      "end": 714.17,
      "text": "Tava com pintadinha ali"
    },
    {
      "start": 714.17,
      "end": 718.28,
      "text": "Vai tá aqui"
    },
    {
      "start": 718.28,
      "end": 719.88,
      "text": "Deixa eu passar"
    },
    {
      "start": 719.88,
      "end": 720.44,
      "text": "Olha o prato"
    },
    {
      "start": 720.44,
      "end": 727.2,
      "text": "E aí"
    },
    {
      "start": 727.2,
      "end": 729.53,
      "text": "Tem uma luz na bala"
    },
    {
      "start": 729.53,
      "end": 730.75,
      "text": "Os pintados que nós pegamos"
    },
    {
      "start": 730.75,
      "end": 734.32,
      "text": "Vai tá aqui"
    },
    {
      "start": 734.32,
      "end": 735.56,
      "text": "Enquanto nada ainda"
    },
    {
      "start": 735.56,
      "end": 739.96,
      "text": "Tamo junto"
    },
    {
      "start": 754.88,
      "end": 777.13,
      "text": "Vocês não sabem"
    },
    {
      "start": 777.13,
      "end": 777.79,
      "text": "Nós estamos pescando"
    },
    {
      "start": 777.79,
      "end": 779.61,
      "text": "No Telespires"
    },
    {
      "start": 779.61,
      "end": 781.37,
      "text": "Aqui de Sorriso"
    },
    {
      "start": 781.37,
      "end": 782.21,
      "text": "Pouquinho pra baixo"
    },
    {
      "start": 782.21,
      "end": 784.03,
      "text": "Pouquinho depois do pedágio"
    },
    {
      "start": 784.03,
      "end": 785.21,
      "text": "Aí nós veio aqui buscar"
    },
    {
      "start": 785.21,
      "end": 786.45,
      "text": "Um amigo nosso"
    },
    {
      "start": 786.45,
      "end": 788.33,
      "text": "Ele já tá ali já"
    },
    {
      "start": 788.33,
      "end": 790.17,
      "text": "Vamos buscar um amigo nosso"
    },
    {
      "start": 790.17,
      "end": 792.09,
      "text": "Esse é aquele carro branco"
    },
    {
      "start": 792.09,
      "end": 793.73,
      "text": "É atrás desse carro aqui"
    },
    {
      "start": 793.73,
      "end": 795.31,
      "text": "Nós veio aqui buscar ele"
    },
    {
      "start": 795.31,
      "end": 798.13,
      "text": "Aí aqui tem meio que um descedorzinho"
    },
    {
      "start": 798.13,
      "end": 800.21,
      "text": "Que a Prefeitura de Sorriso fez"
    },
    {
      "start": 800.21,
      "end": 802.75,
      "text": "Pra apoiar pra pesca esportiva"
    },
    {
      "start": 802.75,
      "end": 804.19,
      "text": "Hoje nós estamos mais aqui"
    },
    {
      "start": 804.19,
      "end": 805.93,
      "text": "Mais pela pesca esportiva"
    },
    {
      "start": 805.93,
      "end": 806.47,
      "text": "Que é o famoso"
    },
    {
      "start": 806.47,
      "end": 807.51,
      "text": "Pé que solta"
    },
    {
      "start": 807.51,
      "end": 808.61,
      "text": "Como vocês podem ter visto ali"
    },
    {
      "start": 808.61,
      "end": 810.41,
      "text": "Aí nós só vai esperar"
    },
    {
      "start": 810.41,
      "end": 811.47,
      "text": "O nosso amigo vir aqui agora"
    },
    {
      "start": 811.47,
      "end": 814.79,
      "text": "Deixou o amigo do meu pai lá"
    },
    {
      "start": 814.79,
      "end": 816.43,
      "text": "Pra guardar o lugar"
    },
    {
      "start": 816.43,
      "end": 820.43,
      "text": "Porque ele já tá pegando peixe demais lá"
    },
    {
      "start": 820.43,
      "end": 824.9,
      "text": "Bom, nós veio buscar esse amigo do pai aqui"
    },
    {
      "start": 824.9,
      "end": 826.81,
      "text": "Agora nós vamos voltar lá"
    },
    {
      "start": 826.81,
      "end": 828.49,
      "text": "Que nós perdeu os peixes por causa dele"
    },
    {
      "start": 828.49,
      "end": 830.25,
      "text": "Vai ter que voltar aqui em cima"
    },
    {
      "start": 830.25,
      "end": 831.84,
      "text": "Bora, vambora"
    },
    {
      "start": 831.84,
      "end": 833.06,
      "text": "Parceria, parceria"
    },
    {
      "start": 833.06,
      "end": 835.3,
      "text": "Parceria da puta"
    },
    {
      "start": 835.3,
      "end": 837.18,
      "text": "Só vou buscar porque o cara é parceiro"
    },
    {
      "start": 837.18,
      "end": 840.24,
      "text": "Bora, feita"
    },
    {
      "start": 840.24,
      "end": 841.16,
      "text": "Bora, vambora"
    },
    {
      "start": 841.16,
      "end": 843.86,
      "text": "Porque o cara ficou trepado lá em cima da árvore"
    },
    {
      "start": 843.86,
      "end": 845.46,
      "text": "Porque eu chegar lá vou ter que mostrar"
    },
    {
      "start": 845.46,
      "end": 848.08,
      "text": "Mas ficou uma cena até engraçada"
    },
    {
      "start": 848.08,
      "end": 862.64,
      "text": "Olha aí, gente"
    },
    {
      "start": 862.64,
      "end": 866.54,
      "text": "Acho que ele ficou em cima da canhada"
    },
    {
      "start": 866.54,
      "end": 870.06,
      "text": "Vai chegar ali agora pra dar uma resgastada nele"
    },
    {
      "start": 870.06,
      "end": 871.56,
      "text": "E o bacara é o mesmo, hein"
    },
    {
      "start": 871.56,
      "end": 881.13,
      "text": "Vamos embora"
    },
    {
      "start": 881.13,
      "end": 883.41,
      "text": "Já chegou aqui no pocinho dos pintados já"
    },
    {
      "start": 883.41,
      "end": 887.44,
      "text": "Só jogar na água e pegar mais"
    },
    {
      "start": 887.44,
      "end": 889.95,
      "text": "Vou jogar dois duplenzinhos"
    },
    {
      "start": 889.95,
      "end": 892.11,
      "text": "Não deu pra filmar"
    },
    {
      "start": 892.11,
      "end": 893.11,
      "text": "Mas tá aí"
    },
    {
      "start": 893.11,
      "end": 893.61,
      "text": "Caralho"
    },
    {
      "start": 893.61,
      "end": 894.17,
      "text": "Vou pedir pra eles mostrar"
    },
    {
      "start": 894.17,
      "end": 894.97,
      "text": "Olha aí, gente, vai pra fora não"
    },
    {
      "start": 894.97,
      "end": 896.07,
      "text": "A gente dá pra aproveitar a chuvada"
    },
    {
      "start": 896.07,
      "end": 897.37,
      "text": "Vou pedir pra eles mostrar aí"
    },
    {
      "start": 897.37,
      "end": 899.37,
      "text": "Não, tô falando assim"
    },
    {
      "start": 899.37,
      "end": 900.95,
      "text": "Deixa eu dar uma filmada ali"
    },
    {
      "start": 900.95,
      "end": 902.37,
      "text": "Uma paura aí, bá"
    },
    {
      "start": 902.37,
      "end": 903.31,
      "text": "Uma paura aí, bá"
    },
    {
      "start": 903.31,
      "end": 904.53,
      "text": "Dá uma filmada ali"
    },
    {
      "start": 904.53,
      "end": 909.56,
      "text": "Não vai atrapalhar mais no rio"
    },
    {
      "start": 909.56,
      "end": 911.55,
      "text": "Quer alicate não?"
    },
    {
      "start": 914.26,
      "end": 915.04,
      "text": "Deixa eu só dar uma mostrada"
    },
    {
      "start": 915.04,
      "end": 918.09,
      "text": "Um grandinho"
    },
    {
      "start": 918.09,
      "end": 926.3,
      "text": "Aqui tá parecendo o Pantanal"
    },
    {
      "start": 926.3,
      "end": 966.44,
      "text": "Só passando pra relembrar"
    },
    {
      "start": 966.44,
      "end": 967.94,
      "text": "Esses peixes que a gente pegou"
    },
    {
      "start": 967.94,
      "end": 969.42,
      "text": "Nós já fizemos a soltura deles"
    },
    {
      "start": 969.42,
      "end": 971.04,
      "text": "Porque eles estavam fora da medida"
    },
    {
      "start": 971.04,
      "end": 972.78,
      "text": "Os peixes que a gente fritou hoje"
    },
    {
      "start": 972.78,
      "end": 974.42,
      "text": "Estavam tudo dentro da medida"
    },
    {
      "start": 974.42,
      "end": 975.62,
      "text": "Então tá tudo certo"
    },
    {
      "start": 975.62,
      "end": 976.62,
      "text": "Tá tudo jóia"
    },
    {
      "start": 976.62,
      "end": 978.18,
      "text": "E fiquem com o vídeo"
    },
    {
      "start": 978.18,
      "end": 980.62,
      "text": "E muito obrigado por estar assistindo"
    },
    {
      "start": 980.62,
      "end": 983.78,
      "text": "Peixinho e peixe frito"
    },
    {
      "start": 983.78,
      "end": 984.7,
      "text": "Frito lá"
    },
    {
      "start": 984.7,
      "end": 985.24,
      "text": "Vamos lá"
    },
    {
      "start": 985.24,
      "end": 986.48,
      "text": "O homem lá"
    },
    {
      "start": 986.48,
      "end": 987.06,
      "text": "Beleza"
    },
    {
      "start": 987.06,
      "end": 989.21,
      "text": "Vem embora"
    },
    {
      "start": 989.21,
      "end": 991.81,
      "text": "Porque quando eu fui buscar o nosso amigo"
    },
    {
      "start": 991.81,
      "end": 993.43,
      "text": "Já era quase 3 horas da tarde"
    },
    {
      "start": 993.43,
      "end": 995.61,
      "text": "Mas deu pra fazer uns"
    },
    {
      "start": 995.61,
      "end": 996.87,
      "text": "Uns videozinhos top"
    },
    {
      "start": 996.87,
      "end": 999.28,
      "text": "E nosso dia foi esse aí"
    },
    {
      "start": 999.28,
      "end": 1000.24,
      "text": "Tranquilo"
    },
    {
      "start": 1000.24,
      "end": 1001.24,
      "text": "Muito peixe"
    },
    {
      "start": 1001.24,
      "end": 1003.12,
      "text": "E todos os peixes que a gente pegou"
    },
    {
      "start": 1003.12,
      "end": 1004.14,
      "text": "A gente soltou"
    },
    {
      "start": 1004.14,
      "end": 1006.31,
      "text": "E só teve alguns"
    },
    {
      "start": 1006.31,
      "end": 1008.03,
      "text": "Os mais maiores que a gente pegou"
    },
    {
      "start": 1008.03,
      "end": 1009.69,
      "text": "Pra gente fazer uns fritos"
    },
    {
      "start": 1009.69,
      "end": 1010.87,
      "text": "E é isso aí, gente"
    },
    {
      "start": 1010.87,
      "end": 1029.74,
      "text": "Seu carro vai se subir"
    },
    {
      "start": 1029.74,
      "end": 1032.03,
      "text": "Do jeito que eu vou mostrar"
    },
    {
      "start": 1032.03,
      "end": 1033.29,
      "text": "É isso aí"
    }
  ],
