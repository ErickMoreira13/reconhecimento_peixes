      "text": "Caraca, que emoção, hein."
    },
    {
      "start": 728.31,
      "end": 729.71,
      "text": "Ai, pai, muito estranho, hein."
    },
    {
      "start": 730.03,
      "end": 733.39,
      "text": "O que que foi isso, será, gente?"
    },
    {
      "start": 733.53,
      "end": 734.85,
      "text": "Pode arrebentar ali, aqui em cima."
    },
    {
      "start": 737.19,
      "end": 738.39,
      "text": "Acho que arrebentou na chumbada."
    },
    {
      "start": 739.88,
      "end": 740.96,
      "text": "Agora o Samuel, agora o Samuel."
    },
    {
      "start": 744.03,
      "end": 745.03,
      "text": "Ai, meu Deus, cadê a lanterna?"
    },
    {
      "start": 745.09,
      "end": 745.41,
      "text": "Não liga."
    },
    {
      "start": 748.83,
      "end": 749.65,
      "text": "Ai, tá embaçado."
    },
    {
      "start": 750.11,
      "end": 750.85,
      "text": "Aí, desembaçou."
    },
    {
      "start": 752.82,
      "end": 753.16,
      "text": "Não, daqui."
    },
    {
      "start": 754.26,
      "end": 754.66,
      "text": "Daqui."
    },
    {
      "start": 756.73,
      "end": 757.67,
      "text": "Ó, o Samuel pegou agora."
    },
    {
      "start": 758.09,
      "end": 758.91,
      "text": "Agora o Samuel."
    },
    {
      "start": 759.51,
      "end": 759.69,
      "text": "Ó."
    },
    {
      "start": 759.69,
      "end": 762.16,
      "text": "Briga, Samuel, com esse peixe."
    },
    {
      "start": 762.52,
      "end": 765.48,
      "text": "É."
    },
    {
      "start": 767.58,
      "end": 769.0,
      "text": "Ó, meu dedo na frente da câmera."
    },
    {
      "start": 770.28,
      "end": 771.68,
      "text": "Ó, bruto na corredeira, hein."
    },
    {
      "start": 771.82,
      "end": 772.64,
      "text": "Já o, já o."
    },
    {
      "start": 777.56,
      "end": 777.96,
      "text": "Iiii."
    },
    {
      "start": 779.54,
      "end": 779.9,
      "text": "Será?"
    },
    {
      "start": 783.82,
      "end": 784.18,
      "text": "Enroscou?"
    },
    {
      "start": 784.78,
      "end": 785.1,
      "text": "Hum."
    },
    {
      "start": 787.36,
      "end": 787.72,
      "text": "Caramba."
    },
    {
      "start": 788.26,
      "end": 792.97,
      "text": "É hoje, hein."
    },
    {
      "start": 798.34,
      "end": 799.06,
      "text": "Cuidado aí, filho."
    },
    {
      "start": 799.18,
      "end": 801.04,
      "text": "Não fica no meio, não fica na beirada do barco, não."
    },
    {
      "start": 801.16,
      "end": 802.16,
      "text": "Já tá..."
    },
    {
      "start": 802.16,
      "end": 803.42,
      "text": "Enroscou o negócio."
    },
    {
      "start": 804.67,
      "end": 805.35,
      "text": "Vem, Samuel."
    },
    {
      "start": 805.75,
      "end": 806.07,
      "text": "Segou?"
    },
    {
      "start": 806.63,
      "end": 807.65,
      "text": "Sobrou a minha vara aqui, Samuel."
    },
    {
      "start": 807.71,
      "end": 808.21,
      "text": "Sobrou a minha vara."
    },
    {
      "start": 808.37,
      "end": 809.29,
      "text": "Não, não é grande, não."
    },
    {
      "start": 809.35,
      "end": 809.67,
      "text": "O que tem."
    },
    {
      "start": 809.67,
      "end": 813.19,
      "text": "E que tá todo embaçado aqui, Júlio?"
    },
    {
      "start": 814.19,
      "end": 815.15,
      "text": "É porque ele..."
    },
    {
      "start": 815.15,
      "end": 815.43,
      "text": "Ah, tá."
    },
    {
      "start": 815.49,
      "end": 815.83,
      "text": "Agora tá."
    },
    {
      "start": 815.95,
      "end": 816.43,
      "text": "Agora..."
    },
    {
      "start": 816.43,
      "end": 817.47,
      "text": "Ó, lá."
    },
    {
      "start": 818.94,
      "end": 819.72,
      "text": "Baleinha, será?"
    },
    {
      "start": 824.03,
      "end": 824.67,
      "text": "Baleinha, velho."
    },
    {
      "start": 825.21,
      "end": 825.97,
      "text": "Ah, doido."
    },
    {
      "start": 827.05,
      "end": 828.13,
      "text": "Uma corredeira na dela."
    },
    {
      "start": 828.35,
      "end": 828.61,
      "text": "Nossa."
    },
    {
      "start": 829.07,
      "end": 830.33,
      "text": "Corredeira dela pegar baleinha."
    },
    {
      "start": 830.43,
      "end": 831.31,
      "text": "O tamanho desse bicho, hein."
    },
    {
      "start": 832.13,
      "end": 833.35,
      "text": "Vou levar pra fazer frito, ó."
    },
    {
      "start": 833.87,
      "end": 834.09,
      "text": "Ó, ih."
    },
    {
      "start": 835.37,
      "end": 836.39,
      "text": "Tá, pega."
    },
    {
      "start": 836.39,
      "end": 837.09,
      "text": "Não, já."
    },
    {
      "start": 839.38,
      "end": 840.7,
      "text": "O Samuel quase atravessou."
    },
    {
      "start": 840.8,
      "end": 842.0,
      "text": "Ela já dá pra usar a dica, velho."
    },
    {
      "start": 842.1,
      "end": 842.46,
      "text": "Uhum."
    },
    {
      "start": 842.84,
      "end": 844.52,
      "text": "Olha o tamanho da baleinha de corno, hein."
    },
    {
      "start": 844.52,
      "end": 845.94,
      "text": "Vai usar a dica?"
    },
    {
      "start": 846.32,
      "end": 846.8,
      "text": "Não, nada."
    },
    {
      "start": 847.36,
      "end": 856.76,
      "text": "Tá dor de baleinha."
    },
    {
      "start": 858.08,
      "end": 859.66,
      "text": "Só pesca baleinha, hein, pai."
    },
    {
      "start": 859.74,
      "end": 860.32,
      "text": "Pelo amor de Deus."
    },
    {
      "start": 860.66,
      "end": 866.02,
      "text": "Só para de gravar já, filho."
    },
    {
      "start": 866.2,
      "end": 868.48,
      "text": "Só falta ter feito esse trabalho pra só ter escapado."
    },
    {
      "start": 872.56,
      "end": 873.76,
      "text": "Senão, só pôr na montaria."
    },
    {
      "start": 876.79,
      "end": 877.81,
      "text": "Pesca dor de baleinha, hein."
    },
    {
      "start": 877.81,
      "end": 878.71,
      "text": "Você falou de mim, aí, ó."
    },
    {
      "start": 880.23,
      "end": 880.55,
      "text": "Viu?"
    },
    {
      "start": 880.69,
      "end": 881.47,
      "text": "Fala dos outros, hein."
    },
    {
      "start": 881.47,
      "end": 882.21,
      "text": "Peguei pouca."
    },
    {
      "start": 882.33,
      "end": 883.17,
      "text": "Você pegou um prazer."
    },
    {
      "start": 885.67,
      "end": 886.37,
      "text": "Chegamos, Deni."
    },
    {
      "start": 886.45,
      "end": 887.81,
      "text": "Só foi os seus dois peixes, né."
    },
    {
      "start": 888.31,
      "end": 890.51,
      "text": "Vou botar o motor, só."
    },
    {
      "start": 890.89,
      "end": 892.52,
      "text": "Filho, ó."
    },
    {
      "start": 892.52,
      "end": 902.39,
      "text": "Vou pegar os dois peixes mesmo."
    },
    {
      "start": 902.47,
      "end": 903.55,
      "text": "Só o nosso frito amanhã, né."
    },
    {
      "start": 905.22,
      "end": 905.86,
      "text": "Aí, ó."
    },
    {
      "start": 907.32,
      "end": 908.5,
      "text": "Bora limpar eles ali."
    },
    {
      "start": 909.06,
      "end": 913.38,
      "text": "Manobrando a camonete."
    },
    {
      "start": 913.46,
      "end": 914.56,
      "text": "Eita, ficou tudo vermelho."
    },
    {
      "start": 914.56,
      "end": 921.57,
      "text": "Pensa, moleque."
    },
    {
      "start": 921.89,
      "end": 923.67,
      "text": "Primeira vez que manobra a carretinha, ó."
    },
    {
      "start": 925.28,
      "end": 926.34,
      "text": "Aí sim, hein."
    },
    {
      "start": 942.74,
      "end": 943.78,
      "text": "Aí sim, hein."
    },
    {
      "start": 945.36,
      "end": 946.94,
      "text": "Primeira vez que ele manobra."
    },
    {
      "start": 947.3,
      "end": 948.22,
      "text": "Já acertou, já."
    },
    {
      "start": 948.38,
      "end": 949.2,
      "text": "Você tá brincando."
    },
    {
      "start": 952.04,
      "end": 954.24,
      "text": "Você andou treinando em casa quando não tava comigo, né?"
    },
    {
      "start": 955.31,
      "end": 956.43,
      "text": "É de primeira vale."
    },
    {
      "start": 956.57,
      "end": 957.73,
      "text": "Você andou treinando, né?"
    },
    {
      "start": 959.25,
      "end": 960.31,
      "text": "Você andou treinando, né?"
    },
    {
      "start": 960.73,
      "end": 961.91,
      "text": "Fala pra mim, aham."
    },
    {
      "start": 961.91,
      "end": 963.45,
      "text": "Pé, ó, né, ó."
    },
    {
      "start": 963.67,
      "end": 964.15,
      "text": "Negativo."
    },
    {
      "start": 964.43,
      "end": 1002.21,
      "text": "Essa foi nossa aventura, nossa noite."
    },
    {
      "start": 1002.79,
      "end": 1004.53,
      "text": "Deixe o like e se inscreve no canal."
    },
    {
      "start": 1004.69,
      "end": 1005.21,
      "text": "Falou!"
    },
    {
      "start": 1005.73,
      "end": 1010.03,
      "text": "Esse foi o nosso vídeo aqui do Rio Machado, nossa pescaria."
    },
    {
      "start": 1010.77,
      "end": 1012.53,
      "text": "Se inscreva aí, igual o Daniel falou."
    },
    {
      "start": 1012.83,
      "end": 1014.39,
      "text": "Deixe o like, deixe o joinha."
    },
    {
      "start": 1015.11,
      "end": 1017.53,
      "text": "Semana que vem pode ter mais."
    },
    {
      "start": 1018.49,
      "end": 1022.44,
      "text": "Ó, passou de lancha lá todos, 200."
    },
    {
      "start": 1022.96,
      "end": 1025.33,
      "text": "Fiquem todos com Deus."
    },
    {
      "start": 1025.67,
      "end": 1027.25,
      "text": "Papai do céu, abençoe cada um."
    },
    {
      "start": 1028.19,
      "end": 1028.83,
      "text": "Tamo junto."
    }
