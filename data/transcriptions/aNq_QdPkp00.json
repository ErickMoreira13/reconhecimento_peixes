    },
    {
      "start": 1218.48,
      "end": 1220.37,
      "text": "Ainda conseguiu pegar esse daqui."
    },
    {
      "start": 1220.37,
      "end": 1221.37,
      "text": "Foi por um trezo."
    },
    {
      "start": 1221.37,
      "end": 1222.37,
      "text": "Porque ele não vira comida de Tiú."
    },
    {
      "start": 1222.37,
      "end": 1223.37,
      "text": "Olha lá."
    },
    {
      "start": 1223.37,
      "end": 1224.37,
      "text": "Tadinho, ó."
    },
    {
      "start": 1224.37,
      "end": 1226.6,
      "text": "O que aconteceu com ele?"
    },
    {
      "start": 1226.6,
      "end": 1228.98,
      "text": "Se rifou o Tiú."
    },
    {
      "start": 1228.98,
      "end": 1232.48,
      "text": "Quase que pegou o bichinho aí, né?"
    },
    {
      "start": 1232.48,
      "end": 1233.48,
      "text": "Passou um remedinho."
    },
    {
      "start": 1233.48,
      "end": 1237.19,
      "text": "Vamos ver se ele vai escapar."
    },
    {
      "start": 1237.19,
      "end": 1239.02,
      "text": "Os pintinhos."
    },
    {
      "start": 1239.02,
      "end": 1240.02,
      "text": "É quatro pintinhos."
    },
    {
      "start": 1240.02,
      "end": 1246.72,
      "text": "Escapa aquele escato."
    },
    {
      "start": 1246.72,
      "end": 1247.72,
      "text": "Coelhadeira, Sabiá."
    },
    {
      "start": 1247.72,
      "end": 1252.63,
      "text": "Olha a fobó."
    },
    {
      "start": 1252.63,
      "end": 1254.85,
      "text": "Você quer escapar."
    },
    {
      "start": 1254.85,
      "end": 1258.85,
      "text": "Agora estamos aqui organizando as coisas para ir embora."
    },
    {
      "start": 1258.85,
      "end": 1262.72,
      "text": "Chegar em casa mais cedo."
    },
    {
      "start": 1262.72,
      "end": 1266.19,
      "text": "Nós só com as barracas armadas, né?"
    },
    {
      "start": 1266.19,
