      "end": 1084.72,
      "text": "Aí as..."
    },
    {
      "start": 1084.72,
      "end": 1085.72,
      "text": "Cadê os pintinhos, Daniela?"
    },
    {
      "start": 1085.72,
      "end": 1087.72,
      "text": "Aqui dentro, eles estão com..."
    },
    {
      "start": 1087.72,
      "end": 1090.72,
      "text": "Não acredito que você está com pintinho dentro da barraca não, Daniela."
    },
    {
      "start": 1090.72,
      "end": 1091.72,
      "text": "Cadê?"
    },
    {
      "start": 1091.72,
      "end": 1094.75,
      "text": "É porque está pingando água para todo lado."
    },
    {
      "start": 1094.75,
      "end": 1095.75,
      "text": "Olha para ver."
    },
    {
      "start": 1095.75,
      "end": 1098.04,
      "text": "Daniela com pintinho dentro da barraca."
    },
    {
      "start": 1098.04,
      "end": 1102.57,
      "text": "Está pingando água para todo lado."
    },
    {
      "start": 1102.57,
      "end": 1103.57,
      "text": "Olha para pintinho."
    },
    {
      "start": 1103.57,
      "end": 1104.57,
      "text": "Cadê, Daniela?"
    },
    {
      "start": 1104.57,
      "end": 1105.57,
      "text": "O tio quase pegou."
    },
    {
      "start": 1105.57,
      "end": 1108.08,
      "text": "Sai de perto, ele."
    },
    {
      "start": 1108.08,
      "end": 1110.08,
      "text": "O bichinho escapou fedendo, né, Dani?"
    },
    {
      "start": 1110.08,
      "end": 1111.08,
      "text": "Sim."
    },
    {
      "start": 1111.08,
      "end": 1112.08,
      "text": "Do tio."
    },
    {
      "start": 1116.48,
      "end": 1117.86,
      "text": "Boa deitar."
    },
    {
      "start": 1117.86,
      "end": 1118.86,
      "text": "Boa deitar, né?"
    },
    {
      "start": 1118.86,
      "end": 1120.86,
      "text": "Não tem como fazer mais nada."
    },
    {
      "start": 1120.86,
      "end": 1123.86,
      "text": "Além de deitar com esse tempinho gostoso."
    },
    {
      "start": 1123.86,
      "end": 1127.05,
      "text": "Bota agora com a gente neguinho e vai aguar as coisas."
    },
    {
      "start": 1127.05,
      "end": 1128.05,
      "text": "Isso."
    },
    {
      "start": 1128.05,
      "end": 1131.17,
      "text": "Para não ficar nada sem aguar."
    },
    {
      "start": 1131.17,
      "end": 1132.17,
      "text": "Ó."
    },
    {
      "start": 1132.17,
      "end": 1133.17,
      "text": "Ó o tuvão."
    },
    {
      "start": 1133.17,
      "end": 1142.56,
      "text": "Olha o vento."
    },
    {
      "start": 1142.56,
      "end": 1143.56,
      "text": "Gracinha."
    },
    {
      "start": 1143.56,
      "end": 1145.56,
      "text": "Um é para sair."
    },
    {
      "start": 1145.56,
      "end": 1146.65,
      "text": "Dois."
    },
    {
      "start": 1146.65,
      "end": 1148.2,
      "text": "Olha lá."
    },
    {
      "start": 1148.2,
      "end": 1150.19,
      "text": "Amém."
    },
    {
      "start": 1150.19,
      "end": 1152.19,
      "text": "Que gracinha, gente."
    },
    {
      "start": 1152.19,
      "end": 1153.19,
      "text": "Olha."
    },
    {
      "start": 1153.19,
      "end": 1156.31,
      "text": "Mas é bonitinho."
    },
    {
      "start": 1156.31,
      "end": 1158.72,
      "text": "Olha lá."
    },
    {
      "start": 1158.72,
      "end": 1160.23,
      "text": "Oi, Daniela."
    },
    {
      "start": 1160.23,
      "end": 1161.23,
      "text": "Aí, Dani, os dois."
    },
    {
      "start": 1161.23,
      "end": 1164.03,
      "text": "Caçando minhoquinha, capaz."
    },
    {
      "start": 1164.03,
      "end": 1168.29,
      "text": "Aí, ó."
    },
    {
      "start": 1168.29,
      "end": 1169.29,
      "text": "É dois."
    },
    {
      "start": 1169.29,
      "end": 1171.19,
      "text": "Foi de gato."
    },
    {
      "start": 1171.19,
      "end": 1172.19,
      "text": "Alma de gato."
    },
    {
      "start": 1173.19,
      "end": 1174.19,
      "text": "Esse que é alma de gato, né?"
    },
    {
      "start": 1174.19,
      "end": 1176.57,
      "text": "Esse é o Bentiville, galera."
    },
    {
      "start": 1176.57,
      "end": 1177.57,
      "text": "Olha que gracinha esse, né?"
    },
    {
      "start": 1177.57,
      "end": 1178.57,
      "text": "Nossa, Bia."
    },
    {
      "start": 1178.57,
      "end": 1179.57,
      "text": "Ele vai até pegar minhoca."
    },
    {
      "start": 1179.57,
      "end": 1180.57,
      "text": "Olha lá."
    },
    {
      "start": 1180.57,
      "end": 1181.57,
      "text": "Não é Bentiville."
    },
    {
      "start": 1181.57,
      "end": 1182.57,
      "text": "Sabiá."
    },
    {
      "start": 1182.57,
      "end": 1183.57,
      "text": "Sabiá."
    },
    {
      "start": 1183.57,
      "end": 1184.57,
      "text": "Ah, Sabiá."
    },
    {
      "start": 1184.57,
      "end": 1185.57,
      "text": "É, Sabiá."
    },
    {
      "start": 1185.57,
      "end": 1187.57,
      "text": "Falando Bentiville, Sabiá."
    },
    {
      "start": 1187.57,
      "end": 1191.59,
      "text": "O chão tá molhado."
    },
    {
      "start": 1191.59,
      "end": 1195.23,
      "text": "Parece que ele tá pegando minhoquinha."
    },
    {
      "start": 1195.23,
      "end": 1196.23,
      "text": "Deu outro."
    },
    {
      "start": 1196.23,
      "end": 1197.26,
      "text": "Voou pra lá, ó."
    },
    {
      "start": 1197.26,
      "end": 1198.26,
      "text": "E esses dois."
    },
    {
      "start": 1198.26,
      "end": 1200.48,
      "text": "Entendi."
    },
    {
      "start": 1200.48,
      "end": 1201.48,
      "text": "Pegar minhoca ali."
    },
    {
      "start": 1201.48,
      "end": 1202.48,
      "text": "Foi pro lado do Tiú."
    },
    {
      "start": 1202.48,
      "end": 1203.48,
      "text": "Pra boca do Tiú."
    },
    {
      "start": 1203.48,
      "end": 1204.48,
      "text": "É."
    },
    {
      "start": 1204.48,
      "end": 1205.48,
      "text": "Não sei, gente."
    },
    {
      "start": 1205.48,
      "end": 1206.48,
      "text": "O Tiú."
    },
    {
      "start": 1206.48,
      "end": 1207.48,
      "text": "O Tiú."
    },
    {
      "start": 1207.48,
      "end": 1208.48,
      "text": "Agarrou um aqui hoje."
    },
    {
      "start": 1208.48,
      "end": 1209.48,
      "text": "Cadê?"
    },
    {
      "start": 1209.48,
      "end": 1210.48,
      "text": "Cadê?"
    },
    {
      "start": 1210.48,
      "end": 1211.48,
      "text": "Cadê?"
    },
    {
      "start": 1211.48,
      "end": 1212.48,
      "text": "Cadê?"
    },
    {
      "start": 1212.48,
      "end": 1213.48,
      "text": "Cadê?"
    },
    {
      "start": 1213.48,
      "end": 1214.48,
      "text": "Cadê?"
    },
    {
      "start": 1214.48,
      "end": 1215.48,
      "text": "Tá ruimzinho?"
    },
    {
      "start": 1215.48,
      "end": 1216.48,
      "text": "Tá."
    },
    {
      "start": 1216.48,
      "end": 1217.48,
      "text": "Tem base, gente."
    },
    {
      "start": 1217.48,
