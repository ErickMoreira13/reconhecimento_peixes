# copia esse arquivo pra .env e preenche com suas keys
# o .env nao vai pro git (ta no gitignore)

# youtube data api v3 - pode por varias separadas por virgula
# cada key tem quota de 10k/dia, entao 3 keys ajudam bastante
YOUTUBE_API_KEYS=key1,key2,key3

# ollama - se ta rodando local, deixa o default
OLLAMA_HOST=http://localhost:11434

# modelos
MODEL_EXTRATOR=qwen2.5:7b
MODEL_VERIFICADOR=llama3.1:8b

# whisper - tamanho do modelo
WHISPER_MODEL=large-v3-turbo
# auto = detecta gpu/cpu sozinho; pode forcar com "cuda" ou "cpu"
WHISPER_DEVICE=auto

# paths
DATA_DIR=./data
